{
  "AppExtractor": {
    "SourceRoot": "",
    "OutputRoot": "",
    "DryRun": false,

    "FilePattern": ".App.",

    "SkipDirectories": [
      "bin",
      "obj",
      ".vs",
      ".git",
      "node_modules",
      "wwwroot\\lib",
      "Migrations",
      "runs"
    ],

    "WholeDirectories": [
      "FreeExamples.Docs"
    ],

    "ExplicitFiles": [
      "appsettings.json",
      "appsettings.Development.json"
    ],

    "RootFileExtensions": [
      ".slnx",
      ".sln",
      ".md",
      ".editorconfig",
      ".gitignore"
    ]
  }
}
