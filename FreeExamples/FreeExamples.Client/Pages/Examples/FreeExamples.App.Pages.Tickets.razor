@page "/Examples/Tickets"
@page "/{TenantCode}/Examples/Tickets"
@implements IDisposable
@inject BlazorDataModel Model

@* Tickets — Main CRUD table with filters *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-ticket me-1"></i> Tickets</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-ticket me-1"></i> Tickets <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Tickets" Subtitle="The core work item — bugs, stories, tasks, epics with multi-field filtering" IconClass="fa-solid fa-ticket">
            <p class="small text-muted mb-0">Every ticket belongs to a project, has a type, status, priority, and optional assignment. Filter across all dimensions simultaneously.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Multi-Filter Pattern"
                     Description="Each dropdown applies a LINQ Where filter. Filters are AND-combined — selecting Status=InProgress AND Priority=High shows only items matching both."
                     Code="@_codeFilter" />
            <InfoTip Title="Ticket Number Generation"
                     Description="Ticket numbers are auto-generated as ProjectKey-Sequence (e.g. WEB-42). The Project entity keeps a NextTicketNumber counter that increments on each ticket creation."
                     Code="@_codeNumber" />
        </div>

        @* Filters *@
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <button type="button" class="btn btn-dark btn-sm" @onclick="LoadData"><i class="fa-solid fa-arrows-rotate me-1"></i>Refresh</button>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterProject" @bind:after="ApplyFilter">
                <option value="">All Projects</option>
                @foreach (var p in _projects.OrderBy(p => p.Name)) { <option value="@p.RecordId">@p.Name</option> }
            </select>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterStatus" @bind:after="ApplyFilter">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<DataObjects.TicketStatus>()) { <option value="@s">@s</option> }
            </select>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterType" @bind:after="ApplyFilter">
                <option value="">All Types</option>
                @foreach (var t in Enum.GetValues<DataObjects.TicketType>()) { <option value="@t">@t</option> }
            </select>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterPriority" @bind:after="ApplyFilter">
                <option value="">All Priorities</option>
                @foreach (var p in Enum.GetValues<DataObjects.TicketPriority>()) { <option value="@p">@p</option> }
            </select>
            <div class="input-group input-group-sm" style="max-width:200px;">
                <span class="input-group-text bg-white"><i class="fa-solid fa-search text-muted"></i></span>
                <input type="text" class="form-control" placeholder="Search..." @bind="_search" @bind:event="oninput" @bind:after="ApplyFilter" />
            </div>
            <span class="text-muted small ms-auto">@_filtered.Count tickets</span>
        </div>

        @* Table *@
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0 small">
                        <thead class="table-light">
                            <tr>
                                <th style="cursor:pointer;" @onclick='() => SortBy("number")'>Number</th>
                                <th style="cursor:pointer;" @onclick='() => SortBy("title")'>Title</th>
                                <th>Project</th>
                                <th style="cursor:pointer;" @onclick='() => SortBy("type")'>Type</th>
                                <th style="cursor:pointer;" @onclick='() => SortBy("status")'>Status</th>
                                <th style="cursor:pointer;" @onclick='() => SortBy("priority")'>Priority</th>
                                <th>Assigned</th>
                                <th style="cursor:pointer;" @onclick='() => SortBy("points")'>Pts</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in _filtered) {
                                var proj = _projects.FirstOrDefault(p => p.RecordId == t.ProjectId);
                                <tr>
                                    <td><code>@t.TicketNumber</code></td>
                                    <td>
                                        <i class="@GetTypeIcon(t.Type) me-1"></i>
                                        @t.Title
                                        @if (!string.IsNullOrEmpty(t.Labels)) {
                                            @foreach (var lbl in t.Labels.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)) {
                                                <span class="badge bg-light text-dark border ms-1" style="font-size:0.55rem;">@lbl</span>
                                            }
                                        }
                                    </td>
                                    <td class="text-muted">@(proj?.Name ?? "—")</td>
                                    <td><span class="badge bg-info bg-opacity-25 text-dark">@t.Type</span></td>
                                    <td><span class="badge @GetStatusBadge(t.Status)">@t.Status</span></td>
                                    <td><span class="badge @GetPriorityBadge(t.Priority)">@t.Priority</span></td>
                                    <td class="text-muted">@(t.AssignedTo ?? "—")</td>
                                    <td class="text-center">@(t.StoryPoints?.ToString() ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "tickets";
    private string _filterProject = "", _filterStatus = "", _filterType = "", _filterPriority = "", _search = "";
    private string _sortField = "number";
    private bool _sortAsc = true;
    private List<DataObjects.Ticket> _all = new(), _filtered = new();
    private List<DataObjects.Project> _projects = new();

    private string _codeFilter = "tickets.Where(t => filterStatus == \"\" || t.Status.ToString() == filterStatus)\n  .Where(t => filterType == \"\" || t.Type.ToString() == filterType)";
    private string _codeNumber = "TicketNumber = $\"{project.ProjectKey}-{project.NextTicketNumber++}\"";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; await LoadData(); }
    }

    private async Task LoadData() {
        _loading = true; StateHasChanged();
        var t = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/GetTickets", new List<Guid>());
        var p = await Helpers.GetOrPost<List<DataObjects.Project>>("api/Data/GetProjects", new List<Guid>());
        _all = t ?? new(); _projects = p ?? new();
        ApplyFilter(); _loading = false; StateHasChanged();
    }

    private void ApplyFilter() {
        IEnumerable<DataObjects.Ticket> q = _all;
        if (Guid.TryParse(_filterProject, out var pid)) q = q.Where(t => t.ProjectId == pid);
        if (Enum.TryParse<DataObjects.TicketStatus>(_filterStatus, out var st)) q = q.Where(t => t.Status == st);
        if (Enum.TryParse<DataObjects.TicketType>(_filterType, out var tt)) q = q.Where(t => t.Type == tt);
        if (Enum.TryParse<DataObjects.TicketPriority>(_filterPriority, out var pr)) q = q.Where(t => t.Priority == pr);
        if (!string.IsNullOrWhiteSpace(_search)) q = q.Where(t => t.Title.Contains(_search, StringComparison.OrdinalIgnoreCase) || t.TicketNumber.Contains(_search, StringComparison.OrdinalIgnoreCase));
        _filtered = ApplySort(q).ToList();
    }

    private void SortBy(string field) { if (_sortField == field) _sortAsc = !_sortAsc; else { _sortField = field; _sortAsc = true; } ApplyFilter(); }

    private IEnumerable<DataObjects.Ticket> ApplySort(IEnumerable<DataObjects.Ticket> q) => _sortField switch {
        "title" => _sortAsc ? q.OrderBy(t => t.Title) : q.OrderByDescending(t => t.Title),
        "type" => _sortAsc ? q.OrderBy(t => t.Type) : q.OrderByDescending(t => t.Type),
        "status" => _sortAsc ? q.OrderBy(t => t.Status) : q.OrderByDescending(t => t.Status),
        "priority" => _sortAsc ? q.OrderBy(t => t.Priority) : q.OrderByDescending(t => t.Priority),
        "points" => _sortAsc ? q.OrderBy(t => t.StoryPoints ?? 99) : q.OrderByDescending(t => t.StoryPoints ?? 0),
        _ => _sortAsc ? q.OrderBy(t => t.TicketNumber) : q.OrderByDescending(t => t.TicketNumber),
    };

    private static string GetTypeIcon(DataObjects.TicketType t) => t switch {
        DataObjects.TicketType.Epic => "fa-solid fa-bolt text-purple", DataObjects.TicketType.Story => "fa-solid fa-book-open text-success",
        DataObjects.TicketType.Bug => "fa-solid fa-bug text-danger", DataObjects.TicketType.Task => "fa-solid fa-check-square text-primary",
        DataObjects.TicketType.Improvement => "fa-solid fa-arrow-up text-info", _ => "fa-solid fa-puzzle-piece text-muted"
    };
    private static string GetStatusBadge(DataObjects.TicketStatus s) => s switch {
        DataObjects.TicketStatus.Done or DataObjects.TicketStatus.Closed => "bg-success",
        DataObjects.TicketStatus.InProgress => "bg-primary", DataObjects.TicketStatus.InReview or DataObjects.TicketStatus.Testing => "bg-info",
        DataObjects.TicketStatus.Wontfix => "bg-dark", _ => "bg-secondary"
    };
    private static string GetPriorityBadge(DataObjects.TicketPriority p) => p switch {
        DataObjects.TicketPriority.Critical => "bg-danger", DataObjects.TicketPriority.High => "bg-warning text-dark",
        DataObjects.TicketPriority.Medium => "bg-info", _ => "bg-secondary"
    };
}
