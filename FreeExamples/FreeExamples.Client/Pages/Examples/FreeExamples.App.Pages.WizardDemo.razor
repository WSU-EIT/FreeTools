@page "/Examples/WizardDemo"
@page "/{TenantCode}/Examples/WizardDemo"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title">Wizard Demo</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-hat-wizard me-1"></i> Multi-Step Wizard Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <p class="text-muted mb-3">
            Demonstrates the multi-step wizard pattern with visual progress indicator.
            <br /><strong>Doc:</strong> <code>008_components.wizard.md</code>
            <br /><strong>Status:</strong> <span class="badge bg-warning text-dark">Phase 3 — Stub</span>
        </p>

        @* Inline wizard stepper *@
        <div class="d-flex justify-content-between align-items-start bg-light rounded-3 p-3 mb-3 shadow-sm">
            @for (int i = 0; i < _steps.Count; i++) {
                var stepIndex = i;
                var step = _steps[i];
                var isCompleted = stepIndex < _currentStep;
                var isCurrent = stepIndex == _currentStep;

                <div class="d-flex flex-column align-items-center flex-fill" style="min-width:70px;">
                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold border border-2 @(isCompleted ? "bg-success border-success text-white" : isCurrent ? "bg-primary border-primary text-white shadow" : "bg-white border-secondary text-muted")"
                         style="width:36px; height:36px; cursor:@(isCompleted ? "pointer" : "default");"
                         @onclick="@(() => { if (isCompleted) _currentStep = stepIndex; })">
                        @if (isCompleted) { <i class="fa fa-check"></i> } else { <span class="small">@(stepIndex + 1)</span> }
                    </div>
                    <div class="text-center mt-2 small fw-semibold @(isCompleted ? "text-success" : isCurrent ? "text-primary" : "text-muted")">
                        @step.Name
                    </div>
                </div>
            }
        </div>

        @* Step Content *@
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><span class="badge bg-primary rounded-pill me-2">@(_currentStep + 1)</span>@_steps[_currentStep].Name</h5>
                    <div class="d-flex gap-2">
                        @if (_currentStep > 0) {
                            <button class="btn btn-outline-secondary" @onclick="Back"><i class="fa fa-arrow-left me-1"></i> Back</button>
                        }
                        @if (_currentStep < _steps.Count - 1) {
                            <button class="btn btn-primary" @onclick="Next">Next <i class="fa fa-arrow-right ms-1"></i></button>
                        } else {
                            <button class="btn btn-success" @onclick="Finish"><i class="fa fa-check me-1"></i> Finish</button>
                        }
                    </div>
                </div>
            </div>
            <div class="card-body">
                @switch (_currentStep) {
                    case 0:
                        <div class="mb-2">
                            <label>Select a Category</label>
                            <select class="form-select" @bind="_selectedCategory">
                                <option value="">-- Choose --</option>
                                <option value="Engineering">Engineering</option>
                                <option value="Marketing">Marketing</option>
                                <option value="Operations">Operations</option>
                            </select>
                        </div>
                        break;
                    case 1:
                        <div class="mb-2">
                            <label>Name</label>
                            <input type="text" class="form-control" @bind="_itemName" />
                        </div>
                        break;
                    case 2:
                        <div class="mb-2">
                            <label>Priority (1-5)</label>
                            <input type="number" class="form-control" @bind="_priority" min="1" max="5" />
                        </div>
                        break;
                    case 3:
                        <h6>Review</h6>
                        <div>Category: <strong>@_selectedCategory</strong></div>
                        <div>Name: <strong>@_itemName</strong></div>
                        <div>Priority: <strong>@_priority</strong></div>
                        break;
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "wizarddemo";
    private int _currentStep = 0;

    private string _selectedCategory = "";
    private string _itemName = "";
    private int _priority = 3;

    private List<WizardStep> _steps = new() {
        new("Category"),
        new("Details"),
        new("Priority"),
        new("Review"),
    };

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.OnChange += OnDataModelUpdated;
        Model.Subscribers_OnChange[_pageName] = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    private void Next()
    {
        if (_currentStep < _steps.Count - 1) _currentStep++;
    }

    private void Back()
    {
        if (_currentStep > 0) _currentStep--;
    }

    private async Task Finish()
    {
        var item = new DataObjects.SampleItem {
            Name = _itemName,
            Category = _selectedCategory,
            Priority = _priority,
            Status = DataObjects.SampleItemStatus.Active,
            Enabled = true,
        };

        await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/SaveSampleItems", new List<DataObjects.SampleItem> { item });
        Model.Message_Saved();
        Helpers.NavigateTo("Examples/SampleItems");
    }

    private record WizardStep(string Name);
}
