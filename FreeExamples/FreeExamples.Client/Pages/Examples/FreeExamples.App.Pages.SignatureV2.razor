@page "/Examples/SignatureV2"
@page "/{TenantCode}/Examples/SignatureV2"
@implements IDisposable
@inject BlazorDataModel Model

@* V2: Document Acknowledgment — checkbox "I have read" + type name + sign *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-file-contract me-1"></i> Document Acknowledgment</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-file-contract me-1"></i> V2: Document Acknowledgment
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="Signature in Context: Document Acknowledgment" Subtitle="Read a policy, check the box, type your name, and sign" IconClass="fa-solid fa-file-contract">
            <div class="row">
                <div class="col-md-6 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Variant?</h6>
                    <p class="small text-muted mb-0">
                        A common pattern in HR and compliance: the user must read a policy document, scroll to the bottom,
                        check a box confirming they've read it, type their full legal name, and then provide a signature.
                        Think employee handbooks, NDAs, or acceptable use policies.
                    </p>
                </div>
                <div class="col-md-6 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>Three-Factor Verification</h6>
                    <p class="small text-muted mb-0">
                        This combines three verification methods: (1) checkbox attestation, (2) typed name confirmation,
                        and (3) handwritten signature. All three must be completed before the "Acknowledge" button
                        enables. This is a stronger workflow than signature alone.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* Document to read *@
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-dark text-white d-flex justify-content-between">
                <span><i class="fa-solid fa-file-shield me-1"></i> Acceptable Use Policy — Rev 2024.3</span>
                <span class="badge bg-warning text-dark">Requires Acknowledgment</span>
            </div>
            <div class="card-body" style="max-height:300px; overflow-y:auto; font-size:0.85rem;">
                <h6>1. Purpose</h6>
                <p>This Acceptable Use Policy (AUP) establishes the guidelines for the appropriate use of company information technology resources, including computers, networks, email, internet access, and data systems.</p>
                <h6>2. Scope</h6>
                <p>This policy applies to all employees, contractors, consultants, temporary workers, and other personnel who access or use any company IT resources, regardless of location or device ownership.</p>
                <h6>3. Acceptable Use</h6>
                <p>Company IT resources are provided for business purposes. Limited personal use is permitted provided it does not interfere with work duties, consume excessive bandwidth, or violate any provision of this policy.</p>
                <h6>4. Prohibited Activities</h6>
                <ul>
                    <li>Unauthorized access to systems, accounts, or data not required for job duties</li>
                    <li>Installing unauthorized software or circumventing security controls</li>
                    <li>Sharing credentials with any person, including IT staff</li>
                    <li>Using company resources for commercial activities unrelated to company business</li>
                    <li>Transmitting confidential data through unapproved channels</li>
                </ul>
                <h6>5. Data Protection</h6>
                <p>All employees must handle sensitive data in accordance with applicable regulations including FERPA, GLBA, HIPAA, and state privacy laws. Data classification labels must be respected at all times.</p>
                <h6>6. Monitoring</h6>
                <p>The company reserves the right to monitor, audit, and log all use of IT resources. Users should have no expectation of privacy when using company systems.</p>
                <h6>7. Enforcement</h6>
                <p>Violations of this policy may result in disciplinary action, up to and including termination of employment and legal action where applicable.</p>
            </div>
        </div>

        @* Acknowledgment section *@
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-white">
                <span class="fw-semibold"><i class="fa-solid fa-clipboard-check me-1"></i> Acknowledgment</span>
            </div>
            <div class="card-body">
                <div class="form-check mb-3">
                    <input type="checkbox" class="form-check-input" id="readPolicy" @bind="_hasRead" />
                    <label class="form-check-label" for="readPolicy">
                        I have read and understand the Acceptable Use Policy in its entirety.
                    </label>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label small">Type your full legal name to confirm <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" placeholder="e.g. John Alexander Smith" @bind="_typedName" />
                        @if (!string.IsNullOrWhiteSpace(_typedName)) {
                            <div class="small text-muted mt-1"><i class="fa-solid fa-check text-success me-1"></i>Name entered: <strong>@_typedName</strong></div>
                        }
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Date</label>
                        <input type="text" class="form-control" value="@DateTime.Now.ToString("MMMM d, yyyy")" disabled />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label small">Signature <span class="text-danger">*</span></label>
                    <Signature @ref="_signaturePad" @bind-Value="_signatureValue" Class="border rounded" />
                </div>

                <div class="d-flex justify-content-between">
                    <div class="small text-muted">
                        @if (!_hasRead) { <span class="text-danger"><i class="fa-solid fa-circle-xmark me-1"></i>Must check "I have read"</span> }
                        else if (string.IsNullOrWhiteSpace(_typedName)) { <span class="text-warning"><i class="fa-solid fa-triangle-exclamation me-1"></i>Type your full name</span> }
                        else { <span class="text-success"><i class="fa-solid fa-circle-check me-1"></i>Ready to acknowledge</span> }
                    </div>
                    <button class="btn btn-primary" @onclick="Acknowledge" disabled="@(!_hasRead || string.IsNullOrWhiteSpace(_typedName))">
                        <i class="fa-solid fa-stamp me-1"></i> Acknowledge Policy
                    </button>
                </div>
            </div>
        </div>

        @if (_acknowledged) {
            <div class="alert alert-success">
                <i class="fa-solid fa-circle-check me-1"></i> <strong>Policy Acknowledged!</strong>
                @_typedName acknowledged the Acceptable Use Policy on @DateTime.Now.ToString("MMMM d, yyyy").
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _acknowledged = false;
    private string _pageName = "signaturev2";
    private bool _hasRead = false;
    private string _typedName = "";
    private Signature? _signaturePad;
    private string _signatureValue = "";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
    private void Acknowledge() { _acknowledged = true; }
}
