@page "/Examples/Backlog"
@page "/{TenantCode}/Examples/Backlog"
@implements IDisposable
@inject BlazorDataModel Model

@* Backlog — Prioritized list of tickets not in any sprint, drag to reorder *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-layer-group me-1"></i> Backlog</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-layer-group me-1"></i> Backlog <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Backlog" Subtitle="Prioritized queue of tickets not yet in a sprint — drag to reorder, inline edit" IconClass="fa-solid fa-layer-group">
            <p class="small text-muted mb-0">All tickets where SprintId is null. Drag rows to reorder priority. Click on priority, story points, or assignee cells to edit inline without leaving the page.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Drag to Reorder"
                     Description="Each row has a drag handle (grip icon). Drag a row up or down to change its priority position. The SortOrder field is updated on drop."
                     Code="@_codeDrag" />
            <InfoTip Title="Inline Edit"
                     Description="Click on Priority, Points, or Assignee cells to toggle inline editing. Changes are saved immediately on blur/Enter."
                     Code="@_codeInline" />
        </div>

        @* Filters *@
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterType" @bind:after="ApplyFilter"><option value="">All Types</option>@foreach (var t in Enum.GetValues<DataObjects.TicketType>()) { <option value="@t">@t</option> }</select>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterPriority" @bind:after="ApplyFilter"><option value="">All Priorities</option>@foreach (var p in Enum.GetValues<DataObjects.TicketPriority>()) { <option value="@p">@p</option> }</select>
            <input type="text" class="form-control form-control-sm" style="width:200px;" placeholder="Search title..." @bind="_search" @bind:after="ApplyFilter" />
            <span class="text-muted small ms-auto">@_filtered.Count items in backlog</span>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0 small">
                    <thead class="table-light">
                        <tr><th style="width:30px;"></th><th>Number</th><th>Title</th><th>Type</th><th style="cursor:pointer;" @onclick='() => SortBy("priority")'>Priority</th><th style="cursor:pointer;" @onclick='() => SortBy("points")'>Pts</th><th>Assigned</th><th>Labels</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _filtered) {
                            <tr draggable="true" @ondragstart="() => _dragging = t" @ondragover:preventDefault="true" @ondrop="() => HandleDrop(t)" class="@(_dragging == t ? "table-primary" : "")">
                                <td class="text-muted" style="cursor:grab;"><i class="fa-solid fa-grip-vertical"></i></td>
                                <td><code>@t.TicketNumber</code></td>
                                <td>@t.Title</td>
                                <td><span class="badge bg-info bg-opacity-25 text-dark">@t.Type</span></td>
                                <td>
                                    @if (_editingId == t.RecordId && _editingField == "priority") {
                                        <select class="form-select form-select-sm" style="width:90px;" @bind="t.Priority" @onblur="() => SaveInline(t)">
                                            @foreach (var p in Enum.GetValues<DataObjects.TicketPriority>()) { <option value="@p">@p</option> }
                                        </select>
                                    } else {
                                        <span class="badge @GetPriorityBadge(t.Priority)" style="cursor:pointer;" @onclick='() => StartEdit(t, "priority")'>@t.Priority</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (_editingId == t.RecordId && _editingField == "points") {
                                        <div class="btn-group btn-group-sm">
                                            @foreach (var pts in _fib) {
                                                <button type="button" class="btn btn-sm @(t.StoryPoints == pts ? "btn-primary" : "btn-outline-secondary") p-0 px-1" style="font-size:0.6rem;" @onclick="() => { t.StoryPoints = pts; SaveInline(t); }">@pts</button>
                                            }
                                        </div>
                                    } else {
                                        <span style="cursor:pointer;" @onclick='() => StartEdit(t, "points")'>@(t.StoryPoints?.ToString() ?? "—")</span>
                                    }
                                </td>
                                <td>
                                    @if (_editingId == t.RecordId && _editingField == "assign") {
                                        <input type="text" class="form-control form-control-sm" style="width:100px;" @bind="t.AssignedTo" @onblur="() => SaveInline(t)" />
                                    } else {
                                        <span class="text-muted" style="cursor:pointer;" @onclick='() => StartEdit(t, "assign")'>@(t.AssignedTo ?? "—")</span>
                                    }
                                </td>
                                <td class="text-muted" style="font-size:0.6rem;">@(t.Labels ?? "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "backlog", _filterType = "", _filterPriority = "", _search = "", _sortField = "";
    private bool _sortAsc = true;
    private List<DataObjects.Ticket> _all = new(), _filtered = new();
    private DataObjects.Ticket? _dragging;
    private Guid _editingId; private string _editingField = "";
    private static readonly int[] _fib = [1, 2, 3, 5, 8, 13, 21];
    private string _codeDrag = "<tr draggable=\"true\" @ondragstart=\"() => _dragging = t\" @ondrop=\"() => HandleDrop(t)\">";
    private string _codeInline = "<span @onclick='() => StartEdit(t, \"field\")'>\n  @t.Value\n</span>";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var t = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/GetTickets", new List<Guid>()) ?? new();
            _all = t.Where(x => x.SprintId == null || x.SprintId == Guid.Empty).OrderBy(x => x.SortOrder).ToList();
            ApplyFilter(); _loading = false; StateHasChanged();
        }
    }

    private void ApplyFilter() {
        _filtered = _all;
        if (Enum.TryParse<DataObjects.TicketType>(_filterType, out var ft)) _filtered = _filtered.Where(t => t.Type == ft).ToList();
        if (Enum.TryParse<DataObjects.TicketPriority>(_filterPriority, out var fp)) _filtered = _filtered.Where(t => t.Priority == fp).ToList();
        if (!string.IsNullOrWhiteSpace(_search)) _filtered = _filtered.Where(t => t.Title.Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void SortBy(string field) {
        if (_sortField == field) _sortAsc = !_sortAsc; else { _sortField = field; _sortAsc = true; }
        _filtered = field switch {
            "priority" => _sortAsc ? _filtered.OrderBy(t => t.Priority).ToList() : _filtered.OrderByDescending(t => t.Priority).ToList(),
            "points" => _sortAsc ? _filtered.OrderBy(t => t.StoryPoints ?? 99).ToList() : _filtered.OrderByDescending(t => t.StoryPoints ?? 0).ToList(),
            _ => _filtered
        };
    }

    private void StartEdit(DataObjects.Ticket t, string field) { _editingId = t.RecordId; _editingField = field; }
    private async Task SaveInline(DataObjects.Ticket t) { _editingId = Guid.Empty; _editingField = ""; await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/SaveTickets", new List<DataObjects.Ticket> { t }); }

    private async Task HandleDrop(DataObjects.Ticket target) {
        if (_dragging == null || _dragging.RecordId == target.RecordId) return;
        _all.Remove(_dragging); var idx = _all.IndexOf(target); _all.Insert(idx, _dragging);
        for (int i = 0; i < _all.Count; i++) _all[i].SortOrder = i;
        _dragging = null; ApplyFilter();
        await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/SaveTickets", _all);
    }

    private static string GetPriorityBadge(DataObjects.TicketPriority p) => p switch { DataObjects.TicketPriority.Critical => "bg-danger", DataObjects.TicketPriority.High => "bg-warning text-dark", DataObjects.TicketPriority.Medium => "bg-info", _ => "bg-secondary" };
}
