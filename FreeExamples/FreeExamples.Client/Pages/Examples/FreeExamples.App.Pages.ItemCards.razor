@page "/Examples/ItemCards"
@page "/{TenantCode}/Examples/ItemCards"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-layer-group me-1"></i> Item Cards</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-layer-group me-1"></i> Item Cards Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="About Item Cards" Subtitle="The same comparison data as visual profile cards with gauges" IconClass="fa-solid fa-layer-group">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This is a <strong>variant</strong> of the Comparison Table demo. Instead of a transposed table,
                        items are displayed as <strong>profile-style cards</strong> with visual progress bars and gauges
                        showing their properties. This is the pattern used on product cards, SaaS pricing tiers, and
                        team member profiles where visual scanning matters more than precise comparison.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What's Different?</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Card layout</strong> — each item is a self-contained card, not a table column</li>
                        <li><strong>Progress bars</strong> — amount and priority shown as visual gauges</li>
                        <li><strong>Quick glance</strong> — scan cards visually without reading a dense table</li>
                        <li><strong>Winner badges</strong> — best values get a crown icon</li>
                        <li><strong>Same API</strong> — identical GetSampleItems data</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>When to Use Which?</h6>
                    <p class="small text-muted mb-0">
                        Use the <strong>Comparison Table</strong> for precise, detailed, property-by-property analysis
                        (like comparing car specs). Use <strong>Item Cards</strong> for quick visual scanning where
                        relative differences matter more than exact numbers (like scanning product cards or team profiles).
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Selection ── *@
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
                <span class="small fw-semibold"><i class="fa-solid fa-check-double me-1"></i> Select Items (2-4)</span>
                <div class="d-flex gap-2">
                    <span class="badge bg-primary rounded-pill">@_selectedIds.Count selected</span>
                    <button class="btn btn-sm btn-primary" @onclick="BuildCards" disabled="@(_selectedIds.Count < 2)">
                        <i class="fa-solid fa-layer-group me-1"></i> Show Cards
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearAll">Clear</button>
                </div>
            </div>
            <div class="card-body p-0" style="max-height:250px; overflow-y:auto;">
                <div class="list-group list-group-flush">
                    @foreach (var item in _allItems) {
                        bool selected = _selectedIds.Contains(item.SampleItemId);
                        <label class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-1 @(selected ? "list-group-item-primary" : "")">
                            <input type="checkbox" class="form-check-input" checked="@selected"
                                   disabled="@(!selected && _selectedIds.Count >= 4)"
                                   @onchange="@(() => ToggleSelect(item.SampleItemId))" />
                            <span class="small fw-semibold flex-grow-1">@item.Name</span>
                            <span class="badge bg-light text-dark border" style="font-size:0.6rem;">@item.Category</span>
                            <span class="badge @GetStatusBadge(item.Status)" style="font-size:0.6rem;">@item.Status</span>
                        </label>
                    }
                </div>
            </div>
        </div>

        @* ── Cards Grid ── *@
        @if (_showCards && _cardItems.Any()) {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-@(Math.Min(_cardItems.Count, 4)) g-3 mb-3">
                @foreach (var item in _cardItems) {
                    decimal maxAmount = _cardItems.Max(i => i.Amount);
                    int minPriority = _cardItems.Min(i => i.Priority);
                    bool bestAmount = item.Amount == maxAmount && _cardItems.Count(i => i.Amount == maxAmount) == 1;
                    bool bestPriority = item.Priority == minPriority && _cardItems.Count(i => i.Priority == minPriority) == 1;

                    <div class="col">
                        <div class="card shadow-sm border-0 h-100">
                            @* Card Header with icon *@
                            <div class="card-header bg-primary bg-gradient text-white text-center py-3">
                                <div class="rounded-circle bg-white text-primary d-inline-flex align-items-center justify-content-center mx-auto mb-2"
                                     style="width:48px; height:48px; font-size:1.2rem; font-weight:700;">
                                    @(item.Name?[0])
                                </div>
                                <div class="fw-semibold">@item.Name</div>
                                <div class="small opacity-75">@item.Category</div>
                            </div>

                            <div class="card-body">
                                @* Status *@
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="small text-muted">Status</span>
                                    <span class="badge @GetStatusBadge(item.Status)">@item.Status</span>
                                </div>

                                @* Amount gauge *@
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between small mb-1">
                                        <span class="text-muted">Amount</span>
                                        <span class="fw-semibold">
                                            @item.Amount.ToString("C")
                                            @if (bestAmount) {
                                                <i class="fa-solid fa-crown text-warning ms-1" title="Highest amount"></i>
                                            }
                                        </span>
                                    </div>
                                    <div class="progress" style="height:8px;">
                                        <div class="progress-bar @(bestAmount ? "bg-success" : "bg-primary")"
                                             style="width:@(maxAmount > 0 ? (int)(item.Amount / maxAmount * 100) : 0)%"></div>
                                    </div>
                                </div>

                                @* Priority gauge *@
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between small mb-1">
                                        <span class="text-muted">Priority</span>
                                        <span class="fw-semibold">
                                            P@item.Priority
                                            @if (bestPriority) {
                                                <i class="fa-solid fa-crown text-warning ms-1" title="Highest priority"></i>
                                            }
                                        </span>
                                    </div>
                                    <div class="progress" style="height:8px;">
                                        @{
                                            int prioPercent = item.Priority switch { 1 => 100, 2 => 75, 3 => 50, 4 => 25, _ => 10 };
                                            string prioColor = item.Priority switch { 1 => "bg-danger", 2 => "bg-warning", 3 => "bg-info", _ => "bg-secondary" };
                                        }
                                        <div class="progress-bar @prioColor" style="width:@prioPercent%"></div>
                                    </div>
                                </div>

                                @* Enabled *@
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small text-muted">Enabled</span>
                                    @if (item.Enabled) {
                                        <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i>Yes</span>
                                    } else {
                                        <span class="badge bg-danger"><i class="fa-solid fa-times me-1"></i>No</span>
                                    }
                                </div>

                                @* Description *@
                                @if (!string.IsNullOrWhiteSpace(item.Description)) {
                                    <div class="border-top pt-2 mt-2">
                                        <div class="small text-muted" style="max-height:60px; overflow:hidden;">
                                            @(item.Description.Length > 100 ? item.Description[..100] + "…" : item.Description)
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex flex-wrap gap-1">
                <InfoTip Title="Progress Bar Gauges"
                         Description="Instead of showing raw numbers in a table cell, we render them as progress bars. The bar width is calculated as a percentage of the maximum value across all compared items. This gives an instant visual sense of relative magnitude without reading numbers."
                         Code="@_codeGauge" />
                <InfoTip Title="Winner Crown"
                         Description="For numeric properties (Amount, Priority), we find the best value across all cards. The card with the best value gets a crown icon. For Amount, highest wins. For Priority, lowest number wins (P1 beats P3). This immediately draws the eye to the leader."
                         Code="@_codeCrown" />
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private bool _showCards = false;
    private string _pageName = "itemcards";

    // InfoTip snippets
    private string _codeGauge = "int widthPercent = (int)(item.Amount / maxAmount * 100);\n<div class=\"progress-bar\" style=\"width:@widthPercent%\"></div>";
    private string _codeCrown = "bool bestAmount = item.Amount == _cardItems.Max(i => i.Amount);\n@if (bestAmount) { <i class=\"fa-solid fa-crown\"></i> }";

    // Data
    private List<DataObjects.SampleItem> _allItems = new();
    private HashSet<Guid> _selectedIds = new();
    private List<DataObjects.SampleItem> _cardItems = new();

    // ── Lifecycle ──

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;

            var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
            if (result != null) {
                _allItems = result.Where(i => !i.Deleted).OrderBy(i => i.Name).ToList();
            }

            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    // ── Selection ──

    private void ToggleSelect(Guid id)
    {
        if (_selectedIds.Contains(id)) _selectedIds.Remove(id);
        else if (_selectedIds.Count < 4) _selectedIds.Add(id);
    }

    private void BuildCards()
    {
        _cardItems = _allItems.Where(i => _selectedIds.Contains(i.SampleItemId)).ToList();
        _showCards = true;
    }

    private void ClearAll()
    {
        _selectedIds.Clear();
        _cardItems.Clear();
        _showCards = false;
    }

    // ── Helpers ──

    private string GetStatusBadge(DataObjects.SampleItemStatus status) => status switch {
        DataObjects.SampleItemStatus.Draft => "bg-secondary",
        DataObjects.SampleItemStatus.Active => "bg-success",
        DataObjects.SampleItemStatus.Completed => "bg-primary",
        DataObjects.SampleItemStatus.Archived => "bg-dark",
        _ => "bg-secondary",
    };
}
