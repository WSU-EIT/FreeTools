@page "/Examples/SampleItemsV3"
@page "/{TenantCode}/Examples/SampleItemsV3"
@implements IDisposable
@inject BlazorDataModel Model

@* V3: Grouped Accordion — items grouped by category with collapsible sections *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-layer-group me-1"></i> Grouped View</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-layer-group me-1"></i> V3: Sample Items — Grouped Accordion <StickyMenuIcon /></h1>
        </div>
        <AboutSection Title="Grouped Accordion View" Subtitle="Items organized by category in collapsible sections" IconClass="fa-solid fa-layer-group">
            <p class="small text-muted mb-0">Items grouped by their Category field. Each group is a collapsible accordion panel with a count badge. Click a group header to expand/collapse. Great for large lists with natural categories.</p>
        </AboutSection>

        <div class="d-flex gap-2 mb-3">
            <button class="btn btn-sm btn-outline-primary" @onclick="ExpandAll"><i class="fa-solid fa-angles-down me-1"></i> Expand All</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CollapseAll"><i class="fa-solid fa-angles-up me-1"></i> Collapse All</button>
            <span class="badge bg-secondary rounded-pill align-self-center">@_items.Count items in @_groups.Count() groups</span>
        </div>

        @foreach (var group in _groups) {
            bool expanded = _expandedGroups.Contains(group.Key);
            <div class="card shadow-sm border-0 mb-2">
                <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center" role="button"
                     @onclick="@(() => ToggleGroup(group.Key))">
                    <span class="fw-semibold">
                        <i class="fa-solid @(expanded ? "fa-chevron-down" : "fa-chevron-right") me-1 small text-muted"></i>
                        @group.Key
                    </span>
                    <span class="badge bg-primary rounded-pill">@group.Count()</span>
                </div>
                @if (expanded) {
                    <div class="card-body p-0">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="small">Name</th>
                                    <th class="small">Status</th>
                                    <th class="small">Priority</th>
                                    <th class="small text-end">Amount</th>
                                    <th class="small text-center">Enabled</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in group.OrderBy(i => i.Name)) {
                                    <tr>
                                        <td class="small fw-semibold">@item.Name</td>
                                        <td><span class="badge @GetStatusBadge(item.Status)" style="font-size:0.6rem;">@item.Status</span></td>
                                        <td class="small">P@item.Priority</td>
                                        <td class="small text-end">@item.Amount.ToString("C")</td>
                                        <td class="text-center">
                                            @if (item.Enabled) { <i class="fa-solid fa-check text-success"></i> } else { <i class="fa-solid fa-times text-danger"></i> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "sampleitemsv3";
    private List<DataObjects.SampleItem> _items = new();
    private IEnumerable<IGrouping<string, DataObjects.SampleItem>> _groups = Enumerable.Empty<IGrouping<string, DataObjects.SampleItem>>();
    private HashSet<string> _expandedGroups = new();

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
            if (result != null) { _items = result.Where(i => !i.Deleted).ToList(); _groups = _items.GroupBy(i => i.Category ?? "Other").OrderBy(g => g.Key); _expandedGroups = _groups.Select(g => g.Key).ToHashSet(); }
            _loading = false; StateHasChanged();
        }
    }
    private void ToggleGroup(string key) { if (!_expandedGroups.Remove(key)) _expandedGroups.Add(key); }
    private void ExpandAll() { _expandedGroups = _groups.Select(g => g.Key).ToHashSet(); }
    private void CollapseAll() { _expandedGroups.Clear(); }
    private string GetStatusBadge(DataObjects.SampleItemStatus s) => s switch { DataObjects.SampleItemStatus.Active => "bg-success", DataObjects.SampleItemStatus.Completed => "bg-primary", DataObjects.SampleItemStatus.Archived => "bg-dark", _ => "bg-secondary" };
}
