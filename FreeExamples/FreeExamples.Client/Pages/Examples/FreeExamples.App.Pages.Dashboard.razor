@page "/Examples/Dashboard"
@page "/{TenantCode}/Examples/Dashboard"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><Language Tag="ExamplesDashboard" IncludeIcon="true" /></h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <Icon Name="Home" /> Examples Dashboard
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="About FreeExamples" Subtitle="A learning playground with every pattern from 30+ real-world apps in one place" IconClass="fa-solid fa-book-open">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This?</h6>
                    <p class="small text-muted mb-0">
                        This is a <strong>demo application</strong> for exploring how real web apps work.
                        Each section below showcases a category of features: data views,
                        file operations, UI components, charts, code editors, and real-time collaboration.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>Why Does It Exist?</h6>
                    <p class="small text-muted mb-0">
                        Our team builds 30+ web applications. They all share the same coding patterns. Instead of digging
                        through 30 separate codebases, this project collects every pattern in one place so you can
                        <strong>see it working</strong>, <strong>read the code</strong>, and <strong>copy it</strong> into your own project.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-compass me-1"></i>How To Explore</h6>
                    <ol class="small text-muted mb-0 ps-3">
                        <li>Use the <strong>search box</strong> below to find examples by name</li>
                        <li>Click a <strong>category pill</strong> to jump to a section</li>
                        <li>Each feature has <strong>variants</strong> showing different approaches to the same problem</li>
                        <li>Look for <i class="fa-solid fa-circle-info text-info"></i> icons for inline code explanations</li>
                    </ol>
                </div>
            </div>
        </AboutSection>

        @* Quick Stats *@
        <div class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-3 mb-4">
            <div class="col">
                <div class="card bg-primary text-white h-100 shadow-sm border-0">
                    <div class="card-body text-center py-3">
                        <div class="h3 mb-0">@_totalPages</div>
                        <div class="small">Total Pages</div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body text-center py-3">
                        <div class="h3 mb-0 text-info">@_categories.Count</div>
                        <div class="small text-muted">Categories</div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body text-center py-3">
                        <div class="h3 mb-0 text-success">@_categories.Sum(c => c.Features.Count)</div>
                        <div class="small text-muted">Features</div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body text-center py-3">
                        <div class="h3 mb-0 text-warning">@_categories.Sum(c => c.Features.Sum(f => f.Variants?.Count ?? 0))</div>
                        <div class="small text-muted">Variants</div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body text-center py-3">
                        <div class="h3 mb-0 text-primary">@_dashboard.TotalItems</div>
                        <div class="small text-muted">Sample Items</div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body text-center py-3">
                        <div class="h3 mb-0 text-success">@_dashboard.ActiveItems</div>
                        <div class="small text-muted">Active Items</div>
                    </div>
                </div>
            </div>
        </div>

        @* Search and Category Filter *@
        <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
            <div class="input-group" style="max-width:320px;">
                <span class="input-group-text bg-white"><i class="fa-solid fa-search text-muted"></i></span>
                <input type="text" class="form-control" placeholder="Search examples..." @bind="_searchTerm" @bind:event="oninput" />
                @if (!string.IsNullOrWhiteSpace(_searchTerm)) {
                    <button class="btn btn-outline-secondary" type="button" @onclick="@(() => _searchTerm = "")">
                        <i class="fa-solid fa-times"></i>
                    </button>
                }
            </div>

            <div class="d-flex flex-wrap gap-1">
                <button class="btn btn-sm @(_categoryFilter == "" ? "btn-dark" : "btn-outline-dark")" @onclick="@(() => _categoryFilter = "")">
                    All
                </button>
                @foreach (var cat in _categories) {
                    <button class="btn btn-sm @(_categoryFilter == cat.Title ? "btn-dark" : "btn-outline-dark")"
                            @onclick="@(() => _categoryFilter = cat.Title)">
                        <i class="@cat.Icon me-1"></i>@cat.Title
                    </button>
                }
            </div>

            <span class="text-muted small ms-auto">
                @FilteredCategories.Sum(c => c.Features.Count(f => MatchesSearch(f))) pages shown
            </span>
        </div>

        @* Category Sections *@
        @foreach (var cat in FilteredCategories) {
            var matchingFeatures = cat.Features.Where(f => MatchesSearch(f)).ToList();
            if (!matchingFeatures.Any()) continue;

            <div class="card mb-4 shadow-sm border-0" id="@cat.Title.Replace(" ", "").Replace("&","")">
                <div class="card-header @cat.HeaderClass py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 text-white">
                            <i class="@cat.Icon me-2"></i>@cat.Title
                        </h5>
                        <span class="badge bg-white text-dark rounded-pill">@matchingFeatures.Count features</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(cat.Description)) {
                        <div class="small text-white-50 mt-1">@cat.Description</div>
                    }
                </div>
                <div class="card-body">
                    @foreach (var feature in matchingFeatures) {
                        <div class="mb-4">
                            @* Feature header row *@
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="mb-0">
                                        <a href="@Helpers.BuildUrl(feature.Route)" class="text-decoration-none">
                                            <i class="@feature.Icon me-1"></i> @feature.Title
                                        </a>
                                        @if (feature.Variants != null && feature.Variants.Any()) {
                                            <span class="badge bg-light text-dark border ms-1" style="font-size:0.7rem;">@feature.Variants.Count variants</span>
                                        }
                                    </h6>
                                    <span class="small text-muted">@feature.Description</span>
                                </div>
                                <a href="@Helpers.BuildUrl(feature.Route)" class="btn btn-sm btn-outline-primary">
                                    <i class="fa-solid fa-arrow-right me-1"></i>Open
                                </a>
                            </div>

                            @* Variant cards *@
                            @if (feature.Variants != null && feature.Variants.Any()) {
                                <div class="row g-2">
                                    @for (var i = 0; i < feature.Variants.Count; i++) {
                                        var v = feature.Variants[i];
                                        var isLast = i == feature.Variants.Count - 1;
                                        <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                                            <div class="card h-100 @(isLast ? "border-warning" : "border-light")">
                                                <div class="card-body text-center px-2 py-2">
                                                    <div class="small fw-semibold mb-1">
                                                        @if (isLast) { <i class="fa-solid fa-star text-warning me-1" title="Latest"></i> }
                                                        @v.Title
                                                    </div>
                                                    <a href="@Helpers.BuildUrl(v.Route)" class="btn btn-sm @(isLast ? "btn-warning" : "btn-outline-primary") w-100">View</a>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        @if (feature != matchingFeatures.Last()) {
                            <hr class="my-2 opacity-25" />
                        }
                    }
                </div>
            </div>
        }

        @* Sample Data Summary *@
        @if (_dashboard.ByCategory.Any()) {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-2">
                    <h6 class="mb-0"><i class="fa-solid fa-database me-1"></i> Sample Data by Category</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover table-sm mb-0">
                        <thead>
                            <tr>
                                <th class="ps-3">Category</th>
                                <th class="text-end">Count</th>
                                <th class="text-end pe-3">Total Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cat in _dashboard.ByCategory) {
                                <tr>
                                    <td class="ps-3">@cat.Category</td>
                                    <td class="text-end">@cat.Count</td>
                                    <td class="text-end pe-3">@cat.TotalAmount.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "examplesdashboard";
    private DataObjects.SampleDashboard _dashboard = new();

    // Filter state
    private string _searchTerm = "";
    private string _categoryFilter = "";

    private int _totalPages => _categories.Sum(c => c.Features.Count + c.Features.Sum(f => f.Variants?.Count ?? 0));

    private IEnumerable<DashboardCategory> FilteredCategories =>
        string.IsNullOrWhiteSpace(_categoryFilter)
            ? _categories
            : _categories.Where(c => c.Title == _categoryFilter);

    private bool MatchesSearch(FeatureEntry f)
    {
        if (string.IsNullOrWhiteSpace(_searchTerm)) return true;
        var term = _searchTerm.ToLower();
        if (f.Title.ToLower().Contains(term)) return true;
        if (f.Description.ToLower().Contains(term)) return true;
        if (f.Variants != null && f.Variants.Any(v => v.Title.ToLower().Contains(term))) return true;
        return false;
    }

