        },
    };

    // Lifecycle

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
            Model.TenantCodeFromUrl = TenantCode;
        }

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            await LoadData();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) {
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        var result = await Helpers.GetOrPost<DataObjects.SampleDashboard>("api/Data/GetSampleDashboard");
        if (result != null) {
            _dashboard = result;
        }

        _loading = false;
        StateHasChanged();
    }

    // Inner Types

    private class DashboardCategory
    {
        public string Title { get; set; }
        public string Icon { get; set; }
        public string HeaderClass { get; set; }
        public string Description { get; set; }
        public List<FeatureEntry> Features { get; set; } = new();

        public DashboardCategory(string title, string icon, string headerClass, string description)
        {
            Title = title; Icon = icon; HeaderClass = headerClass; Description = description;
        }
    }

    private class FeatureEntry
    {
        public string Title { get; set; }
        public string Route { get; set; }
        public string Icon { get; set; }
        public string Description { get; set; }
        public List<VariantEntry>? Variants { get; set; }

        public FeatureEntry(string title, string route, string icon, string description)
        {
            Title = title; Route = route; Icon = icon; Description = description;
        }
    }

    private class VariantEntry
    {
        public string Title { get; set; }
        public string Route { get; set; }

        public VariantEntry(string title, string route)
        {
            Title = title; Route = route;
        }
    }
}
