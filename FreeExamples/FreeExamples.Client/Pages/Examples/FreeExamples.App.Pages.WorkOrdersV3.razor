@page "/Examples/WorkOrdersV3"
@page "/{TenantCode}/Examples/WorkOrdersV3"
@implements IDisposable
@inject BlazorDataModel Model

@* V3: Technician View — Mobile-friendly card list filtered to my assignments *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-hard-hat me-1"></i> Technician View</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-hard-hat me-1"></i> V3: Technician View <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Technician View" Subtitle="Mobile-friendly card list for field technicians — tap to update status, log hours" IconClass="fa-solid fa-hard-hat">
            <p class="small text-muted mb-0">Filtered to "my assignments." Each card has tap-to-update-status buttons, an hours timer, and a completion notes field. Designed for mobile-first use.</p>
        </AboutSection>

        @* Technician selector *@
        <div class="d-flex align-items-center gap-2 mb-3">
            <label class="form-label mb-0 small fw-semibold">Viewing as:</label>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_techName" @bind:after="Refresh">
                @foreach (var name in _techNames) { <option value="@name">@name</option> }
            </select>
        </div>

        <div class="row row-cols-1 row-cols-md-2 g-3">
            @foreach (var w in _myOrders) {
                <div class="col">
                    <div class="card border-0 shadow-sm" style="border-left:3px solid @GetUrgencyColor(w.Urgency) !important;">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center py-1">
                            <span class="fw-semibold small">@w.Title</span>
                            <span class="badge" style="background-color:@GetUrgencyColor(w.Urgency); color:white;">@w.Urgency</span>
                        </div>
                        <div class="card-body small">
                            <div class="mb-2">
                                <i class="fa-solid fa-building me-1 text-muted"></i>@w.Building — @w.Floor, Room @w.RoomNumber
                            </div>
                            <div class="mb-2 text-muted">@w.Description</div>

                            @* Status buttons *@
                            <div class="d-flex flex-wrap gap-1 mb-2">
                                @foreach (var s in new[] { DataObjects.WorkOrderStatus.InProgress, DataObjects.WorkOrderStatus.OnHold, DataObjects.WorkOrderStatus.Completed }) {
                                    <button class="btn btn-sm @(w.Status == s ? "btn-dark" : "btn-outline-dark")" @onclick="() => UpdateStatus(w, s)">@s</button>
                                }
                            </div>

                            @* Hours *@
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <label class="form-label mb-0 small">Hours:</label>
                                <input type="number" class="form-control form-control-sm" style="width:80px;" step="0.5" @bind="w.ActualHours" />
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => SaveOrder(w)"><i class="fa-solid fa-floppy-disk"></i></button>
                            </div>

                            @* Completion notes *@
                            @if (w.Status == DataObjects.WorkOrderStatus.Completed) {
                                <div>
                                    <label class="form-label small fw-semibold">Completion Notes</label>
                                    <textarea class="form-control form-control-sm" rows="2" @bind="w.CompletionNotes"></textarea>
                                    <button class="btn btn-success btn-sm mt-1" @onclick="() => SaveOrder(w)"><i class="fa-solid fa-check me-1"></i>Save & Close</button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!_myOrders.Any()) {
            <div class="text-center text-muted py-5"><i class="fa-solid fa-check-circle fa-2x mb-2 text-success"></i><div>No open assignments!</div></div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "workordersv3", _techName = "";
    private List<DataObjects.WorkOrder> _all = new(), _myOrders = new();
    private List<string> _techNames = new();

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            _all = await Helpers.GetOrPost<List<DataObjects.WorkOrder>>("api/Data/GetWorkOrders", new List<Guid>()) ?? new();
            _techNames = _all.Where(w => !string.IsNullOrEmpty(w.AssignedTo)).Select(w => w.AssignedTo!).Distinct().OrderBy(n => n).ToList();
            _techName = _techNames.FirstOrDefault() ?? "";
            Refresh(); _loading = false; StateHasChanged();
        }
    }

    private void Refresh() {
        _myOrders = _all.Where(w => w.AssignedTo == _techName && w.Status != DataObjects.WorkOrderStatus.Closed).OrderByDescending(w => w.Urgency).ToList();
    }

    private async Task UpdateStatus(DataObjects.WorkOrder w, DataObjects.WorkOrderStatus s) {
        w.Status = s;
        if (s == DataObjects.WorkOrderStatus.Completed) w.CompletedDate = DateTime.Now;
        await Helpers.GetOrPost<List<DataObjects.WorkOrder>>("api/Data/SaveWorkOrders", new List<DataObjects.WorkOrder> { w });
        Refresh(); StateHasChanged();
    }

    private async Task SaveOrder(DataObjects.WorkOrder w) {
        await Helpers.GetOrPost<List<DataObjects.WorkOrder>>("api/Data/SaveWorkOrders", new List<DataObjects.WorkOrder> { w });
        StateHasChanged();
    }

    private static string GetUrgencyColor(DataObjects.WorkOrderUrgency u) => u switch { DataObjects.WorkOrderUrgency.Emergency => "#dc3545", DataObjects.WorkOrderUrgency.High => "#fd7e14", DataObjects.WorkOrderUrgency.Normal => "#0d6efd", _ => "#6c757d" };
}
