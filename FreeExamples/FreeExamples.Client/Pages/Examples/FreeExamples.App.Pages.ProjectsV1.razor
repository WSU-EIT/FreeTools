@page "/Examples/ProjectsV1"
@page "/{TenantCode}/Examples/ProjectsV1"
@implements IDisposable
@inject BlazorDataModel Model

@* V1: Project Tree — Full interactive tree with side panel detail *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-folder-tree me-1"></i> Project Tree</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-folder-tree me-1"></i> V1: Project Tree <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Interactive Project Tree" Subtitle="Click any node to see details in the side panel with breadcrumb trail" IconClass="fa-solid fa-folder-tree">
            <p class="small text-muted mb-0">Full expand/collapse tree with a split panel. Click a node on the left to see its details, breadcrumb path, and child projects on the right.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Split Panel Layout"
                     Description="Uses Bootstrap's col-md-5 / col-md-7 split. The left panel is a scrollable tree list, the right panel shows selected project details."
                     Code="@_codeSplit" />
            <InfoTip Title="Breadcrumb Path"
                     Description="The FullPath is computed by walking from the current node up through its parents, producing 'Root → Child → Grandchild'."
                     Code="@_codeBreadcrumb" />
        </div>

        <div class="row g-3">
            @* Left: Tree *@
            <div class="col-md-5">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <span><i class="fa-solid fa-folder-tree me-1"></i> Projects</span>
                        <button class="btn btn-sm btn-outline-light" @onclick="ToggleExpandAll">
                            @(_allExpanded ? "Collapse" : "Expand") All
                        </button>
                    </div>
                    <div class="card-body p-0" style="max-height:600px; overflow-y:auto;">
                        <div class="list-group list-group-flush">
                                @foreach (var node in GetFlatTreeNodes(null, 0)) {
                                    var p = node.Project;
                                    var depth = node.Depth;
                                    var hasKids = _all.Any(c => c.ParentProjectId == p.RecordId);
                                    var isExp = _expanded.Contains(p.RecordId);
                                    var isSelected = _selected?.RecordId == p.RecordId;
                                    <button class="list-group-item list-group-item-action @(isSelected ? "active" : "") py-1" style="padding-left:@(12 + depth * 20)px;" @onclick="() => SelectProject(p.RecordId)">
                                        <span class="d-flex align-items-center gap-1">
                                            @if (hasKids) {
                                                <i class="fa-solid @(isExp ? "fa-chevron-down" : "fa-chevron-right") text-muted" style="width:14px; cursor:pointer;"
                                                   @onclick="() => { if (!_expanded.Remove(p.RecordId)) _expanded.Add(p.RecordId); }" @onclick:stopPropagation="true"></i>
                                            } else {
                                                <span style="width:14px;"></span>
                                            }
                                            @if (!string.IsNullOrEmpty(p.Color)) {
                                                <span class="rounded-circle d-inline-block" style="width:8px; height:8px; background:@p.Color;"></span>
                                            }
                                            <span class="small">@p.Name</span>
                                            <span class="badge @GetStatusBadge(p.Status) ms-auto" style="font-size:0.6rem;">@p.Status</span>
                                        </span>
                                    </button>
                                }
                            </div>
                    </div>
                </div>
            </div>

            @* Right: Detail *@
            <div class="col-md-7">
                @if (_selected != null) {
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-0 small">
                                    @foreach (var crumb in GetBreadcrumbs(_selected.RecordId)) {
                                        <li class="breadcrumb-item @(crumb.RecordId == _selected.RecordId ? "active" : "")">
                                            @if (crumb.RecordId != _selected.RecordId) {
                                                <a href="javascript:void(0)" @onclick="() => SelectProject(crumb.RecordId)">@crumb.Name</a>
                                            } else {
                                                @crumb.Name
                                            }
                                        </li>
                                    }
                                </ol>
                            </nav>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="mb-1">
                                        @if (!string.IsNullOrEmpty(_selected.Color)) {
                                            <span class="rounded-circle d-inline-block me-1" style="width:12px; height:12px; background:@_selected.Color;"></span>
                                        }
                                        @_selected.Name
                                    </h5>
                                    <code class="small text-muted">@_selected.ProjectKey</code>
                                </div>
                                <span class="badge @GetStatusBadge(_selected.Status) fs-6">@_selected.Status</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_selected.Description)) {
                                <p class="text-muted mb-3">@_selected.Description</p>
                            }

                            <div class="row g-3 mb-3">
                                <div class="col-sm-6">
                                    <div class="small text-muted">Lead</div>
                                    <div class="fw-semibold">@_selected.LeadName</div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="small text-muted">Department</div>
                                    <div class="fw-semibold">@(_selected.Department ?? "—")</div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="small text-muted">Start Date</div>
                                    <div>@(_selected.StartDate?.ToString("MMM d, yyyy") ?? "—")</div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="small text-muted">Target End</div>
                                    <div>@(_selected.TargetEndDate?.ToString("MMM d, yyyy") ?? "—")</div>
                                </div>
                            </div>

                            @* Sub-projects *@
                            @{ var children = _all.Where(p => p.ParentProjectId == _selected.RecordId).OrderBy(p => p.SortOrder).ToList(); }
                            @if (children.Any()) {
                                <h6 class="mt-3"><i class="fa-solid fa-sitemap me-1"></i> Sub-Projects (@children.Count)</h6>
                                <div class="list-group">
                                    @foreach (var child in children) {
                                        <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" @onclick="() => SelectProject(child.RecordId)">
                                            <span>
                                                @if (!string.IsNullOrEmpty(child.Color)) {
                                                    <span class="rounded-circle d-inline-block me-1" style="width:8px; height:8px; background:@child.Color;"></span>
                                                }
                                                @child.Name <code class="small ms-1">@child.ProjectKey</code>
                                            </span>
                                            <span class="badge @GetStatusBadge(child.Status)">@child.Status</span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                } else {
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center text-muted py-5">
                            <i class="fa-solid fa-arrow-left fa-2x mb-2 opacity-50"></i>
                            <div>Select a project from the tree to see its details</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _allExpanded = true;
    private string _pageName = "projectsv1";
    private HashSet<Guid> _expanded = new();
    private List<DataObjects.Project> _all = new();
    private DataObjects.Project? _selected;

    private string _codeSplit = "<div class=\"row g-3\">\n  <div class=\"col-md-5\"><!-- tree --></div>\n  <div class=\"col-md-7\"><!-- detail --></div>\n</div>";
    private string _codeBreadcrumb = "GetBreadcrumbs(id) walks parent chain\n→ [\"Root\", \"Child\", \"Current\"]";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var result = await Helpers.GetOrPost<List<DataObjects.Project>>("api/Data/GetProjects", new List<Guid>());
            _all = result ?? new();
            _expanded = new HashSet<Guid>(_all.Select(p => p.RecordId));
            _loading = false; StateHasChanged();
        }
    }

    private void SelectProject(Guid id) { _selected = _all.FirstOrDefault(p => p.RecordId == id); }

    private void ToggleExpandAll() {
        _allExpanded = !_allExpanded;
        _expanded = _allExpanded ? new HashSet<Guid>(_all.Select(p => p.RecordId)) : new();
    }

    private List<DataObjects.Project> GetBreadcrumbs(Guid id) {
        var crumbs = new List<DataObjects.Project>();
        var current = _all.FirstOrDefault(p => p.RecordId == id);
        while (current != null) {
            crumbs.Insert(0, current);
            current = current.ParentProjectId.HasValue ? _all.FirstOrDefault(p => p.RecordId == current.ParentProjectId.Value) : null;
        }
        return crumbs;
    }

    private record TreeNode(DataObjects.Project Project, int Depth);

    private List<TreeNode> GetFlatTreeNodes(Guid? parentId, int depth) {
        var result = new List<TreeNode>();
        var children = _all.Where(p => p.ParentProjectId == parentId).OrderBy(p => p.SortOrder).ThenBy(p => p.Name);
        foreach (var p in children) {
            result.Add(new TreeNode(p, depth));
            var hasKids = _all.Any(c => c.ParentProjectId == p.RecordId);
            if (hasKids && _expanded.Contains(p.RecordId)) {
                result.AddRange(GetFlatTreeNodes(p.RecordId, depth + 1));
            }
        }
        return result;
    }

    private static string GetStatusBadge(DataObjects.ProjectStatus s) => s switch {
        DataObjects.ProjectStatus.Active => "bg-success", DataObjects.ProjectStatus.Completed => "bg-primary",
        DataObjects.ProjectStatus.OnHold => "bg-warning text-dark", DataObjects.ProjectStatus.Archived => "bg-dark", _ => "bg-secondary"
    };
}
