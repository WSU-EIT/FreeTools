@page "/Examples/BootstrapV10"
@page "/{TenantCode}/Examples/BootstrapV10"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-window-restore me-1"></i> Modals &amp; Toasts</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-window-restore me-1"></i> V10: Modal Workflows &amp; Toasts
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="Bootstrap in Context: Modal Workflows &amp; Toasts" Subtitle="Multi-step modals and toast notifications — the CICD Import pattern" IconClass="fa-solid fa-window-restore">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This demonstrates <strong>modal-lg</strong> with a multi-step wizard flow and a
                        <strong>toast notification system</strong>. The CICD Import tool uses a large modal to walk
                        users through file selection, preview, and confirmation. Toast notifications appear in the
                        corner after actions complete.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>modal-lg</strong> and <strong>modal-dialog-centered</strong></li>
                        <li><strong>modal-footer</strong> with Next/Back/Finish buttons</li>
                        <li><strong>progress-bar</strong> showing wizard step progress</li>
                        <li><strong>toast</strong> notifications stacked in a corner</li>
                        <li><strong>Confirmation modal</strong> for destructive actions</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        The wizard modal tracks a step number. The modal-footer buttons advance or go back.
                        A progress-bar at the top reflects current step. Toasts are managed in a list and auto-dismiss
                        after a timeout. Each toast has a type (success, error, info) for color coding.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Action Cards ── *@
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <i class="fa-solid fa-file-import fa-2x text-primary mb-2"></i>
                        <h6>Import Wizard</h6>
                        <p class="small text-muted">Multi-step modal-lg wizard with progress bar.</p>
                        <button class="btn btn-primary btn-sm" @onclick="OpenImportWizard"><i class="fa-solid fa-wand-magic-sparkles me-1"></i> Start Import</button>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <i class="fa-solid fa-trash-can fa-2x text-danger mb-2"></i>
                        <h6>Confirm Delete</h6>
                        <p class="small text-muted">Confirmation modal for destructive actions.</p>
                        <button class="btn btn-danger btn-sm" @onclick="@(() => _showConfirm = true)"><i class="fa-solid fa-trash me-1"></i> Delete Item</button>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <i class="fa-solid fa-bell fa-2x text-success mb-2"></i>
                        <h6>Toast Notifications</h6>
                        <p class="small text-muted">Show toasts with different severity levels.</p>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-success" @onclick="@(() => ShowToast("Success", "Operation completed.", "success"))">Success</button>
                            <button class="btn btn-danger" @onclick="@(() => ShowToast("Error", "Something went wrong.", "error"))">Error</button>
                            <button class="btn btn-info" @onclick="@(() => ShowToast("Info", "New update available.", "info"))">Info</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="modal-lg + modal-dialog-centered"
                     Description="modal-lg creates a wider modal for complex content. modal-dialog-centered vertically centers it. Production uses this for import wizards, bulk operations, and detailed forms that need more space than a standard modal."
                     Code="@_codeModalLg" />
            <InfoTip Title="Toast Notification System"
                     Description="Toasts appear in a fixed corner (toast-container position-fixed). Each toast has bg-success/bg-danger/bg-info for type. They auto-dismiss via Task.Delay. In MainLayout, toasts stack and animate. The toast-header has a close button."
                     Code="@_codeToast" />
            <InfoTip Title="Confirmation Modal"
                     Description="Before destructive actions (delete, archive, reset), show a small confirmation modal. It names the item and action clearly. The danger button is red. This prevents accidental deletions — every production app uses this pattern."
                     Code="@_codeConfirm" />
        </div>

        @* ── Import History Table ── *@
        <h5 class="mb-3"><i class="fa-solid fa-clock-rotate-left me-1"></i> Import History</h5>
        <table class="table table-hover table-sm">
            <thead class="table-dark">
                <tr><th>Date</th><th>File</th><th>Records</th><th>Status</th></tr>
            </thead>
            <tbody>
                @foreach (var h in _importHistory) {
                    <tr>
                        <td class="small">@h.Date.ToString("g")</td>
                        <td class="small">@h.FileName</td>
                        <td class="small">@h.RecordCount</td>
                        <td><span class="badge @(h.Success ? "bg-success" : "bg-danger")">@(h.Success ? "Success" : "Failed")</span></td>
                    </tr>
                }
            </tbody>
        </table>

        @* ── Import Wizard Modal ── *@
        @if (_showImportWizard) {
            <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="fa-solid fa-file-import me-1"></i> Import Wizard — Step @_wizardStep of 3</h5>
                            <button type="button" class="btn-close" @onclick="CloseWizard"></button>
                        </div>
                        <div class="progress" style="height:4px; border-radius:0;">
                            <div class="progress-bar" style="width:@(_wizardStep * 100 / 3)%"></div>
                        </div>
                        <div class="modal-body">
                            @if (_wizardStep == 1) {
                                <h6>Step 1: Select Source</h6>
                                <p class="small text-muted">Choose the file format and upload your data file.</p>
                                <div class="mb-3">
                                    <label class="form-label small">File Format</label>
                                    <select class="form-select" @bind="_importFormat">
                                        <option>CSV</option><option>JSON</option><option>Excel</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small">File Name (simulated)</label>
                                    <input type="text" class="form-control" @bind="_importFileName" placeholder="data-export.csv" />
                                </div>
                            } else if (_wizardStep == 2) {
                                <h6>Step 2: Preview</h6>
                                <p class="small text-muted">Review the data before importing.</p>
                                <div class="alert alert-info small py-1"><i class="fa-solid fa-circle-info me-1"></i> Found 42 records in <strong>@_importFileName</strong> (@_importFormat format)</div>
                                <table class="table table-sm table-bordered">
                                    <thead class="table-light"><tr><th>Name</th><th>Category</th><th>Status</th></tr></thead>
                                    <tbody>
                                        <tr><td>Sample Record 1</td><td>Engineering</td><td>Active</td></tr>
                                        <tr><td>Sample Record 2</td><td>Marketing</td><td>Draft</td></tr>
                                        <tr><td>Sample Record 3</td><td>Operations</td><td>Active</td></tr>
                                    </tbody>
                                </table>
                                <div class="small text-muted">Showing 3 of 42 records...</div>
                            } else if (_wizardStep == 3) {
                                <h6>Step 3: Confirm</h6>
                                <p class="small text-muted">Review and confirm the import.</p>
                                <div class="card bg-light border-0 mb-3">
                                    <div class="card-body small">
                                        <div><strong>File:</strong> @_importFileName</div>
                                        <div><strong>Format:</strong> @_importFormat</div>
                                        <div><strong>Records:</strong> 42</div>
                                        <div><strong>Action:</strong> Insert new, update existing by name</div>
                                    </div>
                                </div>
                                @if (_importing) {
                                    <div class="progress mb-2">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:@_importProgress%">@_importProgress%</div>
                                    </div>
                                }
                            }
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseWizard">Cancel</button>
                            @if (_wizardStep > 1) {
                                <button class="btn btn-outline-primary" @onclick="@(() => _wizardStep--)" disabled="@_importing">Back</button>
                            }
                            @if (_wizardStep < 3) {
                                <button class="btn btn-primary" @onclick="@(() => _wizardStep++)">Next <i class="fa-solid fa-arrow-right ms-1"></i></button>
                            } else {
                                <button class="btn btn-success" @onclick="RunImport" disabled="@_importing"><i class="fa-solid fa-check me-1"></i> Import</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ── Confirm Modal ── *@
        @if (_showConfirm) {
            <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title text-danger"><i class="fa-solid fa-triangle-exclamation me-1"></i> Confirm Delete</h5>
                            <button type="button" class="btn-close" @onclick="@(() => _showConfirm = false)"></button>
                        </div>
                        <div class="modal-body">
                            <p>Are you sure you want to delete <strong>Sample Item</strong>? This action cannot be undone.</p>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="@(() => _showConfirm = false)">Cancel</button>
                            <button class="btn btn-danger" @onclick="ConfirmDelete"><i class="fa-solid fa-trash me-1"></i> Delete</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ── Toast Container ── *@
        <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:1090;">
            @foreach (var toast in _toasts) {
                <div class="toast show" role="alert">
                    <div class="toast-header @GetToastHeaderClass(toast.Type)">
                        <i class="@GetToastIcon(toast.Type) me-1"></i>
                        <strong class="me-auto">@toast.Title</strong>
                        <small class="@(toast.Type == "error" ? "text-white-50" : "text-muted")">just now</small>
                        <button type="button" class="btn-close @(toast.Type == "error" ? "btn-close-white" : "")" @onclick="@(() => _toasts.Remove(toast))"></button>
                    </div>
                    <div class="toast-body small">@toast.Message</div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "bootstrapv10";

    private string _codeModalLg = "<div class=\"modal-dialog modal-lg modal-dialog-centered\">\n  <div class=\"modal-content\">\n    <div class=\"modal-header\">...</div>\n    <div class=\"modal-body\">...</div>\n    <div class=\"modal-footer\">\n      <button class=\"btn btn-primary\">Next</button>\n    </div>\n  </div>\n</div>";
    private string _codeToast = "<div class=\"toast-container position-fixed bottom-0 end-0 p-3\">\n  <div class=\"toast show\">\n    <div class=\"toast-header\">\n      <strong>Title</strong>\n      <button class=\"btn-close\"></button>\n    </div>\n    <div class=\"toast-body\">Message</div>\n  </div>\n</div>";
    private string _codeConfirm = "<div class=\"modal-body\">\n  Are you sure you want to delete <strong>Item</strong>?\n</div>\n<div class=\"modal-footer\">\n  <button class=\"btn btn-secondary\">Cancel</button>\n  <button class=\"btn btn-danger\">Delete</button>\n</div>";

    // Wizard state
    private bool _showImportWizard = false, _importing = false, _showConfirm = false;
    private int _wizardStep = 1, _importProgress = 0;
    private string _importFormat = "CSV", _importFileName = "data-export.csv";

    private List<ToastItem> _toasts = new();
    private List<ImportRecord> _importHistory = new() {
        new(DateTime.Now.AddDays(-3), "users-q4.csv", 156, true),
        new(DateTime.Now.AddDays(-7), "products.json", 89, true),
        new(DateTime.Now.AddDays(-14), "bad-data.csv", 0, false),
    };

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }

    private void OpenImportWizard() { _wizardStep = 1; _importing = false; _importProgress = 0; _showImportWizard = true; }
    private void CloseWizard() { _showImportWizard = false; }
    private async Task RunImport() {
        _importing = true; _importProgress = 0;
        for (int i = 1; i <= 10; i++) { await Task.Delay(200); _importProgress = i * 10; StateHasChanged(); }
        _importHistory.Insert(0, new ImportRecord(DateTime.Now, _importFileName, 42, true));
        _importing = false; _showImportWizard = false;
        ShowToast("Import Complete", $"Successfully imported 42 records from {_importFileName}.", "success");
    }
    private void ConfirmDelete() { _showConfirm = false; ShowToast("Deleted", "Item was deleted successfully.", "success"); }
    private void ShowToast(string title, string message, string type) {
        var toast = new ToastItem(title, message, type);
        _toasts.Add(toast);
        _ = Task.Delay(4000).ContinueWith(_ => InvokeAsync(() => { _toasts.Remove(toast); StateHasChanged(); }));
    }

    private string GetToastHeaderClass(string type) => type switch { "error" => "bg-danger text-white", "success" => "bg-success text-white", _ => "bg-info text-white" };
    private string GetToastIcon(string type) => type switch { "error" => "fa-solid fa-circle-xmark", "success" => "fa-solid fa-circle-check", _ => "fa-solid fa-circle-info" };

    private record ToastItem(string Title, string Message, string Type);
    private record ImportRecord(DateTime Date, string FileName, int RecordCount, bool Success);
}
