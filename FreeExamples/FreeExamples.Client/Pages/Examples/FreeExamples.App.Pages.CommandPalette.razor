@page "/Examples/CommandPalette"
@page "/{TenantCode}/Examples/CommandPalette"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-terminal me-1"></i> Command Palette</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-terminal me-1"></i> Command Palette Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="About Command Palette" Subtitle="The same Search API in a VS Code / Spotlight / Raycast overlay" IconClass="fa-solid fa-terminal">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This is a <strong>variant</strong> of the Search & Autocomplete demo. It uses the exact same
                        <code>GetSampleItems</code> API but displays results in a <strong>centered overlay modal</strong> —
                        the pattern used by VS Code's Ctrl+P, macOS Spotlight, Raycast, and GitHub's command palette.
                        Instead of a search bar with a dropdown, you get a floating dialog over a dimmed page.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What's Different?</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Modal overlay</strong> — centered dialog over a dimmed backdrop</li>
                        <li><strong>Category grouping</strong> — results grouped by category with headers</li>
                        <li><strong>Shortcut trigger</strong> — opened via button (Ctrl+K in production)</li>
                        <li><strong>Action hints</strong> — "Enter to open · Esc to close" footer</li>
                        <li><strong>Same API</strong> — identical data source, completely different UI</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>When to Use Which?</h6>
                    <p class="small text-muted mb-0">
                        Use the <strong>inline search</strong> (Search & Autocomplete page) when search is the primary
                        action on the page — like a Google search page. Use the <strong>command palette</strong> (this
                        page) when search is a secondary shortcut that overlays the current page — like VS Code's Ctrl+P
                        or GitHub's command palette. Same data, different UX context.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Trigger Button ── *@
        <div class="text-center mb-4">
            <button class="btn btn-outline-secondary btn-lg px-4" @onclick="OpenPalette">
                <i class="fa-solid fa-magnifying-glass me-2"></i>
                Search items...
                <span class="badge bg-light text-muted border ms-3" style="font-size:0.65rem;">Ctrl+K</span>
            </button>
            <div class="small text-muted mt-2">Click the button above to open the command palette</div>
            <InfoTip Title="Trigger Pattern"
                     Description="In production, this would be triggered by a keyboard shortcut (Ctrl+K or Ctrl+P). The button is a fallback for discoverability. GitHub shows 'Type / to search' in the nav bar. VS Code shows a search icon. The key insight: the palette is always one keystroke away."
                     Code="@_codeTrigger" />
        </div>

        @* ── Selected Items History ── *@
        @if (_selectedHistory.Any()) {
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white py-2">
                    <span class="small fw-semibold"><i class="fa-solid fa-clock-rotate-left me-1"></i> Selection History</span>
                    <button class="btn btn-sm btn-link text-muted float-end p-0" @onclick="@(() => _selectedHistory.Clear())">Clear</button>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="small">Name</th>
                                <th class="small">Category</th>
                                <th class="small">Status</th>
                                <th class="small text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _selectedHistory) {
                                <tr>
                                    <td class="small fw-semibold">@item.Name</td>
                                    <td class="small"><span class="badge bg-light text-dark border" style="font-size:0.6rem;">@item.Category</span></td>
                                    <td><span class="badge @GetStatusBadge(item.Status)" style="font-size:0.6rem;">@item.Status</span></td>
                                    <td class="small text-end">@item.Amount.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── Command Palette Overlay ── *@
        @if (_paletteOpen) {
            @* Backdrop *@
            <div class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center"
                 style="z-index:1055; background:rgba(0,0,0,0.5); padding-top:10vh;"
                 @onclick="ClosePalette">

                @* Palette Dialog *@
                <div class="bg-white rounded-3 shadow-lg d-flex flex-column" style="width:min(600px, 90vw); max-height:70vh;"
                     @onclick:stopPropagation>

                    @* Search Input *@
                    <div class="p-3 border-bottom">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                @if (_searching) {
                                    <span class="spinner-border spinner-border-sm text-primary"></span>
                                } else {
                                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                                }
                            </span>
                            <input type="text" class="form-control form-control-lg border-start-0"
                                   placeholder="Search sample items..."
                                   @bind="_searchTerm"
                                   @bind:event="oninput"
                                   @bind:after="OnSearchInput"
                                   @onkeydown="HandleKeydown"
                                   autofocus />
                        </div>
                    </div>

                    @* Results *@
                    <div class="flex-grow-1 overflow-auto">
                        @if (_groupedResults.Any()) {
                            int globalIdx = 0;
                            @foreach (var group in _groupedResults) {
                                <div class="px-3 py-1 bg-light border-bottom">
                                    <span class="small fw-semibold text-muted text-uppercase" style="font-size:0.65rem;">
                                        @group.Key
                                        <span class="badge bg-secondary rounded-pill ms-1" style="font-size:0.55rem;">@group.Count()</span>
                                    </span>
                                </div>
                                @foreach (var item in group) {
                                    int idx = globalIdx++;
                                    <div class="px-3 py-2 d-flex align-items-center border-bottom @(idx == _highlightIndex ? "bg-primary bg-opacity-10" : "")"
                                         role="button" @onclick="@(() => SelectItem(item))">
                                        <i class="fa-solid fa-file-lines text-muted me-2"></i>
                                        <div class="flex-grow-1">
                                            <span class="small fw-semibold">@((MarkupString)HighlightMatch(item.Name, _searchTerm))</span>
                                            <span class="badge @GetStatusBadge(item.Status) ms-2" style="font-size:0.55rem;">@item.Status</span>
                                        </div>
                                        <span class="small text-muted">@item.Amount.ToString("C")</span>
                                    </div>
                                }
                            }
                        } else if (!string.IsNullOrWhiteSpace(_searchTerm) && _searchTerm.Length >= 2 && !_searching) {
                            <div class="text-center py-5">
                                <i class="fa-solid fa-folder-open fa-2x text-muted opacity-25 mb-2"></i>
                                <div class="text-muted small">No items match "<strong>@_searchTerm</strong>"</div>
                            </div>
                        } else if (string.IsNullOrWhiteSpace(_searchTerm)) {
                            <div class="text-center py-5">
                                <i class="fa-solid fa-magnifying-glass fa-2x text-muted opacity-25 mb-2"></i>
                                <div class="text-muted small">Type to search across all sample items</div>
                            </div>
                        }
                    </div>

                    @* Footer *@
                    <div class="px-3 py-2 border-top bg-light d-flex justify-content-between">
                        <div class="d-flex gap-3 small text-muted">
                            <span><kbd>↑↓</kbd> Navigate</span>
                            <span><kbd>Enter</kbd> Select</span>
                            <span><kbd>Esc</kbd> Close</span>
                        </div>
                        <span class="small text-muted">@_flatResults.Count results</span>
                    </div>
                </div>
            </div>
        }

        <div class="d-flex flex-wrap gap-1 mt-2">
            <InfoTip Title="Category Grouping"
                     Description="Results are grouped by Category using LINQ's GroupBy. Each group gets a header row with the category name and count badge. Within each group, items are listed by name. The highlight index counts across all groups linearly (global index)."
                     Code="@_codeGrouping" />
            <InfoTip Title="Keyboard Shortcut Footer"
                     Description="The footer shows available keyboard shortcuts using kbd elements. This is a discoverability pattern — users learn the shortcuts by seeing them. VS Code, GitHub, and Figma all show shortcut hints in their command palettes."
                     Code="@_codeFooter" />
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private bool _searching = false;
    private bool _paletteOpen = false;
    private string _pageName = "commandpalette";

    // InfoTip snippets
    private string _codeTrigger = "<button @onclick=\"OpenPalette\">Search...\n    <span class=\"badge\">Ctrl+K</span>\n</button>";
    private string _codeGrouping = "var grouped = results\n    .GroupBy(i => i.Category)\n    .OrderBy(g => g.Key);";
    private string _codeFooter = "<div><kbd>↑↓</kbd> Navigate  <kbd>Enter</kbd> Select  <kbd>Esc</kbd> Close</div>";

    // State
    private string _searchTerm = "";
    private List<DataObjects.SampleItem> _allItems = new();
    private List<DataObjects.SampleItem> _flatResults = new();
    private IEnumerable<IGrouping<string, DataObjects.SampleItem>> _groupedResults = Enumerable.Empty<IGrouping<string, DataObjects.SampleItem>>();
    private int _highlightIndex = -1;
    private List<DataObjects.SampleItem> _selectedHistory = new();
    private System.Timers.Timer _debounceTimer = null!;

    // ── Lifecycle ──

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
        _debounceTimer?.Dispose();
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }

        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += DebounceElapsed;
        _debounceTimer.AutoReset = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;

            var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
            if (result != null) {
                _allItems = result.Where(i => !i.Deleted).ToList();
            }

            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    // ── Palette ──

    private void OpenPalette()
    {
        _paletteOpen = true;
        _searchTerm = "";
        _flatResults.Clear();
        _groupedResults = Enumerable.Empty<IGrouping<string, DataObjects.SampleItem>>();
        _highlightIndex = -1;
    }

    private void ClosePalette()
    {
        _paletteOpen = false;
    }

    // ── Search ──

    private void OnSearchInput()
    {
        _highlightIndex = -1;
        _debounceTimer.Stop();

        if (!string.IsNullOrWhiteSpace(_searchTerm) && _searchTerm.Length >= 2) {
            _searching = true;
            _debounceTimer.Start();
        } else {
            _flatResults.Clear();
            _groupedResults = Enumerable.Empty<IGrouping<string, DataObjects.SampleItem>>();
            _searching = false;
        }
    }

    private async void DebounceElapsed(object? source, System.Timers.ElapsedEventArgs e)
    {
        await InvokeAsync(() => {
            string term = _searchTerm?.ToLower() ?? "";

            _flatResults = _allItems
                .Where(i =>
                    (i.Name?.ToLower().Contains(term) == true) ||
                    (i.Description?.ToLower().Contains(term) == true) ||
                    (i.Category?.ToLower().Contains(term) == true))
                .OrderBy(i => i.Category)
                .ThenBy(i => i.Name)
                .Take(15)
                .ToList();

            _groupedResults = _flatResults.GroupBy(i => i.Category ?? "Other").OrderBy(g => g.Key);
            _searching = false;
            StateHasChanged();
        });
    }

    // ── Keyboard ──

    private void HandleKeydown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Escape") {
            ClosePalette();
            return;
        }

        if (!_flatResults.Any()) return;

        if (e.Key == "ArrowDown") {
            _highlightIndex = Math.Min(_highlightIndex + 1, _flatResults.Count - 1);
        } else if (e.Key == "ArrowUp") {
            _highlightIndex = Math.Max(_highlightIndex - 1, 0);
        } else if (e.Key == "Enter" && _highlightIndex >= 0 && _highlightIndex < _flatResults.Count) {
            SelectItem(_flatResults[_highlightIndex]);
        }
    }

    // ── Selection ──

    private void SelectItem(DataObjects.SampleItem item)
    {
        if (!_selectedHistory.Any(h => h.SampleItemId == item.SampleItemId)) {
            _selectedHistory.Insert(0, item);
            if (_selectedHistory.Count > 10) _selectedHistory.RemoveAt(10);
        }
        ClosePalette();
    }

    // ── Helpers ──

    private string HighlightMatch(string text, string? term)
    {
        if (string.IsNullOrWhiteSpace(term) || string.IsNullOrWhiteSpace(text)) return text ?? "";
        int idx = text.IndexOf(term, StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return text;
        return text[..idx] + "<strong>" + text[idx..(idx + term.Length)] + "</strong>" + text[(idx + term.Length)..];
    }

    private string GetStatusBadge(DataObjects.SampleItemStatus status) => status switch {
        DataObjects.SampleItemStatus.Draft => "bg-secondary",
        DataObjects.SampleItemStatus.Active => "bg-success",
        DataObjects.SampleItemStatus.Completed => "bg-primary",
        DataObjects.SampleItemStatus.Archived => "bg-dark",
        _ => "bg-secondary",
    };
}
