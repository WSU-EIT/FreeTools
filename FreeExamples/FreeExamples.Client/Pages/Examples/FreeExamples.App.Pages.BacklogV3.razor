@page "/Examples/BacklogV3"
@page "/{TenantCode}/Examples/BacklogV3"
@implements IDisposable
@inject BlazorDataModel Model

@* V3: Grouped Backlog — Group by type, priority, assignee, or label *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-object-group me-1"></i> Grouped Backlog</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-object-group me-1"></i> V3: Grouped Backlog <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Grouped Backlog" Subtitle="Backlog tickets grouped by type, priority, assignee, or label with collapsible sections" IconClass="fa-solid fa-object-group">
            <p class="small text-muted mb-0">Toggle between grouping modes. Each group is collapsible. Shows ticket count per group and highlights unassigned or unestimated tickets.</p>
        </AboutSection>

        @* Group-by selector *@
        <div class="d-flex align-items-center gap-2 mb-3">
            <label class="form-label mb-0 small fw-semibold">Group by:</label>
            <div class="btn-group btn-group-sm">
                <button class="btn @(_groupBy == "type" ? "btn-dark" : "btn-outline-dark")" @onclick='() => _groupBy = "type"'>Type</button>
                <button class="btn @(_groupBy == "priority" ? "btn-dark" : "btn-outline-dark")" @onclick='() => _groupBy = "priority"'>Priority</button>
                <button class="btn @(_groupBy == "assignee" ? "btn-dark" : "btn-outline-dark")" @onclick='() => _groupBy = "assignee"'>Assignee</button>
                <button class="btn @(_groupBy == "label" ? "btn-dark" : "btn-outline-dark")" @onclick='() => _groupBy = "label"'>Label</button>
            </div>
            <span class="text-muted small ms-auto">@_backlog.Count items</span>
        </div>

        @foreach (var grp in GetGroups()) {
            var isCollapsed = _collapsed.Contains(grp.Key);
            <div class="card border-0 shadow-sm mb-2">
                <div class="card-header bg-light py-1 d-flex justify-content-between align-items-center" style="cursor:pointer;" @onclick="() => ToggleCollapse(grp.Key)">
                    <span class="small fw-semibold">
                        <i class="fa-solid @(isCollapsed ? "fa-chevron-right" : "fa-chevron-down") me-1 text-muted" style="font-size:0.6rem;"></i>
                        @grp.Key
                    </span>
                    <span class="badge bg-secondary rounded-pill">@grp.Items.Count</span>
                </div>
                @if (!isCollapsed) {
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0 small">
                            <tbody>
                                @foreach (var t in grp.Items) {
                                    <tr>
                                        <td style="width:100px;"><code>@t.TicketNumber</code></td>
                                        <td>@t.Title</td>
                                        <td style="width:70px;"><span class="badge @GetPriorityBadge(t.Priority)" style="font-size:0.5rem;">@t.Priority</span></td>
                                        <td style="width:40px;" class="text-center">@(t.StoryPoints?.ToString() ?? "<span class='text-warning'>?</span>")</td>
                                        <td style="width:100px;" class="text-muted @(string.IsNullOrEmpty(t.AssignedTo) ? "text-warning fw-semibold" : "")">@(t.AssignedTo ?? "Unassigned")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "backlogv3", _groupBy = "type";
    private List<DataObjects.Ticket> _backlog = new();
    private HashSet<string> _collapsed = new();

    private record GroupRow(string Key, List<DataObjects.Ticket> Items);

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var t = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/GetTickets", new List<Guid>()) ?? new();
            _backlog = t.Where(x => x.SprintId == null || x.SprintId == Guid.Empty).OrderBy(x => x.SortOrder).ToList();
            _loading = false; StateHasChanged();
        }
    }

    private void ToggleCollapse(string key) { if (!_collapsed.Remove(key)) _collapsed.Add(key); }

    private List<GroupRow> GetGroups() => _groupBy switch {
        "type" => _backlog.GroupBy(t => t.Type.ToString()).OrderBy(g => g.Key).Select(g => new GroupRow(g.Key, g.ToList())).ToList(),
        "priority" => _backlog.GroupBy(t => t.Priority.ToString()).OrderBy(g => g.Key).Select(g => new GroupRow(g.Key, g.ToList())).ToList(),
        "assignee" => _backlog.GroupBy(t => t.AssignedTo ?? "Unassigned").OrderBy(g => g.Key).Select(g => new GroupRow(g.Key, g.ToList())).ToList(),
        "label" => _backlog.SelectMany(t => (t.Labels ?? "Unlabeled").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).DefaultIfEmpty("Unlabeled").Select(l => (Label: l, Ticket: t)))
                           .GroupBy(x => x.Label).OrderBy(g => g.Key).Select(g => new GroupRow(g.Key, g.Select(x => x.Ticket).ToList())).ToList(),
        _ => new()
    };

    private static string GetPriorityBadge(DataObjects.TicketPriority p) => p switch { DataObjects.TicketPriority.Critical => "bg-danger", DataObjects.TicketPriority.High => "bg-warning text-dark", DataObjects.TicketPriority.Medium => "bg-info", _ => "bg-secondary" };
}
