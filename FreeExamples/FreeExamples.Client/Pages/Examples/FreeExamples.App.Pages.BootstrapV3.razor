@page "/Examples/BootstrapV3"
@page "/{TenantCode}/Examples/BootstrapV3"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-triangle-exclamation me-1"></i> Error Pages</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-triangle-exclamation me-1"></i> V3: Error Pages <StickyMenuIcon /></h1></div>

        <ExampleNav />
        <AboutSection Title="Bootstrap in Context: Error Pages" Subtitle="404, 403, and 500 error pages — Bootstrap layout for the pages users hope they never see" IconClass="fa-solid fa-triangle-exclamation">
            <p class="small text-muted mb-0">Standard HTTP error pages (404, 403, 500) built with Bootstrap typography, icons, and buttons. Every app needs these.</p>
        </AboutSection>
        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Error Page Typography"
                     Description="Error pages use display-4 for the large error code, lead text-muted for the subtitle, and small text-muted for the description. This is standard Bootstrap typography hierarchy. The large icon (fa-5x) provides instant visual recognition."
                     Code="@_codeErrorTypography" />
            <InfoTip Title="CTA Buttons on Error Pages"
                     Description="Each error page has action buttons: 'Go Home' (btn-primary) for 404, 'Go Back' (btn-outline-secondary) for 403, and dual buttons for 500 (Retry + Support). The d-flex gap-2 justify-content-center layout centers multiple buttons."
                     Code="@_codeCtaButtons" />
            <InfoTip Title="Error Page Selection"
                     Description="The btn-group below lets you switch between error types. In production, these are separate routes (/error/404, /error/403, /error/500). Here they're shown together for learning. The active button uses the solid variant while others use outline."
                     Code="@_codeErrorToggle" />
        </div>

        <div class="text-center mb-3">
            <div class="btn-group btn-group-sm">
                <button class="btn @(_errorType == 404 ? "btn-warning" : "btn-outline-warning")" @onclick="@(() => _errorType = 404)">404</button>
                <button class="btn @(_errorType == 403 ? "btn-danger" : "btn-outline-danger")" @onclick="@(() => _errorType = 403)">403</button>
                <button class="btn @(_errorType == 500 ? "btn-secondary" : "btn-outline-secondary")" @onclick="@(() => _errorType = 500)">500</button>
            </div>
        </div>

        @if (_errorType == 404) {
        <div class="text-center py-5"><i class="fa-solid fa-ghost fa-5x text-warning mb-3"></i><h1 class="display-4">404</h1><p class="lead text-muted">Page not found</p><p class="small text-muted">The page you're looking for doesn't exist or has been moved.</p><a href="#" class="btn btn-primary"><i class="fa-solid fa-home me-1"></i> Go Home</a></div>
        } else if (_errorType == 403) {
        <div class="text-center py-5"><i class="fa-solid fa-lock fa-5x text-danger mb-3"></i><h1 class="display-4">403</h1><p class="lead text-muted">Access Denied</p><p class="small text-muted">You don't have permission to view this resource. Contact your administrator.</p><a href="#" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left me-1"></i> Go Back</a></div>
        } else {
        <div class="text-center py-5"><i class="fa-solid fa-server fa-5x text-secondary mb-3"></i><h1 class="display-4">500</h1><p class="lead text-muted">Internal Server Error</p><p class="small text-muted">Something went wrong on our end. Please try again later.</p><div class="d-flex gap-2 justify-content-center"><a href="#" class="btn btn-primary"><i class="fa-solid fa-arrows-rotate me-1"></i> Retry</a><a href="#" class="btn btn-outline-secondary"><i class="fa-solid fa-life-ring me-1"></i> Support</a></div></div>
        }
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "bootstrapv3";
    private int _errorType = 404;
    private string _codeErrorTypography = "<h1 class=\"display-4\">404</h1>\n<p class=\"lead text-muted\">Page not found</p>\n<p class=\"small text-muted\">Description</p>";
    private string _codeCtaButtons = "<div class=\"d-flex gap-2 justify-content-center\">\n  <a class=\"btn btn-primary\">Retry</a>\n  <a class=\"btn btn-outline-secondary\">Support</a>\n</div>";
    private string _codeErrorToggle = "<div class=\"btn-group btn-group-sm\">\n  <button class=\"btn @(_errorType == 404 ? \"btn-warning\" : \"btn-outline-warning\")\"\n    @onclick=\"() => _errorType = 404\">404</button>\n</div>";
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
}
