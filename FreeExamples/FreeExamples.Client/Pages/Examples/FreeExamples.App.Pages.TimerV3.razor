@page "/Examples/TimerV3"
@page "/{TenantCode}/Examples/TimerV3"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-spinner me-1"></i> Auto-Refresh</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-spinner me-1"></i> V3: Auto-Refresh Dashboard <StickyMenuIcon /></h1></div>

        <ExampleNav />
        <AboutSection Title="Timer in Context: Auto-Refresh" Subtitle="Data refreshes automatically every N seconds — the monitoring dashboard pattern" IconClass="fa-solid fa-spinner">
            <p class="small text-muted mb-0">A dashboard that auto-refreshes its data on an interval. Configurable refresh rate. Shows last-refresh timestamp and next-refresh countdown.</p>
        </AboutSection>
        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Auto-Refresh Polling"
                     Description="A timer periodically refreshes data from the server (e.g., every 30 seconds). The interval is configurable. A 'Last refreshed: X seconds ago' indicator shows data freshness. This is the dashboard auto-refresh pattern."
                     Code="@_codeAutoRefresh" />
            <InfoTip Title="Refresh Interval Selector"
                     Description="A dropdown lets users choose the refresh interval (5s, 15s, 30s, 60s, Off). Changing the interval resets the timer. 'Off' stops auto-refresh entirely. This gives users control over update frequency vs performance."
                     Code="@_codeIntervalSelector" />
            <InfoTip Title="Loading Spinner During Refresh"
                     Description="While data is refreshing, a small spinner (spinner-border spinner-border-sm) appears next to the last-refreshed text. This indicates background activity without blocking the UI. The data table stays visible and interactive during refresh."
                     Code="@_codeRefreshSpinner" />
        </div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="small text-muted">Last refresh: <strong>@_lastRefresh?.ToString("h:mm:ss tt")</strong> · Refresh #@_refreshCount</div>
            <div class="d-flex gap-2 align-items-center">
                <select class="form-select form-select-sm" style="width:auto;" @bind="_intervalSeconds" @bind:after="UpdateInterval"><option value="5">5s</option><option value="10">10s</option><option value="30">30s</option><option value="60">60s</option></select>
                <button class="btn btn-sm @(_autoRefresh ? "btn-danger" : "btn-success")" @onclick="ToggleAutoRefresh">@(_autoRefresh ? "Stop" : "Start")</button>
            </div>
        </div>
        <div class="row row-cols-2 row-cols-md-4 g-2 mb-3">
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h5 mb-0">@_cpu%</div><div class="small text-muted">CPU</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h5 mb-0">@_memory%</div><div class="small text-muted">Memory</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h5 mb-0">@_requests</div><div class="small text-muted">Req/s</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h5 mb-0">@_latency ms</div><div class="small text-muted">Latency</div></div></div>
        </div>
        @if (_autoRefresh) { <div class="progress" style="height:3px;"><div class="progress-bar bg-primary" style="width:@(_nextRefreshPct)%; transition:width 1s linear;"></div></div> }
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _autoRefresh = false;
    private string _pageName = "timerv3";
    private string _codeAutoRefresh = "_timer.Elapsed += async (s, e) => {\n  var data = await Http.GetFromJsonAsync<List<Item>>(\"api/items\");\n  await InvokeAsync(() => { _items = data; StateHasChanged(); });\n};";
    private string _codeIntervalSelector = "<select @bind=\"_intervalSeconds\" @bind:after=\"ResetTimer\">\n  <option value=\"5\">5 seconds</option>\n  <option value=\"30\">30 seconds</option>\n  <option value=\"0\">Off</option>\n</select>";
    private string _codeRefreshSpinner = "@if (_refreshing) {\n  <span class=\"spinner-border spinner-border-sm\"></span>\n}\n<span>Last refreshed: @_lastRefresh</span>";
    private int _intervalSeconds = 10, _refreshCount = 0, _cpu = 42, _memory = 68, _requests = 124, _latency = 89;
    private int _nextRefreshPct = 100;
    private DateTime? _lastRefresh;
    private System.Timers.Timer? _timer;
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); _timer?.Dispose(); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); _timer = new System.Timers.Timer(1000); _timer.Elapsed += (s, e) => InvokeAsync(() => { _nextRefreshPct -= (100 / _intervalSeconds); if (_nextRefreshPct <= 0) { Refresh(); _nextRefreshPct = 100; } StateHasChanged(); }); _lastRefresh = DateTime.Now; }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
    private void Refresh() { var r = new Random(); _cpu = r.Next(20, 85); _memory = r.Next(50, 90); _requests = r.Next(80, 200); _latency = r.Next(50, 200); _refreshCount++; _lastRefresh = DateTime.Now; }
    private void ToggleAutoRefresh() { _autoRefresh = !_autoRefresh; if (_autoRefresh) { _nextRefreshPct = 100; _timer?.Start(); } else _timer?.Stop(); }
    private void UpdateInterval() { if (_autoRefresh) { _timer?.Stop(); _nextRefreshPct = 100; _timer?.Start(); } }
}
