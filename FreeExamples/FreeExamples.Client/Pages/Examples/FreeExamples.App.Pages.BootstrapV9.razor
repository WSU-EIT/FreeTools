@page "/Examples/BootstrapV9"
@page "/{TenantCode}/Examples/BootstrapV9"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-pen-to-square me-1"></i> Master-Detail</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-pen-to-square me-1"></i> V9: Master-Detail Edit Form
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="Bootstrap in Context: Master-Detail Edit Form" Subtitle="Edit/View toggle with split-button save — the Credentials pattern" IconClass="fa-solid fa-pen-to-square">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This demonstrates the <strong>master-detail edit form</strong> used in Credentials and
                        DependencyManager. A left-side list selects an item, and the right side shows a detail form
                        that toggles between read-only view and editable mode.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Edit/View toggle</strong> with form-switch</li>
                        <li><strong>Split-button dropdown</strong> for Save variations</li>
                        <li><strong>Card sections</strong> organizing form fields</li>
                        <li><strong>Alert-danger</strong> for validation messages</li>
                        <li><strong>Soft-delete</strong> with undelete option</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        The left column shows a list-group of items. Clicking one loads it into the detail form on
                        the right. The AllowEdit toggle switches between disabled (view) and enabled (edit) inputs.
                        The split-button save has a primary action and a dropdown for alternate save modes.
                    </p>
                </div>
            </div>
        </AboutSection>

        <div class="row">
            @* ── Left: Item List ── *@
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                        <span class="small fw-semibold"><i class="fa-solid fa-list me-1"></i> Items</span>
                        <button class="btn btn-sm btn-primary" @onclick="AddNew"><i class="fa-solid fa-plus"></i></button>
                    </div>
                    <div class="list-group list-group-flush" style="max-height:500px; overflow-y:auto;">
                        @foreach (var item in _items.Where(i => !i.Deleted)) {
                            <button class="list-group-item list-group-item-action @(_selected == item ? "active" : "")" @onclick="@(() => SelectItem(item))">
                                <div class="d-flex justify-content-between">
                                    <span class="small fw-semibold">@item.Name</span>
                                    <span class="badge @GetTypeBadge(item.Type)">@item.Type</span>
                                </div>
                                <div class="small @(_selected == item ? "text-white-50" : "text-muted")">@item.Category</div>
                            </button>
                        }
                    </div>
                    @if (_items.Any(i => i.Deleted)) {
                        <div class="card-footer bg-white py-1">
                            <button class="btn btn-link btn-sm text-muted p-0" @onclick="@(() => _showDeleted = !_showDeleted)">
                                <i class="fa-solid fa-trash me-1"></i> @(_showDeleted ? "Hide" : "Show") Deleted (@_items.Count(i => i.Deleted))
                            </button>
                            @if (_showDeleted) {
                                @foreach (var item in _items.Where(i => i.Deleted)) {
                                    <div class="d-flex justify-content-between align-items-center py-1">
                                        <span class="small text-muted text-decoration-line-through">@item.Name</span>
                                        <button class="btn btn-xs btn-outline-success" @onclick="@(() => { item.Deleted = false; })"><i class="fa-solid fa-rotate-left"></i></button>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            </div>

            @* ── Right: Detail Form ── *@
            <div class="col-md-8 mb-3">
                @if (_selected != null) {
                    @* Edit/View Toggle *@
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="allowEdit" @bind="_allowEdit" />
                            <label class="form-check-label small" for="allowEdit">Allow Editing</label>
                        </div>
                        <InfoTip Title="Edit/View Toggle"
                                 Description="In Credentials, the AllowEdit switch controls whether form fields are editable or read-only. This prevents accidental edits. The user must explicitly enable editing. All form-control elements get the 'disabled' attribute when AllowEdit is false."
                                 Code="@_codeEditToggle" />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_validationError)) {
                        <div class="alert alert-danger small py-2"><i class="fa-solid fa-triangle-exclamation me-1"></i> @_validationError</div>
                    }
                    @if (_saveSuccess) {
                        <div class="alert alert-success small py-2"><i class="fa-solid fa-check-circle me-1"></i> Saved successfully.</div>
                    }

                    @* Details Card *@
                    <div class="card shadow-sm border-0 mb-3">
                        <div class="card-header bg-white py-2"><span class="small fw-semibold"><i class="fa-solid fa-circle-info me-1"></i> Details</span></div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label class="form-label small">Name</label>
                                    <input type="text" class="form-control form-control-sm" @bind="_selected.Name" disabled="@(!_allowEdit)" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">Type</label>
                                    <select class="form-select form-select-sm" @bind="_selected.Type" disabled="@(!_allowEdit)">
                                        <option>Database</option><option>API</option><option>Service</option><option>File</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Category</label>
                                    <input type="text" class="form-control form-control-sm" @bind="_selected.Category" disabled="@(!_allowEdit)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Owner</label>
                                    <input type="text" class="form-control form-control-sm" @bind="_selected.Owner" disabled="@(!_allowEdit)" />
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Connection Card *@
                    <div class="card shadow-sm border-0 mb-3">
                        <div class="card-header bg-white py-2"><span class="small fw-semibold"><i class="fa-solid fa-link me-1"></i> Connection</span></div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label small">Connection String / URL</label>
                                    <input type="text" class="form-control form-control-sm" @bind="_selected.ConnectionString" disabled="@(!_allowEdit)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Username</label>
                                    <input type="text" class="form-control form-control-sm" @bind="_selected.Username" disabled="@(!_allowEdit)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small">Password</label>
                                    <div class="input-group input-group-sm">
                                        <input type="@(_showPassword ? "text" : "password")" class="form-control" @bind="_selected.Password" disabled="@(!_allowEdit)" />
                                        <button class="btn btn-outline-secondary" @onclick="@(() => _showPassword = !_showPassword)" disabled="@(!_allowEdit)">
                                            <i class="fa-solid @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Notes Card *@
                    <div class="card shadow-sm border-0 mb-3">
                        <div class="card-header bg-white py-2"><span class="small fw-semibold"><i class="fa-solid fa-sticky-note me-1"></i> Notes</span></div>
                        <div class="card-body">
                            <textarea class="form-control form-control-sm" rows="3" @bind="_selected.Notes" disabled="@(!_allowEdit)"></textarea>
                        </div>
                    </div>

                    @* Action Buttons *@
                    <div class="d-flex justify-content-between">
                        <button class="btn btn-outline-danger btn-sm" @onclick="DeleteSelected" disabled="@(!_allowEdit)">
                            <i class="fa-solid fa-trash me-1"></i> Delete
                        </button>
                        <div>
                            <div class="btn-group">
                                <button class="btn btn-success" @onclick="Save" disabled="@(!_allowEdit)">
                                    <i class="fa-solid fa-floppy-disk me-1"></i> Save
                                </button>
                                <button type="button" class="btn btn-success dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" disabled="@(!_allowEdit)">
                                    <span class="visually-hidden">Toggle Dropdown</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><button class="dropdown-item" @onclick="Save"><i class="fa-solid fa-floppy-disk me-1"></i> Save</button></li>
                                    <li><button class="dropdown-item" @onclick="SaveAndClose"><i class="fa-solid fa-floppy-disk me-1"></i> Save &amp; Close</button></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><button class="dropdown-item" @onclick="SaveAsNew"><i class="fa-solid fa-copy me-1"></i> Save as New</button></li>
                                </ul>
                            </div>
                            <InfoTip Title="Split-Button Save"
                                     Description="The split-button dropdown is used in Helpdesk for 'Save / Save Without Notification'. The left button does the primary save. The right arrow opens a dropdown with alternate save actions. This is dropdown-toggle-split with btn-group."
                                     Code="@_codeSplitButton" />
                        </div>
                    </div>
                } else {
                    <div class="text-center py-5 text-muted">
                        <i class="fa-solid fa-hand-pointer fa-3x mb-3 opacity-50"></i>
                        <div>Select an item from the list to view details.</div>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _allowEdit = false, _showPassword = false, _showDeleted = false, _saveSuccess = false;
    private string _pageName = "bootstrapv9";
    private string _validationError = "";

    private string _codeEditToggle = "<div class=\"form-check form-switch\">\n  <input class=\"form-check-input\" @bind=\"_allowEdit\" />\n  <label>Allow Editing</label>\n</div>\n<input class=\"form-control\" disabled=\"@(!_allowEdit)\" />";
    private string _codeSplitButton = "<div class=\"btn-group\">\n  <button class=\"btn btn-success\" @onclick=\"Save\">Save</button>\n  <button class=\"btn btn-success dropdown-toggle dropdown-toggle-split\"\n    data-bs-toggle=\"dropdown\"></button>\n  <ul class=\"dropdown-menu\">\n    <li><button class=\"dropdown-item\">Save & Close</button></li>\n  </ul>\n</div>";

    private CredentialItem? _selected;
    private List<CredentialItem> _items = new();

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() {
        Model.View = _pageName; Model.OnChange += StateHasChanged;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName);
        _items = new List<CredentialItem> {
            new() { Name = "Production DB", Type = "Database", Category = "Production", Owner = "DBA Team", ConnectionString = "Server=prod-sql;Database=AppDB;", Username = "app_user", Password = "s3cret!", Notes = "Primary production database." },
            new() { Name = "Staging API", Type = "API", Category = "Staging", Owner = "Dev Team", ConnectionString = "https://staging-api.example.com", Username = "api_key", Password = "stg_key_123", Notes = "Staging environment API." },
            new() { Name = "Backup Service", Type = "Service", Category = "Infrastructure", Owner = "Ops Team", ConnectionString = "https://backup.internal", Username = "backup_svc", Password = "bkp_pass", Notes = "Nightly backup service account." },
            new() { Name = "Log Storage", Type = "File", Category = "Infrastructure", Owner = "Ops Team", ConnectionString = "\\\\fileserver\\logs", Username = "", Password = "", Notes = "Shared log directory." },
        };
    }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }

    private void SelectItem(CredentialItem item) { _selected = item; _allowEdit = false; _validationError = ""; _saveSuccess = false; _showPassword = false; }
    private void AddNew() { var n = new CredentialItem { Name = "New Item", Type = "Database", Category = "", Owner = "" }; _items.Insert(0, n); _selected = n; _allowEdit = true; }
    private void DeleteSelected() { if (_selected != null) { _selected.Deleted = true; _selected = null; _allowEdit = false; } }
    private void Save() {
        if (_selected != null && string.IsNullOrWhiteSpace(_selected.Name)) { _validationError = "Name is required."; return; }
        _validationError = ""; _saveSuccess = true;
        _ = Task.Delay(2000).ContinueWith(_ => InvokeAsync(() => { _saveSuccess = false; StateHasChanged(); }));
    }
    private void SaveAndClose() { Save(); if (string.IsNullOrWhiteSpace(_validationError)) { _selected = null; _allowEdit = false; } }
    private void SaveAsNew() { if (_selected != null) { var copy = new CredentialItem { Name = _selected.Name + " (Copy)", Type = _selected.Type, Category = _selected.Category, Owner = _selected.Owner, ConnectionString = _selected.ConnectionString, Username = _selected.Username, Password = _selected.Password, Notes = _selected.Notes }; _items.Insert(0, copy); _selected = copy; } }

    private string GetTypeBadge(string type) => type switch { "Database" => "bg-primary", "API" => "bg-success", "Service" => "bg-warning text-dark", "File" => "bg-info", _ => "bg-secondary" };

    private class CredentialItem {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public string Category { get; set; } = "";
        public string Owner { get; set; } = "";
        public string ConnectionString { get; set; } = "";
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public string Notes { get; set; } = "";
        public bool Deleted { get; set; } = false;
    }
}
