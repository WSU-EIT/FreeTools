@page "/Examples/ImageGallery"
@page "/{TenantCode}/Examples/ImageGallery"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-images me-1"></i> Image Gallery</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-images me-1"></i> Image Gallery / Lightbox Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="About Image Galleries" Subtitle="Thumbnail grids with lightbox overlays — the Instagram / Rover / Ford pattern" IconClass="fa-solid fa-images">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This demonstrates an <strong>image gallery</strong> with a <strong>lightbox</strong> overlay.
                        Click a thumbnail to see it full-size in a dark overlay with prev/next navigation. Instagram,
                        Rover, Ford, and every e-commerce product page use this pattern. Since we don't host actual
                        images, we use <strong>SVG placeholder tiles</strong> with FontAwesome icons — the pattern
                        is identical regardless of image source.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Responsive grid</strong> — 2/3/4 columns with a toggle</li>
                        <li><strong>Full-screen overlay</strong> — Bootstrap modal used as lightbox</li>
                        <li><strong>Prev/Next navigation</strong> — cycle through images with arrows</li>
                        <li><strong>Keyboard support</strong> — ← → arrows and Esc to close</li>
                        <li><strong>Image counter</strong> — "3 of 12" position indicator</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>Why Placeholder Tiles?</h6>
                    <p class="small text-muted mb-0">
                        Real images require hosting, CDN, resizing, and lazy loading — each a separate lesson.
                        This demo focuses on the <strong>gallery UI pattern</strong>: grid layout, click-to-expand,
                        navigation, and keyboard shortcuts. The colored tiles with icons work exactly like images
                        would — swap in <code>&lt;img&gt;</code> tags and everything else stays the same.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Grid Controls ── *@
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <label class="form-label mb-0 small text-muted">Grid:</label>
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sm @(_columns == 2 ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _columns = 2)">2 Cols</button>
                <button type="button" class="btn btn-sm @(_columns == 3 ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _columns = 3)">3 Cols</button>
                <button type="button" class="btn btn-sm @(_columns == 4 ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _columns = 4)">4 Cols</button>
            </div>
            <span class="badge bg-secondary rounded-pill">@_galleryItems.Count items</span>
            <InfoTip Title="Grid Columns"
                     Description="The column count is set using Bootstrap's row-cols-* classes. 'row-cols-2' puts 2 items per row, 'row-cols-3' puts 3. This is fully responsive — on mobile it always drops to 1 column. No custom CSS needed."
                     Code="@_codeGridCols" />
        </div>

        @* ── Thumbnail Grid ── *@
        <div class="row row-cols-1 row-cols-md-@_columns g-3 mb-4">
            @for (int i = 0; i < _galleryItems.Count; i++) {
                int idx = i;
                var item = _galleryItems[i];
                <div class="col">
                    <div class="card border-0 shadow-sm h-100" role="button" @onclick="@(() => OpenLightbox(idx))">
                        @* Placeholder tile acting as image *@
                        <div class="card-img-top d-flex align-items-center justify-content-center text-white"
                             style="height:180px; background:@item.Color;">
                            <i class="@item.Icon fa-3x opacity-75"></i>
                        </div>
                        <div class="card-body py-2">
                            <div class="small fw-semibold">@item.Title</div>
                            <div class="d-flex justify-content-between">
                                <span class="small text-muted">@item.Category</span>
                                <span class="badge bg-light text-dark border" style="font-size:0.6rem;">@item.Dimensions</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Lightbox Overlay (using Bootstrap modal pattern via manual visibility) ── *@
        @if (_lightboxOpen) {
            var current = _galleryItems[_lightboxIndex];

            @* Backdrop *@
            <div class="position-fixed top-0 start-0 w-100 h-100 d-flex flex-column" style="z-index:1055; background:rgba(0,0,0,0.9);"
                 @onclick="CloseLightbox" @onkeydown="HandleLightboxKeydown" tabindex="0">

                @* Top bar *@
                <div class="d-flex justify-content-between align-items-center p-3" @onclick:stopPropagation>
                    <span class="text-white small">
                        <strong>@current.Title</strong> — @current.Category
                    </span>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-white small opacity-75">@(_lightboxIndex + 1) of @_galleryItems.Count</span>
                        <button class="btn btn-sm btn-outline-light" @onclick="CloseLightbox" title="Close (Esc)">
                            <i class="fa-solid fa-times"></i>
                        </button>
                    </div>
                </div>

                @* Main content area with prev/next *@
                <div class="flex-grow-1 d-flex align-items-center justify-content-center position-relative" @onclick:stopPropagation>
                    @* Prev button *@
                    <button class="btn btn-outline-light btn-lg position-absolute start-0 ms-3" @onclick="PrevImage" @onclick:stopPropagation>
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>

                    @* Large image placeholder *@
                    <div class="d-flex align-items-center justify-content-center text-white rounded shadow-lg"
                         style="width:60vw; height:60vh; max-width:800px; max-height:600px; background:@current.Color;">
                        <div class="text-center">
                            <i class="@current.Icon fa-5x opacity-75 mb-3"></i>
                            <div class="h5">@current.Title</div>
                            <div class="small opacity-75">@current.Dimensions — @current.Category</div>
                        </div>
                    </div>

                    @* Next button *@
                    <button class="btn btn-outline-light btn-lg position-absolute end-0 me-3" @onclick="NextImage" @onclick:stopPropagation>
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>

                @* Thumbnail strip *@
                <div class="d-flex justify-content-center gap-2 p-3 overflow-auto" @onclick:stopPropagation>
                    @for (int i = 0; i < _galleryItems.Count; i++) {
                        int thumbIdx = i;
                        var thumb = _galleryItems[i];
                        <div class="d-flex align-items-center justify-content-center rounded @(thumbIdx == _lightboxIndex ? "border border-2 border-white" : "opacity-50")"
                             style="width:48px; height:48px; min-width:48px; background:@thumb.Color; cursor:pointer;"
                             @onclick="@(() => _lightboxIndex = thumbIdx)" @onclick:stopPropagation>
                            <i class="@thumb.Icon text-white small"></i>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── InfoTips Row ── *@
        <div class="d-flex flex-wrap gap-1 mt-2">
            <InfoTip Title="Lightbox Overlay"
                     Description="The lightbox is a full-screen div positioned fixed over everything (z-index 1055). A dark semi-transparent background dims the page. The image is centered using flexbox. Clicking the backdrop closes it. This is the same concept as a Bootstrap modal but manually built for maximum control."
                     Code="@_codeLightbox" />
            <InfoTip Title="Keyboard Navigation"
                     Description="The lightbox container has tabindex=0 and an onkeydown handler. ArrowLeft goes to the previous image, ArrowRight to the next, and Escape closes the lightbox. This makes the gallery accessible without a mouse."
                     Code="@_codeKeyboardNav" />
            <InfoTip Title="Thumbnail Strip"
                     Description="The bottom row shows small versions of all images. The current image has a white border; others are dimmed (opacity-50). Clicking a thumbnail jumps directly to that image. The strip scrolls horizontally (overflow-auto) if there are many items."
                     Code="@_codeThumbs" />
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "imagegallery";

    // InfoTip snippets
    private string _codeGridCols = "<div class=\"row row-cols-1 row-cols-md-@_columns g-3\">";
    private string _codeLightbox = "<div class=\"position-fixed top-0 start-0 w-100 h-100\"\n    style=\"z-index:1055; background:rgba(0,0,0,0.9);\">";
    private string _codeKeyboardNav = "if (e.Key == \"ArrowRight\") NextImage();\nif (e.Key == \"ArrowLeft\") PrevImage();\nif (e.Key == \"Escape\") CloseLightbox();";
    private string _codeThumbs = "<div class=\"d-flex justify-content-center gap-2 overflow-auto\">\n    @foreach thumb ... class=\"@(thumbIdx == _lightboxIndex ? \"border-white\" : \"opacity-50\")\"";

    // State
    private int _columns = 3;
    private bool _lightboxOpen = false;
    private int _lightboxIndex = 0;

    // Gallery data
    private List<GalleryItem> _galleryItems = new List<GalleryItem> {
        new("Mountain Landscape", "Nature", "fa-solid fa-mountain-sun", "#2d6a4f", "1920 × 1080"),
        new("Ocean Sunset", "Nature", "fa-solid fa-water", "#0077b6", "2560 × 1440"),
        new("City Skyline", "Urban", "fa-solid fa-city", "#495057", "1920 × 1080"),
        new("Forest Path", "Nature", "fa-solid fa-tree", "#40916c", "3840 × 2160"),
        new("Circuit Board", "Technology", "fa-solid fa-microchip", "#7209b7", "1280 × 720"),
        new("Abstract Art", "Art", "fa-solid fa-palette", "#f72585", "1600 × 1200"),
        new("Space Nebula", "Science", "fa-solid fa-star", "#240046", "2560 × 1600"),
        new("Desert Dunes", "Nature", "fa-solid fa-sun", "#e76f51", "1920 × 1080"),
        new("Architecture", "Urban", "fa-solid fa-building", "#6c757d", "2400 × 1600"),
        new("Data Center", "Technology", "fa-solid fa-server", "#264653", "1920 × 1280"),
        new("Coral Reef", "Nature", "fa-solid fa-fish", "#0096c7", "3200 × 2400"),
        new("Night Sky", "Science", "fa-solid fa-moon", "#1d3557", "2560 × 1440"),
    };

    // ── Lifecycle ──

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    // ── Lightbox ──

    private void OpenLightbox(int index)
    {
        _lightboxIndex = index;
        _lightboxOpen = true;
    }

    private void CloseLightbox()
    {
        _lightboxOpen = false;
    }

    private void NextImage()
    {
        _lightboxIndex = (_lightboxIndex + 1) % _galleryItems.Count;
    }

    private void PrevImage()
    {
        _lightboxIndex = (_lightboxIndex - 1 + _galleryItems.Count) % _galleryItems.Count;
    }

    private void HandleLightboxKeydown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "ArrowRight") NextImage();
        else if (e.Key == "ArrowLeft") PrevImage();
        else if (e.Key == "Escape") CloseLightbox();
    }

    // ── Inner Types ──

    private record GalleryItem(string Title, string Category, string Icon, string Color, string Dimensions);
}
