@page "/Examples/WorkOrdersV1"
@page "/{TenantCode}/Examples/WorkOrdersV1"
@implements IDisposable
@inject BlazorDataModel Model

@* V1: Submit Request — Public-facing form with cascading dropdowns *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-paper-plane me-1"></i> Submit Request</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-paper-plane me-1"></i> V1: Submit Request <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Submit Work Order" Subtitle="Public-facing request form with 3-level cascading dropdowns (Building → Floor → Room)" IconClass="fa-solid fa-paper-plane">
            <p class="small text-muted mb-0">Demonstrates cascading dependent dropdowns: selecting a building populates floors, selecting a floor populates rooms. Urgency options include color-coded descriptions.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Cascading Dropdowns"
                     Description="When Building changes, Floor resets and shows only valid floors for that building. When Floor changes, Room resets and shows only rooms on that floor."
                     Code="@_codeCascade" />
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-primary text-white"><i class="fa-solid fa-paper-plane me-1"></i>Submit a Facilities Request</div>
                    <div class="card-body">
                        @if (_submitted) {
                            <div class="text-center py-4">
                                <i class="fa-solid fa-circle-check fa-3x text-success mb-2"></i>
                                <h5>Request Submitted!</h5>
                                <p class="text-muted small">Your work order has been received and will be reviewed by the dispatch team.</p>
                                <button class="btn btn-outline-primary btn-sm" @onclick="Reset">Submit Another</button>
                            </div>
                        } else {
                            <div class="row g-3">
                                @* Location: cascading dropdowns *@
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold">Building <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" @bind="_building" @bind:after="BuildingChanged">
                                        <option value="">Select building...</option>
                                        @foreach (var b in _buildings) { <option value="@b">@b</option> }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold">Floor <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" @bind="_floor" @bind:after="FloorChanged" disabled="@(string.IsNullOrEmpty(_building))">
                                        <option value="">Select floor...</option>
                                        @foreach (var f in _floors) { <option value="@f">@f</option> }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold">Room <span class="text-danger">*</span></label>
                                    <select class="form-select form-select-sm" @bind="_room" disabled="@(string.IsNullOrEmpty(_floor))">
                                        <option value="">Select room...</option>
                                        @foreach (var r in _rooms) { <option value="@r">@r</option> }
                                    </select>
                                </div>

                                <div class="col-12">
                                    <label class="form-label small fw-semibold">Title <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-sm" @bind="_title" placeholder="Brief summary of the issue" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Category</label>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var c in Enum.GetValues<DataObjects.WorkOrderCategory>()) {
                                            <button class="btn btn-sm @(_category == c ? "btn-primary" : "btn-outline-secondary")" @onclick="() => _category = c">
                                                <i class="@GetCategoryIcon(c) me-1"></i>@c
                                            </button>
                                        }
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Urgency</label>
                                    @foreach (var u in Enum.GetValues<DataObjects.WorkOrderUrgency>()) {
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="urgency" checked="@(_urgency == u)" @onchange="() => _urgency = u" />
                                            <label class="form-check-label small">
                                                <span class="badge" style="background-color:@GetUrgencyColor(u); color:white;">@u</span>
                                                <span class="text-muted ms-1">@GetUrgencyDesc(u)</span>
                                            </label>
                                        </div>
                                    }
                                </div>

                                <div class="col-12">
                                    <label class="form-label small fw-semibold">Description <span class="text-danger">*</span></label>
                                    <textarea class="form-control form-control-sm" rows="4" @bind="_description" placeholder="Describe the issue in detail"></textarea>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Your Name</label>
                                    <input type="text" class="form-control form-control-sm" @bind="_requester" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Your Email</label>
                                    <input type="email" class="form-control form-control-sm" @bind="_email" />
                                </div>

                                <div class="col-12">
                                    <button class="btn btn-primary" @onclick="Submit" disabled="@(!CanSubmit())"><i class="fa-solid fa-paper-plane me-1"></i>Submit Request</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _submitted = false;
    private string _pageName = "workordersv1";
    private string _building = "", _floor = "", _room = "", _title = "", _description = "", _requester = "Current User", _email = "user@example.edu";
    private DataObjects.WorkOrderCategory _category = DataObjects.WorkOrderCategory.Other;
    private DataObjects.WorkOrderUrgency _urgency = DataObjects.WorkOrderUrgency.Normal;
    private List<string> _floors = new(), _rooms = new();

    private static readonly string[] _buildings = ["Todd Hall", "Sloan Hall", "Cleveland Hall", "Science Building", "Smith Gym", "Library"];
    private static readonly Dictionary<string, string[]> _floorMap = new() {
        ["Todd Hall"] = ["1st Floor", "2nd Floor", "3rd Floor", "Basement"],
        ["Sloan Hall"] = ["1st Floor", "2nd Floor"],
        ["Cleveland Hall"] = ["1st Floor", "2nd Floor", "3rd Floor"],
        ["Science Building"] = ["1st Floor", "2nd Floor", "3rd Floor", "4th Floor"],
        ["Smith Gym"] = ["Main Level", "Upper Level", "Lower Level"],
        ["Library"] = ["1st Floor", "2nd Floor", "3rd Floor"]
    };
    private static readonly Dictionary<string, string[]> _roomMap = new() {
        ["1st Floor"] = ["101", "102", "103", "104", "105"],
        ["2nd Floor"] = ["201", "202", "203", "204", "205"],
        ["3rd Floor"] = ["301", "302", "303", "304"],
        ["4th Floor"] = ["401", "402", "403"],
        ["Basement"] = ["B01", "B02", "B03"],
        ["Main Level"] = ["Gym A", "Gym B", "Locker Room"],
        ["Upper Level"] = ["Track", "Weight Room"],
        ["Lower Level"] = ["Pool", "Storage"]
    };

    private string _codeCascade = "<select @bind=\"_building\" @bind:after=\"BuildingChanged\">\n<select @bind=\"_floor\" disabled=\"@(string.IsNullOrEmpty(_building))\">";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; await Task.CompletedTask; StateHasChanged(); }
    }

    private void BuildingChanged() { _floor = ""; _room = ""; _floors = _floorMap.TryGetValue(_building, out var f) ? f.ToList() : new(); _rooms = new(); }
    private void FloorChanged() { _room = ""; _rooms = _roomMap.TryGetValue(_floor, out var r) ? r.ToList() : new(); }
    private bool CanSubmit() => !string.IsNullOrEmpty(_building) && !string.IsNullOrEmpty(_floor) && !string.IsNullOrEmpty(_room) && !string.IsNullOrEmpty(_title) && !string.IsNullOrEmpty(_description);

    private async Task Submit() {
        var wo = new DataObjects.WorkOrder { Title = _title, Description = _description, Building = _building, Floor = _floor, RoomNumber = _room, Category = _category, Urgency = _urgency, Status = DataObjects.WorkOrderStatus.Submitted, RequestedBy = _requester, RequestedByEmail = _email, RequestedDate = DateTime.Now };
        await Helpers.GetOrPost<List<DataObjects.WorkOrder>>("api/Data/SaveWorkOrders", new List<DataObjects.WorkOrder> { wo });
        _submitted = true; StateHasChanged();
    }

    private void Reset() { _submitted = false; _title = ""; _description = ""; _building = ""; _floor = ""; _room = ""; _category = DataObjects.WorkOrderCategory.Other; _urgency = DataObjects.WorkOrderUrgency.Normal; }

    private static string GetUrgencyColor(DataObjects.WorkOrderUrgency u) => u switch { DataObjects.WorkOrderUrgency.Emergency => "#dc3545", DataObjects.WorkOrderUrgency.High => "#fd7e14", DataObjects.WorkOrderUrgency.Normal => "#0d6efd", _ => "#6c757d" };
    private static string GetUrgencyDesc(DataObjects.WorkOrderUrgency u) => u switch { DataObjects.WorkOrderUrgency.Emergency => "Safety hazard — response within 1 hour", DataObjects.WorkOrderUrgency.High => "Major disruption — response same day", DataObjects.WorkOrderUrgency.Normal => "Standard request — within 3 business days", _ => "Low priority — scheduled maintenance" };
    private static string GetCategoryIcon(DataObjects.WorkOrderCategory c) => c switch { DataObjects.WorkOrderCategory.Plumbing => "fa-solid fa-faucet-drip", DataObjects.WorkOrderCategory.Electrical => "fa-solid fa-bolt", DataObjects.WorkOrderCategory.HVAC => "fa-solid fa-wind", DataObjects.WorkOrderCategory.Custodial => "fa-solid fa-broom", DataObjects.WorkOrderCategory.Grounds => "fa-solid fa-tree", DataObjects.WorkOrderCategory.Locksmith => "fa-solid fa-key", _ => "fa-solid fa-tools" };
}
