@page "/Examples/SignalRDemo"
@page "/{TenantCode}/Examples/SignalRDemo"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title">SignalR Demo</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-tower-broadcast me-1"></i> SignalR Real-Time Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="About SignalR Demo" Subtitle="See changes appear instantly across browser tabs — no refresh needed" IconClass="fa-solid fa-tower-broadcast">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        Normally, a web page only updates when you click something or refresh. <strong>SignalR</strong>
                        changes that — it creates a live connection between the server and your browser so the server
                        can <strong>push</strong> updates to you instantly. Imagine a group chat: when someone sends
                        a message, everyone sees it immediately. That's what SignalR does for data.
                        <em>Try opening this page in two browser tabs to see it in action.</em>
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Presence board</strong> — see who else is online and what page they're viewing</li>
                        <li><strong>Activity feed</strong> — a live log of events (saves, deletes) with timestamps</li>
                        <li><strong>Live table</strong> — rows update in-place when data changes on the server</li>
                        <li><strong>Pending badge</strong> — a counter showing how many updates arrived since you last looked</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        When the page loads, your browser opens a <strong>WebSocket</strong> — a persistent connection
                        to the server (like a phone call that stays open). When anyone saves or deletes data, the server
                        sends a message through that connection to <strong>every connected browser</strong>. Your page
                        receives the message and updates the display without you doing anything.
                    </p>
                </div>
            </div>
        </AboutSection>

        <div class="row">
            @* ================================================================
               LEFT COLUMN: Active Users Presence Board
               Pattern from: Helpdesk4 ActiveUsers page + FlexCRM call center
               Shows who's online with real-time last-seen timestamps.
               ================================================================ *@
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0">
                            <i class="fa-solid fa-users me-1"></i> Active Users
                            <InfoTip Title="Active Users Presence"
                                     Description="This list shows who is online right now. The server tracks each user's last activity time. Users active in the last 30 seconds show as Active (green); those quiet for 30s to 5min show as Away (yellow). After 5 minutes they disappear. The You badge marks your own entry."
                                     Code="@_codeActiveUsers" />
                            @{ int onlineCount = Model.ActiveUsers.Count(x => x.LastAccess > DateTime.UtcNow.AddMinutes(-5)); }
                            <span class="badge bg-success rounded-pill ms-1">@onlineCount online</span>
                            <InfoTip Title="Online Count Badge"
                                     Description="This green pill-shaped badge shows how many users are currently online. It recalculates every time SignalR delivers an update. The rounded-pill class makes the badge oval-shaped. The count comes from filtering the active users list by last access time."
                                     Code="@_codeOnlineCount" />
                        </h6>
                    </div>
                    <div class="card-body p-0" style="max-height:400px; overflow:auto;">
                        @if (Model.ActiveUsers.Any(x => x.LastAccess > DateTime.UtcNow.AddMinutes(-5))) {
                            @foreach (var user in Model.ActiveUsers
                                .Where(x => x.LastAccess > DateTime.UtcNow.AddMinutes(-5))
                                .OrderBy(x => x.FirstName).ThenBy(x => x.LastName)) {
                                bool isMe = user.UserId == Model.User.UserId;
                                bool recentlyActive = user.LastAccess > DateTime.UtcNow.AddSeconds(-30);
                                string statusColor = recentlyActive ? "text-success" : "text-warning";
                                string statusLabel = recentlyActive ? "Active" : "Away";

                                <div class="d-flex align-items-center px-3 py-2 border-bottom @(isMe ? "bg-light" : "")">
                                    <div class="me-2">
                                        <i class="fa-solid fa-circle @statusColor" style="font-size:0.6em;"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold small">
                                            @user.FirstName @user.LastName
                                            @if (isMe) { <span class="badge bg-primary ms-1" style="font-size:0.65em;">You</span> }
                                        </div>
                                        <div class="text-muted" style="font-size:0.75em;">
                                            @if (!string.IsNullOrWhiteSpace(user.UserPreferences?.LastView)) {
                                                <i class="fa-solid fa-location-dot me-1"></i>@user.UserPreferences.LastView
                                            }
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge @(recentlyActive ? "bg-success" : "bg-warning text-dark")" style="font-size:0.65em;">@statusLabel</span>
                                    </div>
                                </div>
                            }
                        } else {
                            <div class="text-muted small p-3">No users online.</div>
                        }
                    </div>
                </div>
            </div>

            @* ================================================================
               RIGHT COLUMN: Live Activity Feed + Inline Actions
               Pattern from: Helpdesk4 Request page (in-place SignalR updates),
               Helpdesk4 Index (pending updates badge, auto-refresh toggle)
               ================================================================ *@
            <div class="col-md-8 mb-4">
                @* Quick-Add Item (triggers SignalR broadcast) *@
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0"><i class="fa-solid fa-bolt me-1"></i> Quick Add (Broadcasts to All Tabs)
                            <InfoTip Title="Quick Add Form"
                                     Description="This mini-form saves a new item and broadcasts the save to all connected browser tabs via SignalR. The Enter key also triggers save (via onkeydown). After saving, every browser tab receives a SignalR update and can choose to refresh its data."
                                     Code="@_codeQuickAdd" />
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-5">
                                <label class="form-label small">Name</label>
                                <input type="text" class="form-control" placeholder="Item name..." @bind="_newItemName"
                                       @onkeydown="@(async (e) => { if (e.Key == "Enter") await SaveItem(); })" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Category</label>
                                <select class="form-select" @bind="_newItemCategory">
                                    <option value="Engineering">Engineering</option>
                                    <option value="Marketing">Marketing</option>
                                    <option value="Operations">Operations</option>
                                    <option value="Finance">Finance</option>
                                    <option value="Support">Support</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Priority</label>
                                <input type="number" class="form-control" min="1" max="5" @bind="_newItemPriority" />
                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-success w-100" @onclick="SaveItem" disabled="@_saving">
                                    @if (_saving) {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    } else {
                                        <i class="fa-solid fa-floppy-disk me-1"></i>
                                    }
                                    Save
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                @* Activity Feed — real-time log of all SignalR events *@
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-header bg-white py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">
                                <i class="fa-solid fa-rss me-1"></i> Activity Feed
                                <InfoTip Title="Activity Feed"
                                         Description="This scrollable list shows every SignalR event in real time — saves, deletes, and data changes. Each entry has a colored icon (green disk = saved, red trash = deleted), a description, and a millisecond-precision timestamp. New events appear at the top."
                                         Code="@_codeActivityFeed" />
                                @if (_activityLog.Any()) {
                                    <span class="badge bg-primary rounded-pill ms-1">@_activityLog.Count</span>
                                }
                            </h6>
                            @if (_activityLog.Any()) {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => { _activityLog.Clear(); StateHasChanged(); })">
                                    <i class="fa-solid fa-eraser me-1"></i> Clear
                                </button>
                            }
                        </div>
                    </div>
                    <div class="card-body p-0" style="max-height:250px; overflow:auto;">
                        @if (!_activityLog.Any()) {
                            <div class="text-muted small p-3 text-center">
                                <i class="fa-solid fa-satellite-dish fa-2x mb-2 d-block"></i>
                                Listening for SignalR events... Save an item or open another tab.
                            </div>
                        }
                        @foreach (var entry in _activityLog) {
                            string iconClass = entry.Type switch {
                                "saved-self" => "fa-solid fa-floppy-disk text-success",
                                "saved-other" => "fa-solid fa-arrow-down text-primary",
                                "deleted-self" => "fa-solid fa-trash text-danger",
                                "deleted-other" => "fa-solid fa-trash text-warning",
                                _ => "fa-solid fa-circle-info text-muted",
                            };

                            <div class="d-flex align-items-start px-3 py-2 border-bottom">
                                <div class="me-2 mt-1"><i class="@iconClass"></i></div>
                                <div class="flex-grow-1">
                                    <div class="small">@((MarkupString)entry.Message)</div>
                                    <div class="text-muted" style="font-size:0.7em;">@entry.Time.ToString("HH:mm:ss.fff")</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @* Live Item Table — updates in-place via SignalR, like Helpdesk4 Request page *@
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">
                                <i class="fa-solid fa-table me-1"></i> Live Items
                                <span class="badge bg-secondary rounded-pill ms-1">@_items.Count</span>
                                @if (_pendingUpdates > 0) {
                                    <span class="badge bg-warning text-dark rounded-pill ms-1 animate__animated animate__pulse animate__infinite">
                                        @_pendingUpdates pending
                                    </span>
                                    <InfoTip Title="Pending Updates Badge"
                                             Description="When Auto-apply is off, incoming SignalR updates are queued instead of applied immediately. This yellow badge pulses to get your attention, showing how many updates are waiting. Click Apply to merge them into the table. This pattern prevents jarring table refreshes while you are reading."
                                             Code="@_codePending" />
                                }
                            </h6>
                            <div class="d-flex gap-2 align-items-center">
                                <div class="form-check form-switch mb-0">
                                    <input type="checkbox" class="form-check-input" id="auto-apply" @bind="_autoApply" />
                                    <label class="form-check-label small" for="auto-apply">Auto-apply
                                        <InfoTip Title="Auto-Apply Toggle"
                                                 Description="When ON, every SignalR update is applied to the table immediately — rows appear, update, or disappear in real time. When OFF, updates queue up and the pending badge shows the count. You decide when to apply them. This gives users control over when their view changes."
                                                 Code="@_codeAutoApply" />
                                    </label>
                                </div>
                                @if (!_autoApply && _pendingUpdates > 0) {
                                    <button class="btn btn-sm btn-primary" @onclick="ApplyPendingUpdates">
                                        <i class="fa-solid fa-download me-1"></i> Apply @_pendingUpdates
                                    </button>
                                }
                                <button class="btn btn-sm btn-outline-secondary" @onclick="LoadData">
                                    <i class="fa-solid fa-refresh"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover table-sm mb-0">
                            <thead>
                                <tr class="table-light">
                                    <th>Name
                                        <InfoTip Title="Row Highlight"
                                                 Description="When a row receives a SignalR update, it briefly turns light blue (table-info) and shows a bolt icon. This visual flash draws your eye to what changed. The highlight fades after a few seconds. The _recentlyUpdatedIds set tracks which rows were just updated."
                                                 Code="@_codeRowHighlight" />
                                    </th>
                                    <th>Category</th>
                                    <th>Status</th>
                                    <th class="text-center">P</th>
                                    <th class="text-end">Amount</th>
                                    <th style="width:1%;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _items.Take(15)) {
                                    bool justUpdated = _recentlyUpdatedIds.Contains(item.SampleItemId);
                                    <tr class="@(justUpdated ? "table-info" : "")">
                                        <td>
                                            @item.Name
                                            @if (justUpdated) { <i class="fa-solid fa-bolt text-primary ms-1" title="Updated via SignalR"></i> }
                                        </td>
                                        <td class="small">@item.Category</td>
                                        <td><span class="badge @GetStatusBadge(item.Status)">@item.Status</span></td>
                                        <td class="text-center">@item.Priority</td>
                                        <td class="text-end small">@item.Amount.ToString("C")</td>
                                        <td>
                                            <button class="btn btn-xs btn-outline-danger" @onclick="@(() => DeleteItem(item.SampleItemId))" title="Delete">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (_items.Count > 15) {
                            <div class="small text-muted text-center py-2">Showing 15 of @_items.Count items.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private bool _saving = false;
    private bool _autoApply = true;
    private int _pendingUpdates = 0;
    private string _pageName = "signalrdemo";
    private string _codeActiveUsers = "Model.ActiveUsers.Where(x => x.LastAccess > DateTime.UtcNow.AddMinutes(-5))";
    private string _codeOnlineCount = "<span class=\"badge bg-success rounded-pill\">@onlineCount online</span>";
    private string _codeQuickAdd = "@onkeydown=\"@(async (e) => {\n    if (e.Key == \"Enter\") await SaveItem();\n})\"";
    private string _codeActivityFeed = "<div class=\"small\">@entry.Message</div>\n<div class=\"text-muted\">@entry.Time.ToString(\"HH:mm:ss.fff\")</div>";
    private string _codePending = "<span class=\"badge bg-warning animate__pulse\">\n    @_pendingUpdates pending\n</span>";
    private string _codeAutoApply = "<input type=\"checkbox\" @bind=\"_autoApply\" />";
    private string _codeRowHighlight = "class=\"@(justUpdated ? \"table-info\" : \"\")\"";
    private string _newItemName = "";
    private string _newItemCategory = "Engineering";
    private int _newItemPriority = 3;
    private List<DataObjects.SampleItem> _items = new();
    private List<ActivityEntry> _activityLog = new();
    private HashSet<Guid> _recentlyUpdatedIds = new();
    private System.Timers.Timer _highlightTimer = new();

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
        Model.OnSignalRUpdate -= SignalRUpdate;
        Model.Subscribers_OnSignalRUpdate.Remove(_pageName);
        _highlightTimer.Stop();
        _highlightTimer.Dispose();
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
        Model.OnSignalRUpdate += SignalRUpdate;
        if (!Model.Subscribers_OnSignalRUpdate.Contains(_pageName)) { Model.Subscribers_OnSignalRUpdate.Add(_pageName); }

        // Timer to clear highlight flash after 3 seconds (like Helpdesk4 toast fade)
        _highlightTimer.Interval = 3000;
        _highlightTimer.AutoReset = false;
        _highlightTimer.Elapsed += (s, e) => {
            _recentlyUpdatedIds.Clear();
            InvokeAsync(StateHasChanged);
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            await LoadData();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    /// <summary>
    /// Core SignalR handler — pattern from Helpdesk4 Request.razor.
    /// Updates items in-place when another user saves/deletes, or queues pending updates.
    /// </summary>
    private async void SignalRUpdate(DataObjects.SignalRUpdate update)
    {
        bool fromOtherUser = update.UserId != Model.User.UserId;
        string who = fromOtherUser ? (update.UserDisplayName ?? "Another user") : "You";

        if (update.UpdateType == DataObjects.SignalRUpdateType.SampleItemSaved) {
            var saved = Helpers.DeserializeObject<DataObjects.SampleItem>(update.ObjectAsString);
            string itemName = saved?.Name ?? "Unknown";

            _activityLog.Insert(0, new ActivityEntry {
                Time = DateTime.Now,
                Type = fromOtherUser ? "saved-other" : "saved-self",
                Message = $"<strong>{who}</strong> saved <em>{itemName}</em>",
            });

            if (saved != null) {
                if (_autoApply || !fromOtherUser) {
                    // In-place update (Helpdesk4 pattern: update the local record without re-fetching)
                    var existing = _items.FindIndex(x => x.SampleItemId == saved.SampleItemId);
                    if (existing >= 0) {
                        _items[existing] = saved;
                    } else {
                        _items.Insert(0, saved);
                    }

                    // Flash highlight
                    _recentlyUpdatedIds.Add(saved.SampleItemId);
                    _highlightTimer.Stop();
                    _highlightTimer.Start();
                } else {
                    _pendingUpdates++;
                }
            }

            await InvokeAsync(StateHasChanged);
        }

        if (update.UpdateType == DataObjects.SignalRUpdateType.SampleItemDeleted) {
            var deletedId = update.ItemId;

            var deletedItem = _items.FirstOrDefault(x => x.SampleItemId == deletedId);
            string itemName = deletedItem?.Name ?? deletedId.ToString() ?? "Unknown";

            _activityLog.Insert(0, new ActivityEntry {
                Time = DateTime.Now,
                Type = fromOtherUser ? "deleted-other" : "deleted-self",
                Message = $"<strong>{who}</strong> deleted <em>{itemName}</em>",
            });

            if (_autoApply || !fromOtherUser) {
                _items.RemoveAll(x => x.SampleItemId == deletedId);
            } else {
                _pendingUpdates++;
            }

            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadData()
    {
        var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
        if (result != null) _items = result;
        _pendingUpdates = 0;

        _loading = false;
        StateHasChanged();
    }

    private async Task ApplyPendingUpdates()
    {
        await LoadData();
    }

    private async Task SaveItem()
    {
        if (string.IsNullOrWhiteSpace(_newItemName)) return;

        _saving = true;
        StateHasChanged();

        var item = new DataObjects.SampleItem {
            Name = _newItemName,
            Category = _newItemCategory,
            Priority = _newItemPriority,
            Status = DataObjects.SampleItemStatus.Active,
            Enabled = true,
        };

        var saved = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/SaveSampleItems", new List<DataObjects.SampleItem> { item });
        if (saved != null && saved.Any()) {
            _newItemName = "";
        }

        _saving = false;
        StateHasChanged();
    }

    private async Task DeleteItem(Guid id)
    {
        await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/DeleteSampleItems", new List<Guid> { id });
    }

    private static string GetStatusBadge(DataObjects.SampleItemStatus status) => status switch {
        DataObjects.SampleItemStatus.Active => "bg-success",
        DataObjects.SampleItemStatus.Completed => "bg-info",
        DataObjects.SampleItemStatus.Archived => "bg-secondary",
        _ => "bg-warning text-dark",
    };

    private class ActivityEntry
    {
        public DateTime Time { get; set; }
        public string Type { get; set; } = "";
        public string Message { get; set; } = "";
    }
}
