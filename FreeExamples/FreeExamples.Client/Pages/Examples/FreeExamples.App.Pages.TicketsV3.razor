@page "/Examples/TicketsV3"
@page "/{TenantCode}/Examples/TicketsV3"
@implements IDisposable
@inject BlazorDataModel Model

@* V3: Quick Create — Lightweight offcanvas for rapid ticket creation *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-bolt me-1"></i> Quick Create</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-bolt me-1"></i> V3: Quick Create <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Quick Create Tickets" Subtitle="Lightweight modal for rapid ticket creation without leaving the page" IconClass="fa-solid fa-bolt">
            <p class="small text-muted mb-0">Click the + button to open a quick-create panel. Just title, type, project, and priority — creates the ticket in Backlog status immediately. Great for board views where speed matters.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Offcanvas Quick Create"
                     Description="Uses Bootstrap's offcanvas component to slide in a minimal form from the right. Only 4 fields — everything else gets defaults."
                     Code="@_codeOffcanvas" />
        </div>

        @* Recent tickets table *@
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="badge bg-secondary rounded-pill">@_all.Count tickets</span>
            <button class="btn btn-primary btn-sm" @onclick="OpenQuickCreate"><i class="fa-solid fa-plus me-1"></i> Quick Create</button>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0 small">
                    <thead class="table-light">
                        <tr><th>Number</th><th>Title</th><th>Type</th><th>Status</th><th>Priority</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _all.OrderByDescending(t => t.RecordId).Take(20)) {
                            <tr class="@(_justCreated == t.RecordId ? "table-success" : "")">
                                <td><code>@t.TicketNumber</code></td>
                                <td>@t.Title</td>
                                <td><span class="badge bg-info bg-opacity-25 text-dark">@t.Type</span></td>
                                <td><span class="badge @GetStatusBadge(t.Status)">@t.Status</span></td>
                                <td><span class="badge @GetPriorityBadge(t.Priority)">@t.Priority</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Quick create panel (inline offcanvas simulation) *@
        @if (_showQuickCreate) {
            <div class="position-fixed top-0 end-0 bottom-0 bg-white shadow-lg border-start" style="width:380px; z-index:1050; overflow-y:auto;">
                <div class="p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0"><i class="fa-solid fa-bolt me-1"></i> Quick Create</h6>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showQuickCreate = false"><i class="fa-solid fa-times"></i></button>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Title *</label>
                        <input type="text" class="form-control form-control-sm" @bind="_qcTitle" placeholder="What needs to be done?" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Project</label>
                        <select class="form-select form-select-sm" @bind="_qcProjectId">
                            @foreach (var p in _projects.OrderBy(p => p.Name)) {
                                <option value="@p.RecordId">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Type</label>
                        <div class="btn-group btn-group-sm w-100">
                            @foreach (var t in new[] { DataObjects.TicketType.Task, DataObjects.TicketType.Bug, DataObjects.TicketType.Story }) {
                                <button type="button" class="btn @(_qcType == t ? "btn-primary" : "btn-outline-secondary")" @onclick="() => _qcType = t">@t</button>
                            }
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Priority</label>
                        <div class="btn-group btn-group-sm w-100">
                            @foreach (var p in Enum.GetValues<DataObjects.TicketPriority>()) {
                                <button type="button" class="btn @(_qcPriority == p ? "btn-primary" : "btn-outline-secondary")" @onclick="() => _qcPriority = p">@p</button>
                            }
                        </div>
                    </div>

                    @if (_qcSaved) {
                        <div class="alert alert-success small py-2"><i class="fa-solid fa-check me-1"></i>Ticket created!</div>
                    }

                    <button class="btn btn-primary btn-sm w-100" @onclick="QuickSave" disabled="@(string.IsNullOrWhiteSpace(_qcTitle) || _saving)">
                        <i class="fa-solid fa-plus me-1"></i> Create Ticket
                    </button>
                </div>
            </div>
            <div class="position-fixed top-0 start-0 bottom-0 end-0" style="background:rgba(0,0,0,0.3); z-index:1040;" @onclick="() => _showQuickCreate = false"></div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _saving = false, _showQuickCreate = false, _qcSaved = false;
    private string _pageName = "ticketsv3";
    private List<DataObjects.Ticket> _all = new();
    private List<DataObjects.Project> _projects = new();
    private string _qcTitle = "", _qcProjectId = "";
    private DataObjects.TicketType _qcType = DataObjects.TicketType.Task;
    private DataObjects.TicketPriority _qcPriority = DataObjects.TicketPriority.Medium;
    private Guid _justCreated = Guid.Empty;
    private string _codeOffcanvas = "<div class=\"position-fixed top-0 end-0 bottom-0 bg-white shadow-lg\" style=\"width:380px;\">\n  <!-- quick form -->\n</div>";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var t = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/GetTickets", new List<Guid>());
            var p = await Helpers.GetOrPost<List<DataObjects.Project>>("api/Data/GetProjects", new List<Guid>());
            _all = t ?? new(); _projects = p ?? new();
            _qcProjectId = _projects.FirstOrDefault()?.RecordId.ToString() ?? "";
            _loading = false; StateHasChanged();
        }
    }

    private void OpenQuickCreate() { _showQuickCreate = true; _qcTitle = ""; _qcSaved = false; }

    private async Task QuickSave() {
        if (string.IsNullOrWhiteSpace(_qcTitle)) return;
        _saving = true; _qcSaved = false;
        var ticket = new DataObjects.Ticket {
            Title = _qcTitle, Type = _qcType, Priority = _qcPriority,
            Status = DataObjects.TicketStatus.Backlog, ReporterName = "Quick Create",
            ProjectId = Guid.TryParse(_qcProjectId, out var pid) ? pid : Guid.Empty,
        };
        var result = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/SaveTickets", new List<DataObjects.Ticket> { ticket });
        if (result?.Any() == true) { _all.Insert(0, result.First()); _justCreated = result.First().RecordId; _qcSaved = true; _qcTitle = ""; }
        _saving = false; StateHasChanged();
    }

    private static string GetStatusBadge(DataObjects.TicketStatus s) => s switch { DataObjects.TicketStatus.Done or DataObjects.TicketStatus.Closed => "bg-success", DataObjects.TicketStatus.InProgress => "bg-primary", _ => "bg-secondary" };
    private static string GetPriorityBadge(DataObjects.TicketPriority p) => p switch { DataObjects.TicketPriority.Critical => "bg-danger", DataObjects.TicketPriority.High => "bg-warning text-dark", DataObjects.TicketPriority.Medium => "bg-info", _ => "bg-secondary" };
}
