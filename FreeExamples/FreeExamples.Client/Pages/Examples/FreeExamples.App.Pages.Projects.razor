@page "/Examples/Projects"
@page "/{TenantCode}/Examples/Projects"
@implements IDisposable
@inject BlazorDataModel Model

@* Projects & Hierarchy — Main list with tree view *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-diagram-project me-1"></i> Projects</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-diagram-project me-1"></i> Projects &amp; Hierarchy <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Projects & Hierarchy" Subtitle="Recursive project tree with expand/collapse, status badges, and progress tracking" IconClass="fa-solid fa-diagram-project">
            <p class="small text-muted mb-0">Projects can contain sub-projects, which can contain sub-sub-projects — unlimited nesting. This pattern applies to org charts, folder structures, category trees, and menu systems.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Recursive Tree Pattern"
                     Description="The tree is built by recursively rendering child projects under each parent. ParentProjectId == null means top-level. The Depth field is computed by walking up the tree."
                     Code="@_codeTree" />
            <InfoTip Title="Progress Computation"
                     Description="Completion percentage is computed from tickets in this project and all descendants. The progress bar uses Bootstrap's bg-success width style."
                     Code="@_codeProgress" />
        </div>

        @* Toolbar *@
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <button type="button" class="btn btn-dark btn-sm" @onclick="LoadData">
                <i class="fa-solid fa-arrows-rotate me-1"></i> Refresh
            </button>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_statusFilter" @bind:after="ApplyFilter">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<DataObjects.ProjectStatus>()) {
                    <option value="@s">@s</option>
                }
            </select>
            <div class="input-group input-group-sm" style="max-width:220px;">
                <span class="input-group-text bg-white"><i class="fa-solid fa-search text-muted"></i></span>
                <input type="text" class="form-control" placeholder="Search..." @bind="_search" @bind:event="oninput" @bind:after="ApplyFilter" />
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ToggleExpandAll">
                <i class="fa-solid @(_allExpanded ? "fa-compress" : "fa-expand") me-1"></i> @(_allExpanded ? "Collapse All" : "Expand All")
            </button>
            <span class="text-muted small ms-auto">@_filtered.Count projects</span>
        </div>

        @* Tree View *@
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40%;">Project</th>
                            <th>Key</th>
                            <th>Lead</th>
                            <th>Status</th>
                            <th class="text-center">Tickets</th>
                            <th style="width:15%;">Progress</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var node in GetFlatTree(null, 0)) {
                            var p = node.Project;
                            var depth = node.Depth;
                            var hasChildren = _filtered.Any(c => c.ParentProjectId == p.RecordId);
                            var isExpanded = _expanded.Contains(p.RecordId);
                            var ticketCount = CountTickets(p.RecordId);
                            var completedCount = CountCompletedTickets(p.RecordId);
                            var pct = ticketCount > 0 ? (int)(completedCount * 100.0 / ticketCount) : 0;

                            <tr>
                                <td>
                                    <span style="padding-left:@(depth * 24)px;" class="d-inline-flex align-items-center gap-1">
                                        @if (hasChildren) {
                                            <button class="btn btn-link btn-sm p-0 text-muted" @onclick="() => ToggleExpand(p.RecordId)" @onclick:stopPropagation="true">
                                                <i class="fa-solid @(isExpanded ? "fa-chevron-down" : "fa-chevron-right")" style="width:14px;"></i>
                                            </button>
                                        } else {
                                            <span style="width:22px; display:inline-block;"></span>
                                        }
                                        @if (!string.IsNullOrEmpty(p.Color)) {
                                            <span class="rounded-circle d-inline-block" style="width:10px; height:10px; background:@p.Color;"></span>
                                        }
                                        <strong>@p.Name</strong>
                                    </span>
                                </td>
                                <td><code class="small">@p.ProjectKey</code></td>
                                <td class="text-muted">@p.LeadName</td>
                                <td><span class="badge @GetStatusBadge(p.Status)">@p.Status</span></td>
                                <td class="text-center">
                                    <span class="badge bg-secondary rounded-pill">@ticketCount</span>
                                </td>
                                <td>
                                    @if (ticketCount > 0) {
                                        <div class="d-flex align-items-center gap-1">
                                            <div class="progress flex-grow-1" style="height:6px;">
                                                <div class="progress-bar bg-success" style="width:@pct%"></div>
                                            </div>
                                            <span class="small text-muted">@pct%</span>
                                        </div>
                                    } else {
                                        <span class="small text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "projects";
    private string _statusFilter = "", _search = "";
    private bool _allExpanded = true;
    private HashSet<Guid> _expanded = new();
    private List<DataObjects.Project> _all = new(), _filtered = new();
    private List<DataObjects.Ticket> _allTickets = new();

    private string _codeTree = "@{ RenderTree(null, 0); }\n// Recursively renders children at increasing indent depth";
    private string _codeProgress = "<div class=\"progress\" style=\"height:6px;\">\n  <div class=\"progress-bar bg-success\" style=\"width:@pct%\"></div>\n</div>";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            await LoadData();
        }
    }

    private async Task LoadData() {
        _loading = true; StateHasChanged();
        var projects = await Helpers.GetOrPost<List<DataObjects.Project>>("api/Data/GetProjects", new List<Guid>());
        var tickets = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/GetTickets", new List<Guid>());
        _all = projects ?? new();
        _allTickets = tickets ?? new();
        if (_allExpanded) _expanded = new HashSet<Guid>(_all.Select(p => p.RecordId));
        ApplyFilter();
        _loading = false; StateHasChanged();
    }

    private void ApplyFilter() {
        _filtered = _all;
        if (!string.IsNullOrEmpty(_statusFilter) && Enum.TryParse<DataObjects.ProjectStatus>(_statusFilter, out var st))
            _filtered = _filtered.Where(p => p.Status == st).ToList();
        if (!string.IsNullOrWhiteSpace(_search))
            _filtered = _filtered.Where(p => p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) || (p.ProjectKey ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void ToggleExpandAll() {
        _allExpanded = !_allExpanded;
        _expanded = _allExpanded ? new HashSet<Guid>(_all.Select(p => p.RecordId)) : new();
    }

    private void ToggleExpand(Guid id) {
        if (!_expanded.Remove(id)) _expanded.Add(id);
    }

    private record TreeNode(DataObjects.Project Project, int Depth);

    private List<TreeNode> GetFlatTree(Guid? parentId, int depth) {
        var result = new List<TreeNode>();
        var children = _filtered.Where(p => p.ParentProjectId == parentId).OrderBy(p => p.SortOrder).ThenBy(p => p.Name);
        foreach (var p in children) {
            result.Add(new TreeNode(p, depth));
            var hasChildren = _filtered.Any(c => c.ParentProjectId == p.RecordId);
            if (hasChildren && _expanded.Contains(p.RecordId)) {
                result.AddRange(GetFlatTree(p.RecordId, depth + 1));
            }
        }
        return result;
    }

    private int CountTickets(Guid projectId) {
        var count = _allTickets.Count(t => t.ProjectId == projectId);
        foreach (var child in _all.Where(p => p.ParentProjectId == projectId))
            count += CountTickets(child.RecordId);
        return count;
    }

    private int CountCompletedTickets(Guid projectId) {
        var count = _allTickets.Count(t => t.ProjectId == projectId && (t.Status == DataObjects.TicketStatus.Done || t.Status == DataObjects.TicketStatus.Closed));
        foreach (var child in _all.Where(p => p.ParentProjectId == projectId))
            count += CountCompletedTickets(child.RecordId);
        return count;
    }

    private static string GetStatusBadge(DataObjects.ProjectStatus s) => s switch {
        DataObjects.ProjectStatus.Active => "bg-success",
        DataObjects.ProjectStatus.Completed => "bg-primary",
        DataObjects.ProjectStatus.OnHold => "bg-warning text-dark",
        DataObjects.ProjectStatus.Archived => "bg-dark",
        _ => "bg-secondary"
    };
}
