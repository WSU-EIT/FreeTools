@page "/Examples/SignatureV5"
@page "/{TenantCode}/Examples/SignatureV5"
@implements IDisposable
@inject BlazorDataModel Model

@* V5: Multi-Section Contract — initial each section + final signature *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-file-lines me-1"></i> Contract Signing</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-file-lines me-1"></i> V5: Multi-Section Contract
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="Signature in Context: Contract with Section Initials" Subtitle="Initial each clause, then sign the full agreement at the end" IconClass="fa-solid fa-file-lines">
            <div class="row">
                <div class="col-md-6 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Variant?</h6>
                    <p class="small text-muted mb-0">
                        Lease agreements, service contracts, and insurance policies require the signer to <strong>initial
                        each section</strong> (confirming they've read it) and then provide a <strong>full signature</strong>
                        at the bottom. This proves the signer read each clause, not just the last page.
                    </p>
                </div>
                <div class="col-md-6 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>Progressive Completion</h6>
                    <p class="small text-muted mb-0">
                        A progress bar tracks how many sections have been initialed. The final signature section
                        only appears after all sections are initialed. This guarantees the signer acknowledges
                        every clause before signing — the DocuSign / HelloSign pattern.
                    </p>
                </div>
            </div>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Contract Builder Pattern"
                     Description="A multi-section contract where the user fills in details (parties, terms, payment) and signs at the end. The progress bar shows completion across all sections. This is the DocuSign/HelloSign workflow where the contract is built step-by-step."
                     Code="@_codeContractBuilder" />
            <InfoTip Title="Section Progress Tracking"
                     Description="A progress bar at the top shows how many sections are complete. Each section has a card with a green check when done. The Submit button enables only when all sections (including signature) are complete. This linear completion pattern ensures nothing is missed."
                     Code="@_codeSectionProgress" />
            <InfoTip Title="Date and Counter-Signature Fields"
                     Description="Contract forms include auto-filled date fields (DateTime.Now) and placeholders for counter-signatures. The signed date locks when the signature is captured. In production, the server records the exact timestamp for legal compliance."
                     Code="@_codeDateCounterSign" />
        </div>

        @* Progress *@
        <div class="mb-3">
            <div class="d-flex justify-content-between small mb-1">
                <span>Sections initialed</span>
                <span>@_initialed.Count(v => v) of @_sections.Count</span>
            </div>
            <div class="progress" style="height:8px;">
                <div class="progress-bar bg-success" style="width:@(_sections.Count > 0 ? (int)(_initialed.Count(v => v) * 100.0 / _sections.Count) : 0)%"></div>
            </div>
        </div>

        @* Contract sections *@
        @for (int i = 0; i < _sections.Count; i++) {
            int idx = i;
            var section = _sections[i];
            <div class="card shadow-sm border-0 mb-2">
                <div class="card-body py-2">
                    <div class="d-flex align-items-start gap-3">
                        <div class="flex-grow-1">
                            <h6 class="mb-1">
                                <span class="badge @(_initialed[idx] ? "bg-success" : "bg-secondary") me-1" style="font-size:0.6rem;">
                                    @(idx + 1)
                                </span>
                                @(section.Title)
                            </h6>
                            <p class="small text-muted mb-0">@(section.Text)</p>
                        </div>
                        <div class="flex-shrink-0 text-center" style="min-width:100px;">
                            @if (_initialed[idx]) {
                                <div class="text-success">
                                    <i class="fa-solid fa-circle-check fa-lg"></i>
                                    <div class="small">Initialed</div>
                                </div>
                            } else {
                                <button class="btn btn-sm btn-outline-primary" @onclick="@(() => InitialSection(idx))">
                                    <i class="fa-solid fa-pen me-1"></i> Initial
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Final signature — only shows when all sections initialed *@
        @if (_initialed.All(v => v)) {
            <div class="card shadow-sm border-success border-2 mb-3 mt-3">
                <div class="card-header bg-success text-white">
                    <i class="fa-solid fa-signature me-1"></i> All Sections Reviewed — Final Signature
                </div>
                <div class="card-body">
                    <div class="alert alert-success small">
                        <i class="fa-solid fa-check-double me-1"></i>
                        All @_sections.Count sections have been initialed. Please provide your full signature below
                        to execute this agreement.
                    </div>
                    <div class="row">
                        <div class="col-md-8">
                            <label class="form-label small fw-semibold">Full Signature</label>
                            <Signature @ref="_signaturePad" @bind-Value="_signatureValue" Class="border rounded" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Printed Name</label>
                            <input type="text" class="form-control form-control-sm mb-2" @bind="_printedName" />
                            <label class="form-label small fw-semibold">Title</label>
                            <input type="text" class="form-control form-control-sm mb-2" @bind="_title" />
                            <label class="form-label small fw-semibold">Date</label>
                            <input type="text" class="form-control form-control-sm" value="@DateTime.Now.ToString("MM/dd/yyyy")" disabled />
                        </div>
                    </div>
                    <div class="text-end mt-3">
                        <button class="btn btn-success" @onclick="ExecuteContract" disabled="@(string.IsNullOrWhiteSpace(_printedName))">
                            <i class="fa-solid fa-file-signature me-1"></i> Execute Agreement
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (_executed) {
            <div class="alert alert-success">
                <i class="fa-solid fa-circle-check me-1"></i> <strong>Agreement Executed!</strong>
                Signed by @_printedName on @DateTime.Now.ToString("MMMM d, yyyy"). All @_sections.Count sections were individually acknowledged.
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _executed = false;
    private string _pageName = "signaturev5";
    private string _codeContractBuilder = "<div class=\"card\">\n  <h6>Section 1: Parties</h6>\n  <!-- party name fields -->\n</div>\n<div class=\"card\">\n  <h6>Section 2: Terms</h6>\n  <!-- term fields -->\n</div>";
    private string _codeSectionProgress = "<div class=\"progress\">\n  <div class=\"progress-bar\" style=\"width:@(completed * 100 / total)%\">\n    @completed of @total\n  </div>\n</div>";
    private string _codeDateCounterSign = "<div class=\"form-floating\">\n  <input type=\"date\" value=\"@DateTime.Now.ToString(\"yyyy-MM-dd\")\" disabled />\n  <label>Signed Date (auto-filled)</label>\n</div>";
    private string _printedName = "";
    private string _title = "";
    private Signature? _signaturePad;
    private string _signatureValue = "";

    private List<ContractSection> _sections = new() {
        new("Scope of Services", "Provider agrees to deliver the software development services described in Exhibit A, including design, implementation, testing, and deployment of the agreed-upon features within the timeline specified."),
        new("Payment Terms", "Client agrees to pay Provider the total fee of $45,000 in three installments: 30% upon signing, 40% at milestone delivery, and 30% upon final acceptance. Late payments incur 1.5% monthly interest."),
        new("Intellectual Property", "All code, documentation, and deliverables created under this agreement become the exclusive property of Client upon full payment. Provider retains no rights to use, license, or distribute the work product."),
        new("Confidentiality", "Both parties agree to keep confidential all proprietary information disclosed during the engagement. This obligation survives termination of the agreement for a period of two (2) years."),
        new("Limitation of Liability", "Provider's total liability under this agreement shall not exceed the total fees paid. Neither party shall be liable for indirect, incidental, or consequential damages arising from this agreement."),
        new("Termination", "Either party may terminate this agreement with 30 days written notice. Upon termination, Client shall pay for all work completed to date. Provider shall deliver all work product created through the termination date."),
    };

    private List<bool> _initialed = new();

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += StateHasChanged;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName);
        _initialed = _sections.Select(_ => false).ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }

    private void InitialSection(int idx) { _initialed[idx] = true; }
    private void ExecuteContract() { _executed = true; }

    private record ContractSection(string Title, string Text);
}
