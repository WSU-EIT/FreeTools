@page "/Examples/ProjectsV2"
@page "/{TenantCode}/Examples/ProjectsV2"
@implements IDisposable
@inject BlazorDataModel Model

@* V2: Project Form — Create/edit project with parent selector and color picker *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-pen-ruler me-1"></i> Project Form</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-pen-ruler me-1"></i> V2: Project Form <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Project Create/Edit Form" Subtitle="Full form with parent selector, color picker, date range, and status" IconClass="fa-solid fa-pen-ruler">
            <p class="small text-muted mb-0">Create or edit projects with a parent dropdown showing the indented tree, a color picker for board display, and all project metadata fields.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Indented Parent Dropdown"
                     Description="The parent project dropdown shows projects indented by depth, so you can visually see the hierarchy while selecting a parent."
                     Code="@_codeParent" />
            <InfoTip Title="Color Picker"
                     Description="Uses a native HTML5 color input (input type=color) for selecting the project's display color on boards and timelines."
                     Code="@_codeColor" />
        </div>

        <div class="row g-3">
            @* Left: Project List *@
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <span><i class="fa-solid fa-list me-1"></i> Projects</span>
                        <button class="btn btn-sm btn-outline-light" @onclick="NewProject"><i class="fa-solid fa-plus me-1"></i>New</button>
                    </div>
                    <div class="list-group list-group-flush" style="max-height:600px; overflow-y:auto;">
                        @foreach (var p in _all.Where(x => x.ParentProjectId == null).OrderBy(x => x.SortOrder)) {
                            <button class="list-group-item list-group-item-action @(_editing?.RecordId == p.RecordId ? "active" : "")" @onclick="() => EditProject(p)">
                                <div class="d-flex justify-content-between">
                                    <span>
                                        @if (!string.IsNullOrEmpty(p.Color)) { <span class="rounded-circle d-inline-block me-1" style="width:8px; height:8px; background:@p.Color;"></span> }
                                        @p.Name
                                    </span>
                                    <span class="badge @GetStatusBadge(p.Status)" style="font-size:0.6rem;">@p.Status</span>
                                </div>
                            </button>
                        }
                    </div>
                </div>
            </div>

            @* Right: Edit Form *@
            <div class="col-md-8">
                @if (_editing != null) {
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">@(_editing.RecordId == Guid.Empty ? "New Project" : "Edit: " + _editing.Name)</span>
                            @if (_saved) { <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i>Saved</span> }
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label class="form-label small fw-semibold">Name</label>
                                    <input type="text" class="form-control form-control-sm" @bind="_editing.Name" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold">Project Key</label>
                                    <input type="text" class="form-control form-control-sm" @bind="_editing.ProjectKey" placeholder="e.g. WEB" maxlength="6" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-semibold">Description</label>
                                    <textarea class="form-control form-control-sm" rows="3" @bind="_editing.Description"></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Parent Project</label>
                                    <select class="form-select form-select-sm" @bind="_selectedParentId">
                                        <option value="">— Top Level —</option>
                                        @foreach (var opt in GetParentOptions(_editing.RecordId)) {
                                            <option value="@opt.Id">@opt.Label</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-semibold">Status</label>
                                    <select class="form-select form-select-sm" @bind="_editing.Status">
                                        @foreach (var s in Enum.GetValues<DataObjects.ProjectStatus>()) {
                                            <option value="@s">@s</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-semibold">Color</label>
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="color" class="form-control form-control-color form-control-sm" @bind="_editColor" style="width:40px; height:32px;" />
                                        <code class="small">@_editColor</code>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Lead Name</label>
                                    <input type="text" class="form-control form-control-sm" @bind="_editing.LeadName" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Lead Email</label>
                                    <input type="email" class="form-control form-control-sm" @bind="_editing.LeadEmail" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Department</label>
                                    <input type="text" class="form-control form-control-sm" @bind="_editing.Department" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-semibold">Start Date</label>
                                    <input type="date" class="form-control form-control-sm" @bind="_editing.StartDate" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-semibold">Target End</label>
                                    <input type="date" class="form-control form-control-sm" @bind="_editing.TargetEndDate" />
                                </div>
                            </div>
                            <div class="d-flex gap-2 mt-3">
                                <button class="btn btn-primary btn-sm" @onclick="SaveProject" disabled="@_saving">
                                    <i class="fa-solid fa-floppy-disk me-1"></i> Save
                                </button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => _editing = null">Cancel</button>
                            </div>
                        </div>
                    </div>
                } else {
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center text-muted py-5">
                            <i class="fa-solid fa-pen-ruler fa-2x mb-2 opacity-50"></i>
                            <div>Select a project to edit or click <strong>New</strong></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _saving = false, _saved = false;
    private string _pageName = "projectsv2";
    private List<DataObjects.Project> _all = new();
    private DataObjects.Project? _editing;
    private string _selectedParentId = "";
    private string _editColor = "#3b82f6";

    private string _codeParent = "<select>\n  <option value=\"\">— Top Level —</option>\n  @{ RenderParentOptions(null, 0, excludeId); }\n</select>";
    private string _codeColor = "<input type=\"color\" class=\"form-control-color\" @bind=\"_editColor\" />";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var result = await Helpers.GetOrPost<List<DataObjects.Project>>("api/Data/GetProjects", new List<Guid>());
            _all = result ?? new();
            _loading = false; StateHasChanged();
        }
    }

    private void NewProject() {
        _editing = new DataObjects.Project { Status = DataObjects.ProjectStatus.Planning };
        _selectedParentId = "";
        _editColor = "#3b82f6";
        _saved = false;
    }

    private void EditProject(DataObjects.Project p) {
        _editing = new DataObjects.Project {
            RecordId = p.RecordId, TenantId = p.TenantId, Name = p.Name, ProjectKey = p.ProjectKey,
            Description = p.Description, ParentProjectId = p.ParentProjectId, Status = p.Status,
            LeadName = p.LeadName, LeadEmail = p.LeadEmail, Department = p.Department,
            StartDate = p.StartDate, TargetEndDate = p.TargetEndDate, Color = p.Color, SortOrder = p.SortOrder,
        };
        _selectedParentId = p.ParentProjectId?.ToString() ?? "";
        _editColor = p.Color ?? "#3b82f6";
        _saved = false;
    }

    private async Task SaveProject() {
        if (_editing == null) return;
        _saving = true; _saved = false;
        _editing.ParentProjectId = Guid.TryParse(_selectedParentId, out var pid) ? pid : null;
        _editing.Color = _editColor;
        var result = await Helpers.GetOrPost<List<DataObjects.Project>>("api/Data/SaveProjects", new List<DataObjects.Project> { _editing });
        if (result?.Any() == true) {
            var saved = result.First();
            var idx = _all.FindIndex(p => p.RecordId == saved.RecordId);
            if (idx >= 0) _all[idx] = saved; else _all.Add(saved);
            _editing = saved;
            _saved = true;
        }
        _saving = false; StateHasChanged();
    }

    private record ParentOption(string Id, string Label);

    private List<ParentOption> GetParentOptions(Guid excludeId) {
        var result = new List<ParentOption>();
        BuildParentOptions(null, 0, excludeId, result);
        return result;
    }

    private void BuildParentOptions(Guid? parentId, int depth, Guid excludeId, List<ParentOption> result) {
        foreach (var p in _all.Where(x => x.ParentProjectId == parentId && x.RecordId != excludeId).OrderBy(x => x.SortOrder)) {
            var indent = new string('\u00A0', depth * 4);
            result.Add(new ParentOption(p.RecordId.ToString(), $"{indent}{p.Name} ({p.ProjectKey})"));
            BuildParentOptions(p.RecordId, depth + 1, excludeId, result);
        }
    }

    private static string GetStatusBadge(DataObjects.ProjectStatus s) => s switch {
        DataObjects.ProjectStatus.Active => "bg-success", DataObjects.ProjectStatus.Completed => "bg-primary",
        DataObjects.ProjectStatus.OnHold => "bg-warning text-dark", DataObjects.ProjectStatus.Archived => "bg-dark", _ => "bg-secondary"
    };
}
