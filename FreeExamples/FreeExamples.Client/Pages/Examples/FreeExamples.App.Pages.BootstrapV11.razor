@page "/Examples/BootstrapV11"
@page "/{TenantCode}/Examples/BootstrapV11"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-table me-1"></i> Data Table</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-table me-1"></i> V11: Data Table with Inline Actions
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="Bootstrap in Context: Data Table with Inline Actions" Subtitle="Sortable tables with per-row actions and bulk select — the DependencyManager pattern" IconClass="fa-solid fa-table">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This demonstrates the <strong>data table with inline actions</strong> pattern from
                        DependencyManager and Helpdesk. Features include: sortable column headers, per-row action
                        buttons (edit, archive, delete), a checkbox column for bulk selection, and pagination.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>table-hover + table-sm</strong> for compact data tables</li>
                        <li><strong>Checkbox column</strong> for bulk select</li>
                        <li><strong>btn-xs</strong> sized action buttons per row</li>
                        <li><strong>Column sorting</strong> with header click</li>
                        <li><strong>Pagination</strong> with page-item/page-link</li>
                        <li><strong>Bulk action bar</strong> that appears on selection</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        Clicking a column header sorts by that column (toggle asc/desc). Checkboxes track selected
                        rows. When any rows are selected, a bulk action bar appears. Pagination divides results into
                        pages. Per-row buttons handle individual item operations.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Bulk Action Bar ── *@
        @if (_selectedIds.Any()) {
            <div class="alert alert-primary py-2 d-flex justify-content-between align-items-center mb-2">
                <span class="small"><strong>@_selectedIds.Count</strong> item@(_selectedIds.Count > 1 ? "s" : "") selected</span>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-primary" @onclick="BulkActivate"><i class="fa-solid fa-check me-1"></i> Activate</button>
                    <button class="btn btn-outline-warning" @onclick="BulkArchive"><i class="fa-solid fa-box-archive me-1"></i> Archive</button>
                    <button class="btn btn-outline-danger" @onclick="BulkDelete"><i class="fa-solid fa-trash me-1"></i> Delete</button>
                </div>
            </div>
        }

        <InfoTip Title="Bulk Action Bar"
                 Description="When one or more checkboxes are checked, a bar appears with bulk action buttons (Activate, Archive, Delete). The count shows how many are selected. This is the DependencyManager pattern — users select multiple rows then apply one action to all."
                 Code="@_codeBulkBar" />

        @* ── Table ── *@
        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width:30px;">
                            <input class="form-check-input" type="checkbox" @bind="_selectAll" @bind:after="ToggleSelectAll" />
                        </th>
                        <th role="button" @onclick="@(() => SortBy("name"))">Name @SortIcon("name")</th>
                        <th role="button" @onclick="@(() => SortBy("category"))">Category @SortIcon("category")</th>
                        <th role="button" @onclick="@(() => SortBy("status"))">Status @SortIcon("status")</th>
                        <th role="button" @onclick="@(() => SortBy("priority"))" class="text-center">Priority @SortIcon("priority")</th>
                        <th role="button" @onclick="@(() => SortBy("amount"))" class="text-end">Amount @SortIcon("amount")</th>
                        <th class="text-end" style="width:140px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in PagedItems) {
                        <tr class="@(_selectedIds.Contains(item.Id) ? "table-primary" : "")">
                            <td><input class="form-check-input" type="checkbox" checked="@(_selectedIds.Contains(item.Id))" @onchange="@(() => ToggleItem(item.Id))" /></td>
                            <td class="small fw-semibold">@item.Name</td>
                            <td><span class="badge bg-light text-dark border" style="font-size:0.65rem;">@item.Category</span></td>
                            <td><span class="badge @GetStatusBadge(item.Status)" style="font-size:0.65rem;">@item.Status</span></td>
                            <td class="text-center"><span class="badge bg-secondary bg-opacity-25 text-dark" style="font-size:0.65rem;">P@item.Priority</span></td>
                            <td class="text-end small">@item.Amount.ToString("C")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary btn-xs" title="Edit" @onclick="@(() => EditItem(item))"><i class="fa-solid fa-pen fa-xs"></i></button>
                                    <button class="btn btn-outline-warning btn-xs" title="Archive" @onclick="@(() => ArchiveItem(item))"><i class="fa-solid fa-box-archive fa-xs"></i></button>
                                    <button class="btn btn-outline-danger btn-xs" title="Delete" @onclick="@(() => DeleteItem(item))"><i class="fa-solid fa-trash fa-xs"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* ── Pagination ── *@
        <div class="d-flex justify-content-between align-items-center">
            <div class="small text-muted">
                Showing @((_currentPage - 1) * _pageSize + 1)–@Math.Min(_currentPage * _pageSize, _sortedItems.Count) of @_sortedItems.Count
            </div>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(_currentPage <= 1 ? "disabled" : "")"><button class="page-link" @onclick="@(() => _currentPage--)">«</button></li>
                    @for (int i = 1; i <= TotalPages; i++) {
                        var p = i;
                        <li class="page-item @(_currentPage == p ? "active" : "")"><button class="page-link" @onclick="@(() => _currentPage = p)">@p</button></li>
                    }
                    <li class="page-item @(_currentPage >= TotalPages ? "disabled" : "")"><button class="page-link" @onclick="@(() => _currentPage++)">»</button></li>
                </ul>
            </nav>
        </div>

        <div class="d-flex flex-wrap gap-1 mt-3">
            <InfoTip Title="Sortable Column Headers"
                     Description="Clicking a table header sorts by that column. An arrow icon shows sort direction. Clicking again reverses. This is done purely in C# with OrderBy/OrderByDescending on the data list. No JavaScript needed."
                     Code="@_codeSortable" />
            <InfoTip Title="btn-xs Inline Actions"
                     Description="Per-row action buttons use btn-xs (extra small) to stay compact. A btn-group keeps them together. Common actions: Edit (pen), Archive (box-archive), Delete (trash). In DependencyManager, every row has these."
                     Code="@_codeBtnXs" />
            <InfoTip Title="Pagination (page-item / page-link)"
                     Description="Bootstrap pagination uses ul.pagination with li.page-item and button/a.page-link. The active page gets the 'active' class. Disabled prev/next buttons get 'disabled'. The showing X-Y of Z text gives context."
                     Code="@_codePagination" />
        </div>

        @* ── Edit Modal ── *@
        @if (_editItem != null) {
            <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="fa-solid fa-pen me-1"></i> Edit Item</h5>
                            <button type="button" class="btn-close" @onclick="@(() => _editItem = null)"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3"><label class="form-label small">Name</label><input type="text" class="form-control" @bind="_editItem.Name" /></div>
                            <div class="mb-3"><label class="form-label small">Category</label><input type="text" class="form-control" @bind="_editItem.Category" /></div>
                            <div class="row g-2">
                                <div class="col-6"><label class="form-label small">Status</label><select class="form-select" @bind="_editItem.Status"><option>Active</option><option>Draft</option><option>Archived</option></select></div>
                                <div class="col-6"><label class="form-label small">Priority</label><input type="number" class="form-control" @bind="_editItem.Priority" min="1" max="5" /></div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="@(() => _editItem = null)">Cancel</button>
                            <button class="btn btn-success" @onclick="@(() => _editItem = null)"><i class="fa-solid fa-check me-1"></i> Save</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _selectAll = false;
    private string _pageName = "bootstrapv11";

    private string _codeBulkBar = "@if (_selectedIds.Any()) {\n  <div class=\"alert alert-primary\">\n    <strong>@_selectedIds.Count</strong> selected\n    <button class=\"btn btn-outline-danger btn-sm\">Delete</button>\n  </div>\n}";
    private string _codeSortable = "<th role=\"button\" @onclick=\"@(() => SortBy(\"name\"))\">\n  Name @SortIcon(\"name\")\n</th>";
    private string _codeBtnXs = "<div class=\"btn-group btn-group-sm\">\n  <button class=\"btn btn-outline-primary btn-xs\"><i class=\"fa-solid fa-pen\"></i></button>\n  <button class=\"btn btn-outline-danger btn-xs\"><i class=\"fa-solid fa-trash\"></i></button>\n</div>";
    private string _codePagination = "<ul class=\"pagination pagination-sm\">\n  <li class=\"page-item active\"><button class=\"page-link\">1</button></li>\n  <li class=\"page-item\"><button class=\"page-link\">2</button></li>\n</ul>";

    private string _sortColumn = "name";
    private bool _sortAsc = true;
    private int _currentPage = 1;
    private int _pageSize = 8;
    private HashSet<int> _selectedIds = new();
    private TableRow? _editItem;

    private List<TableRow> _allItems = new();
    private List<TableRow> _sortedItems = new();
    private IEnumerable<TableRow> PagedItems => _sortedItems.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_sortedItems.Count / (double)_pageSize));

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() {
        Model.View = _pageName; Model.OnChange += StateHasChanged;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName);
        var cats = new[] { "Engineering", "Marketing", "Sales", "Operations", "Finance" };
        var statuses = new[] { "Active", "Draft", "Archived" };
        var rng = new Random(42);
        for (int i = 1; i <= 35; i++) {
            _allItems.Add(new TableRow { Id = i, Name = $"Item {i:D3}", Category = cats[rng.Next(cats.Length)], Status = statuses[rng.Next(statuses.Length)], Priority = rng.Next(1, 6), Amount = Math.Round(rng.NextDouble() * 5000, 2) });
        }
        ApplySort();
    }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }

    private void SortBy(string col) { if (_sortColumn == col) _sortAsc = !_sortAsc; else { _sortColumn = col; _sortAsc = true; } ApplySort(); }
    private void ApplySort() {
        _sortedItems = _sortColumn switch {
            "name" => (_sortAsc ? _allItems.OrderBy(x => x.Name) : _allItems.OrderByDescending(x => x.Name)).ToList(),
            "category" => (_sortAsc ? _allItems.OrderBy(x => x.Category) : _allItems.OrderByDescending(x => x.Category)).ToList(),
            "status" => (_sortAsc ? _allItems.OrderBy(x => x.Status) : _allItems.OrderByDescending(x => x.Status)).ToList(),
            "priority" => (_sortAsc ? _allItems.OrderBy(x => x.Priority) : _allItems.OrderByDescending(x => x.Priority)).ToList(),
            "amount" => (_sortAsc ? _allItems.OrderBy(x => x.Amount) : _allItems.OrderByDescending(x => x.Amount)).ToList(),
            _ => _allItems,
        };
    }

    private MarkupString SortIcon(string col) => _sortColumn == col ? new MarkupString($"<i class=\"fa-solid fa-sort-{(_sortAsc ? "up" : "down")} ms-1\"></i>") : new MarkupString("<i class=\"fa-solid fa-sort ms-1 opacity-25\"></i>");

    private void ToggleItem(int id) { if (!_selectedIds.Remove(id)) _selectedIds.Add(id); _selectAll = _selectedIds.Count == PagedItems.Count(); }
    private void ToggleSelectAll() { if (_selectAll) foreach (var i in PagedItems) _selectedIds.Add(i.Id); else _selectedIds.Clear(); }
    private void EditItem(TableRow item) { _editItem = item; }
    private void ArchiveItem(TableRow item) { item.Status = "Archived"; }
    private void DeleteItem(TableRow item) { _allItems.Remove(item); _selectedIds.Remove(item.Id); ApplySort(); }
    private void BulkActivate() { foreach (var id in _selectedIds.ToList()) { var i = _allItems.FirstOrDefault(x => x.Id == id); if (i != null) i.Status = "Active"; } _selectedIds.Clear(); _selectAll = false; }
    private void BulkArchive() { foreach (var id in _selectedIds.ToList()) { var i = _allItems.FirstOrDefault(x => x.Id == id); if (i != null) i.Status = "Archived"; } _selectedIds.Clear(); _selectAll = false; }
    private void BulkDelete() { _allItems.RemoveAll(x => _selectedIds.Contains(x.Id)); _selectedIds.Clear(); _selectAll = false; ApplySort(); }

    private string GetStatusBadge(string s) => s switch { "Active" => "bg-success", "Draft" => "bg-secondary", "Archived" => "bg-dark", _ => "bg-secondary" };

    private class TableRow { public int Id { get; set; } public string Name { get; set; } = ""; public string Category { get; set; } = ""; public string Status { get; set; } = ""; public int Priority { get; set; } public double Amount { get; set; } }
}
