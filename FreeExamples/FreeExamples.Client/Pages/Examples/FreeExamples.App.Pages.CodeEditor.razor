@page "/Examples/CodeEditor"
@page "/{TenantCode}/Examples/CodeEditor"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title">Code Editor</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-code me-1"></i> Code Editor Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="About Code Editor" Subtitle="A full-featured code editor running inside your web browser" IconClass="fa-solid fa-code">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This embeds <strong>Monaco Editor</strong> — the same editor engine that powers
                        Visual Studio Code — directly in the web page. You can type code, switch between
                        programming languages (HTML, CSS, JavaScript, C#, JSON, SQL), and even compare
                        two versions of code side-by-side using "diff mode".
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Syntax highlighting</strong> — coloring code so keywords, strings, and numbers stand out</li>
                        <li><strong>Language modes</strong> — the editor understands different programming languages</li>
                        <li><strong>Two-way binding</strong> — what you type is instantly available to C# code and vice versa</li>
                        <li><strong>Diff mode</strong> — comparing two texts side-by-side with differences highlighted</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        Monaco is a JavaScript library. The Blazor wrapper creates a <code>&lt;div&gt;</code>,
                        then JavaScript initializes the Monaco editor inside it. When you type, JavaScript
                        sends the updated text back to C# (via "JS interop" — a bridge between JavaScript
                        and C#). This lets server-side code react to what you type in real time.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* Language selector *@
        <div class="mb-3">
            <label for="lang-select">Language
                <InfoTip Title="Language Selector"
                         Description="This dropdown changes the programming language the editor understands. When you switch from HTML to C#, the editor re-colors the text using C# syntax rules — keywords like class turn blue, strings turn red, comments turn green. The language is passed to Monaco as a parameter."
                         Code="@_codeLangSelect" />
            </label>
            <select id="lang-select" class="form-select" style="max-width:200px;" @bind="_language" @bind:after="OnLanguageChanged">
                <option value="@MonacoEditor.MonacoLanguage.html">HTML</option>
                <option value="@MonacoEditor.MonacoLanguage.css">CSS</option>
                <option value="@MonacoEditor.MonacoLanguage.javascript">JavaScript</option>
                <option value="@MonacoEditor.MonacoLanguage.csharp">C#</option>
                <option value="@MonacoEditor.MonacoLanguage.json">JSON</option>
                <option value="@MonacoEditor.MonacoLanguage.sql">SQL</option>
            </select>
        </div>

        @* Insert at cursor demo *@
        <div class="mb-3">
            <button class="btn btn-sm btn-outline-primary" @onclick="InsertSnippet" aria-label="Insert code snippet at cursor position">
                <i class="fa fa-plus me-1" aria-hidden="true"></i> Insert Snippet at Cursor
            </button>
            <InfoTip Title="Insert at Cursor"
                     Description="This button inserts pre-written code at wherever your cursor is positioned in the editor. It demonstrates that C# can programmatically control the editor's content and cursor position via JavaScript interop — C# tells JavaScript to insert this text at the cursor."
                     Code="@_codeInsert" />
        </div>

        @* Editor *@
        <InfoTip Title="Monaco Editor Component"
                 Description="This is the Monaco code editor — the same engine that powers VS Code — running in a web page. It is a Blazor component that wraps a JavaScript library. The bind-Value attribute creates two-way binding: changes you type are sent to C#, and changes from C# update the editor."
                 Code="@_codeMonaco" />
        <div role="region" aria-label="Code editor">
        <MonacoEditor @ref="_editor"
            Language="@_language"
            @bind-Value="_code"
            MinHeight="400px" />
        </div>

        <div class="mt-3">
            <h6>Current Value (live binding)
                <InfoTip Title="Live Binding Display"
                         Description="This pre block shows the exact same text that is in the editor above — in real time. As you type, Blazor's two-way binding updates the _code variable, and this block re-renders. This proves the binding works and demonstrates how to display raw content from a component."
                         Code="@_codeBinding" />
            </h6>
            <pre class="border rounded p-2 bg-light" style="max-height:200px; overflow:auto;" aria-label="Current editor value" aria-live="polite">@_code</pre>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "codeeditor";
    private string _codeLangSelect = "<select @bind=\"_language\" @bind:after=\"OnLanguageChanged\">";
    private string _codeInsert = "await _editor.InsertAtCursor(\"snippet text\")";
    private string _codeMonaco = "<MonacoEditor @ref=\"_editor\"\n    Language=\"@_language\"\n    @bind-Value=\"_code\"\n    MinHeight=\"400px\" />";
    private string _codeBinding = "<pre>@_code</pre>";
    private string _language = MonacoEditor.MonacoLanguage.html;
    private string _code = "<div class=\"container\">\n    <h1>Hello FreeCRM</h1>\n    <p>Edit me in Monaco!</p>\n</div>";
    private MonacoEditor _editor = null!;

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    private async Task OnLanguageChanged()
    {
        _code = _language switch {
            MonacoEditor.MonacoLanguage.css => "body {\n    font-family: sans-serif;\n    background: #f5f5f5;\n}",
            MonacoEditor.MonacoLanguage.javascript => "function greet(name) {\n    console.log(`Hello, ${name}!`);\n}\n\ngreet('FreeCRM');",
            MonacoEditor.MonacoLanguage.csharp => "public class Example\n{\n    public string Name { get; set; } = \"FreeCRM\";\n\n    public void Greet()\n    {\n        Console.WriteLine($\"Hello, {Name}!\");\n    }\n}",
            MonacoEditor.MonacoLanguage.json => "{\n    \"name\": \"FreeCRM\",\n    \"version\": \"1.0.0\",\n    \"features\": [\"SignalR\", \"Monaco\", \"Highcharts\"]\n}",
            MonacoEditor.MonacoLanguage.sql => "SELECT u.FirstName, u.LastName, d.DepartmentName\nFROM Users u\nJOIN Departments d ON u.DepartmentId = d.DepartmentId\nWHERE u.Enabled = 1\nORDER BY u.LastName;",
            _ => "<div class=\"container\">\n    <h1>Hello FreeCRM</h1>\n    <p>Edit me in Monaco!</p>\n</div>",
        };

        await _editor.SetLanguage(_language);
        await _editor.SetValue(_code);
        Model.AddMessage($"Language changed to {_language}.", MessageType.Success);
    }

    private async Task InsertSnippet()
    {
        await _editor.InsertValue("/* Inserted at cursor */\n");
        Model.AddMessage("Snippet inserted at cursor.", MessageType.Info);
    }
}
