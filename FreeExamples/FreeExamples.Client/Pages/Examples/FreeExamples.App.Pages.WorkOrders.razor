@page "/Examples/WorkOrders"
@page "/{TenantCode}/Examples/WorkOrders"
@implements IDisposable
@inject BlazorDataModel Model

@* Work Orders — Main CRUD table with status/urgency/building/category filters *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-wrench me-1"></i> Work Orders</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-wrench me-1"></i> Work Orders <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Work Orders" Subtitle="Facilities maintenance tracking — submit, dispatch, complete work orders" IconClass="fa-solid fa-wrench">
            <p class="small text-muted mb-0">Track facilities requests with status workflow, urgency color coding, building/floor/room location, and category filtering. SLA-style urgency indicators show at-a-glance priority.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Urgency Color Coding"
                     Description="Emergency = red, High = orange, Normal = blue, Low = gray. Applied to both the badge and a left-border accent on the table row."
                     Code="@_codeUrgency" />
        </div>

        @* Filters *@
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterStatus" @bind:after="ApplyFilter"><option value="">All Statuses</option>@foreach (var s in Enum.GetValues<DataObjects.WorkOrderStatus>()) { <option value="@s">@s</option> }</select>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterUrgency" @bind:after="ApplyFilter"><option value="">All Urgencies</option>@foreach (var u in Enum.GetValues<DataObjects.WorkOrderUrgency>()) { <option value="@u">@u</option> }</select>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterBuilding" @bind:after="ApplyFilter"><option value="">All Buildings</option>@foreach (var b in _all.Select(w => w.Building).Distinct().OrderBy(b => b)) { <option value="@b">@b</option> }</select>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterCategory" @bind:after="ApplyFilter"><option value="">All Categories</option>@foreach (var c in Enum.GetValues<DataObjects.WorkOrderCategory>()) { <option value="@c">@c</option> }</select>
            <span class="text-muted small ms-auto">@_filtered.Count work orders</span>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0 small">
                    <thead class="table-light"><tr><th>Title</th><th>Building</th><th>Room</th><th>Category</th><th>Urgency</th><th>Status</th><th>Assigned</th><th>Requested</th></tr></thead>
                    <tbody>
                        @foreach (var w in _filtered) {
                            <tr style="border-left: 3px solid @GetUrgencyColor(w.Urgency);">
                                <td class="fw-semibold">@w.Title</td>
                                <td>@w.Building</td><td>@w.Floor - @w.RoomNumber</td>
                                <td><span class="badge bg-info bg-opacity-25 text-dark">@w.Category</span></td>
                                <td><span class="badge" style="background-color:@GetUrgencyColor(w.Urgency); color:white;">@w.Urgency</span></td>
                                <td><span class="badge @GetStatusBadge(w.Status)">@w.Status</span></td>
                                <td class="text-muted">@(w.AssignedTo ?? "Unassigned")</td>
                                <td class="text-muted">@w.RequestedDate.ToString("MMM d")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "workorders", _filterStatus = "", _filterUrgency = "", _filterBuilding = "", _filterCategory = "";
    private List<DataObjects.WorkOrder> _all = new(), _filtered = new();
    private string _codeUrgency = "<tr style=\"border-left: 3px solid @GetUrgencyColor(w.Urgency);\">";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            _all = await Helpers.GetOrPost<List<DataObjects.WorkOrder>>("api/Data/GetWorkOrders", new List<Guid>()) ?? new();
            ApplyFilter(); _loading = false; StateHasChanged();
        }
    }

    private void ApplyFilter() {
        _filtered = _all;
        if (Enum.TryParse<DataObjects.WorkOrderStatus>(_filterStatus, out var fs)) _filtered = _filtered.Where(w => w.Status == fs).ToList();
        if (Enum.TryParse<DataObjects.WorkOrderUrgency>(_filterUrgency, out var fu)) _filtered = _filtered.Where(w => w.Urgency == fu).ToList();
        if (!string.IsNullOrEmpty(_filterBuilding)) _filtered = _filtered.Where(w => w.Building == _filterBuilding).ToList();
        if (Enum.TryParse<DataObjects.WorkOrderCategory>(_filterCategory, out var fc)) _filtered = _filtered.Where(w => w.Category == fc).ToList();
    }

    private static string GetUrgencyColor(DataObjects.WorkOrderUrgency u) => u switch { DataObjects.WorkOrderUrgency.Emergency => "#dc3545", DataObjects.WorkOrderUrgency.High => "#fd7e14", DataObjects.WorkOrderUrgency.Normal => "#0d6efd", _ => "#6c757d" };
    private static string GetStatusBadge(DataObjects.WorkOrderStatus s) => s switch { DataObjects.WorkOrderStatus.Completed or DataObjects.WorkOrderStatus.Closed => "bg-success", DataObjects.WorkOrderStatus.InProgress => "bg-primary", DataObjects.WorkOrderStatus.Assigned => "bg-info", _ => "bg-secondary" };
}
