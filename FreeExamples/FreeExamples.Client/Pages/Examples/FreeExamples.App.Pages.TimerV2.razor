@page "/Examples/TimerV2"
@page "/{TenantCode}/Examples/TimerV2"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-clock me-1"></i> Session Timeout</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-clock me-1"></i> V2: Session Timeout Warning <StickyMenuIcon /></h1></div>
        <AboutSection Title="Timer in Context: Session Timeout" Subtitle="A countdown warning before your session expires — the banking / portal pattern" IconClass="fa-solid fa-clock">
            <p class="small text-muted mb-0">A 30-second countdown modal that appears when a session is about to expire. Click "Stay Logged In" to reset, or let it expire. Every banking site has this.</p>
        </AboutSection>
        <div class="text-center py-4"><button class="btn btn-lg btn-warning" @onclick="TriggerTimeout"><i class="fa-solid fa-clock me-1"></i> Simulate Session Timeout</button></div>
        @if (_showWarning) {
            <div class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="z-index:9999; background:rgba(0,0,0,0.5);">
                <div class="card shadow-lg border-warning" style="max-width:400px;"><div class="card-header bg-warning text-dark"><i class="fa-solid fa-triangle-exclamation me-1"></i> Session Expiring</div><div class="card-body text-center">
                    <div class="display-4 fw-bold @(_countdown <= 10 ? "text-danger" : "text-warning") mb-2">@_countdown</div>
                    <p class="small">Your session will expire in @_countdown seconds due to inactivity.</p>
                    <div class="d-flex gap-2 justify-content-center"><button class="btn btn-success" @onclick="StayLoggedIn"><i class="fa-solid fa-arrows-rotate me-1"></i> Stay Logged In</button><button class="btn btn-outline-secondary" @onclick="Logout">Log Out</button></div>
                </div></div>
            </div>
        }
        @if (_expired) { <div class="alert alert-danger text-center"><i class="fa-solid fa-lock me-1"></i> Session expired. You would be redirected to the login page.</div> }
        @if (_stayedIn) { <div class="alert alert-success text-center"><i class="fa-solid fa-check me-1"></i> Session extended! Timer reset.</div> }
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _showWarning = false, _expired = false, _stayedIn = false;
    private string _pageName = "timerv2";
    private int _countdown = 30;
    private System.Timers.Timer? _timer;
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); _timer?.Dispose(); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); _timer = new System.Timers.Timer(1000); _timer.Elapsed += (s, e) => InvokeAsync(() => { if (_countdown <= 0) { _timer.Stop(); _showWarning = false; _expired = true; } else { _countdown--; } StateHasChanged(); }); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
    private void TriggerTimeout() { _countdown = 30; _showWarning = true; _expired = false; _stayedIn = false; _timer?.Start(); }
    private void StayLoggedIn() { _timer?.Stop(); _showWarning = false; _stayedIn = true; }
    private void Logout() { _timer?.Stop(); _showWarning = false; _expired = true; }
}
