@page "/Examples/BoardViews"
@page "/{TenantCode}/Examples/BoardViews"
@implements IDisposable
@inject BlazorDataModel Model

@* Board Views — Default Kanban board for tickets *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-table-columns me-1"></i> Board Views</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-table-columns me-1"></i> Board Views <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Board Views" Subtitle="Kanban board showing tickets as cards in status columns with drag-and-drop" IconClass="fa-solid fa-table-columns">
            <p class="small text-muted mb-0">Tickets displayed as cards organized by status columns. Drag cards between columns to change status. Builds on the existing KanbanBoard pattern but uses real ticket data.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Status Columns"
                     Description="Each TicketStatus value becomes a column. Cards show ticket number, title, type icon, priority badge, and assignee."
                     Code="@_codeBoard" />
        </div>

        @* Project filter *@
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <select class="form-select form-select-sm" style="width:auto;" @bind="_filterProject" @bind:after="ApplyFilter">
                <option value="">All Projects</option>
                @foreach (var p in _projects.OrderBy(p => p.Name)) { <option value="@p.RecordId">@p.Name</option> }
            </select>
            <span class="text-muted small ms-auto">@_filtered.Count tickets</span>
        </div>

        @* Kanban columns *@
        <div class="d-flex gap-2 overflow-auto pb-3">
            @foreach (var status in _columns) {
                var colTickets = _filtered.Where(t => t.Status == status).OrderBy(t => t.SortOrder).ToList();
                var isDropTarget = _dragOverCol == status;
                <div class="flex-shrink-0" style="width:220px;">
                    <div class="card border-0 shadow-sm @(isDropTarget ? "border-primary border-2" : "")"
                         @ondragover="() => _dragOverCol = status" @ondragover:preventDefault="true"
                         @ondrop="() => HandleDrop(status)" @ondragleave="() => _dragOverCol = null">
                        <div class="card-header bg-dark text-white py-1 d-flex justify-content-between small">
                            <span>@status</span>
                            <span class="badge bg-white text-dark rounded-pill">@colTickets.Count</span>
                        </div>
                        <div class="card-body p-1" style="min-height:200px; max-height:500px; overflow-y:auto;">
                            @foreach (var t in colTickets) {
                                <div class="card mb-1 border-0 shadow-sm" draggable="true"
                                     @ondragstart="() => _dragging = t" @ondragend="() => _dragging = null"
                                     style="cursor:grab;">
                                    <div class="card-body p-2 small">
                                        <div class="d-flex justify-content-between mb-1">
                                            <code style="font-size:0.65rem;">@t.TicketNumber</code>
                                            <span class="badge @GetPriorityBadge(t.Priority)" style="font-size:0.5rem;">@t.Priority</span>
                                        </div>
                                        <div class="fw-semibold" style="font-size:0.75rem;">@t.Title</div>
                                        @if (!string.IsNullOrEmpty(t.AssignedTo)) {
                                            <div class="text-muted mt-1" style="font-size:0.65rem;"><i class="fa-solid fa-user me-1"></i>@t.AssignedTo</div>
                                        }
                                        @if (t.StoryPoints.HasValue) {
                                            <span class="badge bg-secondary rounded-pill mt-1" style="font-size:0.55rem;">@t.StoryPoints pts</span>
                                        }
                                    </div>
                                </div>
                            }
                            @if (!colTickets.Any()) {
                                <div class="text-center text-muted small py-3 opacity-50">Empty</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "boardviews";
    private string _filterProject = "";
    private List<DataObjects.Ticket> _all = new(), _filtered = new();
    private List<DataObjects.Project> _projects = new();
    private DataObjects.Ticket? _dragging;
    private DataObjects.TicketStatus? _dragOverCol;
    private static readonly DataObjects.TicketStatus[] _columns = [DataObjects.TicketStatus.Backlog, DataObjects.TicketStatus.ToDo, DataObjects.TicketStatus.InProgress, DataObjects.TicketStatus.InReview, DataObjects.TicketStatus.Testing, DataObjects.TicketStatus.Done];
    private string _codeBoard = "<div class=\"d-flex gap-2\">\n  @foreach (var status in columns) {\n    <div class=\"flex-shrink-0\" style=\"width:220px;\" @ondrop=\"() => HandleDrop(status)\">\n    </div>\n  }\n</div>";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var t = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/GetTickets", new List<Guid>());
            var p = await Helpers.GetOrPost<List<DataObjects.Project>>("api/Data/GetProjects", new List<Guid>());
            _all = t ?? new(); _projects = p ?? new(); ApplyFilter();
            _loading = false; StateHasChanged();
        }
    }

    private void ApplyFilter() {
        _filtered = _all;
        if (Guid.TryParse(_filterProject, out var pid)) _filtered = _filtered.Where(t => t.ProjectId == pid).ToList();
    }

    private async Task HandleDrop(DataObjects.TicketStatus newStatus) {
        _dragOverCol = null;
        if (_dragging == null || _dragging.Status == newStatus) return;
        _dragging.Status = newStatus;
        await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/SaveTickets", new List<DataObjects.Ticket> { _dragging });
        _dragging = null; StateHasChanged();
    }

    private static string GetPriorityBadge(DataObjects.TicketPriority p) => p switch {
        DataObjects.TicketPriority.Critical => "bg-danger", DataObjects.TicketPriority.High => "bg-warning text-dark",
        DataObjects.TicketPriority.Medium => "bg-info", _ => "bg-secondary"
    };
}
