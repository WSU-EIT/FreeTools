@page "/Examples/BacklogV1"
@page "/{TenantCode}/Examples/BacklogV1"
@implements IDisposable
@inject BlazorDataModel Model

@* V1: Grooming View — Split panel: condensed backlog list + detail panel *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-magnifying-glass-chart me-1"></i> Grooming View</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-magnifying-glass-chart me-1"></i> V1: Grooming View <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Grooming View" Subtitle="Split panel — condensed backlog list on left, full ticket detail on right" IconClass="fa-solid fa-magnifying-glass-chart">
            <p class="small text-muted mb-0">Click a row on the left to see full details on the right: description, comments, linked tickets. Update story points and mark as "refined" from the detail panel.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Fibonacci Point Selector"
                     Description="A static int array [1,2,3,5,8,13,21] renders as a btn-group. Clicking a value calls SetPoints(pts) which saves the ticket via API immediately. The active button uses btn-primary vs btn-outline-secondary. This is the standard estimation UI."
                     Code="@_codeFibButtons" />
            <InfoTip Title="Refined vs. Needs Estimation Badge"
                     Description="A conditional badge shows green 'Refined (has estimate)' when StoryPoints > 0, or yellow 'Needs estimation' when null or zero. This visual cue helps the team spot ungroomed tickets at a glance during backlog grooming sessions."
                     Code="@_codeRefinedBadge" />
            <InfoTip Title="Condensed List with Priority + Points"
                     Description="Each list item packs ticket number, title, priority badge, and story points into a single compact row using d-flex justify-content-between. Badges use font-size:0.45rem to stay tiny. The active item gets the Bootstrap 'active' class."
                     Code="@_codeCondensedRow" />
        </div>

        <div class="row g-3">
            @* Left: Condensed list *@
            <div class="col-md-5">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-dark text-white py-1 d-flex justify-content-between small">
                        <span>Backlog (@_backlog.Count)</span>
                        <span class="text-white-50">Click to detail →</span>
                    </div>
                    <div class="list-group list-group-flush" style="max-height:600px; overflow-y:auto;">
                        @foreach (var t in _backlog) {
                            var isSelected = _selected?.RecordId == t.RecordId;
                            <button class="list-group-item list-group-item-action py-1 @(isSelected ? "active" : "")" @onclick="() => SelectTicket(t)">
                                <div class="d-flex justify-content-between small">
                                    <span><code style="font-size:0.6rem;">@t.TicketNumber</code> @t.Title</span>
                                    <span>
                                        <span class="badge @GetPriorityBadge(t.Priority)" style="font-size:0.45rem;">@t.Priority</span>
                                        <span class="badge bg-secondary rounded-pill" style="font-size:0.45rem;">@(t.StoryPoints?.ToString() ?? "?")pts</span>
                                    </span>
                                </div>
                            </button>
                        }
                        @if (!_backlog.Any()) { <div class="text-center text-muted py-4 small">Backlog empty</div> }
                    </div>
                </div>
            </div>

            @* Right: Detail *@
            <div class="col-md-7">
                @if (_selected != null) {
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="fw-semibold"><code>@_selected.TicketNumber</code> @_selected.Title</span>
                            <div class="d-flex gap-1">
                                <span class="badge @GetPriorityBadge(_selected.Priority)">@_selected.Priority</span>
                                <span class="badge bg-info bg-opacity-25 text-dark">@_selected.Type</span>
                            </div>
                        </div>
                        <div class="card-body small">
                            @* Description *@
                            <div class="mb-3">
                                <h6 class="small fw-semibold">Description</h6>
                                <div class="border rounded p-2 bg-light" style="min-height:60px;">@(_selected.Description ?? "No description")</div>
                            </div>

                            @* Metadata *@
                            <div class="row g-2 mb-3">
                                <div class="col-6"><span class="text-muted">Reporter:</span> @_selected.ReporterName</div>
                                <div class="col-6"><span class="text-muted">Assigned:</span> @(_selected.AssignedTo ?? "Unassigned")</div>
                                <div class="col-6"><span class="text-muted">Labels:</span> @(_selected.Labels ?? "None")</div>
                                <div class="col-6"><span class="text-muted">Due:</span> @(_selected.DueDate?.ToString("MMM d, yyyy") ?? "—")</div>
                            </div>

                            @* Story points edit *@
                            <div class="mb-3">
                                <h6 class="small fw-semibold">Story Points</h6>
                                <div class="btn-group btn-group-sm">
                                    @foreach (var pts in _fib) {
                                        <button class="btn @(_selected.StoryPoints == pts ? "btn-primary" : "btn-outline-secondary")" @onclick="() => SetPoints(pts)">@pts</button>
                                    }
                                </div>
                            </div>

                            @* Comments *@
                            <div class="mb-3">
                                <h6 class="small fw-semibold">Comments (@_selected.Comments.Count)</h6>
                                @if (_selected.Comments.Any()) {
                                    @foreach (var c in _selected.Comments.OrderByDescending(c => c.CreatedDate)) {
                                        <div class="border-start border-3 border-primary ps-2 mb-2">
                                            <div class="d-flex justify-content-between"><span class="fw-semibold">@c.AuthorName</span><span class="text-muted" style="font-size:0.6rem;">@c.CreatedDate.ToString("MMM d, h:mm tt")</span></div>
                                            <div>@c.Body</div>
                                        </div>
                                    }
                                } else {
                                    <div class="text-muted">No comments yet</div>
                                }
                            </div>

                            @* Refined badge *@
                            <div class="d-flex gap-2">
                                @if (_selected.StoryPoints.HasValue && _selected.StoryPoints > 0) {
                                    <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i>Refined (has estimate)</span>
                                } else {
                                    <span class="badge bg-warning text-dark"><i class="fa-solid fa-question me-1"></i>Needs estimation</span>
                                }
                            </div>
                        </div>
                    </div>
                } else {
                    <div class="card border-0 shadow-sm"><div class="card-body text-center text-muted py-5"><i class="fa-solid fa-arrow-left fa-2x mb-2 opacity-50"></i><div>Select a ticket to see details</div></div></div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "backlogv1";
    private List<DataObjects.Ticket> _backlog = new();
    private DataObjects.Ticket? _selected;
    private static readonly int[] _fib = [1, 2, 3, 5, 8, 13, 21];

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var t = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/GetTickets", new List<Guid>()) ?? new();
            _backlog = t.Where(x => x.SprintId == null || x.SprintId == Guid.Empty).OrderBy(x => x.SortOrder).ToList();
            _loading = false; StateHasChanged();
        }
    }

    private void SelectTicket(DataObjects.Ticket t) => _selected = t;

    private async Task SetPoints(int pts) {
        if (_selected == null) return;
        _selected.StoryPoints = pts;
        await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/SaveTickets", new List<DataObjects.Ticket> { _selected });
        StateHasChanged();
    }

    private static string GetPriorityBadge(DataObjects.TicketPriority p) => p switch { DataObjects.TicketPriority.Critical => "bg-danger", DataObjects.TicketPriority.High => "bg-warning text-dark", DataObjects.TicketPriority.Medium => "bg-info", _ => "bg-secondary" };

    private string _codeFibButtons = @"static readonly int[] _fib = [1,2,3,5,8,13,21];

<div class=""btn-group btn-group-sm"">
  @foreach (var pts in _fib) {
    <button class=""btn @(_selected.StoryPoints == pts
      ? ""btn-primary"" : ""btn-outline-secondary"")""
      @onclick=""() => SetPoints(pts)"">@pts</button>
  }
</div>

async Task SetPoints(int pts) {
  _selected.StoryPoints = pts;
  await SaveTickets(new[] { _selected });
}";

    private string _codeRefinedBadge = @"@if (_selected.StoryPoints.HasValue
    && _selected.StoryPoints > 0) {
  <span class=""badge bg-success"">
    <i class=""fa-solid fa-check me-1""/>
    Refined (has estimate)
  </span>
} else {
  <span class=""badge bg-warning text-dark"">
    <i class=""fa-solid fa-question me-1""/>
    Needs estimation
  </span>
}";

    private string _codeCondensedRow = @"<button class=""list-group-item
  list-group-item-action
  @(isSelected ? ""active"" : """")"">
  <div class=""d-flex justify-content-between small"">
    <span>
      <code>@t.TicketNumber</code> @t.Title
    </span>
    <span>
      <span class=""badge @GetPriorityBadge(t.Priority)""
            style=""font-size:0.45rem;"">@t.Priority</span>
      <span class=""badge bg-secondary rounded-pill""
            style=""font-size:0.45rem;"">
        @(t.StoryPoints?.ToString() ?? ""?"")pts
      </span>
    </span>
  </div>
</button>";
}
