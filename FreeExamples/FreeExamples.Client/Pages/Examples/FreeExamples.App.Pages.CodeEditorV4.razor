@page "/Examples/CodeEditorV4"
@page "/{TenantCode}/Examples/CodeEditorV4"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-code-compare me-1"></i> Diff Viewer</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-code-compare me-1"></i> V4: Code Diff Viewer <StickyMenuIcon /></h1></div>
        <AboutSection Title="Code Editor in Context: Diff Viewer" Subtitle="Side-by-side code comparison — the GitHub PR / VS Code diff pattern" IconClass="fa-solid fa-code-compare">
            <p class="small text-muted mb-0">View changes between two versions of a file side-by-side with added/removed line highlighting. The GitHub pull request review pattern.</p>
        </AboutSection>
        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Side-by-Side Diff View"
                     Description="Two pre blocks side by side (col-md-6 each) show the original and modified code. Lines that differ get bg-danger bg-opacity-10 (removed) or bg-success bg-opacity-10 (added). This is the GitHub/GitLab diff viewer pattern."
                     Code="@_codeSideBySide" />
            <InfoTip Title="Line Number Gutters"
                     Description="Each code line has a small line number in text-muted on the left. A CSS counter or manual numbering provides this. Line numbers help users reference specific changes. Monaco Editor provides this automatically."
                     Code="@_codeLineNumbers" />
            <InfoTip Title="Diff Stats Summary"
                     Description="A summary bar shows additions (text-success +N) and deletions (text-danger -N). This gives a quick sense of change magnitude. The same summary appears in GitHub PR headers and git diff --stat output."
                     Code="@_codeDiffStats" />
        </div>
        <div class="card shadow-sm border-0 mb-3"><div class="card-header bg-white py-2 d-flex justify-content-between"><span class="small fw-semibold"><i class="fa-solid fa-code-compare me-1"></i> Program.cs</span><div><span class="badge bg-success me-1">+3 added</span><span class="badge bg-danger">-1 removed</span></div></div>
            <div class="card-body p-0"><div class="row g-0">
                <div class="col-6 border-end"><div class="small text-muted bg-light px-2 py-1 border-bottom">Before (main)</div>
                    <pre class="px-2 py-1 mb-0" style="font-size:0.7rem; line-height:1.6;">
 1  var builder = WebApplication.CreateBuilder(args);
 2  builder.Services.AddRazorPages();
<span class="bg-danger bg-opacity-25 d-block"> 3  builder.Services.AddServerSideBlazor();</span>
 4  var app = builder.Build();
 5  app.MapRazorPages();
 6  app.Run();</pre></div>
                <div class="col-6"><div class="small text-muted bg-light px-2 py-1 border-bottom">After (feature/interactive)</div>
                    <pre class="px-2 py-1 mb-0" style="font-size:0.7rem; line-height:1.6;">
 1  var builder = WebApplication.CreateBuilder(args);
 2  builder.Services.AddRazorPages();
<span class="bg-success bg-opacity-25 d-block"> 3  builder.Services.AddRazorComponents()</span>
<span class="bg-success bg-opacity-25 d-block"> 4      .AddInteractiveServerComponents()</span>
<span class="bg-success bg-opacity-25 d-block"> 5      .AddInteractiveWebAssemblyComponents();</span>
 6  var app = builder.Build();
 7  app.MapRazorPages();
 8  app.Run();</pre></div>
            </div></div>
        </div>
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "codeeditorv4";
    private string _codeSideBySide = "<div class=\"row\">\n  <div class=\"col-md-6\"><pre>Original</pre></div>\n  <div class=\"col-md-6\"><pre>Modified</pre></div>\n</div>";
    private string _codeLineNumbers = "<div class=\"d-flex\">\n  <span class=\"text-muted\" style=\"width:30px\">1</span>\n  <span>code line here</span>\n</div>";
    private string _codeDiffStats = "<span class=\"text-success\">+12 additions</span>\n<span class=\"text-danger\">-3 deletions</span>";
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
}
