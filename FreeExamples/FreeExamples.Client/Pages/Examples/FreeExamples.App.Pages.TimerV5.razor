@page "/Examples/TimerV5"
@page "/{TenantCode}/Examples/TimerV5"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-calendar-check me-1"></i> Event Countdown</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-calendar-check me-1"></i> V5: Event Countdown <StickyMenuIcon /></h1></div>
        <AboutSection Title="Timer in Context: Event Countdown" Subtitle="Days/hours/minutes/seconds countdown to a future event" IconClass="fa-solid fa-calendar-check">
            <p class="small text-muted mb-0">A large-format countdown timer to a future event. Shows days, hours, minutes, and seconds. Common on product launch pages and conference sites.</p>
        </AboutSection>
        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Event Countdown Display"
                     Description="A large countdown showing days, hours, minutes, and seconds until an event. Each unit has its own display block. This is the product launch / event landing page pattern. The countdown updates every second."
                     Code="@_codeCountdown" />
            <InfoTip Title="Countdown Unit Blocks"
                     Description="Each time unit (days, hours, minutes, seconds) gets a card with a large number and small label below. d-flex gap-3 spaces them evenly. The cards use shadow-sm and rounded for a polished look."
                     Code="@_codeUnitBlocks" />
            <InfoTip Title="Event Complete State"
                     Description="When the countdown reaches 0, the display switches from numbers to a celebration message with a confetti icon. The state transition (counting → complete) is handled by a simple bool. This 'done' state prevents showing negative times."
                     Code="@_codeEventComplete" />
        </div>
        <div class="text-center py-5"><h3 class="text-muted mb-4">Time Until Launch</h3>
            <div class="row justify-content-center g-3">
                @foreach (var u in new[] { ("Days", _days), ("Hours", _hours), ("Minutes", _mins), ("Seconds", _secs) }) {
                    <div class="col-auto"><div class="bg-dark text-white rounded-3 p-3 shadow" style="min-width:100px;"><div class="display-4 fw-bold">@u.Item2.ToString("D2")</div><div class="small text-muted">@u.Item1</div></div></div>
                }
            </div>
            <div class="mt-4"><span class="badge bg-primary rounded-pill px-3 py-2">March 15, 2025 at 9:00 AM</span></div>
        </div>
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "timerv5";
    private string _codeCountdown = "var remaining = _eventDate - DateTime.Now;\nvar days = remaining.Days;\nvar hours = remaining.Hours;\nvar minutes = remaining.Minutes;\nvar seconds = remaining.Seconds;";
    private string _codeUnitBlocks = "<div class=\"d-flex gap-3 justify-content-center\">\n  <div class=\"card text-center px-3 py-2\">\n    <div class=\"display-4\">@days</div>\n    <div class=\"small text-muted\">Days</div>\n  </div>\n  <!-- hours, minutes, seconds -->\n</div>";
    private string _codeEventComplete = "@if (_complete) {\n  <div class=\"text-center\">\n    <i class=\"fa-solid fa-party-horn fa-3x\"></i>\n    <h3>Event has started!</h3>\n  </div>\n}";
    private int _days = 42, _hours = 7, _mins = 23, _secs = 45;
    private System.Timers.Timer? _timer;
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); _timer?.Dispose(); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); _timer = new System.Timers.Timer(1000); _timer.Elapsed += (s, e) => InvokeAsync(() => { var target = new DateTime(2025, 3, 15, 9, 0, 0); var diff = target - DateTime.Now; if (diff.TotalSeconds > 0) { _days = diff.Days; _hours = diff.Hours; _mins = diff.Minutes; _secs = diff.Seconds; } StateHasChanged(); }); _timer.Start(); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
}
