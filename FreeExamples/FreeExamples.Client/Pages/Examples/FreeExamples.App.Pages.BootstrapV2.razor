@page "/Examples/BootstrapV2"
@page "/{TenantCode}/Examples/BootstrapV2"
@implements IDisposable
@inject BlazorDataModel Model

@* V2: Settings Page — Bootstrap form controls in a realistic settings UI *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-gear me-1"></i> Settings Page</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-gear me-1"></i> V2: Application Settings <StickyMenuIcon /></h1></div>
        <AboutSection Title="Bootstrap in Context: Settings Page" Subtitle="Form controls, switches, selects, and validation in a real settings page" IconClass="fa-solid fa-gear">
            <p class="small text-muted mb-0">Bootstrap form components organized into tabbed settings sections. Demonstrates form groups, switches, range sliders, input groups, and validation feedback in a realistic admin panel context.</p>
        </AboutSection>

        <ul class="nav nav-tabs mb-3">
            @foreach (var tab in new[] { "General", "Notifications", "Security", "Appearance" }) {
                <li class="nav-item"><a class="nav-link @(_activeTab == tab ? "active" : "")" href="#" @onclick="@(() => _activeTab = tab)" @onclick:preventDefault>@tab</a></li>
            }
        </ul>

        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                @if (_activeTab == "General") {
                    <div class="row mb-3"><div class="col-md-6"><label class="form-label small">Application Name</label><input type="text" class="form-control form-control-sm" value="FreeExamples" /></div><div class="col-md-6"><label class="form-label small">Time Zone</label><select class="form-select form-select-sm"><option>Pacific (UTC-8)</option><option>Mountain (UTC-7)</option><option>Central (UTC-6)</option><option>Eastern (UTC-5)</option></select></div></div>
                    <div class="mb-3"><label class="form-label small">Description</label><textarea class="form-control form-control-sm" rows="2">A demo application showcasing Blazor patterns</textarea></div>
                    <div class="form-check form-switch mb-2"><input type="checkbox" class="form-check-input" checked /><label class="form-check-label small">Enable public access</label></div>
                    <div class="form-check form-switch mb-2"><input type="checkbox" class="form-check-input" /><label class="form-check-label small">Maintenance mode</label></div>
                } else if (_activeTab == "Notifications") {
                    <h6 class="small fw-semibold mb-3">Email Notifications</h6>
                    <div class="form-check form-switch mb-2"><input type="checkbox" class="form-check-input" checked /><label class="form-check-label small">New user registrations</label></div>
                    <div class="form-check form-switch mb-2"><input type="checkbox" class="form-check-input" checked /><label class="form-check-label small">Error alerts (500 errors)</label></div>
                    <div class="form-check form-switch mb-2"><input type="checkbox" class="form-check-input" /><label class="form-check-label small">Weekly activity digest</label></div>
                    <div class="form-check form-switch mb-2"><input type="checkbox" class="form-check-input" /><label class="form-check-label small">Comment replies</label></div>
                    <hr />
                    <label class="form-label small">Notification Email</label>
                    <div class="input-group input-group-sm"><span class="input-group-text">@@</span><input type="email" class="form-control" value="admin@example.com" /></div>
                } else if (_activeTab == "Security") {
                    <div class="mb-3"><label class="form-label small">Session Timeout (minutes)</label><input type="range" class="form-range" min="5" max="120" value="30" /><div class="small text-muted">30 minutes</div></div>
                    <div class="mb-3"><label class="form-label small">Maximum Login Attempts</label><select class="form-select form-select-sm" style="width:auto;"><option>3</option><option>5</option><option>10</option></select></div>
                    <div class="form-check form-switch mb-2"><input type="checkbox" class="form-check-input" checked /><label class="form-check-label small">Require two-factor authentication</label></div>
                    <div class="form-check form-switch mb-2"><input type="checkbox" class="form-check-input" checked /><label class="form-check-label small">Enforce password complexity</label></div>
                    <div class="alert alert-warning small mt-3"><i class="fa-solid fa-shield-halved me-1"></i> Password complexity requires minimum 12 characters, uppercase, lowercase, number, and special character.</div>
                } else {
                    <label class="form-label small">Theme</label>
                    <div class="d-flex gap-2 mb-3">
                        @foreach (var theme in new[] { ("Light", "bg-white border"), ("Dark", "bg-dark"), ("Blue", "bg-primary") }) {
                            <div class="rounded p-3 text-center @theme.Item2 @(theme.Item1 == "Dark" ? "text-white" : "")" style="width:80px; cursor:pointer; border:2px solid transparent;">
                                <div class="small">@theme.Item1</div>
                            </div>
                        }
                    </div>
                    <label class="form-label small">Font Size</label>
                    <div class="btn-group btn-group-sm mb-3"><button class="btn btn-outline-secondary">Small</button><button class="btn btn-primary">Medium</button><button class="btn btn-outline-secondary">Large</button></div>
                    <div class="form-check form-switch mb-2"><input type="checkbox" class="form-check-input" /><label class="form-check-label small">Compact navigation</label></div>
                    <div class="form-check form-switch mb-2"><input type="checkbox" class="form-check-input" checked /><label class="form-check-label small">Show sidebar</label></div>
                }
            </div>
            <div class="card-footer bg-light d-flex justify-content-end gap-2">
                <button class="btn btn-sm btn-outline-secondary">Cancel</button>
                <button class="btn btn-sm btn-primary"><i class="fa-solid fa-save me-1"></i> Save Changes</button>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "bootstrapv2";
    private string _activeTab = "General";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
}
