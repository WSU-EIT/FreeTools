@page "/Examples/SprintPlanningV2"
@page "/{TenantCode}/Examples/SprintPlanningV2"
@implements IDisposable
@inject BlazorDataModel Model

@* V2: Active Sprint — Dashboard with burndown, countdown, status breakdown *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-person-running me-1"></i> Active Sprint</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-person-running me-1"></i> V2: Active Sprint <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Active Sprint Dashboard" Subtitle="Live sprint tracking with burndown, countdown, and status breakdown" IconClass="fa-solid fa-person-running">
            <p class="small text-muted mb-0">Sprint goal at top, days remaining countdown, burndown progress bar, ticket status breakdown, and a list of all committed tickets with status badges.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Burndown Bar"
                     Description="A simple horizontal bar showing completed points vs. total planned. The ideal pace line is calculated from days elapsed / total days."
                     Code="@_codeBurn" />
        </div>

        @* Sprint selector *@
        <div class="d-flex align-items-center gap-2 mb-3">
            <label class="form-label mb-0 small fw-semibold">Sprint:</label>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_selectedSprintId" @bind:after="Refresh">
                @foreach (var s in _sprints.Where(s => s.Status == DataObjects.SprintStatus.Active || s.Status == DataObjects.SprintStatus.Planning).OrderByDescending(s => s.StartDate)) {
                    <option value="@s.RecordId">@s.Name</option>
                }
            </select>
        </div>

        @if (_active != null) {
            var tickets = _sprintTickets;
            var totalPts = tickets.Where(t => t.StoryPoints.HasValue).Sum(t => t.StoryPoints!.Value);
            var donePts = tickets.Where(t => (t.Status == DataObjects.TicketStatus.Done || t.Status == DataObjects.TicketStatus.Closed) && t.StoryPoints.HasValue).Sum(t => t.StoryPoints!.Value);
            var burnPct = totalPts > 0 ? (int)(donePts * 100.0 / totalPts) : 0;
            var daysTotal = _active.StartDate.HasValue && _active.EndDate.HasValue ? (_active.EndDate.Value - _active.StartDate.Value).Days : 0;
            var daysElapsed = _active.StartDate.HasValue ? (int)(DateTime.Now - _active.StartDate.Value).TotalDays : 0;
            var daysRemaining = _active.EndDate.HasValue ? Math.Max(0, (int)(_active.EndDate.Value - DateTime.Now).TotalDays) : 0;
            var idealPct = daysTotal > 0 ? Math.Min(100, (int)(daysElapsed * 100.0 / daysTotal)) : 0;

            @* Sprint goal hero *@
            @if (!string.IsNullOrEmpty(_active.Goal)) {
                <div class="alert alert-primary py-2 small mb-3"><i class="fa-solid fa-bullseye me-1"></i><strong>Goal:</strong> @_active.Goal</div>
            }

            @* Stats row *@
            <div class="row g-3 mb-3">
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body py-2">
                            <div class="fs-3 fw-bold @(daysRemaining <= 2 ? "text-danger" : "text-primary")">@daysRemaining</div>
                            <div class="text-muted small">Days Remaining</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body py-2">
                            <div class="fs-3 fw-bold text-success">@donePts / @totalPts</div>
                            <div class="text-muted small">Points Done</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body py-2">
                            <div class="fs-3 fw-bold">@tickets.Count</div>
                            <div class="text-muted small">Tickets</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body py-2">
                            <div class="fs-3 fw-bold">@burnPct%</div>
                            <div class="text-muted small">Complete</div>
                        </div>
                    </div>
                </div>
            </div>

            @* Burndown bar *@
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>Burndown: @donePts / @totalPts points</span>
                        <span class="text-muted">Ideal pace: @idealPct%</span>
                    </div>
                    <div class="progress" style="height:14px; position:relative;">
                        <div class="progress-bar bg-success" style="width:@burnPct%">@burnPct%</div>
                    </div>
                    @if (burnPct < idealPct - 10) {
                        <div class="text-danger small mt-1"><i class="fa-solid fa-triangle-exclamation me-1"></i>Behind pace by @(idealPct - burnPct)%</div>
                    }
                </div>
            </div>

            @* Status breakdown *@
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-light py-1 small fw-semibold">Status Breakdown</div>
                <div class="card-body py-2">
                    <div class="row g-2 small">
                        @foreach (var grp in tickets.GroupBy(t => t.Status).OrderBy(g => g.Key)) {
                            var pct = tickets.Count > 0 ? (int)(grp.Count() * 100.0 / tickets.Count) : 0;
                            <div class="col-md-4 col-6">
                                <div class="d-flex justify-content-between"><span>@grp.Key</span><span class="fw-bold">@grp.Count()</span></div>
                                <div class="progress" style="height:4px;"><div class="progress-bar @GetStatusColor(grp.Key)" style="width:@pct%"></div></div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Ticket list *@
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light py-1 small fw-semibold">Committed Tickets</div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0 small">
                        <thead class="table-light"><tr><th>Number</th><th>Title</th><th>Status</th><th>Priority</th><th>Assigned</th><th class="text-center">Pts</th></tr></thead>
                        <tbody>
                            @foreach (var t in tickets.OrderBy(t => t.Status).ThenBy(t => t.SortOrder)) {
                                <tr>
                                    <td><code>@t.TicketNumber</code></td><td>@t.Title</td>
                                    <td><span class="badge @GetStatusColor(t.Status)">@t.Status</span></td>
                                    <td><span class="badge @GetPriorityBadge(t.Priority)" style="font-size:0.55rem;">@t.Priority</span></td>
                                    <td class="text-muted">@(t.AssignedTo ?? "—")</td>
                                    <td class="text-center">@(t.StoryPoints?.ToString() ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        } else {
            <div class="text-center text-muted py-5">No active sprint found.</div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "sprintplanningv2", _selectedSprintId = "";
    private List<DataObjects.Sprint> _sprints = new();
    private List<DataObjects.Ticket> _allTickets = new(), _sprintTickets = new();
    private DataObjects.Sprint? _active;
    private string _codeBurn = "<div class=\"progress\"><div class=\"progress-bar bg-success\" style=\"width:@burnPct%\">@burnPct%</div></div>";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            _sprints = await Helpers.GetOrPost<List<DataObjects.Sprint>>("api/Data/GetSprints", new List<Guid>()) ?? new();
            _allTickets = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/GetTickets", new List<Guid>()) ?? new();
            var act = _sprints.FirstOrDefault(s => s.Status == DataObjects.SprintStatus.Active) ?? _sprints.FirstOrDefault();
            if (act != null) _selectedSprintId = act.RecordId.ToString();
            Refresh(); _loading = false; StateHasChanged();
        }
    }

    private void Refresh() {
        _active = Guid.TryParse(_selectedSprintId, out var sid) ? _sprints.FirstOrDefault(s => s.RecordId == sid) : null;
        _sprintTickets = _active != null ? _allTickets.Where(t => t.SprintId == _active.RecordId).ToList() : new();
    }

    private static string GetStatusColor(DataObjects.TicketStatus s) => s switch { DataObjects.TicketStatus.Done or DataObjects.TicketStatus.Closed => "bg-success", DataObjects.TicketStatus.InProgress => "bg-primary", DataObjects.TicketStatus.InReview or DataObjects.TicketStatus.Testing => "bg-info", _ => "bg-secondary" };
    private static string GetPriorityBadge(DataObjects.TicketPriority p) => p switch { DataObjects.TicketPriority.Critical => "bg-danger", DataObjects.TicketPriority.High => "bg-warning text-dark", DataObjects.TicketPriority.Medium => "bg-info", _ => "bg-secondary" };
}
