@page "/Examples/NetworkGraph"
@page "/{TenantCode}/Examples/NetworkGraph"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title">Network Graph</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-diagram-project me-1"></i> Network Graph Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="About Network Graph" Subtitle="See how things connect to each other in an interactive, animated diagram" IconClass="fa-solid fa-diagram-project">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        A <strong>network graph</strong> is a diagram where circles ("nodes") represent things
                        and lines ("edges") show how they're connected. Think of a family tree, a social network,
                        or a map of computer servers. You can drag nodes around, click them to select them,
                        and watch them bounce into position using physics simulation.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Nodes and edges</strong> — the basic building blocks of any graph</li>
                        <li><strong>Physics simulation</strong> — nodes repel each other and settle into a layout automatically</li>
                        <li><strong>Solver modes</strong> — different algorithms for arranging nodes (repulsion vs Barnes-Hut)</li>
                        <li><strong>Click interaction</strong> — selecting a node shows its details</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        The <strong>vis.js</strong> JavaScript library does the heavy lifting. C# builds a list
                        of nodes and edges, passes them to JavaScript, and vis.js draws and animates the graph
                        inside a <code>&lt;div&gt;</code>. When you click a node, JavaScript calls back into C#
                        (via "JS interop") so the page can react. The physics engine runs continuously to keep
                        nodes from overlapping.
                    </p>
                </div>
            </div>
        </AboutSection>

        <div class="btn-group mb-3" role="group" aria-label="Graph layout controls">
            <button type="button" class="btn btn-dark" @onclick="RandomizeLayout" aria-label="Randomize graph layout">
                <i class="fa-solid fa-shuffle me-1" aria-hidden="true"></i> Randomize Layout
            </button>
            <button type="button" class="btn @(_solver == "repulsion" ? "btn-primary" : "btn-outline-primary")"
                    @onclick="@(() => SetSolver("repulsion"))" aria-pressed="@(_solver == "repulsion")" aria-label="Use repulsion solver">
                Repulsion
            </button>
            <button type="button" class="btn @(_solver == "barnesHut" ? "btn-primary" : "btn-outline-primary")"
                    @onclick="@(() => SetSolver("barnesHut"))" aria-pressed="@(_solver == "barnesHut")" aria-label="Use Barnes-Hut solver">
                Barnes-Hut
            </button>
        </div>

        <div class="mb-2 text-muted small" aria-live="polite">@_nodes.Count nodes, @_relationships.Count edges</div>

        @if (_nodes.Any()) {
            <div role="region" aria-label="Interactive network graph visualization">
            <NetworkChart @ref="_chart"
                Nodes="_nodes"
                Relationships="_relationships"
                NetworkSolver="@_solver"
                OnElementSelected="@((string id) => OnNodeSelected(id))"
                OnRelationshipSelected="@((string id) => OnEdgeSelected(id))"
                OnLoadFailed="@(() => OnChartLoadFailed())" />
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "networkgraph";
    private string _solver = "repulsion";
    private NetworkChart? _chart;

    private DataObjects.SampleGraphData _graphData = new();
    private List<NetworkChart.NetworkNode> _nodes = new();
    private List<NetworkChart.NetworkRelationship> _relationships = new();

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            await LoadData();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    private async Task LoadData()
    {
        var result = await Helpers.GetOrPost<DataObjects.SampleGraphData>("api/Data/GetSampleGraphData");
        if (result != null) {
            _graphData = result;
            BuildChartData();
            Model.AddMessage($"Loaded {_nodes.Count} nodes and {_relationships.Count} edges.", MessageType.Success);
        } else {
            Model.AddMessage("Failed to load graph data.", MessageType.Danger);
        }

        _loading = false;
        StateHasChanged();
    }

    private void BuildChartData()
    {
        _nodes = new List<NetworkChart.NetworkNode>();
        _relationships = new List<NetworkChart.NetworkRelationship>();

        foreach (var node in _graphData.Nodes) {
            bool isCategory = node.Group == "category";

            string iconCode = isCategory ? "f07b" : node.Group switch {  // folder for category
                "active" => "f058",     // circle-check
                "completed" => "f00c",  // check
                "archived" => "f187",   // archive
                _ => "f15b",            // file (draft)
            };

            string iconColor = isCategory ? "#6f42c1" : node.Group switch {
                "active" => "#28a745",
                "completed" => "#17a2b8",
                "archived" => "#6c757d",
                _ => "#ffc107",
            };

            _nodes.Add(new NetworkChart.NetworkNode {
                id = node.Id.ToString(),
                label = node.Label,
                title = $"<strong>{node.Label}</strong><br/>Group: {node.Group}",
                shape = "icon",
                icon = new NetworkChart.NetworkNodeIcon {
                    code = iconCode,
                    size = isCategory ? 60 : 35,
                    color = iconColor,
                },
            });
        }

        foreach (var edge in _graphData.Edges) {
            _relationships.Add(new NetworkChart.NetworkRelationship {
                id = $"{edge.From}-{edge.To}",
                from = edge.From.ToString(),
                to = edge.To.ToString(),
                label = edge.Label ?? "",
                arrows = "to",
            });
        }
    }

    private void OnNodeSelected(string id)
    {
        var node = _graphData.Nodes.FirstOrDefault(n => n.Id.ToString() == id);
        string info = node != null
            ? $"{node.Label} (Group: {node.Group}, ID: {node.Id})"
            : $"Node ID: {id}";
        Model.AddMessage(info, MessageType.Info);
    }

    private void OnEdgeSelected(string id)
    {
        Model.AddMessage($"Edge selected: {id}", MessageType.Info);
    }

    private void OnChartLoadFailed()
    {
        Model.AddMessage("Failed to load the vis.js network library. Check your internet connection.", MessageType.Danger, AutoHide: false);
        StateHasChanged();
    }

    private async Task RandomizeLayout()
    {
        if (_chart != null) {
            await _chart.RandomizeLayout();
            Model.AddMessage("Layout randomized.", MessageType.Success);
        }
    }

    private async Task SetSolver(string solver)
    {
        _solver = solver;
        if (_chart != null) {
            await _chart.UpdateNetworkSolver(solver);
            Model.AddMessage($"Solver changed to {solver}.", MessageType.Success);
        }
    }
}
