@page "/Examples/BacklogV4"
@page "/{TenantCode}/Examples/BacklogV4"
@implements IDisposable
@inject BlazorDataModel Model

@* V4: Saved Views — Create/manage saved filter views as tabs *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-bookmark me-1"></i> Saved Views</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-bookmark me-1"></i> V4: Saved Views <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Saved Views" Subtitle="Create and manage saved filter presets as tabs across the top of the backlog" IconClass="fa-solid fa-bookmark">
            <p class="small text-muted mb-0">Define a filter (type, priority, assignee), save it with a name, and it appears as a clickable tab. Click a tab to apply that filter instantly. Edit or delete saved views.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Dynamic Nav Tabs from Data"
                     Description="@_descNavTabs"
                     Code="@_codeNavTabs" />
            <InfoTip Title="Pipe-Delimited Filter Storage"
                     Description="FilterJson stores filters as 'type|priority|assignee' — a simple pipe-delimited string. ApplyView splits it and applies each non-empty segment with Enum.TryParse or string.Contains. This avoids JSON parsing overhead for simple filter presets."
                     Code="@_codeFilterParse" />
            <InfoTip Title="SaveMany / DeleteMany Pattern"
                     Description="SaveView() creates a new SavedView object and posts it via SaveSavedViews (SaveMany pattern). DeleteView() posts the RecordId via DeleteSavedViews (DeleteMany). Both follow the standard GetMany/SaveMany/DeleteMany API convention used across the app."
                     Code="@_codeSaveDelete" />
        </div>

        @* Saved view tabs *@
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item"><button class="nav-link @(_activeViewId == null ? "active" : "")" @onclick="() => { _activeViewId = null; ApplyFilter(); }">All</button></li>
            @foreach (var v in _views) {
                <li class="nav-item">
                    <button class="nav-link @(_activeViewId == v.RecordId ? "active" : "") d-flex align-items-center gap-1" @onclick="() => ApplyView(v)">
                        @v.Name
                        <i class="fa-solid fa-times text-muted" style="font-size:0.5rem; cursor:pointer;" @onclick="() => DeleteView(v)" @onclick:stopPropagation="true"></i>
                    </button>
                </li>
            }
            <li class="nav-item"><button class="nav-link text-primary" @onclick="() => _showCreate = !_showCreate"><i class="fa-solid fa-plus"></i></button></li>
        </ul>

        @* Create view form *@
        @if (_showCreate) {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3"><label class="form-label small fw-semibold">View Name</label><input type="text" class="form-control form-control-sm" @bind="_newName" /></div>
                        <div class="col-md-2"><label class="form-label small fw-semibold">Type</label><select class="form-select form-select-sm" @bind="_newType"><option value="">Any</option>@foreach (var t in Enum.GetValues<DataObjects.TicketType>()) { <option value="@t">@t</option> }</select></div>
                        <div class="col-md-2"><label class="form-label small fw-semibold">Priority</label><select class="form-select form-select-sm" @bind="_newPriority"><option value="">Any</option>@foreach (var p in Enum.GetValues<DataObjects.TicketPriority>()) { <option value="@p">@p</option> }</select></div>
                        <div class="col-md-2"><label class="form-label small fw-semibold">Assigned</label><input type="text" class="form-control form-control-sm" @bind="_newAssign" placeholder="Name or empty" /></div>
                        <div class="col-md-2"><label class="form-label small fw-semibold">Group By</label><select class="form-select form-select-sm" @bind="_newGroup"><option value="">None</option><option value="type">Type</option><option value="priority">Priority</option><option value="assignee">Assignee</option></select></div>
                        <div class="col-md-1"><button class="btn btn-primary btn-sm w-100" @onclick="SaveView">Save</button></div>
                    </div>
                </div>
            </div>
        }

        @* Filtered backlog *@
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light py-1 d-flex justify-content-between small">
                <span>@(_activeViewId != null ? _views.FirstOrDefault(v => v.RecordId == _activeViewId)?.Name ?? "View" : "All Backlog")</span>
                <span class="text-muted">@_filtered.Count items</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0 small">
                    <thead class="table-light"><tr><th>Number</th><th>Title</th><th>Type</th><th>Priority</th><th>Pts</th><th>Assigned</th></tr></thead>
                    <tbody>
                        @foreach (var t in _filtered) {
                            <tr>
                                <td><code>@t.TicketNumber</code></td><td>@t.Title</td>
                                <td><span class="badge bg-info bg-opacity-25 text-dark">@t.Type</span></td>
                                <td><span class="badge @GetPriorityBadge(t.Priority)">@t.Priority</span></td>
                                <td class="text-center">@(t.StoryPoints?.ToString() ?? "—")</td>
                                <td class="text-muted">@(t.AssignedTo ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _showCreate = false;
    private string _pageName = "backlogv4";
    private List<DataObjects.Ticket> _backlog = new(), _filtered = new();
    private List<DataObjects.SavedView> _views = new();
    private Guid? _activeViewId;
    private string _newName = "", _newType = "", _newPriority = "", _newAssign = "", _newGroup = "";

    private string _descNavTabs = "Saved views are stored as data objects with Name and FilterJson. The nav-tabs are generated by @foreach over _views. Each tab gets an active class when _activeViewId matches. A '+' tab toggles the create form. Delete uses @onclick:stopPropagation so clicking the X doesn't also select the tab.";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var t = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/GetTickets", new List<Guid>()) ?? new();
            _backlog = t.Where(x => x.SprintId == null || x.SprintId == Guid.Empty).OrderBy(x => x.SortOrder).ToList();
            _views = await Helpers.GetOrPost<List<DataObjects.SavedView>>("api/Data/GetSavedViews", new List<Guid>()) ?? new();
            _filtered = _backlog; _loading = false; StateHasChanged();
        }
    }

    private void ApplyFilter() { _filtered = _backlog; _activeViewId = null; }

    private void ApplyView(DataObjects.SavedView v) {
        _activeViewId = v.RecordId;
        _filtered = _backlog;
        if (!string.IsNullOrEmpty(v.FilterJson)) {
            var parts = v.FilterJson.Split('|');
            if (parts.Length >= 1 && Enum.TryParse<DataObjects.TicketType>(parts[0], out var ft)) _filtered = _filtered.Where(t => t.Type == ft).ToList();
            if (parts.Length >= 2 && Enum.TryParse<DataObjects.TicketPriority>(parts[1], out var fp)) _filtered = _filtered.Where(t => t.Priority == fp).ToList();
            if (parts.Length >= 3 && !string.IsNullOrEmpty(parts[2])) {
                var a = parts[2];
                _filtered = a == "unassigned" ? _filtered.Where(t => string.IsNullOrEmpty(t.AssignedTo)).ToList() : _filtered.Where(t => (t.AssignedTo ?? "").Contains(a, StringComparison.OrdinalIgnoreCase)).ToList();
            }
        }
    }

    private async Task SaveView() {
        if (string.IsNullOrWhiteSpace(_newName)) return;
        var v = new DataObjects.SavedView { Name = _newName, FilterJson = $"{_newType}|{_newPriority}|{_newAssign}", GroupByField = string.IsNullOrEmpty(_newGroup) ? null : _newGroup, CreatedBy = "Current User" };
        var result = await Helpers.GetOrPost<List<DataObjects.SavedView>>("api/Data/SaveSavedViews", new List<DataObjects.SavedView> { v });
        if (result?.Any() == true) _views.Add(result.First());
        _newName = ""; _newType = ""; _newPriority = ""; _newAssign = ""; _newGroup = ""; _showCreate = false; StateHasChanged();
    }

    private async Task DeleteView(DataObjects.SavedView v) {
        await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/DeleteSavedViews", new List<Guid> { v.RecordId });
        _views.Remove(v); if (_activeViewId == v.RecordId) { _activeViewId = null; _filtered = _backlog; } StateHasChanged();
    }

    private static string GetPriorityBadge(DataObjects.TicketPriority p) => p switch { DataObjects.TicketPriority.Critical => "bg-danger", DataObjects.TicketPriority.High => "bg-warning text-dark", DataObjects.TicketPriority.Medium => "bg-info", _ => "bg-secondary" };

    private string _codeNavTabs = @"<ul class=""nav nav-tabs mb-3"">
  <li class=""nav-item"">
    <button class=""nav-link
      @(_activeViewId == null ? ""active"" : """")"">
      All
    </button>
  </li>
  @foreach (var v in _views) {
    <li class=""nav-item"">
      <button class=""nav-link""
              @onclick=""() => ApplyView(v)"">
        @v.Name
        <i class=""fa-solid fa-times""
           @onclick=""() => DeleteView(v)""
           @onclick:stopPropagation=""true""/>
      </button>
    </li>
  }
  <li>
    <button @onclick=""() => _showCreate = !_showCreate"">
      <i class=""fa-solid fa-plus""/>
    </button>
  </li>
</ul>";

    private string _codeFilterParse = @"void ApplyView(SavedView v) {
  _activeViewId = v.RecordId;
  _filtered = _backlog;  // start from all
  var parts = v.FilterJson.Split('|');
  // parts[0] = type, parts[1] = priority,
  // parts[2] = assignee
  if (Enum.TryParse(parts[0], out TicketType ft))
    _filtered = _filtered
      .Where(t => t.Type == ft).ToList();
  if (Enum.TryParse(parts[1], out TicketPriority fp))
    _filtered = _filtered
      .Where(t => t.Priority == fp).ToList();
  if (!string.IsNullOrEmpty(parts[2]))
    _filtered = _filtered
      .Where(t => t.AssignedTo?.Contains(parts[2])
        == true).ToList();
}";

    private string _codeSaveDelete = @"// SaveMany pattern — post a list
async Task SaveView() {
  var v = new SavedView {
    Name = _newName,
    FilterJson = $""{_newType}|{_newPriority}|{_newAssign}""
  };
  var result = await SaveSavedViews(new[] { v });
  _views.Add(result.First());
}

// DeleteMany pattern — post a list of IDs
async Task DeleteView(SavedView v) {
  await DeleteSavedViews(new[] { v.RecordId });
  _views.Remove(v);
}";
}
