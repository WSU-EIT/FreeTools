@page "/Examples/FileDemoV6"
@page "/{TenantCode}/Examples/FileDemoV6"
@implements IDisposable
@inject BlazorDataModel Model

@* V6: File Type Policy Manager — manage an allow/block list of file types and see the upload component react to changes *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-shield-halved me-1"></i> Upload Policy</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-shield-halved me-1"></i> V6: File Type Policy Manager <StickyMenuIcon /></h1>
        </div>
        <AboutSection Title="File Upload in Context: Upload Policy" Subtitle="Manage which file types are allowed or blocked, then see the upload component reflect the changes instantly" IconClass="fa-solid fa-shield-halved">
            <p class="small text-muted mb-0">An admin settings page where you configure which file types users are allowed to upload. Add or remove extensions from the approved list, toggle between allow/block mode, and click "Apply Policy" to force the upload component to re-render with the new rules. This demonstrates the Blazor equivalent of Knockout's <code>if: true → if: false</code> trick — changing a component's <code>@@key</code> forces Blazor to destroy and recreate it.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Force Re-render with Component Key"
                     Description="In Knockout you'd flip an if: binding to force a re-render. In Blazor, you set a key directive on a component. When the key value changes, Blazor destroys the old instance and creates a fresh one. This is the idiomatic way to force a component to reset without toggling visibility."
                     Code="@_codeKey" />
            <InfoTip Title="Observable List Pattern"
                     Description="The file type list is a regular List<FileTypeRule>. When you add, remove, or toggle items, you call StateHasChanged() — Blazor's equivalent of Knockout's observable notification. The UI re-renders automatically. No manual DOM manipulation needed."
                     Code="@_codeObservable" />
            <InfoTip Title="Apply Policy Button"
                     Description="Clicking Apply Policy increments _uploadKey, which changes the key directive on the UploadFile component. Blazor sees a new key and recreates the component from scratch with the updated SupportedFileTypes list. This is useful when a child component caches its parameters internally."
                     Code="@_codeApply" />
        </div>

        <div class="row">
            @* Left column: File Type Policy Editor *@
            <div class="col-lg-5 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <span class="fw-semibold small"><i class="fa-solid fa-list-check me-1"></i> File Type Policy</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" id="policyModeSwitch" @bind="_allowListMode" />
                            <label class="form-check-label small" for="policyModeSwitch">
                                @(_allowListMode ? "Allow List (only these)" : "Block List (everything except these)")
                            </label>
                        </div>
                    </div>
                    <div class="card-body">
                        @* Add new file type *@
                        <div class="input-group input-group-sm mb-3">
                            <span class="input-group-text"><i class="fa-solid fa-plus"></i></span>
                            <input type="text" class="form-control" placeholder="e.g. .pdf, .docx, .png" @bind="_newExtension" @onkeydown="OnAddKeyDown" />
                            <button class="btn btn-outline-primary" @onclick="AddFileType" disabled="@string.IsNullOrWhiteSpace(_newExtension)">Add</button>
                        </div>

                        @* Quick-add presets *@
                        <div class="mb-3">
                            <span class="small text-muted me-1">Quick add:</span>
                            <button class="btn btn-xs btn-outline-secondary me-1 mb-1" @onclick='() => QuickAdd("Documents", ".pdf", ".docx", ".xlsx", ".pptx", ".txt")'>📄 Documents</button>
                            <button class="btn btn-xs btn-outline-secondary me-1 mb-1" @onclick='() => QuickAdd("Images", ".jpg", ".png", ".gif", ".svg", ".webp")'>🖼️ Images</button>
                            <button class="btn btn-xs btn-outline-secondary me-1 mb-1" @onclick='() => QuickAdd("Data", ".csv", ".json", ".xml", ".yaml")'>📊 Data</button>
                            <button class="btn btn-xs btn-outline-secondary me-1 mb-1" @onclick='() => QuickAdd("Code", ".cs", ".js", ".ts", ".html", ".css")'>💻 Code</button>
                            <button class="btn btn-xs btn-outline-danger mb-1" @onclick="ClearAll">🗑️ Clear All</button>
                        </div>

                        @* File type list *@
                        @if (_fileTypes.Count == 0) {
                            <div class="text-center py-3 text-muted small">
                                <i class="fa-solid fa-inbox fa-2x mb-2 d-block"></i>
                                No file types configured. Add extensions above.
                            </div>
                        } else {
                            <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                                @foreach (var ft in _fileTypes.OrderBy(f => f.Extension)) {
                                    var item = ft;
                                    <div class="list-group-item d-flex align-items-center py-1 px-2">
                                        <div class="form-check form-switch me-2 mb-0">
                                            <input class="form-check-input" type="checkbox" checked="@item.Enabled"
                                                   @onchange="@(e => ToggleFileType(item))" />
                                        </div>
                                        <span class="badge @(item.Enabled ? "bg-success" : "bg-secondary") me-2" style="min-width: 60px;">
                                            @item.Extension.ToUpper()
                                        </span>
                                        <span class="small flex-grow-1 @(!item.Enabled ? "text-decoration-line-through text-muted" : "")">
                                            @item.Description
                                        </span>
                                        <button class="btn btn-xs btn-outline-danger ms-1" @onclick="@(() => RemoveFileType(item))">
                                            <i class="fa-solid fa-times"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-white d-flex justify-content-between align-items-center">
                        <span class="small text-muted">
                            @_fileTypes.Count(f => f.Enabled) of @_fileTypes.Count enabled
                        </span>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ResetToDefaults">
                                <i class="fa-solid fa-rotate-left me-1"></i> Reset
                            </button>
                            <button class="btn btn-sm btn-primary" @onclick="ApplyPolicy">
                                <i class="fa-solid fa-check me-1"></i> Apply Policy
                                @if (_pendingChanges) {
                                    <span class="badge bg-warning text-dark ms-1">!</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>

                @* Applied policy display *@
                <div class="card shadow-sm border-0 mt-3">
                    <div class="card-header bg-white">
                        <span class="fw-semibold small"><i class="fa-solid fa-eye me-1"></i> Currently Applied Policy</span>
                    </div>
                    <div class="card-body py-2">
                        @if (_appliedTypes.Count == 0) {
                            <span class="small text-muted">No policy applied — all file types accepted.</span>
                        } else {
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var ext in _appliedTypes) {
                                    <span class="badge bg-primary">@ext.ToUpper()</span>
                                }
                            </div>
                            <div class="small text-muted mt-1">
                                Mode: <strong>@(_allowListMode ? "Allow List" : "Block List")</strong>
                                · Refreshes: <strong>@_applyCount</strong>
                                · Upload key: <strong>@_uploadKey</strong>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Right column: Upload component + uploaded files *@
            <div class="col-lg-7 mb-3">
                @* Upload zone — keyed so it re-creates when policy changes *@
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <span class="fw-semibold small"><i class="fa-solid fa-cloud-arrow-up me-1"></i> Upload Files</span>
                        <span class="badge bg-info">key=@_uploadKey</span>
                    </div>
                    <div class="card-body">
                        @if (_appliedTypes.Count > 0) {
                            <UploadFile @key="_uploadKey"
                                UploadType="Microsoft.AspNetCore.Components.Forms.IBrowserFile"
                                AllowMultipleUploads="true"
                                SupportedFileTypes="@_appliedTypes"
                                OnUploadComplete="@((List<DataObjects.FileStorage> files) => OnFilesUploaded(files))" />
                        } else {
                            <div class="text-center py-4 text-muted">
                                <i class="fa-solid fa-ban fa-2x mb-2 d-block"></i>
                                <span class="small">No file types are enabled. Configure the policy on the left and click "Apply Policy".</span>
                            </div>
                        }
                    </div>
                </div>

                @* Upload log *@
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <span class="fw-semibold small"><i class="fa-solid fa-list me-1"></i> Upload Log (@_uploadedFiles.Count)</span>
                        @if (_uploadedFiles.Count > 0) {
                            <button class="btn btn-xs btn-outline-danger" @onclick="ClearUploads">Clear</button>
                        }
                    </div>
                    <div class="card-body p-0">
                        @if (_uploadedFiles.Count == 0) {
                            <div class="text-center py-3 text-muted small">No files uploaded yet.</div>
                        } else {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="small">File</th>
                                        <th class="small">Type</th>
                                        <th class="small text-end">Size</th>
                                        <th class="small">Status</th>
                                        <th class="small"><span class="visually-hidden">Actions</span></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var file in _uploadedFiles) {
                                        var ext = file.Extension?.TrimStart('.').ToUpper() ?? "?";
                                        var allowed = _appliedTypes.Any(t => t.Equals(file.Extension, StringComparison.OrdinalIgnoreCase));
                                        <tr>
                                            <td class="small">@file.FileName</td>
                                            <td><span class="badge bg-secondary">@ext</span></td>
                                            <td class="small text-end">@FormatBytes(file.Bytes ?? 0)</td>
                                            <td>
                                                @if (allowed) {
                                                    <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i>Allowed</span>
                                                } else {
                                                    <span class="badge bg-danger"><i class="fa-solid fa-ban me-1"></i>Blocked</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-xs btn-outline-danger" @onclick="@(() => _uploadedFiles.Remove(file))">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "filedemov6";
    private string _newExtension = "";
    private bool _allowListMode = true;
    private bool _pendingChanges = false;
    private int _uploadKey = 1;
    private int _applyCount = 0;

    // InfoTip code snippets
    private string _codeKey = "@* Changing @key forces Blazor to destroy + recreate the component *@\n<UploadFile @key=\"_uploadKey\"\n    SupportedFileTypes=\"@_appliedTypes\" />\n\nvoid ApplyPolicy() {\n    _uploadKey++;  // new key = fresh component\n}";
    private string _codeObservable = "// In Knockout: ko.observableArray()\n// In Blazor: just a List<T> + StateHasChanged()\nList<FileTypeRule> _fileTypes = new();\n\nvoid AddFileType(string ext) {\n    _fileTypes.Add(new(ext, true));\n    StateHasChanged();  // tells Blazor to re-render\n}";
    private string _codeApply = "void ApplyPolicy() {\n    // Build the new allowed list\n    _appliedTypes = _fileTypes\n        .Where(f => f.Enabled)\n        .Select(f => f.Extension)\n        .ToList();\n\n    // Increment key to force UploadFile to re-create\n    _uploadKey++;\n    _pendingChanges = false;\n}";

    // The editable list of file type rules
    private List<FileTypeRule> _fileTypes = [];

    // The currently applied list (what the UploadFile component is using)
    private List<string> _appliedTypes = [];

    // Uploaded files log
    private List<DataObjects.FileStorage> _uploadedFiles = [];

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() {
        Model.View = _pageName;
        Model.OnChange += StateHasChanged;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName);
        ResetToDefaults();
        ApplyPolicy();
    }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); }
        await Task.CompletedTask;
    }

    private void AddFileType() {
        if (string.IsNullOrWhiteSpace(_newExtension)) return;

        // Support comma-separated input like ".pdf, .docx"
        var parts = _newExtension.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var part in parts) {
            var ext = part.StartsWith('.') ? part.ToLowerInvariant() : $".{part.ToLowerInvariant()}";
            if (!_fileTypes.Any(f => f.Extension.Equals(ext, StringComparison.OrdinalIgnoreCase))) {
                _fileTypes.Add(new FileTypeRule(ext, GetDescription(ext), true));
                _pendingChanges = true;
            }
        }
        _newExtension = "";
    }

    private void OnAddKeyDown(KeyboardEventArgs e) {
        if (e.Key == "Enter") AddFileType();
    }

    private void QuickAdd(string category, params string[] extensions) {
        foreach (var ext in extensions) {
            if (!_fileTypes.Any(f => f.Extension.Equals(ext, StringComparison.OrdinalIgnoreCase))) {
                _fileTypes.Add(new FileTypeRule(ext, GetDescription(ext), true));
            }
        }
        _pendingChanges = true;
    }

    private void RemoveFileType(FileTypeRule item) {
        _fileTypes.Remove(item);
        _pendingChanges = true;
    }

    private void ToggleFileType(FileTypeRule item) {
        item.Enabled = !item.Enabled;
        _pendingChanges = true;
    }

    private void ClearAll() {
        _fileTypes.Clear();
        _pendingChanges = true;
    }

    private void ResetToDefaults() {
        _fileTypes = [
            new(".txt",  "Plain text file", true),
            new(".csv",  "Comma-separated values", true),
            new(".json", "JSON data file", true),
            new(".xml",  "XML document", true),
            new(".pdf",  "PDF document", false),
            new(".docx", "Word document", false),
            new(".xlsx", "Excel spreadsheet", false),
            new(".png",  "PNG image", false),
            new(".jpg",  "JPEG image", false),
        ];
        _pendingChanges = true;
    }

    private void ApplyPolicy() {
        // Build the new applied list from enabled rules
        _appliedTypes = _fileTypes
            .Where(f => f.Enabled)
            .Select(f => f.Extension)
            .ToList();

        // Increment the key — this forces Blazor to destroy and recreate the UploadFile component
        // This is the Blazor equivalent of Knockout's if:true → if:false trick
        _uploadKey++;
        _applyCount++;
        _pendingChanges = false;

        Model.AddMessage($"Policy applied: {_appliedTypes.Count} file type(s) enabled. Upload component refreshed (key={_uploadKey}).", MessageType.Success);
    }

    private void OnFilesUploaded(List<DataObjects.FileStorage> files) {
        _uploadedFiles.AddRange(files);
        Model.AddMessage($"Uploaded {files.Count} file(s).", MessageType.Success);
        StateHasChanged();
    }

    private void ClearUploads() {
        _uploadedFiles.Clear();
    }

    private static string FormatBytes(long bytes) {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private static string GetDescription(string ext) => ext.ToLowerInvariant() switch {
        ".txt"  => "Plain text file",
        ".csv"  => "Comma-separated values",
        ".json" => "JSON data file",
        ".xml"  => "XML document",
        ".pdf"  => "PDF document",
        ".docx" => "Word document",
        ".doc"  => "Word document (legacy)",
        ".xlsx" => "Excel spreadsheet",
        ".xls"  => "Excel spreadsheet (legacy)",
        ".pptx" => "PowerPoint presentation",
        ".png"  => "PNG image",
        ".jpg"  => "JPEG image",
        ".jpeg" => "JPEG image",
        ".gif"  => "GIF image",
        ".svg"  => "SVG vector image",
        ".webp" => "WebP image",
        ".zip"  => "ZIP archive",
        ".html" => "HTML document",
        ".css"  => "CSS stylesheet",
        ".js"   => "JavaScript file",
        ".ts"   => "TypeScript file",
        ".cs"   => "C# source file",
        ".yaml" => "YAML config file",
        ".md"   => "Markdown document",
        ".log"  => "Log file",
        ".har"  => "HTTP archive",
        _       => $"{ext.TrimStart('.').ToUpper()} file"
    };

    private class FileTypeRule(string extension, string description, bool enabled) {
        public string Extension { get; set; } = extension;
        public string Description { get; set; } = description;
        public bool Enabled { get; set; } = enabled;
    }
}
