@page "/Examples/GitBrowser"
@page "/{TenantCode}/Examples/GitBrowser"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-code-branch me-1"></i> Git Repository Browser</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-code-branch me-1"></i> Git Repository Browser
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="About Git Browser" Subtitle="Browse the files inside any public code repository from your browser" IconClass="fa-solid fa-code-branch">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        <strong>Git</strong> is a version control system — it tracks every change ever made to a
                        set of files (like a time machine for code). A <strong>repository</strong> ("repo") is a
                        folder of files managed by Git. This page lets you paste a public repo URL, and the server
                        downloads ("clones") the repo so you can browse its folders and view files with
                        syntax highlighting — all without installing anything.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Repository cloning</strong> — downloading a repo's files to the server</li>
                        <li><strong>Directory browsing</strong> — clicking folders to navigate, just like File Explorer</li>
                        <li><strong>Breadcrumb navigation</strong> — a clickable path trail showing where you are</li>
                        <li><strong>File viewing</strong> — reading source code with syntax-colored highlighting</li>
                        <li><strong>Binary detection</strong> — knowing when a file is an image or program (not readable as text)</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        When you click Clone, the server uses <strong>LibGit2Sharp</strong> (a C# Git library)
                        to download the repo into a temporary folder. It then builds a list of files and folders.
                        When you click a folder, it sends that path to the server and gets the contents back.
                        When you click a file, it reads the file content and shows it in the Monaco code editor
                        with the right language coloring based on the file extension (.cs = C#, .js = JavaScript, etc.).
                    </p>
                </div>
            </div>
        </AboutSection>

        @* Repo URL input *@
        <div class="mb-3">
            <label for="git-repo-url" class="form-label fw-semibold">Repository URL
                <InfoTip Title="Repository URL Input"
                         Description="Paste the URL of any public Git repository here (e.g., from GitHub). When you click Browse, the server downloads just the latest snapshot (depth=1, no history) into memory, reads all files, then deletes the temp clone. Everything is served from memory after that."
                         Code="@_codeRepoUrl" />
            </label>
            <div class="input-group" style="max-width: 600px;">
                <span class="input-group-text bg-white" aria-hidden="true"><i class="fa fa-code-branch text-muted"></i></span>
                <input type="text" id="git-repo-url" class="form-control"
                       @bind="_repoUrl"
                       placeholder="https://github.com/user/repo"
                       aria-label="Git repository URL" />
                <button class="btn btn-primary" @onclick="CloneAndBrowse" disabled="@_loadingEntries"
                        aria-label="Clone and browse repository">
                    @if (_loadingEntries) {
                        <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                        <span>Cloning...</span>
                    } else {
                        <i class="fa fa-download me-1" aria-hidden="true"></i>
                        <span>Browse</span>
                    }
                </button>
            </div>
            @if (_loadingEntries && _progressMessages.Count > 0) {
                <div class="mt-2 p-2 bg-dark text-light rounded small font-monospace" style="max-height: 160px; overflow-y: auto;">
                    @foreach (var msg in _progressMessages) {
                        <div>@msg</div>
                    }
                </div>
            }
        </div>

        @if (_cloned) {
            @* Breadcrumb navigation *@
            <nav aria-label="Repository path" class="mb-3">
                <InfoTip Title="Breadcrumb Navigation"
                         Description="This clickable path trail shows where you are in the repository folder tree. Each segment is a folder name — click any segment to jump back to that folder. Root takes you to the top level. The breadcrumb is built by splitting the current path on / and creating a link for each segment."
                         Code="@_codeBreadcrumb" />
                <ol class="breadcrumb mb-0 bg-light rounded-3 p-2 px-3 shadow-sm">
                    <li class="breadcrumb-item @(string.IsNullOrEmpty(_currentPath) ? "active" : "")">
                        @if (string.IsNullOrEmpty(_currentPath)) {
                            <span><i class="fa fa-home me-1" aria-hidden="true"></i> root</span>
                        } else {
                            <a href="javascript:void(0)" @onclick="@(() => NavigateTo(""))" class="text-decoration-none">
                                <i class="fa fa-home me-1" aria-hidden="true"></i> root
                            </a>
                        }
                    </li>
                    @{ var segments = GetPathSegments(); }
                    @for (int i = 0; i < segments.Count; i++) {
                        var seg = segments[i];
                        var isLast = i == segments.Count - 1;
                        <li class="breadcrumb-item @(isLast ? "active" : "")">
                            @if (isLast) {
                                <span>@seg.Name</span>
                            } else {
                                <a href="javascript:void(0)" @onclick="@(() => NavigateTo(seg.FullPath))" class="text-decoration-none">
                                    @seg.Name
                                </a>
                            }
                        </li>
                    }
                </ol>
            </nav>

            @if (_viewingFile != null) {
                @* File viewer with Monaco editor *@
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="@GetFileIcon(_viewingFile.Extension)" aria-hidden="true"></i>
                            <span class="fw-semibold">@_viewingFile.Name</span>
                            <span class="badge bg-secondary">@FormatBytes(_viewingFile.Size)</span>
                            <InfoTip Title="File Viewer"
                                     Description="When you click a file, its contents load into a read-only Monaco editor with syntax highlighting. The editor language is auto-detected from the file extension — .cs files get C# coloring, .js gets JavaScript, etc. Binary files (images, compiled programs) show a placeholder message instead."
                                     Code="@_codeFileViewer" />
                        </div>
                        <button class="btn btn-outline-light btn-sm" @onclick="CloseFile" aria-label="Close file viewer">
                            <i class="fa fa-times me-1" aria-hidden="true"></i> Close
                        </button>
                    </div>
                    <div class="card-body p-0">
                        @if (_viewingFile.IsBinary) {
                            <div class="text-center py-5 text-muted">
                                <i class="fa fa-file fa-3x mb-3" aria-hidden="true"></i>
                                <div>@_viewingFile.Content</div>
                            </div>
                        } else {
                            <MonacoEditor @ref="_editor"
                                Language="@_monacoLanguage"
                                Value="@_viewingFile.Content"
                                ReadOnly="true"
                                MinHeight="500px" />
                        }
                    </div>
                </div>
            } else if (_loadingEntries) {
                <LoadingMessage />
            } else {
                @* Directory listing *@
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-dark text-white py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>
                                <i class="fa fa-folder-open me-1" aria-hidden="true"></i>
                                @(string.IsNullOrEmpty(_currentPath) ? "/" : "/" + _currentPath)
                                <InfoTip Title="Directory Listing"
                                         Description="This list shows the folders and files in the current directory — folders first (with folder icons), then files (with type-specific icons). Click a folder to navigate into it; click a file to view its contents. The .. entry at the top takes you up one directory level."
                                         Code="@_codeDirList" />
                            </span>
                            <span class="badge bg-secondary">@_entries.Count items</span>
                        </div>
                    </div>
                    <div class="list-group list-group-flush">
                        @if (!string.IsNullOrEmpty(_currentPath)) {
                            <button class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2"
                                    @onclick="NavigateUp" aria-label="Go up one directory">
                                <i class="fa fa-level-up text-muted" aria-hidden="true"></i>
                                <span class="text-muted">..</span>
                            </button>
                        }
                        @if (_entries.Count == 0) {
                            <div class="list-group-item text-center text-muted py-4">
                                <i class="fa fa-inbox fa-2x mb-2" aria-hidden="true"></i>
                                <div>Empty directory</div>
                            </div>
                        }
                        @foreach (var entry in _entries) {
                            <button class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2"
                                    @onclick="@(() => OnEntryClicked(entry))"
                                    aria-label="@(entry.IsDirectory ? "Open folder" : "View file") @entry.Name">
                                @if (entry.IsDirectory) {
                                    <i class="fa fa-folder text-warning" aria-hidden="true"></i>
                                } else {
                                    <i class="@GetFileIcon(entry.Extension)" aria-hidden="true"></i>
                                }
                                <span class="flex-grow-1 @(entry.IsDirectory ? "fw-semibold" : "")">@entry.Name</span>
                                @if (!entry.IsDirectory) {
                                    <span class="text-muted small">@FormatBytes(entry.Size)</span>
                                }
                                @if (entry.IsDirectory) {
                                    <i class="fa fa-chevron-right text-muted small" aria-hidden="true"></i>
                                }
                            </button>
                        }
                    </div>
                </div>
            }
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "gitbrowser";
    private string _codeRepoUrl = "git clone --depth 1 --single-branch --no-tags <url>";
    private string _codeBreadcrumb = "<nav aria-label=\"Repository path\">\n    <ol class=\"breadcrumb\">...</ol>\n</nav>";
    private string _codeDirList = "@foreach (var entry in _entries) {\n    <button @onclick=\"OnEntryClicked(entry)\">\n}";
    private string _codeFileViewer = "<MonacoEditor Language=\"@_monacoLanguage\"\n    Value=\"@_viewingFile.Content\"\n    ReadOnly=\"true\" />";

    private string _repoUrl = "https://github.com/WSU-EIT/FreeTools";
    private bool _cloned = false;
    private bool _loadingEntries = false;
    private string _currentPath = "";
    private List<DataObjects.GitRepoEntry> _entries = new();
    private DataObjects.GitFileContent? _viewingFile = null;
    private string _monacoLanguage = MonacoEditor.MonacoLanguage.plaintext;
    private MonacoEditor? _editor;
    private List<string> _progressMessages = new();

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.OnSignalRUpdate -= OnSignalRUpdate;
        Model.Subscribers_OnChange.Remove(_pageName);
        Model.Subscribers_OnSignalRUpdate.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        Model.OnSignalRUpdate += OnSignalRUpdate;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
        if (!Model.Subscribers_OnSignalRUpdate.Contains(_pageName)) { Model.Subscribers_OnSignalRUpdate.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            _loading = false;
            StateHasChanged();

            // Auto-clone the default repo on first load
            await CloneAndBrowse();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    private void OnSignalRUpdate(DataObjects.SignalRUpdate update)
    {
        if (update.UpdateType == DataObjects.SignalRUpdateType.GitCloneProgress && !string.IsNullOrWhiteSpace(update.Message)) {
            _progressMessages.Add(update.Message);
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task CloneAndBrowse()
    {
        if (string.IsNullOrWhiteSpace(_repoUrl)) return;

        _loadingEntries = true;
        _cloned = false;
        _viewingFile = null;
        _currentPath = "";
        _entries.Clear();
        _progressMessages.Clear();
        _progressMessages.Add("Requesting clone...");
        StateHasChanged();

        var result = await Helpers.GetOrPost<List<DataObjects.GitRepoEntry>>(
            "api/Data/GetGitRepoContents",
            new DataObjects.GitBrowseRequest { RepoUrl = _repoUrl, Path = "" });

        if (result != null) {
            _entries = result;
            _cloned = true;
            _progressMessages.Add($"Done — {result.Count} items loaded.");
        } else {
            _progressMessages.Add("Failed to clone repository.");
            Model.AddMessage("Failed to clone repository. Ensure the URL is a valid public git repo.", MessageType.Danger);
        }

        _loadingEntries = false;
        StateHasChanged();
    }

    private async Task NavigateTo(string path)
    {
        _viewingFile = null;
        _currentPath = path;
        _loadingEntries = true;
        StateHasChanged();

        var result = await Helpers.GetOrPost<List<DataObjects.GitRepoEntry>>(
            "api/Data/GetGitRepoContents",
            new DataObjects.GitBrowseRequest { RepoUrl = _repoUrl, Path = path });

        _entries = result ?? new();
        _loadingEntries = false;
        StateHasChanged();
    }

    private async Task NavigateUp()
    {
        if (string.IsNullOrEmpty(_currentPath)) return;
        var lastSlash = _currentPath.LastIndexOf('/');
        var parentPath = lastSlash > 0 ? _currentPath[..lastSlash] : "";
        await NavigateTo(parentPath);
    }

    private async Task OnEntryClicked(DataObjects.GitRepoEntry entry)
    {
        if (entry.IsDirectory) {
            await NavigateTo(entry.Path);
        } else {
            await ViewFile(entry.Path);
        }
    }

    private async Task ViewFile(string filePath)
    {
        _loadingEntries = true;
        StateHasChanged();

        var result = await Helpers.GetOrPost<DataObjects.GitFileContent>(
            "api/Data/GetGitFileContent",
            new DataObjects.GitFileRequest { RepoUrl = _repoUrl, FilePath = filePath });

        if (result != null) {
            _viewingFile = result;
            _monacoLanguage = GetMonacoLanguage(result.Extension);
            // Update breadcrumb path to show file location
            var lastSlash = filePath.LastIndexOf('/');
            _currentPath = lastSlash > 0 ? filePath[..lastSlash] : "";
            // Append the file name to the path for breadcrumb display
            _currentPath = filePath;
        }

        _loadingEntries = false;
        StateHasChanged();
    }

    private void CloseFile()
    {
        _viewingFile = null;
        // Navigate back to the parent directory
        var lastSlash = _currentPath.LastIndexOf('/');
        _currentPath = lastSlash > 0 ? _currentPath[..lastSlash] : "";
        StateHasChanged();
        // Re-fetch the directory listing
        _ = NavigateTo(_currentPath);
    }

    private List<PathSegment> GetPathSegments()
    {
        if (string.IsNullOrEmpty(_currentPath)) return new();

        var parts = _currentPath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        var segments = new List<PathSegment>();
        for (int i = 0; i < parts.Length; i++) {
            segments.Add(new PathSegment {
                Name = parts[i],
                FullPath = string.Join("/", parts.Take(i + 1))
            });
        }
        return segments;
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1024 * 1024) return $"{bytes / (1024.0 * 1024.0):F1} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes} B";
    }

    private static string GetFileIcon(string ext) => ext.ToLowerInvariant() switch {
        ".cs" => "fa fa-file-code text-success",
        ".razor" => "fa fa-file-code text-primary",
        ".js" => "fa fa-file-code text-warning",
        ".ts" => "fa fa-file-code text-info",
        ".css" or ".scss" => "fa fa-file-code text-info",
        ".html" or ".htm" => "fa fa-file-code text-danger",
        ".json" => "fa fa-file-code text-secondary",
        ".xml" or ".csproj" or ".sln" => "fa fa-file-code text-muted",
        ".md" => "fa fa-file-text text-primary",
        ".yml" or ".yaml" => "fa fa-file-code text-info",
        ".png" or ".jpg" or ".jpeg" or ".gif" or ".svg" or ".ico" => "fa fa-file-image text-success",
        ".pdf" => "fa fa-file-pdf text-danger",
        ".zip" or ".tar" or ".gz" => "fa fa-file-archive text-warning",
        _ => "fa fa-file text-muted"
    };

    private static string GetMonacoLanguage(string ext) => ext.ToLowerInvariant() switch {
        ".cs" => MonacoEditor.MonacoLanguage.csharp,
        ".razor" => MonacoEditor.MonacoLanguage.razor,
        ".js" => MonacoEditor.MonacoLanguage.javascript,
        ".ts" => MonacoEditor.MonacoLanguage.typescript,
        ".css" => MonacoEditor.MonacoLanguage.css,
        ".scss" => MonacoEditor.MonacoLanguage.scss,
        ".html" or ".htm" => MonacoEditor.MonacoLanguage.html,
        ".json" => MonacoEditor.MonacoLanguage.json,
        ".xml" or ".csproj" or ".props" or ".targets" => MonacoEditor.MonacoLanguage.xml,
        ".md" => MonacoEditor.MonacoLanguage.markdown,
        ".yml" or ".yaml" => MonacoEditor.MonacoLanguage.yaml,
        ".sql" => MonacoEditor.MonacoLanguage.sql,
        ".py" => MonacoEditor.MonacoLanguage.python,
        ".java" => MonacoEditor.MonacoLanguage.java,
        ".go" => MonacoEditor.MonacoLanguage.go,
        ".rs" => MonacoEditor.MonacoLanguage.rust,
        ".rb" => MonacoEditor.MonacoLanguage.ruby,
        ".php" => MonacoEditor.MonacoLanguage.php,
        ".sh" or ".bash" => MonacoEditor.MonacoLanguage.shell,
        ".ps1" => MonacoEditor.MonacoLanguage.powershell,
        ".dockerfile" => MonacoEditor.MonacoLanguage.dockerfile,
        ".bat" or ".cmd" => MonacoEditor.MonacoLanguage.bat,
        ".ini" or ".cfg" => MonacoEditor.MonacoLanguage.ini,
        ".swift" => MonacoEditor.MonacoLanguage.swift,
        ".kt" => MonacoEditor.MonacoLanguage.kotlin,
        ".r" => MonacoEditor.MonacoLanguage.r,
        ".lua" => MonacoEditor.MonacoLanguage.lua,
        ".pl" or ".pm" => MonacoEditor.MonacoLanguage.perl,
        ".vb" => MonacoEditor.MonacoLanguage.vb,
        ".fs" or ".fsx" => MonacoEditor.MonacoLanguage.fsharp,
        ".cpp" or ".cc" or ".cxx" => MonacoEditor.MonacoLanguage.cpp,
        ".c" or ".h" => MonacoEditor.MonacoLanguage.c,
        ".bicep" => MonacoEditor.MonacoLanguage.bicep,
        ".graphql" or ".gql" => MonacoEditor.MonacoLanguage.graphql,
        ".proto" => MonacoEditor.MonacoLanguage.proto,
        ".less" => MonacoEditor.MonacoLanguage.less,
        ".sln" => MonacoEditor.MonacoLanguage.plaintext,
        _ => MonacoEditor.MonacoLanguage.plaintext
    };

    private record PathSegment {
        public string Name { get; set; } = "";
        public string FullPath { get; set; } = "";
    }
}
