@page "/Examples/ApiKeyDemo"
@page "/{TenantCode}/Examples/ApiKeyDemo"
@implements IDisposable
@inject BlazorDataModel Model
@inject IJSRuntime jsRuntime
@inject HttpClient Http

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-key me-1"></i> API Key Middleware</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-key me-1"></i> API Key Middleware Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="About API Key Middleware" Subtitle="Learn how web apps protect their APIs with secret keys" IconClass="fa-solid fa-key">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        An <strong>API</strong> (Application Programming Interface) is a way for programs to talk
                        to each other over the internet. But you don't want just anyone calling your API — you need
                        a <strong>key</strong> (like a password) to prove you're authorized. This page lets you generate
                        keys, test them against a protected endpoint, and watch the request log to see what happens
                        when valid and invalid keys are used.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>API keys</strong> — secret strings that identify who is calling your API</li>
                        <li><strong>SHA-256 hashing</strong> — one-way scrambling so the raw key is never stored on the server</li>
                        <li><strong>Bearer tokens</strong> — sending your key in an HTTP header (<code>Authorization: Bearer your-key</code>)</li>
                        <li><strong>Middleware</strong> — code that runs before every request to check if the key is valid</li>
                        <li><strong>NuGet client</strong> — a reusable C# library for calling the protected API from other apps</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        When you generate a key, the server creates a random string and stores only its <strong>hash</strong>
                        (a scrambled version). When someone calls the API with a key, the <strong>middleware</strong>
                        (a checkpoint between the request and your code) hashes the incoming key and compares it
                        to the stored hash. If they match, the request proceeds. If not, the server returns a
                        401 "Unauthorized" error. The key is shown once and can never be retrieved again.
                    </p>
                </div>
            </div>
        </AboutSection>

        <div class="row">
            @* ============================================================
               LEFT COLUMN: Key Management
               ============================================================ *@
            <div class="col-lg-5 mb-4">
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-header bg-dark text-white py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span><i class="fa fa-key me-1" aria-hidden="true"></i> API Keys</span>
                            <span class="badge bg-secondary">@_keys.Count</span>
                        </div>
                    </div>
                    <div class="card-body">
                        @* Generate new key *@
                        <div class="input-group mb-3">
                            <input type="text" class="form-control" placeholder="Key name (e.g. Mobile App)"
                                   @bind="_newKeyName" @bind:event="oninput"
                                   @onkeydown="@(async (e) => { if (e.Key == "Enter") await GenerateKey(); })"
                                   aria-label="New API key name" />
                            <button class="btn btn-success" @onclick="GenerateKey"
                                    disabled="@string.IsNullOrWhiteSpace(_newKeyName)"
                                    aria-label="Generate new API key">
                                <i class="fa fa-plus me-1" aria-hidden="true"></i> Generate
                            </button>
                            <InfoTip Title="Generate Key"
                                     Description="Clicking Generate creates a cryptographically random 32-byte key. The server stores only the SHA-256 hash (a one-way scramble) — never the raw key. The plaintext key is shown once in the yellow warning box. If you lose it, you must generate a new one. This is how real API keys work (GitHub, Stripe, etc.)."
                                     Code="@_codeGenerate" />
                        </div>

                        @* Plaintext key display (shown once) *@
                        @if (!string.IsNullOrWhiteSpace(_lastGeneratedKey)) {
                            <div class="alert alert-warning d-flex align-items-start" role="alert">
                                <i class="fa fa-exclamation-triangle me-2 mt-1" aria-hidden="true"></i>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold small">Copy this key now — it won't be shown again!
                                        <InfoTip Title="One-Time Key Display"
                                                 Description="This yellow warning box shows the raw API key exactly once. After you navigate away or generate another key, it disappears forever. The Copy button puts the key on your clipboard. This pattern mimics how GitHub Personal Access Tokens work — shown once, stored hashed."
                                                 Code="@_codeOneTime" />
                                    </div>
                                    <code class="d-block my-1 text-break" style="font-size: 0.8em;">@_lastGeneratedKey</code>
                                    <button class="btn btn-sm btn-outline-dark" @onclick="CopyKeyToClipboard"
                                            aria-label="Copy API key to clipboard">
                                        <i class="fa fa-copy me-1" aria-hidden="true"></i> Copy
                                    </button>
                                    <InfoTip Title="Copy to Clipboard"
                                             Description="This button uses the browser's Clipboard API to copy the key to your clipboard. One click — the text is copied without selecting it manually. In code, navigator.clipboard.writeText() is called via JavaScript interop. A success toast confirms the copy."
                                             Code="@_codeCopy" />
                                </div>
                            </div>
                        }

                        @* Key list *@
                        @if (!_keys.Any()) {
                            <div class="text-muted text-center small py-3">
                                <i class="fa fa-key fa-2x mb-2 d-block" aria-hidden="true"></i>
                                No keys yet. Generate one above.
                            </div>
                        }
                        @foreach (var key in _keys) {
                            <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                                <div>
                                    <div class="fw-semibold small">
                                        @key.Name
                                        @if (key.IsActive) {
                                            <span class="badge bg-success ms-1">Active</span>
                                        } else {
                                            <span class="badge bg-danger ms-1">Revoked</span>
                                        }
                                    </div>
                                    <div class="text-muted" style="font-size: 0.75em;">
                                        <code>@key.KeyPrefix</code> · @key.RequestCount requests · @key.CreatedAt.ToString("HH:mm:ss")
                                    </div>
                                </div>
                                @if (key.IsActive) {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="@(() => RevokeKey(key.ApiKeyId))"
                                            aria-label="Revoke @key.Name">
                                        <i class="fa fa-ban" aria-hidden="true"></i>
                                    </button>
                                    <InfoTip Title="Revoke Key"
                                             Description="Revoking a key marks it as inactive in the database. Any future requests using that key will be rejected with a 401 error. The key is not deleted — it stays in the list as Revoked (red badge) for audit purposes. This is safer than deleting because you keep a record of what existed."
                                             Code="@_codeRevoke" />
                                }
                            </div>
                        }
                    </div>
                </div>

                @* How It Works *@
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-dark text-white py-2">
                        <i class="fa fa-info-circle me-1" aria-hidden="true"></i> How It Works
                    </div>
                    <div class="card-body small">
                        <ol class="mb-0 ps-3">
                            <li class="mb-1"><strong>Generate</strong> — creates a random 32-byte key, stores only the <strong>SHA-256 hash</strong>.</li>
                            <li class="mb-1"><strong>Request</strong> — client sends <code>Authorization: Bearer &lt;key&gt;</code> header.</li>
                            <li class="mb-1"><strong>Middleware</strong> — intercepts <code>/api/demo/external/*</code> routes, hashes the provided key, compares to stored hash.</li>
                            <li class="mb-1"><strong>Pass/Fail</strong> — valid key → sets <code>HttpContext.Items["ApiKeyInfo"]</code> and continues. Invalid → returns 401 JSON error.</li>
                            <li class="mb-0"><strong>Controller</strong> — reads the validated identity from <code>HttpContext.Items</code>.</li>
                        </ol>
                    </div>
                </div>
            </div>

            @* ============================================================
               RIGHT COLUMN: Test Console + Request Log
               ============================================================ *@
            <div class="col-lg-7 mb-4">
                @* Test Console *@
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-header bg-dark text-white py-2">
                        <i class="fa fa-terminal me-1" aria-hidden="true"></i> Test Console
                        <InfoTip Title="Test Console"
                                 Description="This panel lets you send real HTTP requests to the protected API endpoint. You choose a method (GET or POST), paste an API key into the Bearer Token field, and click Send. The response shows the status code (200 = success, 401 = unauthorized) and the response body. It is like Postman built into the page."
                                 Code="@_codeTestConsole" />
                    </div>
                    <div class="card-body">
                        <div class="row g-2 mb-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold">Method</label>
                                <select class="form-select form-select-sm" @bind="_testMethod">
                                    <option value="POST">POST /data</option>
                                    <option value="GET">GET /ping</option>
                                </select>
                            </div>
                            <div class="col-md-8">
                                <label class="form-label small fw-semibold">Bearer Token</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text" aria-hidden="true"><i class="fa fa-lock text-muted"></i></span>
                                    <input type="text" class="form-control font-monospace" placeholder="Paste API key here..."
                                           @bind="_testApiKey" aria-label="API key for test request" />
                                </div>
                            </div>
                        </div>

                        @if (_testMethod == "POST") {
                            <div class="mb-3">
                                <label class="form-label small fw-semibold">Request Body</label>
                                <input type="text" class="form-control form-control-sm" placeholder="Test message..."
                                       @bind="_testMessage" aria-label="Test message body" />
                            </div>
                        }

                        <div class="d-flex gap-2 mb-3">
                            <button class="btn btn-primary btn-sm" @onclick="SendTestRequest" disabled="@_sending"
                                    aria-label="Send test request">
                                @if (_sending) {
                                    <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                                } else {
                                    <i class="fa fa-paper-plane me-1" aria-hidden="true"></i>
                                }
                                Send Request
                            </button>
                            <button class="btn btn-outline-warning btn-sm" @onclick="SendWithoutKey"
                                    aria-label="Send request without API key">
                                <i class="fa fa-unlock me-1" aria-hidden="true"></i> Send Without Key
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="SendWithBadKey"
                                    aria-label="Send request with invalid API key">
                                <i class="fa fa-times me-1" aria-hidden="true"></i> Send Bad Key
                            </button>
                            <InfoTip Title="Failure Test Buttons"
                                     Description="These buttons intentionally send invalid requests so you can see what happens. Send Without Key omits the Authorization header entirely — the middleware returns 401. Send Bad Key sends a random string — the hash will not match any stored key, so it also returns 401. This demonstrates the security in action."
                                     Code="@_codeFailBtns" />
                        </div>

                        @* Response display *@
                        @if (_lastResponse != null) {
                            <div class="border rounded p-2 bg-light">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-semibold small">Response</span>
                                    <span class="badge @(_lastStatusCode >= 200 && _lastStatusCode < 300 ? "bg-success" : _lastStatusCode == 401 ? "bg-danger" : "bg-warning text-dark")">
                                        @_lastStatusCode
                                    </span>
                                </div>
                                <pre class="mb-0 small" style="max-height: 200px; overflow: auto; white-space: pre-wrap;">@_lastResponse</pre>
                            </div>
                        }
                    </div>
                </div>

                @* Request Log *@
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-dark text-white py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span><i class="fa fa-list me-1" aria-hidden="true"></i> Request Log
                                <InfoTip Title="Request Log"
                                         Description="Every API request is logged here with timestamp, HTTP method, which key was used, the response status code, and a detail message. Green rows = successful (200). Red rows = unauthorized (401). This audit log is essential for security — in production you would use this to detect suspicious activity."
                                         Code="@_codeRequestLog" />
                            </span>
                            <button class="btn btn-outline-light btn-sm" @onclick="RefreshLogs"
                                    aria-label="Refresh request log">
                                <i class="fa fa-refresh" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0" style="max-height: 350px; overflow: auto;">
                        @if (!_logs.Any()) {
                            <div class="text-muted text-center small py-4">
                                <i class="fa fa-inbox fa-2x mb-2 d-block" aria-hidden="true"></i>
                                No requests yet. Send a test request above.
                            </div>
                        }
                        <table class="table table-sm table-hover mb-0" aria-label="API request log">
                            <thead class="table-light" style="position: sticky; top: 0;">
                                <tr>
                                    <th scope="col" class="small">Time</th>
                                    <th scope="col" class="small">Method</th>
                                    <th scope="col" class="small">Key</th>
                                    <th scope="col" class="small">Status</th>
                                    <th scope="col" class="small">Detail</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in _logs) {
                                    string rowClass = log.StatusCode >= 200 && log.StatusCode < 300 ? "" : "table-danger";
                                    <tr class="@rowClass">
                                        <td class="small text-muted">@log.Timestamp.ToString("HH:mm:ss.fff")</td>
                                        <td class="small"><code>@log.Method</code></td>
                                        <td class="small">@(log.KeyName ?? "—")</td>
                                        <td class="small">
                                            <span class="badge @(log.StatusCode < 300 ? "bg-success" : "bg-danger")">@log.StatusCode</span>
                                        </td>
                                        <td class="small text-truncate" style="max-width: 200px;">@log.Detail</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "apikeydemo";
    private string _codeGenerate = "var key = Convert.ToBase64String(\n    RandomNumberGenerator.GetBytes(32))";
    private string _codeOneTime = "<code>@_lastGeneratedKey</code>";
    private string _codeCopy = "await Helpers.CopyToClipboard(text)";
    private string _codeRevoke = "<button @onclick=\"@(() => RevokeKey(key.ApiKeyId))\">";
    private string _codeTestConsole = "Authorization: Bearer <your-key>";
    private string _codeFailBtns = "<button @onclick=\"SendWithoutKey\">\n    Send Without Key\n</button>";
    private string _codeRequestLog = "<table class=\"table\" aria-label=\"API request log\">";

    // Key management
    private string _newKeyName = "";
    private string _lastGeneratedKey = "";
    private List<DataObjects.ApiKeyInfo> _keys = new();

    // Test console
    private string _testMethod = "POST";
    private string _testApiKey = "";
    private string _testMessage = "Hello from the test console!";
    private bool _sending = false;
    private string? _lastResponse = null;
    private int _lastStatusCode = 0;

    // Request log
    private List<DataObjects.ApiKeyRequestLog> _logs = new();

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            await LoadKeys();
            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    private async Task LoadKeys()
    {
        var result = await Helpers.GetOrPost<List<DataObjects.ApiKeyInfo>>("api/Data/GetApiKeys", new { });
        if (result != null) _keys = result;
    }

    private async Task GenerateKey()
    {
        if (string.IsNullOrWhiteSpace(_newKeyName)) return;

        var result = await Helpers.GetOrPost<GenerateKeyResponse>("api/Data/GenerateApiKey",
            new DataObjects.ApiKeyTestRequest { Message = _newKeyName });

        if (result != null) {
            _lastGeneratedKey = result.PlaintextKey;
            _testApiKey = result.PlaintextKey; // Auto-fill the test console
            _newKeyName = "";
            await LoadKeys();
        }
        StateHasChanged();
    }

    private async Task RevokeKey(Guid apiKeyId)
    {
        await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/RevokeApiKey", apiKeyId);
        await LoadKeys();
        StateHasChanged();
    }

    private async Task CopyKeyToClipboard()
    {
        try {
            await jsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _lastGeneratedKey);
            Model.AddMessage("API key copied to clipboard!", MessageType.Success);
        } catch {
            Model.AddMessage("Could not copy — use manual selection.", MessageType.Warning);
        }
    }

    private async Task SendTestRequest()
    {
        await SendRequest(_testApiKey);
    }

    private async Task SendWithoutKey()
    {
        await SendRequest("");
    }

    private async Task SendWithBadKey()
    {
        await SendRequest("this-is-a-bad-key-that-will-fail");
    }

    private async Task SendRequest(string apiKey)
    {
        _sending = true;
        _lastResponse = null;
        StateHasChanged();

        try {
            string url;
            string method;
            object? body = null;

            if (_testMethod == "GET") {
                url = "api/demo/external/ping";
                method = "GET";
            } else {
                url = "api/demo/external/data";
                method = "POST";
                body = new DataObjects.ApiKeyTestRequest { Message = _testMessage };
            }

            // Use raw HttpClient to send with custom auth header (bypassing Helpers.GetOrPost cookie auth)
            var request = new HttpRequestMessage(new HttpMethod(method), url);

            if (!string.IsNullOrWhiteSpace(apiKey)) {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", apiKey);
            }

            if (body != null) {
                request.Content = System.Net.Http.Json.JsonContent.Create(body);
            }

            var response = await Http.SendAsync(request);
            _lastStatusCode = (int)response.StatusCode;
            _lastResponse = await response.Content.ReadAsStringAsync();

            // Pretty-format JSON response
            try {
                var doc = System.Text.Json.JsonDocument.Parse(_lastResponse);
                _lastResponse = System.Text.Json.JsonSerializer.Serialize(doc, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            } catch { /* Not JSON, leave as-is */ }
        } catch (Exception ex) {
            _lastStatusCode = 0;
            _lastResponse = $"Error: {ex.Message}";
        }

        _sending = false;
        await RefreshLogs();
        await LoadKeys(); // Refresh request counts
        StateHasChanged();
    }

    private async Task RefreshLogs()
    {
        var result = await Helpers.GetOrPost<List<DataObjects.ApiKeyRequestLog>>("api/Data/GetApiKeyLogs");
        if (result != null) _logs = result;
        StateHasChanged();
    }

    private class GenerateKeyResponse
    {
        public DataObjects.ApiKeyInfo? KeyInfo { get; set; }
        public string PlaintextKey { get; set; } = "";
    }
}
