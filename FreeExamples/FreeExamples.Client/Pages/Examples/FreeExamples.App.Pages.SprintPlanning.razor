@page "/Examples/SprintPlanning"
@page "/{TenantCode}/Examples/SprintPlanning"
@implements IDisposable
@inject BlazorDataModel Model

@* Sprint Planning — Sprint list with status, dates, and capacity gauges *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-flag-checkered me-1"></i> Sprint Planning</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-flag-checkered me-1"></i> Sprint Planning <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="Sprint Planning" Subtitle="Sprint lifecycle management — create, plan, track, and complete sprints" IconClass="fa-solid fa-flag-checkered">
            <p class="small text-muted mb-0">View all sprints with their status, date ranges, goals, and planned vs. capacity gauges. Create new sprints or manage the lifecycle of existing ones.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Capacity Gauge"
                     Description="The gauge compares planned story points against team capacity. When planned exceeds capacity, the bar turns red as an over-commitment warning."
                     Code="@_codeGauge" />
        </div>

        @* Tabs *@
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item"><button class="nav-link @(_tab == "active" ? "active" : "")" @onclick='() => _tab = "active"'>Current / Upcoming</button></li>
            <li class="nav-item"><button class="nav-link @(_tab == "past" ? "active" : "")" @onclick='() => _tab = "past"'>Past Sprints</button></li>
        </ul>

        <div class="row row-cols-1 row-cols-md-2 g-3">
            @foreach (var s in GetFilteredSprints()) {
                var sprintTickets = _tickets.Where(t => t.SprintId == s.RecordId).ToList();
                var planned = sprintTickets.Where(t => t.StoryPoints.HasValue).Sum(t => t.StoryPoints!.Value);
                var completed = sprintTickets.Where(t => (t.Status == DataObjects.TicketStatus.Done || t.Status == DataObjects.TicketStatus.Closed) && t.StoryPoints.HasValue).Sum(t => t.StoryPoints!.Value);
                var capacity = s.CapacityPoints ?? 0;
                var capPct = capacity > 0 ? Math.Min(100, (int)(planned * 100.0 / capacity)) : 0;
                var overCapacity = capacity > 0 && planned > capacity;

                <div class="col">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">@s.Name</h6>
                            <span class="badge @GetSprintBadge(s.Status)">@s.Status</span>
                        </div>
                        <div class="card-body small">
                            @if (!string.IsNullOrEmpty(s.Goal)) {
                                <p class="text-muted mb-2"><i class="fa-solid fa-bullseye me-1"></i>@s.Goal</p>
                            }
                            <div class="row g-2 mb-2">
                                <div class="col-6"><div class="text-muted">Start</div><div>@(s.StartDate?.ToString("MMM d") ?? "—")</div></div>
                                <div class="col-6"><div class="text-muted">End</div><div>@(s.EndDate?.ToString("MMM d") ?? "—")</div></div>
                                <div class="col-6"><div class="text-muted">Tickets</div><div class="fw-bold">@sprintTickets.Count</div></div>
                                <div class="col-6"><div class="text-muted">Completed</div><div class="fw-bold text-success">@completed / @planned pts</div></div>
                            </div>
                            @if (capacity > 0) {
                                <div class="mb-1 d-flex justify-content-between">
                                    <span class="text-muted">Capacity: @planned / @capacity pts</span>
                                    @if (overCapacity) { <span class="badge bg-danger">Over!</span> }
                                </div>
                                <div class="progress" style="height:8px;">
                                    <div class="progress-bar @(overCapacity ? "bg-danger" : "bg-primary")" style="width:@capPct%"></div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!GetFilteredSprints().Any()) {
            <div class="text-center text-muted py-5">No sprints in this tab.</div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "sprintplanning", _tab = "active";
    private List<DataObjects.Sprint> _sprints = new();
    private List<DataObjects.Ticket> _tickets = new();
    private string _codeGauge = "var overCapacity = planned > capacity;\n<div class=\"progress-bar @(overCapacity ? \"bg-danger\" : \"bg-primary\")\" style=\"width:@pct%\">";

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            _sprints = await Helpers.GetOrPost<List<DataObjects.Sprint>>("api/Data/GetSprints", new List<Guid>()) ?? new();
            _tickets = await Helpers.GetOrPost<List<DataObjects.Ticket>>("api/Data/GetTickets", new List<Guid>()) ?? new();
            _loading = false; StateHasChanged();
        }
    }

    private IEnumerable<DataObjects.Sprint> GetFilteredSprints() =>
        _tab == "active" ? _sprints.Where(s => s.Status != DataObjects.SprintStatus.Completed && s.Status != DataObjects.SprintStatus.Cancelled)
                         : _sprints.Where(s => s.Status == DataObjects.SprintStatus.Completed || s.Status == DataObjects.SprintStatus.Cancelled);

    private static string GetSprintBadge(DataObjects.SprintStatus s) => s switch {
        DataObjects.SprintStatus.Active => "bg-success", DataObjects.SprintStatus.Completed => "bg-primary",
        DataObjects.SprintStatus.Cancelled => "bg-dark", _ => "bg-secondary"
    };
}
