@page "/Examples/SignalRV3"
@page "/{TenantCode}/Examples/SignalRV3"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-chart-bar me-1"></i> Live Poll</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-chart-bar me-1"></i> V3: Live Voting / Poll <StickyMenuIcon /></h1></div>
        <AboutSection Title="SignalR in Context: Live Polling" Subtitle="Vote and see results update in real-time — the Slido / Mentimeter pattern" IconClass="fa-solid fa-chart-bar">
            <p class="small text-muted mb-0">SignalR broadcasts vote events so everyone sees the bar chart update live. Click a choice to vote. Results animate as votes come in.</p>
        </AboutSection>
        <div class="card shadow-sm border-0 mb-3"><div class="card-header bg-primary text-white"><i class="fa-solid fa-question me-1"></i> What's the most important feature for our next release?</div><div class="card-body">
            @foreach (var opt in _options) {
                int total = _options.Sum(o => o.Votes);
                int pct = total > 0 ? (int)(opt.Votes * 100.0 / total) : 0;
                <div class="mb-3"><div class="d-flex justify-content-between mb-1"><span class="small fw-semibold">@opt.Label</span><span class="small">@opt.Votes votes (@pct%)</span></div>
                    <div class="progress" style="height:30px; cursor:pointer;" @onclick="@(() => Vote(opt))"><div class="progress-bar bg-primary" style="width:@pct%"><span class="small">@pct%</span></div></div>
                </div>
            }
            <div class="text-end small text-muted">Total votes: @_options.Sum(o => o.Votes) · <button class="btn btn-link btn-sm p-0" @onclick="AddRandomVotes">Simulate 10 votes</button></div>
        </div></div>
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "signalrv3";
    private List<PollOption> _options = new() { new("Dark mode support", 24), new("Mobile app", 18), new("API improvements", 31), new("Better search", 15), new("Performance", 22) };
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
    private void Vote(PollOption opt) { opt.Votes++; }
    private void AddRandomVotes() { var r = new Random(); for (int i = 0; i < 10; i++) _options[r.Next(_options.Count)].Votes++; }
    private class PollOption { public string Label; public int Votes; public PollOption(string l, int v) { Label = l; Votes = v; } }
}
