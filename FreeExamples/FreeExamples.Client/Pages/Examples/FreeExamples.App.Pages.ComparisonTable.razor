@page "/Examples/ComparisonTable"
@page "/{TenantCode}/Examples/ComparisonTable"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-table-columns me-1"></i> Comparison Table</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-table-columns me-1"></i> Comparison Table Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="About Comparison Tables" Subtitle="Select items and compare them side-by-side — the Ford / Amazon pattern" IconClass="fa-solid fa-table-columns">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This demonstrates a <strong>comparison table</strong> — select 2-4 items and see their
                        properties side-by-side with differences highlighted. Ford uses this for vehicle specs,
                        Amazon for product comparisons, and SaaS pricing pages for plan tiers. The table is
                        <strong>transposed</strong>: items are columns, properties are rows.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Transposed table</strong> — columns = items, rows = properties (opposite of normal)</li>
                        <li><strong>Multi-select with checkboxes</strong> — pick items from a list to compare</li>
                        <li><strong>Difference highlighting</strong> — rows where values differ get a subtle tint</li>
                        <li><strong>Column management</strong> — remove individual columns with ×</li>
                        <li><strong>Responsive scroll</strong> — horizontal scroll on mobile when columns overflow</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        You select items from a checkbox list. When you click Compare, the page builds a transposed
                        table — for each property (Name, Category, Amount, etc.) it creates a row and fills in one
                        cell per selected item. If all values in a row are identical, the row is plain. If they
                        differ, the row gets a colored highlight so differences jump out at a glance.
                    </p>
                </div>
            </div>
        </AboutSection>

        @if (!_comparing) {
            @* ── Selection Phase ── *@
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="fa-solid fa-check-double me-1"></i> Select Items to Compare (2-4)</span>
                    <span class="badge bg-primary rounded-pill">@_selectedIds.Count selected</span>
                </div>
                <div class="card-body p-0" style="max-height:350px; overflow-y:auto;">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:1%;"><span class="visually-hidden">Select</span></th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _allItems) {
                                bool selected = _selectedIds.Contains(item.SampleItemId);
                                <tr class="@(selected ? "table-primary" : "")" @onclick="@(() => ToggleSelect(item.SampleItemId))">
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@selected"
                                               disabled="@(!selected && _selectedIds.Count >= 4)" />
                                    </td>
                                    <td class="small fw-semibold">@item.Name</td>
                                    <td class="small">@item.Category</td>
                                    <td><span class="badge @GetStatusBadge(item.Status)" style="font-size:0.65rem;">@item.Status</span></td>
                                    <td class="small text-end">@item.Amount.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-light d-flex gap-2">
                    <button class="btn btn-primary btn-sm" @onclick="StartComparison" disabled="@(_selectedIds.Count < 2)">
                        <i class="fa-solid fa-table-columns me-1"></i> Compare @_selectedIds.Count Items
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ClearSelection" disabled="@(_selectedIds.Count == 0)">
                        <i class="fa-solid fa-times me-1"></i> Clear
                    </button>
                    <InfoTip Title="Multi-Select"
                             Description="Click any row to toggle its checkbox. When 4 items are selected, remaining checkboxes disable to enforce the maximum. The 'table-primary' class highlights selected rows with a blue tint. The Compare button enables only when 2+ items are selected."
                             Code="@_codeMultiSelect" />
                </div>
            </div>
        } else {
            @* ── Comparison Phase ── *@
            <div class="d-flex flex-wrap gap-2 mb-3">
                <button class="btn btn-outline-secondary btn-sm" @onclick="BackToSelection">
                    <i class="fa-solid fa-arrow-left me-1"></i> Back to Selection
                </button>
                <InfoTip Title="Comparison Table"
                         Description="This table is transposed: columns are items, rows are properties. For each property, the code checks if all values are the same. If they differ, the row gets 'table-warning' (yellow tint) to draw your eye. Same values = plain row."
                         Code="@_codeComparison" />
            </div>

            <div class="table-responsive">
                <table class="table table-bordered mb-3">
                    @* Column Headers = Selected Items *@
                    <thead>
                        <tr class="table-dark">
                            <th>Property</th>
                            @foreach (var item in _comparedItems) {
                                <th>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="small">@item.Name</span>
                                        <button class="btn btn-sm btn-link text-white p-0 ms-1" @onclick="@(() => RemoveFromComparison(item.SampleItemId))" title="Remove">
                                            <i class="fa-solid fa-times"></i>
                                        </button>
                                    </div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prop in _propertyRows) {
                            var values = _comparedItems.Select(i => prop.GetValue(i)).ToList();
                            bool allSame = values.Distinct().Count() <= 1;

                            <tr class="@(!allSame ? "table-warning" : "")">
                                <td class="fw-semibold small text-muted">
                                    @prop.Label
                                    @if (!allSame) {
                                        <i class="fa-solid fa-circle-exclamation text-warning ms-1" title="Values differ"></i>
                                    }
                                </td>
                                @foreach (var item in _comparedItems) {
                                    string val = prop.GetValue(item);
                                    bool isBest = !allSame && prop.IsBest != null && prop.IsBest(item, _comparedItems);

                                    <td class="small">
                                        @if (prop.RenderHtml != null) {
                                            @((MarkupString)prop.RenderHtml(item))
                                        } else {
                                            @val
                                        }
                                        @if (isBest) {
                                            <span class="badge bg-success ms-1" style="font-size:0.55rem;">BEST</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <InfoTip Title="Difference Highlighting"
                     Description="For each row, we collect all values into a list and check values.Distinct().Count(). If count == 1, all values are the same (plain row). If count > 1, values differ (yellow highlight). This makes it easy to spot differences in a large table at a glance."
                     Code="@_codeDiffHighlight" />
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private bool _comparing = false;
    private string _pageName = "comparisontable";

    // InfoTip snippets
    private string _codeMultiSelect = "if (_selectedIds.Contains(id)) _selectedIds.Remove(id);\nelse if (_selectedIds.Count < 4) _selectedIds.Add(id);";
    private string _codeComparison = "// Columns = items, Rows = properties\n@foreach (var prop in _propertyRows) {\n    @foreach (var item in _comparedItems) {\n        <td>@prop.GetValue(item)</td>\n    }\n}";
    private string _codeDiffHighlight = "var values = items.Select(i => prop.GetValue(i));\nbool allSame = values.Distinct().Count() <= 1;\n// allSame → plain row, else → table-warning";

    // Data
    private List<DataObjects.SampleItem> _allItems = new();
    private HashSet<Guid> _selectedIds = new();
    private List<DataObjects.SampleItem> _comparedItems = new();
    private List<PropertyRow> _propertyRows = new();

    // ── Lifecycle ──

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }

        // Build property rows definition
        _propertyRows = new List<PropertyRow> {
            new("Name", i => i.Name ?? ""),
            new("Category", i => i.Category ?? ""),
            new("Status", i => i.Status.ToString()) { RenderHtml = i => $"<span class='badge {GetStatusBadge(i.Status)}'>{i.Status}</span>" },
            new("Priority", i => i.Priority.ToString()) { IsBest = (i, all) => i.Priority == all.Min(x => x.Priority) },
            new("Amount", i => i.Amount.ToString("C")) { IsBest = (i, all) => i.Amount == all.Max(x => x.Amount) },
            new("Enabled", i => i.Enabled ? "Yes" : "No") { RenderHtml = i => i.Enabled ? "<i class='fa-solid fa-check text-success'></i> Yes" : "<i class='fa-solid fa-times text-danger'></i> No" },
            new("Description", i => string.IsNullOrWhiteSpace(i.Description) ? "—" : (i.Description.Length > 80 ? i.Description[..80] + "…" : i.Description)),
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;

            var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
            if (result != null) {
                _allItems = result.Where(i => !i.Deleted).OrderBy(i => i.Name).ToList();
            }

            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    // ── Selection ──

    private void ToggleSelect(Guid id)
    {
        if (_selectedIds.Contains(id)) {
            _selectedIds.Remove(id);
        } else if (_selectedIds.Count < 4) {
            _selectedIds.Add(id);
        }
    }

    private void ClearSelection()
    {
        _selectedIds.Clear();
    }

    // ── Comparison ──

    private void StartComparison()
    {
        if (_selectedIds.Count < 2) return;

        _comparedItems = _allItems.Where(i => _selectedIds.Contains(i.SampleItemId)).ToList();
        _comparing = true;
    }

    private void BackToSelection()
    {
        _comparing = false;
    }

    private void RemoveFromComparison(Guid id)
    {
        _comparedItems.RemoveAll(i => i.SampleItemId == id);
        _selectedIds.Remove(id);

        if (_comparedItems.Count < 2) {
            _comparing = false;
        }
    }

    // ── Helpers ──

    private string GetStatusBadge(DataObjects.SampleItemStatus status) => status switch {
        DataObjects.SampleItemStatus.Draft => "bg-secondary",
        DataObjects.SampleItemStatus.Active => "bg-success",
        DataObjects.SampleItemStatus.Completed => "bg-primary",
        DataObjects.SampleItemStatus.Archived => "bg-dark",
        _ => "bg-secondary",
    };

    // ── Inner Types ──

    private class PropertyRow
    {
        public string Label { get; set; }
        public Func<DataObjects.SampleItem, string> GetValue { get; set; }
        public Func<DataObjects.SampleItem, string>? RenderHtml { get; set; }
        public Func<DataObjects.SampleItem, List<DataObjects.SampleItem>, bool>? IsBest { get; set; }

        public PropertyRow(string label, Func<DataObjects.SampleItem, string> getValue)
        {
            Label = label;
            GetValue = getValue;
        }
    }
}
