@page "/Examples/SignalRV2"
@page "/{TenantCode}/Examples/SignalRV2"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-users me-1"></i> Online Users</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-users me-1"></i> V2: Online Presence Tracker <StickyMenuIcon /></h1></div>
        <AboutSection Title="SignalR in Context: Online Presence" Subtitle="See who's online and what they're viewing — the Google Docs / Figma pattern" IconClass="fa-solid fa-users">
            <p class="small text-muted mb-0">SignalR tracks which users are online and what page they're on. Shows colored presence indicators and live user counts. The Google Docs collaborator list pattern.</p>
        </AboutSection>
        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Colored Avatar Circles"
                     Description="Each user has a rounded-circle with a unique background color and initials. The color is stored per-user. This is the Google Docs/Figma collaborator avatar pattern. Small sizes (32px) keep the list compact."
                     Code="@_codeAvatarCircle" />
            <InfoTip Title="Online/Offline Badges"
                     Description="Each user shows a badge: bg-success for Online, bg-secondary for Offline. The list sorts online users first (OrderByDescending(u => u.Online)). The current page shows what the user is viewing — useful for collaboration awareness."
                     Code="@_codeOnlineBadge" />
            <InfoTip Title="Toggle Simulation"
                     Description="The 'Toggle Random' button simulates SignalR events by randomly changing a user's online status. In production, SignalR hub events (OnConnectedAsync/OnDisconnectedAsync) would update presence automatically in real-time."
                     Code="@_codeToggleSim" />
        </div>
        <div class="card shadow-sm border-0 mb-3"><div class="card-header bg-white d-flex justify-content-between py-2"><span class="small fw-semibold"><i class="fa-solid fa-circle text-success me-1" style="font-size:0.5rem;"></i> @_users.Count(u => u.Online) Online Now</span><button class="btn btn-sm btn-outline-primary" @onclick="ToggleUser"><i class="fa-solid fa-shuffle me-1"></i> Toggle Random</button></div><div class="card-body p-0">
            @foreach (var u in _users.OrderByDescending(u => u.Online).ThenBy(u => u.Name)) {
                <div class="px-3 py-2 border-bottom d-flex align-items-center gap-2">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-semibold" style="width:32px;height:32px;font-size:0.7rem;background:@u.Color;">@u.Initials</div>
                    <div class="flex-grow-1"><div class="small fw-semibold">@u.Name</div><div class="small text-muted">@(u.Online ? u.CurrentPage : "Offline")</div></div>
                    <span class="badge @(u.Online ? "bg-success" : "bg-secondary")">@(u.Online ? "Online" : "Offline")</span>
                </div>
            }
        </div></div>
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "signalrv2";
    private string _codeAvatarCircle = "<div class=\"rounded-circle text-white\"\n  style=\"width:32px;height:32px;background:@u.Color\">\n  @u.Initials\n</div>";
    private string _codeOnlineBadge = "<span class=\"badge @(u.Online ? \"bg-success\" : \"bg-secondary\")\">\n  @(u.Online ? \"Online\" : \"Offline\")\n</span>";
    private string _codeToggleSim = "// Simulates SignalR hub events:\n// OnConnectedAsync -> user goes Online\n// OnDisconnectedAsync -> user goes Offline";
    private List<UserPresence> _users = new() {
        new("Sarah Kim", "SK", "#4f46e5", true, "Dashboard"), new("Mike Dean", "MD", "#059669", true, "Sample Items"),
        new("Lisa Ray", "LR", "#d97706", true, "Charts"), new("Tom Wu", "TW", "#dc2626", false, ""),
        new("Amy Chen", "AC", "#7c3aed", true, "Code Editor"), new("Bob Hall", "BH", "#0891b2", false, ""),
    };
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
    private void ToggleUser() { var r = new Random(); var u = _users[r.Next(_users.Count)]; u.Online = !u.Online; if (u.Online) u.CurrentPage = new[] { "Dashboard", "Sample Items", "Charts", "Settings" }[r.Next(4)]; }
    private class UserPresence { public string Name; public string Initials; public string Color; public bool Online; public string CurrentPage;
        public UserPresence(string n, string i, string c, bool o, string p) { Name=n; Initials=i; Color=c; Online=o; CurrentPage=p; } }
}
