@page "/Examples/CommentThread"
@page "/{TenantCode}/Examples/CommentThread"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-comments me-1"></i> Comment Thread</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-comments me-1"></i> Comment Thread Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="About Comment Threads" Subtitle="Threaded conversations — the Jira / GitHub / helpdesk pattern" IconClass="fa-solid fa-comments">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This demonstrates a <strong>comment thread</strong> — a list of user-authored messages attached
                        to a record. Every helpdesk ticket, Jira issue, GitHub PR, and support chat uses this pattern.
                        It's fundamentally different from the SignalR Demo's activity log, which shows system-generated
                        events. Here, real users write messages, edit them, and delete them.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Chat-style layout</strong> — messages flow bottom-up with newest at the end</li>
                        <li><strong>Avatar initials</strong> — colored circles with user initials (no image needed)</li>
                        <li><strong>Relative timestamps</strong> — "2 min ago" instead of "2025-06-28 14:32:05"</li>
                        <li><strong>Inline edit/delete</strong> — modify a message without navigating away</li>
                        <li><strong>SignalR sync</strong> — comments appear in other tabs in real time</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        Each comment is a simple object: author, text, timestamp. When you click Send, it POSTs to
                        <code>SaveComment</code> which stores it in memory and broadcasts via SignalR. Other tabs
                        receive the broadcast and add the comment to their list. Editing replaces the text and adds
                        an "(edited)" marker. Deleting uses the two-click pattern.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Item Selector ── *@
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <label class="form-label mb-0 small text-muted">Commenting on:</label>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_selectedItemId" @bind:after="LoadComments">
                @foreach (var item in _items) {
                    <option value="@item.SampleItemId">@item.Name (@item.Category)</option>
                }
            </select>
            <span class="badge bg-secondary rounded-pill">@_comments.Count comments</span>
            <InfoTip Title="Item Selector"
                     Description="Comments are attached to a specific record (like a Jira issue or helpdesk ticket). The dropdown picks which SampleItem you're commenting on. In a real app, this would be the ticket detail page."
                     Code="@_codeItemSelect" />
        </div>

        @* ── Comment Thread ── *@
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-white py-2">
                <span class="small fw-semibold"><i class="fa-solid fa-message me-1"></i> Discussion</span>
                <InfoTip Title="Comment Thread"
                         Description="Comments are ordered oldest-first (chat style) so the conversation reads top-to-bottom like a book. Each comment shows an avatar circle with initials, the author name, a relative timestamp, and the message text. This is the same layout Jira, GitHub, and Slack use."
                         Code="@_codeThread" />
            </div>
            <div class="card-body" style="max-height:450px; overflow-y:auto;">
                @if (!_comments.Any()) {
                    <div class="text-center py-5">
                        <i class="fa-regular fa-comment-dots fa-3x text-muted opacity-50 mb-2"></i>
                        <div class="text-muted">No comments yet. Start the conversation!</div>
                    </div>
                } else {
                    @foreach (var comment in _comments) {
                        <div class="d-flex mb-3 @(_recentIds.Contains(comment.CommentId) ? "bg-info bg-opacity-10 rounded p-2" : "")">
                            @* Avatar *@
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center flex-shrink-0 me-2"
                                 style="width:36px; height:36px; font-size:0.8rem; font-weight:600;"
                                 title="@comment.AuthorName">
                                @comment.AuthorInitials
                            </div>

                            @* Comment Body *@
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="fw-semibold small">@comment.AuthorName</span>
                                    <span class="text-muted small" title="@comment.Created.ToLocalTime().ToString("f")">
                                        @FormatRelativeTime(comment.Created)
                                    </span>
                                    @if (comment.Edited.HasValue) {
                                        <span class="text-muted small fst-italic">(edited)</span>
                                        <InfoTip Title="Edited Marker"
                                                 Description="When a comment has been edited, we show '(edited)' next to the timestamp. The Edited property stores the edit time. Hovering shows the original post time. This is the same pattern GitHub and Slack use."
                                                 Code="@_codeEdited" />
                                    }
                                </div>

                                @if (_editingCommentId == comment.CommentId) {
                                    @* Edit Mode *@
                                    <div class="mb-1">
                                        <textarea class="form-control form-control-sm" rows="2" @bind="_editText"></textarea>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-primary" @onclick="@(() => SaveEdit(comment))">
                                            <i class="fa-solid fa-check me-1"></i>Save
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                                    </div>
                                } else {
                                    @* Display Mode *@
                                    <div class="small">@comment.Text</div>

                                    @* Actions *@
                                    <div class="mt-1">
                                        <button class="btn btn-sm btn-link text-muted p-0 me-2" @onclick="@(() => StartEdit(comment))" title="Edit">
                                            <i class="fa-solid fa-pencil"></i> <span class="small">Edit</span>
                                        </button>
                                        @if (_deletingCommentId == comment.CommentId) {
                                            <button class="btn btn-sm btn-link text-muted p-0 me-1" @onclick="CancelDelete">
                                                <i class="fa-solid fa-times"></i> <span class="small">Cancel</span>
                                            </button>
                                            <button class="btn btn-sm btn-link text-danger p-0" @onclick="@(() => ConfirmDelete(comment.CommentId))">
                                                <i class="fa-solid fa-check"></i> <span class="small">Confirm Delete</span>
                                            </button>
                                        } else {
                                            <button class="btn btn-sm btn-link text-muted p-0" @onclick="@(() => _deletingCommentId = comment.CommentId)" title="Delete">
                                                <i class="fa-solid fa-trash"></i> <span class="small">Delete</span>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            @* ── Add Comment ── *@
            <div class="card-footer bg-light">
                <div class="d-flex gap-2">
                    <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center flex-shrink-0"
                         style="width:36px; height:36px; font-size:0.8rem; font-weight:600;">
                        @_currentUserInitials
                    </div>
                    <div class="flex-grow-1">
                        <textarea class="form-control form-control-sm" rows="2" @bind="_newCommentText"
                                  placeholder="Write a comment..." @onkeydown="HandleCommentKeydown"></textarea>
                    </div>
                    <div class="d-flex align-items-end">
                        <button class="btn btn-primary btn-sm" @onclick="AddComment"
                                disabled="@(string.IsNullOrWhiteSpace(_newCommentText) || _saving)">
                            @if (_saving) {
                                <span class="spinner-border spinner-border-sm"></span>
                            } else {
                                <i class="fa-solid fa-paper-plane"></i>
                            }
                        </button>
                    </div>
                </div>
                <div class="small text-muted mt-1">
                    Press <kbd>Ctrl</kbd>+<kbd>Enter</kbd> to send
                    <InfoTip Title="Add Comment"
                             Description="The comment input follows the chat pattern: textarea at the bottom, Send button on the right. Ctrl+Enter is a keyboard shortcut for power users. The button disables while saving to prevent double-submits. After saving, the textarea clears and the new comment appears at the bottom."
                             Code="@_codeAddComment" />
                </div>
            </div>
        </div>

        @* InfoTip row *@
        <div class="d-flex flex-wrap gap-1 mt-2">
            <InfoTip Title="Relative Timestamps"
                     Description="Instead of showing '2025-06-28 14:32:05', we show 'just now', '2 min ago', '1 hour ago', 'yesterday'. This is calculated by subtracting the comment time from DateTime.UtcNow and picking the right unit. The full timestamp is still available on hover (title attribute)."
                     Code="@_codeRelativeTime" />
            <InfoTip Title="Avatar Initials"
                     Description="Instead of loading profile pictures (which requires image hosting), we extract the user's initials and show them in a colored circle. 'John Smith' becomes 'JS'. This is done with string splitting — no image required. The same pattern is used in Microsoft Teams and Outlook."
                     Code="@_codeAvatar" />
            <InfoTip Title="Two-Click Delete"
                     Description="Clicking Delete shows Cancel and Confirm buttons. You must click Confirm to actually delete. This prevents accidental deletions — the same pattern used on EditSampleItem and the BootstrapShowcase cards."
                     Code="@_codeTwoClick" />
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private bool _saving = false;
    private string _pageName = "commentthread";

    // InfoTip snippets
    private string _codeItemSelect = "<select @bind=\"_selectedItemId\" @bind:after=\"LoadComments\">";
    private string _codeThread = "@foreach (var comment in _comments) {\n    <div class=\"d-flex mb-3\">\n        <!-- avatar circle -->\n        <!-- comment body -->\n    </div>\n}";
    private string _codeEdited = "@if (comment.Edited.HasValue) {\n    <span class=\"fst-italic\">(edited)</span>\n}";
    private string _codeAddComment = "@onkeydown=\"HandleCommentKeydown\"\n// In handler:\nif (e.Key == \"Enter\" && e.CtrlKey) await AddComment();";
    private string _codeRelativeTime = "var elapsed = DateTime.UtcNow - comment.Created;\nif (elapsed.TotalSeconds < 60) return \"just now\";\nif (elapsed.TotalMinutes < 60) return $\"{(int)elapsed.TotalMinutes} min ago\";";
    private string _codeAvatar = "var parts = name.Split(' ');\nvar initials = string.Concat(parts.Select(p => p[0])).ToUpper();";
    private string _codeTwoClick = "if (_deletingCommentId == comment.CommentId) {\n    // Show Cancel + Confirm\n} else {\n    // Show Delete button\n}";

    // Data
    private List<DataObjects.SampleItem> _items = new();
    private List<DataObjects.SampleComment> _comments = new();
    private Guid _selectedItemId;

    // Input state
    private string _newCommentText = "";
    private string _currentUserInitials = "";

    // Edit state
    private Guid? _editingCommentId;
    private string _editText = "";

    // Delete state
    private Guid? _deletingCommentId;

    // SignalR highlight
    private HashSet<Guid> _recentIds = new();

    // ── Lifecycle ──

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.OnSignalRUpdate -= SignalRUpdate;
        Model.Subscribers_OnChange.Remove(_pageName);
        Model.Subscribers_OnSignalRUpdate.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        Model.OnSignalRUpdate += SignalRUpdate;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
        if (!Model.Subscribers_OnSignalRUpdate.Contains(_pageName)) { Model.Subscribers_OnSignalRUpdate.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;

            // Get current user initials
            string displayName = (Model.User.FirstName + " " + Model.User.LastName).Trim();
            if (string.IsNullOrWhiteSpace(displayName)) displayName = Model.User.Email ?? "User";
            _currentUserInitials = GetInitials(displayName);

            // Load items for the selector
            var items = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
            if (items != null && items.Any()) {
                _items = items.Where(i => !i.Deleted).Take(10).ToList();
                _selectedItemId = _items.First().SampleItemId;
                await LoadComments();
            }

            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    // ── SignalR ──

    private async void SignalRUpdate(DataObjects.SignalRUpdate update)
    {
        if (update.UpdateType == DataObjects.SignalRUpdateType.CommentSaved) {
            var saved = Helpers.DeserializeObject<DataObjects.SampleComment>(update.ObjectAsString);
            if (saved == null || saved.SampleItemId != _selectedItemId) return;

            var existing = _comments.FirstOrDefault(c => c.CommentId == saved.CommentId);
            if (existing != null) {
                int idx = _comments.IndexOf(existing);
                _comments[idx] = saved;
            } else {
                _comments.Add(saved);
                _recentIds.Add(saved.CommentId);
            }

            await InvokeAsync(StateHasChanged);
            await Task.Delay(2000);
            _recentIds.Remove(saved.CommentId);
            await InvokeAsync(StateHasChanged);
        } else if (update.UpdateType == DataObjects.SignalRUpdateType.CommentDeleted) {
            _comments.RemoveAll(c => c.CommentId == update.ItemId);
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Data Loading ──

    private async Task LoadComments()
    {
        if (_selectedItemId == Guid.Empty) return;

        var result = await Helpers.GetOrPost<List<DataObjects.SampleComment>>("api/Data/GetComments", _selectedItemId);
        if (result != null) {
            _comments = result;
        }
        StateHasChanged();
    }

    // ── Add Comment ──

    private async Task AddComment()
    {
        if (string.IsNullOrWhiteSpace(_newCommentText)) return;

        _saving = true;
        StateHasChanged();

        string displayName = (Model.User.FirstName + " " + Model.User.LastName).Trim();
        if (string.IsNullOrWhiteSpace(displayName)) displayName = Model.User.Email ?? "User";
        var comment = new DataObjects.SampleComment {
            SampleItemId = _selectedItemId,
            AuthorName = displayName,
            AuthorInitials = GetInitials(displayName),
            Text = _newCommentText.Trim(),
        };

        var result = await Helpers.GetOrPost<DataObjects.SampleComment>("api/Data/SaveComment", comment);
        if (result != null) {
            // Optimistic add (SignalR will also fire)
            if (!_comments.Any(c => c.CommentId == result.CommentId)) {
                _comments.Add(result);
            }
            _newCommentText = "";
        }

        _saving = false;
        StateHasChanged();
    }

    private async Task HandleCommentKeydown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey) {
            await AddComment();
        }
    }

    // ── Edit ──

    private void StartEdit(DataObjects.SampleComment comment)
    {
        _editingCommentId = comment.CommentId;
        _editText = comment.Text;
    }

    private void CancelEdit()
    {
        _editingCommentId = null;
        _editText = "";
    }

    private async Task SaveEdit(DataObjects.SampleComment comment)
    {
        if (string.IsNullOrWhiteSpace(_editText)) return;

        comment.Text = _editText.Trim();
        var result = await Helpers.GetOrPost<DataObjects.SampleComment>("api/Data/SaveComment", comment);
        if (result != null) {
            int idx = _comments.FindIndex(c => c.CommentId == result.CommentId);
            if (idx >= 0) _comments[idx] = result;
        }

        _editingCommentId = null;
        _editText = "";
        StateHasChanged();
    }

    // ── Delete ──

    private void CancelDelete()
    {
        _deletingCommentId = null;
    }

    private async Task ConfirmDelete(Guid commentId)
    {
        await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/DeleteComment", commentId);
        _comments.RemoveAll(c => c.CommentId == commentId);
        _deletingCommentId = null;
        StateHasChanged();
    }

    // ── Helpers ──

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        string[] parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(parts.Select(p => p[0])).ToUpper();
    }

    private string FormatRelativeTime(DateTime utcTime)
    {
        TimeSpan elapsed = DateTime.UtcNow - utcTime;

        if (elapsed.TotalSeconds < 60) return "just now";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes} min ago";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours} hour{((int)elapsed.TotalHours == 1 ? "" : "s")} ago";
        if (elapsed.TotalDays < 2) return "yesterday";
        if (elapsed.TotalDays < 30) return $"{(int)elapsed.TotalDays} days ago";
        return utcTime.ToLocalTime().ToString("MMM d, yyyy");
    }
}
