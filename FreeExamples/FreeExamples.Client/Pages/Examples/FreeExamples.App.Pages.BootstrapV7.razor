@page "/Examples/BootstrapV7"
@page "/{TenantCode}/Examples/BootstrapV7"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-gear me-1"></i> Settings Admin</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-gear me-1"></i> V7: Settings Admin Panel
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="Bootstrap in Context: Settings Admin Panel" Subtitle="Tabbed settings with form-floating and form-switch — the Helpdesk Settings pattern" IconClass="fa-solid fa-gear">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This demonstrates a <strong>tabbed admin settings page</strong> like Helpdesk Settings, which has
                        7+ tabs (General, Theme, Auth, Email, etc.). Each tab contains form fields specific to that section.
                        One Save button at the bottom saves all tabs at once.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>nav-tabs + tab-pane</strong> for section navigation</li>
                        <li><strong>form-floating</strong> for floating label inputs</li>
                        <li><strong>form-switch</strong> for toggle settings</li>
                        <li><strong>alert-info</strong> for section help text</li>
                        <li><strong>Save All</strong> button pattern with success feedback</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        Bootstrap nav-tabs switch between tab-pane sections without page reload. Each tab has its own
                        form fields. The active tab is tracked in state. Clicking Save shows a success alert.
                        In production, this would POST all settings to the server in one call.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Tabs ── *@
        <ul class="nav nav-tabs mb-0">
            @foreach (var tab in _tabs) {
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == tab.Key ? "active" : "")" @onclick="@(() => _activeTab = tab.Key)">
                        <i class="@tab.Icon me-1"></i> @tab.Label
                    </button>
                </li>
            }
        </ul>

        <InfoTip Title="nav-tabs Pattern"
                 Description="Bootstrap nav-tabs create a tabbed interface without page navigation. The active tab gets the 'active' class. Each tab's content is shown/hidden by matching the _activeTab state variable. In Helpdesk Settings, there are 7+ tabs managed this way."
                 Code="@_codeNavTabs" />

        <div class="card border-top-0 rounded-top-0 shadow-sm mb-3">
            <div class="card-body">
                @* ── General Tab ── *@
                @if (_activeTab == "general") {
                    <div class="alert alert-info small py-2"><i class="fa-solid fa-circle-info me-1"></i> Configure the basic application settings.</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="appTitle" placeholder="App Title" @bind="_appTitle" />
                                <label for="appTitle">Application Title</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="appSubtitle" placeholder="Subtitle" @bind="_appSubtitle" />
                                <label for="appSubtitle">Subtitle</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select class="form-select" id="timezone" @bind="_timezone">
                                    <option value="EST">Eastern (EST)</option>
                                    <option value="CST">Central (CST)</option>
                                    <option value="MST">Mountain (MST)</option>
                                    <option value="PST">Pacific (PST)</option>
                                </select>
                                <label for="timezone">Timezone</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="pageSize" placeholder="25" @bind="_pageSize" />
                                <label for="pageSize">Default Page Size</label>
                            </div>
                        </div>
                    </div>
                    <InfoTip Title="form-floating"
                             Description="form-floating creates inputs where the label floats above the value when focused or filled. The placeholder is required for the animation to work. The label element must come AFTER the input. This is used on all Identity/Auth pages in production."
                             Code="@_codeFormFloating" />
                }

                @* ── Appearance Tab ── *@
                @if (_activeTab == "appearance") {
                    <div class="alert alert-info small py-2"><i class="fa-solid fa-circle-info me-1"></i> Customize the look and feel of the application.</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small">Primary Color</label>
                            <input type="color" class="form-control form-control-color" @bind="_primaryColor" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Logo URL</label>
                            <input type="text" class="form-control" placeholder="https://..." @bind="_logoUrl" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="darkMode" @bind="_darkMode" /><label class="form-check-label" for="darkMode">Enable Dark Mode</label></div>
                            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="showLogo" @bind="_showLogo" /><label class="form-check-label" for="showLogo">Show Logo in Navbar</label></div>
                            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="compactMode" @bind="_compactMode" /><label class="form-check-label" for="compactMode">Compact Navigation</label></div>
                        </div>
                    </div>
                    <InfoTip Title="form-switch Toggles"
                             Description="form-switch creates iOS-style toggle switches. They're used extensively in production settings pages — Helpdesk alone has 20+ switches for features like 'Enable SSO', 'Allow File Uploads', 'Show Knowledgebase'. Each switch binds to a boolean property."
                             Code="@_codeFormSwitch" />
                }

                @* ── Notifications Tab ── *@
                @if (_activeTab == "notifications") {
                    <div class="alert alert-info small py-2"><i class="fa-solid fa-circle-info me-1"></i> Configure email and notification preferences.</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="email" class="form-control" id="adminEmail" placeholder="admin@example.com" @bind="_adminEmail" />
                                <label for="adminEmail">Admin Email</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="smtpServer" placeholder="smtp.example.com" @bind="_smtpServer" />
                                <label for="smtpServer">SMTP Server</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="emailOnNew" @bind="_emailOnNew" /><label class="form-check-label" for="emailOnNew">Email on New Items</label></div>
                            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="emailOnUpdate" @bind="_emailOnUpdate" /><label class="form-check-label" for="emailOnUpdate">Email on Status Changes</label></div>
                            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="dailyDigest" @bind="_dailyDigest" /><label class="form-check-label" for="dailyDigest">Daily Digest Summary</label></div>
                        </div>
                    </div>
                }

                @* ── Security Tab ── *@
                @if (_activeTab == "security") {
                    <div class="alert alert-warning small py-2"><i class="fa-solid fa-shield-halved me-1"></i> Security settings affect all users. Change with caution.</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select class="form-select" id="authMethod" @bind="_authMethod">
                                    <option value="local">Local Authentication</option>
                                    <option value="sso">Single Sign-On (SSO)</option>
                                    <option value="both">Both</option>
                                </select>
                                <label for="authMethod">Authentication Method</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="sessionTimeout" placeholder="30" @bind="_sessionTimeout" />
                                <label for="sessionTimeout">Session Timeout (minutes)</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="require2fa" @bind="_require2fa" /><label class="form-check-label" for="require2fa">Require Two-Factor Authentication</label></div>
                            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="lockoutEnabled" @bind="_lockoutEnabled" /><label class="form-check-label" for="lockoutEnabled">Enable Account Lockout</label></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ── Save Button ── *@
        @if (_saved) {
            <div class="alert alert-success py-2 small"><i class="fa-solid fa-check-circle me-1"></i> Settings saved successfully.</div>
        }
        <div class="d-flex justify-content-end">
            <button class="btn btn-success" @onclick="SaveSettings"><i class="fa-solid fa-floppy-disk me-1"></i> Save All Settings</button>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _saved = false;
    private string _pageName = "bootstrapv7";
    private string _activeTab = "general";

    private string _codeNavTabs = "<ul class=\"nav nav-tabs\">\n  <li class=\"nav-item\">\n    <button class=\"nav-link @(_activeTab == \"general\" ? \"active\" : \"\")\" @onclick=\"...\">General</button>\n  </li>\n</ul>";
    private string _codeFormFloating = "<div class=\"form-floating\">\n  <input class=\"form-control\" id=\"x\" placeholder=\"...\" @bind=\"_val\" />\n  <label for=\"x\">Label</label>\n</div>";
    private string _codeFormSwitch = "<div class=\"form-check form-switch\">\n  <input class=\"form-check-input\" type=\"checkbox\" @bind=\"_enabled\" />\n  <label class=\"form-check-label\">Enable Feature</label>\n</div>";

    // General
    private string _appTitle = "FreeExamples", _appSubtitle = "Demo Application", _timezone = "EST";
    private int _pageSize = 25;
    // Appearance
    private string _primaryColor = "#0d6efd", _logoUrl = "";
    private bool _darkMode = false, _showLogo = true, _compactMode = false;
    // Notifications
    private string _adminEmail = "admin@example.com", _smtpServer = "smtp.example.com";
    private bool _emailOnNew = true, _emailOnUpdate = true, _dailyDigest = false;
    // Security
    private string _authMethod = "local";
    private int _sessionTimeout = 30;
    private bool _require2fa = false, _lockoutEnabled = true;

    private List<(string Key, string Label, string Icon)> _tabs = new() {
        ("general", "General", "fa-solid fa-gear"),
        ("appearance", "Appearance", "fa-solid fa-palette"),
        ("notifications", "Notifications", "fa-solid fa-bell"),
        ("security", "Security", "fa-solid fa-shield-halved"),
    };

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }

    private void SaveSettings() { _saved = true; _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { _saved = false; StateHasChanged(); })); }
}
