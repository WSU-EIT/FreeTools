@page "/Examples/FileDemoV4"
@page "/{TenantCode}/Examples/FileDemoV4"
@implements IDisposable
@inject BlazorDataModel Model

@* V4: Bulk Import — CSV/Excel upload with preview and validation *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-file-csv me-1"></i> Bulk Import</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-file-csv me-1"></i> V4: Bulk Import with Preview <StickyMenuIcon /></h1>
        </div>
        <AboutSection Title="File Upload in Context: Bulk Data Import" Subtitle="Upload a CSV/Excel file, preview the data, validate, then import" IconClass="fa-solid fa-file-csv">
            <p class="small text-muted mb-0">Upload a CSV, see a preview of what will be imported, review validation errors, then confirm. This is the Salesforce data import, GitHub issue import, or Azure DevOps bulk update pattern.</p>
        </AboutSection>

        @if (!_fileUploaded) {
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body text-center py-5">
                    <i class="fa-solid fa-file-csv fa-3x text-muted mb-3"></i>
                    <h5>Upload CSV or Excel File</h5>
                    <p class="small text-muted">Import sample items in bulk. Expected columns: Name, Category, Status, Priority, Amount</p>
                    <button class="btn btn-primary" @onclick="SimulateUpload"><i class="fa-solid fa-upload me-1"></i> Choose File</button>
                    <div class="small text-muted mt-2">Or drag and drop a .csv or .xlsx file here</div>
                </div>
            </div>
        } else {
            @* Preview *@
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white d-flex justify-content-between">
                    <span class="fw-semibold small"><i class="fa-solid fa-eye me-1"></i> Import Preview — sample_items.csv</span>
                    <div class="d-flex gap-2">
                        <span class="badge bg-success rounded-pill">@_previewRows.Count(r => r.Valid) valid</span>
                        <span class="badge bg-danger rounded-pill">@_previewRows.Count(r => !r.Valid) errors</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0 small">
                        <thead class="table-light">
                            <tr><th style="width:30px;"></th><th>Row</th><th>Name</th><th>Category</th><th>Status</th><th>Priority</th><th>Amount</th><th>Issue</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _previewRows) {
                                <tr class="@(!row.Valid ? "table-danger" : "")">
                                    <td>@if (row.Valid) { <i class="fa-solid fa-check text-success"></i> } else { <i class="fa-solid fa-triangle-exclamation text-danger"></i> }</td>
                                    <td>@row.RowNum</td><td>@row.Name</td><td>@row.Category</td><td>@row.Status</td><td>@row.Priority</td><td>@row.Amount</td>
                                    <td class="text-danger">@row.Error</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-light d-flex justify-content-between">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => _fileUploaded = false)"><i class="fa-solid fa-arrow-left me-1"></i> Choose Different File</button>
                    <button class="btn btn-sm btn-success" @onclick="Import" disabled="@(!_previewRows.Any(r => r.Valid))">
                        <i class="fa-solid fa-file-import me-1"></i> Import @_previewRows.Count(r => r.Valid) Valid Rows
                    </button>
                </div>
            </div>
        }

        @if (_imported) {
            <div class="alert alert-success"><i class="fa-solid fa-circle-check me-1"></i> <strong>Import Complete!</strong> @_previewRows.Count(r => r.Valid) rows imported, @_previewRows.Count(r => !r.Valid) skipped.</div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _fileUploaded = false, _imported = false;
    private string _pageName = "filedemov4";
    private List<PreviewRow> _previewRows = new();

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }

    private void SimulateUpload() {
        _fileUploaded = true;
        _previewRows = new() {
            new(1, "Widget Alpha", "Engineering", "Active", "1", "$1,200", true, ""),
            new(2, "Beta Module", "Sales", "Draft", "2", "$800", true, ""),
            new(3, "", "Marketing", "Active", "1", "$500", false, "Name is required"),
            new(4, "Delta Service", "Engineering", "Active", "3", "$2,100", true, ""),
            new(5, "Epsilon Tool", "Support", "InvalidStatus", "1", "$300", false, "Invalid status value"),
            new(6, "Zeta Report", "Finance", "Completed", "2", "$950", true, ""),
            new(7, "Eta Process", "Engineering", "Active", "1", "abc", false, "Amount must be numeric"),
            new(8, "Theta Widget", "Sales", "Draft", "4", "$1,500", true, ""),
        };
    }
    private void Import() { _imported = true; }

    private record PreviewRow(int RowNum, string Name, string Category, string Status, string Priority, string Amount, bool Valid, string Error);
}
