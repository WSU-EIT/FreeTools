@page "/Examples/SignatureDemo"
@page "/{TenantCode}/Examples/SignatureDemo"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title">Signature Demo</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-signature me-1"></i> Digital Signature Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="About Signature Demo" Subtitle="Draw your signature with a mouse or finger, just like signing a form" IconClass="fa-solid fa-signature">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        A <strong>digital signature pad</strong> lets you draw your signature using
                        your mouse (on a computer) or your finger (on a phone/tablet). It captures
                        the drawing as data that can be saved and displayed later — just like signing
                        a paper form, but electronically. You can clear it and try again.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Canvas drawing</strong> — capturing mouse/touch movements and drawing lines</li>
                        <li><strong>Data binding</strong> — the signature data syncs between JavaScript and C# automatically</li>
                        <li><strong>Base30 encoding</strong> — a compact way to store drawing strokes as text</li>
                        <li><strong>JS interop</strong> — C# and JavaScript working together in the same page</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        The signature pad uses <strong>jSignature</strong>, a JavaScript library that creates
                        an HTML <code>&lt;canvas&gt;</code> element (a drawing surface). When you draw, it records
                        every stroke as a series of coordinates. Those coordinates are compressed into a "base30"
                        string and sent back to C# via JS interop. The string can be saved to a database
                        and rendered back as an image later.
                    </p>
                </div>
            </div>
        </AboutSection>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Signature Pad
                    <InfoTip Title="Signature Pad Component"
                             Description="This component wraps jSignature, a JavaScript library that creates a drawing surface (HTML canvas). Draw with your mouse or finger. The library captures your strokes and converts them to a compact text format called base30. The bind-Value sends that text back to C# automatically."
                             Code="@_codeSignaturePad" />
                </h6>
                <div>
                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearSignature"
                            disabled="@(string.IsNullOrWhiteSpace(_signatureValue))">
                        <i class="fas fa-eraser me-1"></i> Clear
                    </button>
                    <InfoTip Title="Clear Signature"
                             Description="This button erases the signature pad and resets the bound value to empty. It is disabled (greyed out) when there is nothing to clear — the disabled attribute checks if the value is empty. This prevents a confusing nothing happened experience."
                             Code="@_codeClearSig" />
                </div>
            </div>
            <div class="card-body">
                <div role="region" aria-label="Signature drawing pad">
                <Signature @ref="_signaturePad"
                    @bind-Value="_signatureValue"
                    Class="border rounded"
                    Id="demo-signature" />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white"><h6 class="mb-0">Status</h6></div>
                    <div class="card-body" aria-live="polite">
                        @if (string.IsNullOrWhiteSpace(_signatureValue)) {
                            <span class="badge bg-warning text-dark" role="status">No signature captured</span>
                        } else {
                            <span class="badge bg-success" role="status">Signature captured</span>
                            <span class="text-muted ms-2 small">(@_signatureValue.Length characters)</span>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white"><h6 class="mb-0">Raw Value (base30)
                        <InfoTip Title="Raw Data Display"
                                 Description="This shows the actual data that gets saved to the database — a string of characters that encodes your drawing. Base30 is more compact than storing the image pixels. The signature can be reconstructed from this string later. In a real app, this string goes into a database column."
                                 Code="@_codeRawData" />
                    </h6></div>
                    <div class="card-body">
                        <pre class="border rounded p-2 bg-light small mb-0" style="max-height:120px; overflow:auto;" aria-label="Signature data value">@(string.IsNullOrWhiteSpace(_signatureValue) ? "(draw a signature above)" : _signatureValue)</pre>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "signaturedemo";
    private string _codeSignaturePad = "<Signature @ref=\"_signaturePad\"\n    @bind-Value=\"_signatureValue\" />";
    private string _codeClearSig = "disabled=\"@(string.IsNullOrWhiteSpace(_signatureValue))\"";
    private string _codeRawData = "<pre>@_signatureValue</pre>";
    private string _signatureValue = "";
    private Signature? _signaturePad;

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    private async Task ClearSignature()
    {
        if (_signaturePad != null) {
            await _signaturePad.Clear();
            Model.AddMessage("Signature cleared.", MessageType.Warning);
        }
    }
}
