@page "/Examples/BootstrapShowcase"
@page "/{TenantCode}/Examples/BootstrapShowcase"
@implements IDisposable
@inject BlazorDataModel Model
@inject Radzen.DialogService DialogService

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title">Bootstrap Showcase</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-palette me-1"></i> Bootstrap Showcase
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="About Bootstrap Showcase" Subtitle="Learn the building blocks that make web pages look professional" IconClass="fa-solid fa-palette">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        <strong>Bootstrap</strong> is a free toolkit of pre-built designs (buttons, cards, tabs, alerts)
                        that web developers use so they don't have to design everything from scratch. Think of it like
                        a LEGO set — you snap together pre-made pieces to build a professional-looking page.
                        This page shows the most common Bootstrap pieces used across our projects.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Cards</strong> — rectangular boxes with a header, body, and optional footer</li>
                        <li><strong>Badges</strong> — small colored labels like "Active" or "Draft"</li>
                        <li><strong>Modals</strong> — popup dialog boxes that appear on top of the page</li>
                        <li><strong>Form validation</strong> — showing error messages when required fields are empty</li>
                        <li><strong>Toasts</strong> — brief notification messages that appear and fade away</li>
                        <li><strong>Accordions</strong> — collapsible sections you click to expand</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        Bootstrap works by adding <strong>CSS classes</strong> to HTML elements. A CSS class is like a
                        label that tells the browser how to style something. For example, adding <code>class="btn btn-primary"</code>
                        to a <code>&lt;button&gt;</code> turns it into a styled blue button. No custom design code needed —
                        Bootstrap's stylesheet handles the colors, sizes, and spacing for you.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* Tabs Demo *@
        <h5 class="mb-3" id="tabs-heading">Tabs</h5>
        <ul class="nav nav-tabs mb-3" role="tablist" aria-labelledby="tabs-heading">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == "cards" ? "active" : "")" @onclick="@(() => _activeTab = "cards")" role="tab" aria-selected="@(_activeTab == "cards")" aria-controls="tab-cards">
                    Status Cards
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == "badges" ? "active" : "")" @onclick="@(() => _activeTab = "badges")" role="tab" aria-selected="@(_activeTab == "badges")" aria-controls="tab-badges">
                    Badges & Status
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == "modals" ? "active" : "")" @onclick="@(() => _activeTab = "modals")" role="tab" aria-selected="@(_activeTab == "modals")" aria-controls="tab-modals">
                    Modals & Dialogs
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == "forms" ? "active" : "")" @onclick="@(() => _activeTab = "forms")" role="tab" aria-selected="@(_activeTab == "forms")" aria-controls="tab-forms">
                    Forms & Inputs
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == "layout" ? "active" : "")" @onclick="@(() => _activeTab = "layout")" role="tab" aria-selected="@(_activeTab == "layout")" aria-controls="tab-layout">
                    Layout Patterns
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == "feedback" ? "active" : "")" @onclick="@(() => _activeTab = "feedback")" role="tab" aria-selected="@(_activeTab == "feedback")" aria-controls="tab-feedback">
                    Feedback & Alerts
                </button>
            </li>
        </ul>

        @if (_activeTab == "cards") {
            <div id="tab-cards" role="tabpanel" aria-labelledby="tabs-heading">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 mb-4">
                @foreach (var item in _items.Take(6)) {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0" role="article" aria-label="@item.Name">
                            <div class="card-header bg-white border-bottom-0 py-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h6 class="card-title mb-0 text-truncate" style="max-width:180px;">@item.Name</h6>
                                    <span class="badge @GetBadge(item.Status)" aria-label="Status: @item.Status">@item.Status</span>
                                </div>
                            </div>
                            <div class="card-body pt-0">
                                <div class="small text-muted mb-1"><i class="fa fa-folder me-1" aria-hidden="true"></i>@item.Category</div>
                                <div class="small text-muted"><i class="fa fa-dollar-sign me-1" aria-hidden="true"></i>@item.Amount.ToString("C")</div>
                            </div>
                            <div class="card-footer bg-white border-top-0 pt-0 pb-3">
                                <button class="btn btn-sm btn-outline-primary" @onclick="@(() => OnEditClicked(item))" title="Edit @item.Name" aria-label="Edit @item.Name"><i class="fa fa-edit" aria-hidden="true"></i></button>
                                @if (_confirmDeleteId == item.SampleItemId) {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelDelete" title="Cancel delete" aria-label="Cancel delete">
                                        <i class="fa fa-times" aria-hidden="true"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" @onclick="@(() => ConfirmDelete(item))" title="Confirm delete @item.Name" aria-label="Confirm delete @item.Name">
                                        <i class="fa fa-check me-1" aria-hidden="true"></i> Confirm
                                    </button>
                                } else {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="@(() => RequestDelete(item))" title="Delete @item.Name" aria-label="Delete @item.Name"><i class="fa fa-trash" aria-hidden="true"></i></button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
            </div>
        }

        @if (_activeTab == "badges") {
            <div id="tab-badges" role="tabpanel" aria-labelledby="tabs-heading">
            <div class="mb-4">
                <h6>Status Badges</h6>
                <span class="badge bg-success me-1" role="status">Active</span>
                <span class="badge bg-danger me-1" role="status">Failed</span>
                <span class="badge bg-primary me-1" role="status">Running</span>
                <span class="badge bg-warning text-dark me-1" role="status">Draft</span>
                <span class="badge bg-secondary me-1" role="status">Archived</span>
                <span class="badge bg-info me-1" role="status">Completed</span>
            </div>
            <div class="mb-4">
                <h6>Priority Badges</h6>
                @for (int i = 1; i <= 5; i++) {
                    <span class="badge bg-primary me-1" role="status">Priority @i</span>
                }
            </div>
            <div class="mb-4">
                <h6>Boolean Icons</h6>
                <div>Enabled: @Helpers.BooleanToIcon(true)</div>
                <div>Disabled: @Helpers.BooleanToIcon(false)</div>
            </div>
            </div>
        }

        @if (_activeTab == "modals") {
            <div id="tab-modals" role="tabpanel" aria-labelledby="tabs-heading">
            <div class="mb-4">
                <h6>Radzen Dialog</h6>
                <p class="small text-muted">Click to open a modal dialog.</p>
                <button class="btn btn-primary" @onclick="OpenDialog" aria-label="Open example dialog">
                    <i class="fa-solid fa-window-restore me-1" aria-hidden="true"></i> Open Dialog
                </button>
            </div>
            <div class="mb-4">
                <h6>Delete Confirmation</h6>
                <p class="small text-muted">Two-click delete pattern: Delete → Confirm Delete.</p>
                <DeleteConfirmation OnConfirmed="OnDeleteConfirmed"
                    CancelText="@Helpers.ConfirmButtonTextCancel"
                    DeleteText="@Helpers.ConfirmButtonTextDelete"
                    ConfirmDeleteText="@Helpers.ConfirmButtonTextConfirmDelete" />
            </div>
            </div>
        }

        @* === Forms & Inputs Tab === *@
        @if (_activeTab == "forms") {
            <div id="tab-forms" role="tabpanel" aria-labelledby="tabs-heading">

            @* Search with Clear — FreeCICD FilterBar pattern *@
            <div class="mb-4">
                <h6>Search with Clear Button</h6>
                <p class="small text-muted">Input group with search icon and dismissable clear button. Pattern from FreeCICD FilterBar.</p>
                <div class="input-group" style="max-width: 400px;">
                    <span class="input-group-text bg-white border-end-0" aria-hidden="true">
                        <i class="fa fa-search text-muted"></i>
                    </span>
                    <input type="text"
                           class="form-control border-start-0"
                           placeholder="Search items..."
                           @bind="_searchTerm"
                           @bind:event="oninput"
                           aria-label="Search items" />
                    @if (!string.IsNullOrWhiteSpace(_searchTerm)) {
                        <button class="btn btn-outline-secondary border-start-0" type="button"
                                @onclick="@(() => _searchTerm = "")" aria-label="Clear search">
                            <i class="fa fa-times" aria-hidden="true"></i>
                        </button>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(_searchTerm)) {
                    <div class="small text-muted mt-1">Searching for: <strong>@_searchTerm</strong></div>
                }
            </div>

            @* Toggle Switch — FreeCICD ViewControls pattern *@
            <div class="mb-4">
                <h6>Toggle Switches</h6>
                <p class="small text-muted">Bootstrap switch toggles for boolean settings. Pattern from FreeCICD Dashboard.</p>
                <div class="d-flex flex-column gap-2" style="max-width: 300px;">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" id="switch-notifications"
                               checked="@_enableNotifications" @onchange="@(e => _enableNotifications = (bool)(e.Value ?? false))" />
                        <label class="form-check-label" for="switch-notifications">
                            <i class="fa fa-bell me-1" aria-hidden="true"></i> Enable Notifications
                        </label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" id="switch-darkmode"
                               checked="@_darkMode" @onchange="@(e => _darkMode = (bool)(e.Value ?? false))" />
                        <label class="form-check-label" for="switch-darkmode">
                            <i class="fa fa-moon me-1" aria-hidden="true"></i> Dark Mode
                        </label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" id="switch-autosave"
                               checked="@_autoSave" @onchange="@(e => _autoSave = (bool)(e.Value ?? false))" />
                        <label class="form-check-label" for="switch-autosave">
                            <i class="fa fa-save me-1" aria-hidden="true"></i> Auto-Save
                        </label>
                    </div>
                </div>
                <div class="small text-muted mt-2">
                    State: Notifications=@_enableNotifications, DarkMode=@_darkMode, AutoSave=@_autoSave
                </div>
            </div>

            @* Inline Required Field Validation — FreeGLBA/PluginPrompts pattern *@
            <div class="mb-4">
                <h6>Required Field Validation (ADA)</h6>
                <p class="small text-muted">
                    Inline validation with <code>aria-required</code>, <code>aria-invalid</code>, and <code>role="alert"</code>.
                    Pattern from PluginPrompts and WizardDemo.
                </p>
                <div class="row g-3" style="max-width: 500px;">
                    <div class="col-12">
                        <label for="demo-email" class="form-label fw-semibold">
                            Email <span class="text-danger" aria-hidden="true">*</span>
                        </label>
                        <input type="email" id="demo-email"
                               class="form-control @(_showFormValidation && string.IsNullOrWhiteSpace(_demoEmail) ? "is-invalid" : !string.IsNullOrWhiteSpace(_demoEmail) ? "is-valid" : "")"
                               @bind="_demoEmail" @bind:event="oninput"
                               placeholder="user@example.com"
                               aria-required="true"
                               aria-describedby="email-help @(_showFormValidation && string.IsNullOrWhiteSpace(_demoEmail) ? "email-err" : "")"
                               aria-invalid="@(_showFormValidation && string.IsNullOrWhiteSpace(_demoEmail) ? "true" : null)" />
                        <div id="email-help" class="form-text">We'll never share your email.</div>
                        @if (_showFormValidation && string.IsNullOrWhiteSpace(_demoEmail)) {
                            <div id="email-err" class="invalid-feedback" role="alert">
                                <i class="fa fa-exclamation-circle me-1" aria-hidden="true"></i> Email is required.
                            </div>
                        }
                    </div>
                    <div class="col-12">
                        <label for="demo-dept" class="form-label fw-semibold">
                            Department <span class="text-danger" aria-hidden="true">*</span>
                        </label>
                        <select id="demo-dept"
                                class="form-select @(_showFormValidation && string.IsNullOrWhiteSpace(_demoDept) ? "is-invalid" : !string.IsNullOrWhiteSpace(_demoDept) ? "is-valid" : "")"
                                @bind="_demoDept"
                                aria-required="true"
                                aria-invalid="@(_showFormValidation && string.IsNullOrWhiteSpace(_demoDept) ? "true" : null)">
                            <option value="">-- Select --</option>
                            <option value="Engineering">Engineering</option>
                            <option value="Marketing">Marketing</option>
                            <option value="Operations">Operations</option>
                        </select>
                        @if (_showFormValidation && string.IsNullOrWhiteSpace(_demoDept)) {
                            <div class="invalid-feedback" role="alert">
                                <i class="fa fa-exclamation-circle me-1" aria-hidden="true"></i> Department is required.
                            </div>
                        }
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary btn-sm" @onclick="@(() => _showFormValidation = true)">
                            <i class="fa fa-check me-1" aria-hidden="true"></i> Validate
                        </button>
                        <button class="btn btn-outline-secondary btn-sm ms-1" @onclick="@(() => { _showFormValidation = false; _demoEmail = ""; _demoDept = ""; })">
                            Reset
                        </button>
                    </div>
                </div>
            </div>

            </div>
        }

        @* === Layout Patterns Tab === *@
        @if (_activeTab == "layout") {
            <div id="tab-layout" role="tabpanel" aria-labelledby="tabs-heading">

            @* Accordion / Collapsible Sections *@
            <div class="mb-4">
                <h6>Accordion / Collapsible Sections</h6>
                <p class="small text-muted">Bootstrap accordion for expandable content sections.</p>
                <div class="accordion" id="demoAccordion">
                    @for (int i = 0; i < _accordionItems.Count; i++) {
                        var idx = i;
                        var item = _accordionItems[i];
                        var isOpen = _openAccordion == idx;
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button @(!isOpen ? "collapsed" : "")" type="button"
                                        @onclick="@(() => _openAccordion = isOpen ? -1 : idx)"
                                        aria-expanded="@isOpen"
                                        aria-controls="accordion-@idx">
                                    <i class="@item.Icon me-2" aria-hidden="true"></i> @item.Title
                                </button>
                            </h2>
                            @if (isOpen) {
                                <div id="accordion-@idx" class="accordion-collapse collapse show">
                                    <div class="accordion-body">@item.Content</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            @* Card / Table View Toggle — FreeCICD ViewControls pattern *@
            <div class="mb-4">
                <h6>Card / Table View Toggle</h6>
                <p class="small text-muted">Switch between card and table views. Pattern from FreeCICD Pipeline Dashboard.</p>
                <div class="btn-group mb-3" role="group" aria-label="View mode">
                    <button type="button" class="btn @(_viewMode == "card" ? "btn-primary" : "btn-outline-primary")"
                            @onclick="@(() => _viewMode = "card")">
                        <i class="fa fa-th-large me-1" aria-hidden="true"></i> Cards
                    </button>
                    <button type="button" class="btn @(_viewMode == "table" ? "btn-primary" : "btn-outline-primary")"
                            @onclick="@(() => _viewMode = "table")">
                        <i class="fa fa-list me-1" aria-hidden="true"></i> Table
                    </button>
                </div>

                @if (_viewMode == "card") {
                    <div class="row row-cols-1 row-cols-md-3 g-2">
                        @foreach (var item in _items.Take(3)) {
                            <div class="col">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body py-2">
                                        <h6 class="card-title mb-1">@item.Name</h6>
                                        <div class="small text-muted">@item.Category</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                } else {
                    <div class="table-responsive">
                        <table class="table table-striped table-sm" aria-label="Sample items">
                            <thead class="table-dark">
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Category</th>
                                    <th scope="col">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _items.Take(3)) {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@item.Category</td>
                                        <td><span class="badge @GetBadge(item.Status)">@item.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            @* Progress Bars *@
            <div class="mb-4">
                <h6>Progress Bars</h6>
                <p class="small text-muted">Various progress bar styles for showing completion status.</p>
                <div class="d-flex flex-column gap-3" style="max-width: 500px;">
                    <div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Build Pipeline</span>
                            <span>75%</span>
                        </div>
                        <div class="progress" role="progressbar" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100" aria-label="Build pipeline progress">
                            <div class="progress-bar bg-primary" style="width: 75%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Test Coverage</span>
                            <span>42%</span>
                        </div>
                        <div class="progress" role="progressbar" aria-valuenow="42" aria-valuemin="0" aria-valuemax="100" aria-label="Test coverage progress">
                            <div class="progress-bar bg-warning" style="width: 42%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Deployment</span>
                            <span>100%</span>
                        </div>
                        <div class="progress" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100" aria-label="Deployment progress">
                            <div class="progress-bar bg-success" style="width: 100%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="small mb-1">Striped + Animated</div>
                        <div class="progress" role="progressbar" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100" aria-label="Animated progress">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" style="width: 60%"></div>
                        </div>
                    </div>
                </div>
            </div>

            </div>
        }

        @* === Feedback & Alerts Tab === *@
        @if (_activeTab == "feedback") {
            <div id="tab-feedback" role="tabpanel" aria-labelledby="tabs-heading">

            @* Toast Notifications — ToastMessages pattern *@
            <div class="mb-4">
                <h6>Toast Notifications</h6>
                <p class="small text-muted">Trigger toast messages using the framework's <code>Model.AddMessage()</code> pattern.</p>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-success btn-sm" @onclick="@(() => Model.AddMessage("Item saved successfully!", MessageType.Success))">
                        <i class="fa fa-check me-1" aria-hidden="true"></i> Success Toast
                    </button>
                    <button class="btn btn-danger btn-sm" @onclick="@(() => Model.AddMessage("Something went wrong.", MessageType.Danger))">
                        <i class="fa fa-times me-1" aria-hidden="true"></i> Error Toast
                    </button>
                    <button class="btn btn-warning btn-sm" @onclick="@(() => Model.AddMessage("Please review before saving.", MessageType.Warning))">
                        <i class="fa fa-exclamation-triangle me-1" aria-hidden="true"></i> Warning Toast
                    </button>
                    <button class="btn btn-info btn-sm" @onclick="@(() => Model.AddMessage("New items are available.", MessageType.Info))">
                        <i class="fa fa-info-circle me-1" aria-hidden="true"></i> Info Toast
                    </button>
                </div>
            </div>

            @* Loading / Spinner Variants *@
            <div class="mb-4">
                <h6>Loading Spinners</h6>
                <p class="small text-muted">Various spinner patterns used for loading states. Pattern from FreeCICD Wizard.</p>
                <div class="d-flex flex-wrap gap-4 align-items-center">
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status" aria-label="Loading">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <div class="small text-muted mt-1">Border</div>
                    </div>
                    <div class="text-center">
                        <div class="spinner-grow text-success" role="status" aria-label="Loading">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <div class="small text-muted mt-1">Grow</div>
                    </div>
                    <div class="text-center">
                        <div class="spinner-border spinner-border-sm text-danger" role="status" aria-label="Loading">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <div class="small text-muted mt-1">Small</div>
                    </div>
                    <div class="text-center">
                        <button class="btn btn-primary btn-sm" disabled>
                            <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                            Saving...
                        </button>
                        <div class="small text-muted mt-1">In Button</div>
                    </div>
                </div>
            </div>

            @* Alert Variants *@
            <div class="mb-4">
                <h6>Alert Variants</h6>
                <p class="small text-muted">Standard Bootstrap alerts with dismiss and icons.</p>
                <div class="alert alert-success d-flex align-items-center" role="alert">
                    <i class="fa fa-check-circle me-2" aria-hidden="true"></i>
                    <div>Changes saved successfully.</div>
                </div>
                <div class="alert alert-warning d-flex align-items-center" role="alert">
                    <i class="fa fa-exclamation-triangle me-2" aria-hidden="true"></i>
                    <div>This action cannot be undone.</div>
                </div>
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                    <i class="fa fa-times-circle me-2" aria-hidden="true"></i>
                    <div>Connection lost. Retrying...</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <div class="alert alert-info d-flex align-items-center" role="alert">
                    <i class="fa fa-info-circle me-2" aria-hidden="true"></i>
                    <div>Tip: Use <kbd>Ctrl+S</kbd> to save quickly.</div>
                </div>
            </div>

            @* Empty State Placeholder *@
            <div class="mb-4">
                <h6>Empty State Placeholder</h6>
                <p class="small text-muted">Pattern for when there is no data to display.</p>
                <div class="card border-dashed border-2 bg-light">
                    <div class="card-body text-center py-5">
                        <i class="fa fa-inbox fa-3x text-muted mb-3" aria-hidden="true"></i>
                        <h6 class="text-muted">No Items Found</h6>
                        <p class="small text-muted mb-3">There are no items matching your criteria. Try adjusting your filters or create a new item.</p>
                        <button class="btn btn-primary btn-sm">
