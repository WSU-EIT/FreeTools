@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "bootstrapshowcase";
    private string _activeTab = "cards";
    private List<DataObjects.SampleItem> _items = new();
    private Guid? _confirmDeleteId;

    // Forms & Inputs tab
    private string _searchTerm = "";
    private bool _enableNotifications = true;
    private bool _darkMode = false;
    private bool _autoSave = true;
    private string _demoEmail = "";
    private string _demoDept = "";
    private bool _showFormValidation = false;

    // Layout Patterns tab
    private string _viewMode = "card";
    private int _openAccordion = 0;
    private List<AccordionItem> _accordionItems = new() {
        new("fa fa-cog", "Configuration", "Application settings and environment configuration. Use appsettings.json for environment-specific values and user secrets for sensitive data."),
        new("fa fa-database", "Database", "Entity Framework Core with SQL Server. Migrations are auto-applied on startup. Use the DataAccess layer for all database operations."),
        new("fa fa-shield", "Security", "Authentication via cookie-based login with optional SSO providers. Role-based authorization with tenant isolation."),
    };

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            await LoadData();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    private async Task LoadData()
    {
        var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
        if (result != null) _items = result;

        _loading = false;
        StateHasChanged();
    }

    private async Task OpenDialog()
    {
        await DialogService.OpenAsync<GetInputDialog>(
            "Example Dialog",
            new Dictionary<string, object> { { "Message", "This is a Radzen DialogService example." } },
            new Radzen.DialogOptions { Width = "400px", Height = "auto" });
    }

    private void OnDeleteConfirmed()
    {
        Model.AddMessage("Delete confirmed! (demo only — nothing was actually deleted)", MessageType.Success);
    }

    private void OnEditClicked(DataObjects.SampleItem item)
    {
        Helpers.NavigateTo("Examples/EditSampleItem/" + item.SampleItemId.ToString());
    }

    private void RequestDelete(DataObjects.SampleItem item)
    {
        _confirmDeleteId = item.SampleItemId;
        StateHasChanged();
    }

    private void CancelDelete()
    {
        _confirmDeleteId = null;
        StateHasChanged();
    }

    private async Task ConfirmDelete(DataObjects.SampleItem item)
    {
        var result = await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/DeleteSampleItems", new List<Guid> { item.SampleItemId });
        if (result != null && result.Result) {
            _items.Remove(item);
            Model.AddMessage($"Deleted '{item.Name}'.", MessageType.Success);
        } else {
            Model.AddMessage($"Failed to delete '{item.Name}'.", MessageType.Danger);
        }
        _confirmDeleteId = null;
        StateHasChanged();
    }

    private static string GetBadge(DataObjects.SampleItemStatus status) => status switch {
        DataObjects.SampleItemStatus.Active => "bg-success",
        DataObjects.SampleItemStatus.Completed => "bg-info",
        DataObjects.SampleItemStatus.Archived => "bg-secondary",
        _ => "bg-warning text-dark",
    };

    private record AccordionItem(string Icon, string Title, string Content);
