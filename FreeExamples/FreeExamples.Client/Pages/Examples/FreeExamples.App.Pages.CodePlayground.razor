@page "/Examples/CodePlayground"
@page "/{TenantCode}/Examples/CodePlayground"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-laptop-code me-1"></i> Code Playground</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-laptop-code me-1"></i> Code Playground
                <StickyMenuIcon />
            </h1>
        </div>

        <ExampleNav />

        <AboutSection Title="About Code Playground" Subtitle="Multiple editors, diff views, and auto-save — every Monaco feature in one place" IconClass="fa-solid fa-laptop-code">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        The Code Editor demo showed the basics. This page goes deeper: <strong>multiple editors</strong>
                        on one page, a <strong>diff viewer</strong> that highlights differences between two versions,
                        and an <strong>API notebook</strong> where you type JSON and send it to a real server endpoint —
                        then see the response in a second editor. Think of it like Postman or CodePen inside the app.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Diff viewer</strong> — see exactly what changed between two versions, like Git</li>
                        <li><strong>Multiple editors</strong> — two editors on one page, each with its own language and state</li>
                        <li><strong>Auto-save with debounce</strong> — saves to the server after you stop typing for 2 seconds</li>
                        <li><strong>API round-trip</strong> — type JSON, post it, see the server response in real time</li>
                        <li><strong>Cursor position tracking</strong> — shows Line/Column like VS Code's status bar</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Is It Different?</h6>
                    <p class="small text-muted mb-0">
                        The Code Editor demo shows <strong>one editor with two-way binding</strong>. This page shows
                        how real applications use Monaco: configuration editors where changes auto-save, API testing
                        consoles with request/response panels, and diff views for reviewing changes before applying them.
                        The Monaco component already supports all of this — we just need to use the right parameters.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Tab Navigation ── *@
        <ul class="nav nav-tabs mb-3" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == "diff" ? "active" : "")" @onclick="@(() => _activeTab = "diff")" role="tab" aria-selected="@(_activeTab == "diff")">
                    <i class="fa-solid fa-code-compare me-1"></i> Diff Viewer
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(_activeTab == "notebook" ? "active" : "")" @onclick="@(() => _activeTab = "notebook")" role="tab" aria-selected="@(_activeTab == "notebook")">
                    <i class="fa-solid fa-paper-plane me-1"></i> API Notebook
                </button>
            </li>
        </ul>

        @* ══════════════════════════════════════════════════
           TAB 1: Diff Viewer
           ══════════════════════════════════════════════════ *@
        @if (_activeTab == "diff") {
            <div role="tabpanel">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <label class="form-label mb-0 small text-muted">Sample:</label>
                    <select class="form-select form-select-sm" style="width:auto;" @bind="_selectedDiffSample" @bind:after="LoadDiffSample">
                        <option value="csharp-refactor">C# — Refactored Method</option>
                        <option value="json-config">JSON — Config Change</option>
                        <option value="html-update">HTML — Added Section</option>
                        <option value="sql-optimize">SQL — Query Optimization</option>
                    </select>

                    <div class="btn-group" role="group" aria-label="Diff view mode">
                        <button type="button" class="btn btn-sm @(_diffSideBySide ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => SetDiffMode(true))">
                            <i class="fa-solid fa-columns me-1"></i> Side by Side
                        </button>
                        <button type="button" class="btn btn-sm @(!_diffSideBySide ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => SetDiffMode(false))">
                            <i class="fa-solid fa-bars me-1"></i> Inline
                        </button>
                    </div>

                    <InfoTip Title="Diff Viewer"
                             Description="The diff editor shows two versions of a file side-by-side with changes highlighted in red (removed) and green (added). This is the same visual pattern as GitHub pull requests, VS Code's diff view, and Git's 'diff' command. The MonacoEditor component switches to diff mode when you provide a ValueToDiff parameter."
                             Code="@_codeDiff" />
                </div>

                @if (_diffSideBySide) {
                    <MonacoEditor @ref="_diffEditor"
                        Language="@_diffLanguage"
                        Value="@_diffModified"
                        ValueToDiff="@_diffOriginal"
                        MinHeight="400px"
                        ReadOnly="true"
                        Id="diff-editor" />
                } else {
                    <MonacoEditor @ref="_diffEditorInline"
                        Language="@_diffLanguage"
                        Value="@_diffModified"
                        ValueToDiff="@_diffOriginal"
                        MinHeight="400px"
                        ReadOnly="true"
                        Id="diff-editor-inline"
                        ConstructorOptionsForDiffEditor="@_inlineDiffOptions" />
                }

                <div class="mt-2 small text-muted">
                    <i class="fa-solid fa-circle-info me-1"></i>
                    Red = removed from original. Green = added in modified. Use the dropdown above to load different diff samples.
                </div>
            </div>
        }

        @* ══════════════════════════════════════════════════
           TAB 2: API Notebook
           ══════════════════════════════════════════════════ *@
        @if (_activeTab == "notebook") {
            <div role="tabpanel">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <label class="form-label mb-0 small text-muted">Endpoint:</label>
                    <select class="form-select form-select-sm" style="width:auto;" @bind="_selectedEndpoint" @bind:after="LoadEndpointTemplate">
                        <option value="GetSampleItems">GetSampleItems (all)</option>
                        <option value="GetSampleDashboard">GetSampleDashboard</option>
                        <option value="GetSampleItemsFiltered">GetSampleItemsFiltered</option>
                        <option value="GetSampleGraphData">GetSampleGraphData</option>
                    </select>

                    <button class="btn btn-sm btn-success" @onclick="ExecuteRequest" disabled="@_executing">
                        @if (_executing) {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        } else {
                            <i class="fa-solid fa-play me-1"></i>
                        }
                        Send Request
                    </button>

                    @if (_lastResponse != null) {
                        <span class="badge @(_lastResponse.Success ? "bg-success" : "bg-danger") ms-1">
                            @_lastResponse.StatusCode
                        </span>
                        <span class="small text-muted">@(_lastResponse.DurationMs)ms</span>
                    }

                    <InfoTip Title="API Notebook"
                             Description="Type a JSON request body in the left editor, pick an endpoint from the dropdown, and click Send. The server executes the request and returns the JSON response in the right editor. This is the same workflow as Postman or the browser's DevTools Network tab — but built into the app."
                             Code="@_codeNotebook" />

                    @* Auto-save status *@
                    <span class="ms-auto small">
                        @if (_autoSaveStatus == "saving") {
                            <span class="text-warning"><i class="fa-solid fa-spinner fa-spin me-1"></i>Saving...</span>
                        } else if (_autoSaveStatus == "saved") {
                            <span class="text-success"><i class="fa-solid fa-circle-check me-1"></i>Saved @_lastSavedTime</span>
                        } else if (_autoSaveStatus == "error") {
                            <span class="text-danger"><i class="fa-solid fa-circle-xmark me-1"></i>Save failed</span>
                        }
                        <InfoTip Title="Auto-Save"
                                 Description="The Monaco component has a built-in Timeout parameter (default 1000ms). Every time you stop typing for that duration, the ValueChanged event fires. We catch that event and POST the content to api/Data/SaveCodeSnippet. The status indicator shows Saving → Saved ✓ with timestamp, or Error ✗ if the server call fails."
                                 Code="@_codeAutoSave" />
                    </span>
                </div>

                <div class="row g-2">
                    @* Request Editor *@
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-dark text-white py-1 d-flex justify-content-between align-items-center">
                                <span class="small fw-semibold"><i class="fa-solid fa-arrow-up-right-from-square me-1"></i> Request Body</span>
                                <span class="small opacity-75">@_selectedEndpoint</span>
                            </div>
                            <div class="card-body p-0">
                                <MonacoEditor @ref="_requestEditor"
                                    Language="@MonacoEditor.MonacoLanguage.json"
                                    @bind-Value="_requestBody"
                                    MinHeight="350px"
                                    Timeout="2000"
                                    PlaceholderText="Type your JSON request body here..."
                                    Id="request-editor" />
                            </div>
                            <div class="card-footer bg-light py-1 d-flex justify-content-between align-items-center">
                                <span class="small text-muted font-monospace">
                                    Ln @(_requestEditor?.EditorCursorPosition?.LineNumber ?? 1), Col @(_requestEditor?.EditorCursorPosition?.Column ?? 1)
                                    <InfoTip Title="Cursor Position"
                                             Description="The Monaco component tracks cursor position via the EditorCursorPosition property. Every time you move the cursor, an event updates the Line and Column numbers — just like the status bar in VS Code. This requires no extra code; the component already exposes it."
                                             Code="@_codeCursor" />
                                </span>
                                <span class="small text-muted">JSON</span>
                            </div>
                        </div>
                    </div>

                    @* Response Editor *@
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-dark text-white py-1 d-flex justify-content-between align-items-center">
                                <span class="small fw-semibold"><i class="fa-solid fa-arrow-down-to-line me-1"></i> Response</span>
                                @if (_lastResponse != null) {
                                    <span class="small opacity-75">@_lastResponse.ResponseBody.Length.ToString("N0") bytes</span>
                                }
                            </div>
                            <div class="card-body p-0">
                                <MonacoEditor @ref="_responseEditor"
                                    Language="@MonacoEditor.MonacoLanguage.json"
                                    @bind-Value="_responseBody"
                                    MinHeight="350px"
                                    ReadOnly="true"
                                    PlaceholderText="Response will appear here after you click Send..."
                                    Id="response-editor" />
                            </div>
                            <div class="card-footer bg-light py-1 d-flex justify-content-between align-items-center">
                                <span class="small text-muted">Read-only
                                    <InfoTip Title="Read-Only Editor"
                                             Description="The response editor is read-only — you can select and copy text, but you can't type in it. This is set with the ReadOnly parameter. The component calls Monaco's updateOptions({ readOnly: true }) through JS interop. The same pattern is used in the Git Browser for viewing source files."
                                             Code="@_codeReadOnly" />
                                </span>
                                <span class="small text-muted">JSON</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* Saved Snippets *@
                @if (_savedSnippets.Any()) {
                    <div class="card mt-3 shadow-sm border-0">
                        <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
                            <span class="small fw-semibold">
                                <i class="fa-solid fa-bookmark me-1"></i> Saved Snippets (@_savedSnippets.Count)
                                <InfoTip Title="Saved Snippets"
                                         Description="Every time auto-save fires, the current request body is stored on the server via SaveCodeSnippet. You can click any saved snippet to reload it into the request editor. This demonstrates the full round-trip: type → debounce → save → reload."
                                         Code="@_codeSnippets" />
                            </span>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadSnippets">
                                <i class="fa-solid fa-arrows-rotate me-1"></i> Refresh
                            </button>
                        </div>
                        <div class="card-body p-0" style="max-height:150px; overflow-y:auto;">
                            <table class="table table-sm table-hover mb-0">
                                <tbody>
                                    @foreach (var snippet in _savedSnippets) {
                                        <tr class="cursor-pointer @(snippet.SnippetId == _currentSnippetId ? "table-active" : "")"
                                            @onclick="@(() => LoadSnippetIntoEditor(snippet))">
                                            <td class="small fw-semibold">@snippet.Title</td>
                                            <td class="small text-muted">@snippet.Language</td>
                                            <td class="small text-muted text-end">@snippet.LastSaved.ToLocalTime().ToString("h:mm:ss tt")</td>
                                            <td style="width:1%;">
                                                <button class="btn btn-xs btn-outline-danger" @onclick:stopPropagation @onclick="@(() => DeleteSnippet(snippet.SnippetId))">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "codeplayground";
    private string _activeTab = "diff";

    // InfoTip code snippets
    private string _codeDiff = "<MonacoEditor\n    Value=\"@_diffModified\"\n    ValueToDiff=\"@_diffOriginal\"\n    ReadOnly=\"true\" />";
    private string _codeNotebook = "var response = await Helpers.GetOrPost<...>(\n    \"api/Data/ExecuteCodePlayground\",\n    new { Endpoint = \"GetSampleItems\", Body = editorContent });";
    private string _codeAutoSave = "// MonacoEditor Timeout=\"2000\" means ValueChanged fires 2s after last keystroke\n<MonacoEditor @bind-Value=\"_requestBody\" Timeout=\"2000\" />\n\n// In the ValueChanged handler:\nawait Helpers.GetOrPost<CodeSnippet>(\"api/Data/SaveCodeSnippet\", snippet);";
    private string _codeCursor = "_requestEditor.EditorCursorPosition.LineNumber\n_requestEditor.EditorCursorPosition.Column";
    private string _codeReadOnly = "<MonacoEditor ReadOnly=\"true\" />";
    private string _codeSnippets = "var snippets = await Helpers.GetOrPost<List<CodeSnippet>>(\"api/Data/GetCodeSnippets\", new List<Guid>());";

    // ── Diff Viewer State ──
    private string _selectedDiffSample = "csharp-refactor";
    private bool _diffSideBySide = true;
    private string _diffOriginal = "";
    private string _diffModified = "";
    private string _diffLanguage = MonacoEditor.MonacoLanguage.csharp;
    private MonacoEditor? _diffEditor;
    private MonacoEditor? _diffEditorInline;
    private BlazorMonaco.Editor.StandaloneDiffEditorConstructionOptions _inlineDiffOptions = new() {
        AutomaticLayout = true,
        RenderSideBySide = false,
        OriginalEditable = false,
        ReadOnly = true,
        ScrollBeyondLastLine = false,
        WordWrap = "on",
        WrappingIndent = "same",
    };

    // ── API Notebook State ──
    private string _selectedEndpoint = "GetSampleItems";
    private string _requestBody = "[]";
    private string _responseBody = "";
    private bool _executing = false;
    private DataObjects.CodePlaygroundResponse? _lastResponse;
    private MonacoEditor? _requestEditor;
    private MonacoEditor? _responseEditor;

    // Auto-save state
    private string _autoSaveStatus = "";
    private string _lastSavedTime = "";
    private Guid _currentSnippetId = Guid.Empty;
    private string _previousRequestBody = "";
    private System.Timers.Timer? _autoSaveTimer;

    // Saved snippets
    private List<DataObjects.CodeSnippet> _savedSnippets = new();

    // ── Lifecycle ──

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
        _autoSaveTimer?.Dispose();
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }

        _autoSaveTimer = new System.Timers.Timer(2500);
        _autoSaveTimer.Elapsed += AutoSaveTimerElapsed;
        _autoSaveTimer.AutoReset = false;

        LoadDiffSample();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            await LoadSnippets();
            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    // ── Diff Viewer ──

    private void LoadDiffSample()
    {
        switch (_selectedDiffSample) {
            case "csharp-refactor":
                _diffLanguage = MonacoEditor.MonacoLanguage.csharp;
                _diffOriginal = "public class UserService\n{\n    public string GetDisplayName(string firstName, string lastName)\n    {\n        if (firstName != null && lastName != null)\n        {\n            return firstName + \" \" + lastName;\n        }\n        else if (firstName != null)\n        {\n            return firstName;\n        }\n        else\n        {\n            return \"Unknown\";\n        }\n    }\n}";
                _diffModified = "public class UserService\n{\n    public string GetDisplayName(string? firstName, string? lastName)\n    {\n        var parts = new[] { firstName, lastName }\n            .Where(p => !string.IsNullOrWhiteSpace(p));\n\n        return parts.Any()\n            ? string.Join(\" \", parts)\n            : \"Unknown\";\n    }\n}";
                break;
            case "json-config":
                _diffLanguage = MonacoEditor.MonacoLanguage.json;
                _diffOriginal = "{\n    \"ConnectionStrings\": {\n        \"Default\": \"Server=localhost;Database=MyApp;Trusted_Connection=True\"\n    },\n    \"Logging\": {\n        \"LogLevel\": {\n            \"Default\": \"Warning\"\n        }\n    }\n}";
                _diffModified = "{\n    \"ConnectionStrings\": {\n        \"Default\": \"Server=prod-sql.example.com;Database=MyApp;User Id=app_user;Password=***\"\n    },\n    \"Logging\": {\n        \"LogLevel\": {\n            \"Default\": \"Information\",\n            \"Microsoft.AspNetCore\": \"Warning\"\n        }\n    },\n    \"Redis\": {\n        \"ConnectionString\": \"prod-redis.example.com:6380,ssl=true\"\n    }\n}";
                break;
            case "html-update":
                _diffLanguage = MonacoEditor.MonacoLanguage.html;
                _diffOriginal = "<div class=\"container\">\n    <h1>Welcome</h1>\n    <p>This is the home page.</p>\n</div>";
                _diffModified = "<div class=\"container\">\n    <h1>Welcome</h1>\n    <p>This is the home page.</p>\n\n    <div class=\"alert alert-info mt-3\">\n        <h4><i class=\"fa-solid fa-info-circle\"></i> What's New</h4>\n        <ul>\n            <li>Added dark mode support</li>\n            <li>Improved search performance</li>\n            <li>Fixed CSV export bug</li>\n        </ul>\n    </div>\n</div>";
                break;
            case "sql-optimize":
                _diffLanguage = MonacoEditor.MonacoLanguage.sql;
                _diffOriginal = "SELECT *\nFROM Users u\nWHERE u.DepartmentId IN (\n    SELECT d.DepartmentId\n    FROM Departments d\n    WHERE d.IsActive = 1\n)\nORDER BY u.LastName";
                _diffModified = "SELECT u.UserId, u.FirstName, u.LastName, u.Email\nFROM Users u\nINNER JOIN Departments d\n    ON u.DepartmentId = d.DepartmentId\n    AND d.IsActive = 1\nWHERE u.Enabled = 1\nORDER BY u.LastName, u.FirstName";
                break;
        }
    }

    private void SetDiffMode(bool sideBySide)
    {
        _diffSideBySide = sideBySide;
    }

    // ── API Notebook ──

    private void LoadEndpointTemplate()
    {
        _requestBody = _selectedEndpoint switch {
            "GetSampleItems" => "[]",
            "GetSampleDashboard" => "// No request body needed — this is a GET-style endpoint",
            "GetSampleItemsFiltered" => "{\n    \"Keyword\": \"\",\n    \"Status\": \"\",\n    \"Category\": \"\",\n    \"Page\": 1,\n    \"PageSize\": 10,\n    \"SortField\": \"Name\",\n    \"SortOrder\": \"asc\"\n}",
            "GetSampleGraphData" => "// No request body needed — returns nodes and edges for vis.js",
            _ => "{}",
        };

        _responseBody = "";
        _lastResponse = null;
        _currentSnippetId = Guid.Empty;

        // Reset the auto-save tracking
        _previousRequestBody = _requestBody;
    }

    private async Task ExecuteRequest()
    {
        _executing = true;
        StateHasChanged();

        // Get current value from the request editor
        var body = _requestBody;
        if (_requestEditor != null) {
            body = await _requestEditor.GetValue();
        }

        // Strip comment lines from request body for endpoints that don't need a body
        var cleanBody = string.Join("\n", body.Split('\n').Where(l => !l.TrimStart().StartsWith("//")));

        var request = new DataObjects.CodePlaygroundRequest {
            Endpoint = _selectedEndpoint,
            Body = cleanBody,
        };

        var result = await Helpers.GetOrPost<DataObjects.CodePlaygroundResponse>("api/Data/ExecuteCodePlayground", request);
        if (result != null) {
            _lastResponse = result;
            _responseBody = result.ResponseBody;
            if (_responseEditor != null) {
                await _responseEditor.SetValue(_responseBody);
            }
        }

        _executing = false;
        StateHasChanged();
    }

    // ── Auto-Save ──

    private async void AutoSaveTimerElapsed(object? source, System.Timers.ElapsedEventArgs e)
    {
        await InvokeAsync(async () => {
            // Only save if content actually changed
            if (_requestBody == _previousRequestBody) return;
            _previousRequestBody = _requestBody;

            _autoSaveStatus = "saving";
            StateHasChanged();

            var snippet = new DataObjects.CodeSnippet {
                SnippetId = _currentSnippetId,
                Title = _selectedEndpoint + " — " + DateTime.Now.ToString("h:mm tt"),
                Content = _requestBody,
                Language = "json",
            };

            var result = await Helpers.GetOrPost<DataObjects.CodeSnippet>("api/Data/SaveCodeSnippet", snippet);
            if (result != null) {
                _currentSnippetId = result.SnippetId;
                _autoSaveStatus = "saved";
                _lastSavedTime = DateTime.Now.ToString("h:mm:ss tt");

                // Refresh snippet list
                await LoadSnippets();
            } else {
                _autoSaveStatus = "error";
            }

            StateHasChanged();
        });
    }

    // Trigger auto-save when the request body changes via Monaco's debounced ValueChanged
    protected override void OnParametersSet()
    {
        // The @bind-Value on the request editor fires ValueChanged after the Timeout delay.
        // We use our own timer on top to batch and detect actual changes.
        if (_autoSaveTimer != null && _activeTab == "notebook" && _requestBody != _previousRequestBody) {
            _autoSaveTimer.Stop();
            _autoSaveTimer.Start();
        }
    }

    // ── Snippets ──

    private async Task LoadSnippets()
    {
        var result = await Helpers.GetOrPost<List<DataObjects.CodeSnippet>>("api/Data/GetCodeSnippets", new List<Guid>());
        if (result != null) {
            _savedSnippets = result;
        }
    }

    private async Task LoadSnippetIntoEditor(DataObjects.CodeSnippet snippet)
    {
        _currentSnippetId = snippet.SnippetId;
        _requestBody = snippet.Content;
        _previousRequestBody = snippet.Content;

        if (_requestEditor != null) {
            await _requestEditor.SetValue(snippet.Content);
        }
    }

    private async Task DeleteSnippet(Guid id)
    {
        await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/DeleteCodeSnippet", id);
        _savedSnippets.RemoveAll(s => s.SnippetId == id);
        if (_currentSnippetId == id) {
            _currentSnippetId = Guid.Empty;
        }
        StateHasChanged();
    }
}
