@page "/Examples/CodeEditorV3"
@page "/{TenantCode}/Examples/CodeEditorV3"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-file-code me-1"></i> Config Editor</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-file-code me-1"></i> V3: Configuration File Editor <StickyMenuIcon /></h1></div>
        <AboutSection Title="Code Editor in Context: Config Editor" Subtitle="Edit appsettings.json / YAML config files with validation feedback" IconClass="fa-solid fa-file-code">
            <p class="small text-muted mb-0">A code editor showing configuration files (JSON/YAML) with real-time validation. Edit appsettings.json and see parsed results — the Azure Portal config blade pattern.</p>
        </AboutSection>
        <div class="row">
            <div class="col-md-4 mb-3"><div class="card shadow-sm border-0"><div class="card-header bg-white py-2"><span class="small fw-semibold">Config Files</span></div><div class="card-body p-0"><div class="list-group list-group-flush">
                @foreach (var f in new[] { "appsettings.json", "appsettings.Development.json", "launchSettings.json" }) {
                    <a href="#" class="list-group-item list-group-item-action py-2 @(f == _activeFile ? "active" : "")" @onclick="@(() => _activeFile = f)" @onclick:preventDefault><i class="fa-solid fa-file-code me-1 small"></i><span class="small">@f</span></a>
                }
            </div></div></div></div>
            <div class="col-md-8 mb-3"><div class="card shadow-sm border-0"><div class="card-header bg-dark text-white py-1 d-flex justify-content-between"><span class="small">@_activeFile</span><button class="btn btn-sm btn-outline-light" @onclick="Validate"><i class="fa-solid fa-check me-1"></i> Validate</button></div>
                <pre class="bg-dark text-light p-3 mb-0" style="font-size:0.75rem; min-height:300px;">@GetContent()</pre>
                @if (_validated) { <div class="card-footer bg-success bg-opacity-10 border-success py-1"><span class="small text-success"><i class="fa-solid fa-circle-check me-1"></i> Valid JSON — no errors found</span></div> }
            </div></div>
        </div>
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false, _validated = false;
    private string _pageName = "codeeditorv3";
    private string _activeFile = "appsettings.json";
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
    private void Validate() { _validated = true; }
    private string GetContent() => _activeFile switch {
        "appsettings.json" => "{\n  \"ConnectionStrings\": {\n    \"DefaultConnection\": \"Server=.;Database=FreeExamples;Trusted_Connection=true\"\n  },\n  \"Logging\": {\n    \"LogLevel\": {\n      \"Default\": \"Information\"\n    }\n  },\n  \"AllowedHosts\": \"*\"\n}",
        "appsettings.Development.json" => "{\n  \"DetailedErrors\": true,\n  \"Logging\": {\n    \"LogLevel\": {\n      \"Default\": \"Debug\",\n      \"Microsoft.AspNetCore\": \"Warning\"\n    }\n  }\n}",
        _ => "{\n  \"profiles\": {\n    \"https\": {\n      \"commandName\": \"Project\",\n      \"launchBrowser\": true,\n      \"applicationUrl\": \"https://localhost:7001\"\n    }\n  }\n}"
    };
}
