@page "/Examples/KanbanBoard"
@page "/{TenantCode}/Examples/KanbanBoard"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><Icon Name="Settings" /> Kanban Board</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-columns me-1"></i> Kanban Board
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="About Kanban Boards" Subtitle="Drag-and-drop cards between status columns — the Trello pattern" IconClass="fa-solid fa-columns">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is a Kanban Board?</h6>
                    <p class="small text-muted mb-0">
                        A <strong>Kanban board</strong> shows work items as cards organized into columns by status.
                        You drag a card from one column to another to change its status — for example, dragging
                        from "Draft" to "Active" marks the item as active. This is the same pattern used by
                        <strong>Trello</strong>, <strong>Jira</strong>, and <strong>Azure DevOps Boards</strong>.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>HTML5 Drag & Drop</strong> — native browser API, no JavaScript library needed</li>
                        <li><strong>Visual feedback</strong> — columns highlight when a card is dragged over them</li>
                        <li><strong>Server persistence</strong> — status changes save to the database immediately</li>
                        <li><strong>SignalR sync</strong> — drag in one tab, see it move in another tab instantly</li>
                        <li><strong>Responsive design</strong> — columns stack vertically on mobile</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-gears me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        Blazor exposes the browser's native drag events as C# callbacks: <code>ondragstart</code> remembers
                        which card you picked up, <code>ondragover</code> highlights the target column, and
                        <code>ondrop</code> updates the item's status and saves it to the server. The entire interaction
                        happens without writing a single line of JavaScript — Blazor handles all the event wiring.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Toolbar ── *@
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <button type="button" class="btn btn-dark" @onclick="LoadData" disabled="@_saving">
                <i class="fa-solid fa-arrows-rotate me-1"></i> Refresh
            </button>

            @* Category filter *@
            <select class="form-select form-select-sm" style="width:auto;" @bind="_categoryFilter" @bind:after="ApplyFilter">
                <option value="">All Categories</option>
                @foreach (var cat in _allCategories) {
                    <option value="@cat">@cat</option>
                }
            </select>

            @* Search *@
            <div class="input-group input-group-sm" style="max-width:220px;">
                <span class="input-group-text bg-white"><i class="fa-solid fa-search text-muted"></i></span>
                <input type="text" class="form-control" placeholder="Search cards..." @bind="_searchTerm" @bind:event="oninput" @bind:after="ApplyFilter" />
                @if (!string.IsNullOrWhiteSpace(_searchTerm)) {
                    <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                        <i class="fa-solid fa-times"></i>
                    </button>
                }
            </div>

            @* Totals *@
            <span class="text-muted small ms-auto">
                @_filteredItems.Count items
                <InfoTip Title="Kanban Board"
                         Description="Each column represents a status. Drag a card from one column to another to change its status. The card count and total amount update in each column header. Changes save to the server immediately and broadcast via SignalR to other browser tabs."
                         Code="@_codeBoard" />
            </span>
        </div>

        @* ── Kanban Columns ── *@
        <div class="kanban-board">
            @foreach (var column in _columns) {
                var colItems = _filteredItems.Where(i => i.Status == column.Status).ToList();
                var isDropTarget = _dragOverColumn == column.Status;

                <div class="kanban-column @(isDropTarget ? "kanban-column-drop-target" : "")"
                     @ondragover="HandleDragOver"
                     @ondragover:preventDefault="true"
                     @ondrop="@(() => HandleDrop(column.Status))"
                     @ondragleave="HandleDragLeave">

                    @* Column Header *@
                    <div class="kanban-column-header @column.HeaderClass">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>
                                <i class="@column.Icon me-1"></i> @column.Title
                            </span>
                            <span class="badge bg-white text-dark rounded-pill">@colItems.Count</span>
                        </div>
                        @if (colItems.Any()) {
                            <div class="small mt-1 opacity-75">
                                @colItems.Sum(i => i.Amount).ToString("C")
                            </div>
                        }
                    </div>

                    @* Cards *@
                    <div class="kanban-column-body">
                        @if (!colItems.Any()) {
                            <div class="kanban-empty-state">
                                <i class="fa-solid fa-inbox opacity-50 mb-1"></i>
                                <div class="small text-muted">No items</div>
                            </div>
                        } else {
                            @foreach (var item in colItems.OrderByDescending(i => i.Priority).ThenBy(i => i.Name)) {
                                var isDragging = _draggedItemId == item.SampleItemId;

                                <div class="kanban-card @(isDragging ? "kanban-card-dragging" : "") @(_recentlyMovedIds.Contains(item.SampleItemId) ? "kanban-card-just-moved" : "")"
                                     draggable="true"
                                     @ondragstart="@(() => HandleDragStart(item))"
                                     @ondragend="HandleDragEnd">

                                    @* Card Header — Name + Priority *@
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <strong class="small">@item.Name</strong>
                                        @if (item.Priority > 0) {
                                            <span class="badge @GetPriorityBadge(item.Priority) ms-1" title="Priority @item.Priority">
                                                P@item.Priority
                                            </span>
                                        }
                                    </div>

                                    @* Category Badge *@
                                    @if (!string.IsNullOrWhiteSpace(item.Category)) {
                                        <span class="badge bg-light text-dark border me-1 mb-1" style="font-size:0.7rem;">@item.Category</span>
                                    }

                                    @* Card Footer — Amount + Enabled + Due Date *@
                                    <div class="d-flex justify-content-between align-items-center mt-1">
                                        <span class="small text-muted">@item.Amount.ToString("C")</span>
                                        <div class="d-flex align-items-center gap-1">
                                            @if (item.DueDate.HasValue) {
                                                <span class="small @(item.DueDate.Value < DateTime.Now ? "text-danger" : "text-muted")" title="Due @item.DueDate.Value.ToShortDateString()">
                                                    <i class="fa-regular fa-calendar"></i> @item.DueDate.Value.ToString("M/d")
                                                </span>
                                            }
                                            @if (item.Enabled) {
                                                <i class="fa-solid fa-circle-check text-success small" title="Enabled"></i>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>

        @* ── InfoTips Row ── *@
        <div class="d-flex flex-wrap gap-1 mt-3">
            <InfoTip Title="Drag and Drop"
                     Description="HTML5 drag-and-drop uses three events: ondragstart fires when you pick up a card (stores the item ID), ondragover fires continuously while dragging over a valid target (we call preventDefault to allow dropping), and ondrop fires when you release the card (updates the status and saves)."
                     Code="@_codeDragDrop" />
            <InfoTip Title="Drop Zone Highlight"
                     Description="When you drag a card over a column, it gets a highlighted border and background. This is done by tracking which column the cursor is over in a _dragOverColumn variable. The ondragleave event clears it when you leave. CSS transitions make the highlight animate smoothly."
                     Code="@_codeDropZone" />
            <InfoTip Title="Card Sorting"
                     Description="Cards within each column are sorted by Priority (highest first) then Name (A-Z). When you drop a card into a new column, it automatically slots into the right position. In a more advanced version, you could add drag-to-reorder within a column."
                     Code="@_codeCardSort" />
            <InfoTip Title="Optimistic Update"
                     Description="When you drop a card, the UI updates immediately (optimistic) before the server responds. If the save fails, the card snaps back to its original column and you see an error message. This makes the interface feel instant even on slow connections."
                     Code="@_codeOptimistic" />
            <InfoTip Title="Move Animation"
                     Description="When a card is dropped into a new column, it briefly flashes with a blue highlight (kanban-card-just-moved class) to draw your eye to where it landed. The highlight fades after 2 seconds. This uses the same pattern as the SignalR row highlight on the SignalR Demo page."
                     Code="@_codeMoveAnim" />
        </div>

        @* ── Move History ── *@
        @if (_moveHistory.Any()) {
            <div class="card mt-3 shadow-sm border-0">
                <div class="card-header bg-white py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="small fw-semibold">
                            <i class="fa-solid fa-clock-rotate-left me-1"></i> Recent Moves
                            <InfoTip Title="Move History"
                                     Description="Every drag-and-drop action is logged here with the item name, old status, new status, and timestamp. In a real application, this audit trail would be saved to the database. It helps teams see who moved what and when."
                                     Code="@_codeMoveHistory" />
                        </span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _moveHistory.Clear()">
                            <i class="fa-solid fa-trash-can me-1"></i> Clear
                        </button>
                    </div>
                </div>
                <div class="card-body p-0" style="max-height:200px; overflow-y:auto;">
                    <table class="table table-sm table-hover mb-0">
                        <tbody>
                            @foreach (var move in _moveHistory) {
                                <tr>
                                    <td class="small" style="width:140px;">@move.Time.ToString("h:mm:ss tt")</td>
                                    <td class="small fw-semibold">@move.ItemName</td>
                                    <td class="small">
                                        <span class="badge @GetStatusBadge(move.FromStatus)">@move.FromStatus</span>
                                        <i class="fa-solid fa-arrow-right mx-1 text-muted"></i>
                                        <span class="badge @GetStatusBadge(move.ToStatus)">@move.ToStatus</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private bool _saving = false;
    private string _pageName = "kanbanboard";

    // InfoTip code snippets
    private string _codeBoard = "<div class=\"kanban-column\"\n     @ondragover=\"HandleDragOver\"\n     @ondragover:preventDefault=\"true\"\n     @ondrop=\"() => HandleDrop(column.Status)\">";
    private string _codeDragDrop = "@ondragstart=\"() => HandleDragStart(item)\"\n@ondragover:preventDefault=\"true\"\n@ondrop=\"() => HandleDrop(column.Status)\"";
    private string _codeDropZone = "class=\"kanban-column\n    @(isDropTarget ? \"kanban-column-drop-target\" : \"\")\"";
    private string _codeCardSort = "colItems\n    .OrderByDescending(i => i.Priority)\n    .ThenBy(i => i.Name)";
    private string _codeOptimistic = "// 1. Update UI immediately\nitem.Status = newStatus;\nStateHasChanged();\n\n// 2. Save to server\nawait Helpers.GetOrPost<...>(\"SaveSampleItems\", item);\n\n// 3. If failed, revert\nif (result == null) item.Status = oldStatus;";
    private string _codeMoveAnim = "_recentlyMovedIds.Add(item.SampleItemId);\nawait Task.Delay(2000);\n_recentlyMovedIds.Remove(item.SampleItemId);";
    private string _codeMoveHistory = "_moveHistory.Insert(0, new MoveEntry {\n    ItemName = item.Name,\n    FromStatus = oldStatus,\n    ToStatus = newStatus\n});";

    // Data
    private List<DataObjects.SampleItem> _allItems = new();
    private List<DataObjects.SampleItem> _filteredItems = new();

    // Filter state
    private string _categoryFilter = "";
    private string _searchTerm = "";
    private List<string> _allCategories = new();

    // Drag state
    private Guid? _draggedItemId;
    private DataObjects.SampleItemStatus? _dragOverColumn;

    // Visual feedback
    private HashSet<Guid> _recentlyMovedIds = new();

    // Move history
    private List<MoveEntry> _moveHistory = new();

    // Column definitions
    private readonly List<KanbanColumn> _columns = new() {
        new(DataObjects.SampleItemStatus.Draft, "Draft", "fa-solid fa-pencil", "kanban-header-draft"),
        new(DataObjects.SampleItemStatus.Active, "Active", "fa-solid fa-bolt", "kanban-header-active"),
        new(DataObjects.SampleItemStatus.Completed, "Completed", "fa-solid fa-circle-check", "kanban-header-completed"),
        new(DataObjects.SampleItemStatus.Archived, "Archived", "fa-solid fa-box-archive", "kanban-header-archived"),
    };

    // ── Lifecycle ──

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.OnSignalRUpdate -= SignalRUpdate;
        Model.Subscribers_OnChange.Remove(_pageName);
        Model.Subscribers_OnSignalRUpdate.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        Model.OnSignalRUpdate += SignalRUpdate;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
        if (!Model.Subscribers_OnSignalRUpdate.Contains(_pageName)) { Model.Subscribers_OnSignalRUpdate.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            await LoadData();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    // ── SignalR ──

    private async void SignalRUpdate(DataObjects.SignalRUpdate update)
    {
        if (update.UpdateType == DataObjects.SignalRUpdateType.SampleItemSaved) {
            var saved = Helpers.DeserializeObject<DataObjects.SampleItem>(update.ObjectAsString);
            if (saved == null) return;

            var existing = _allItems.FirstOrDefault(i => i.SampleItemId == saved.SampleItemId);
            if (existing != null) {
                // Track if status changed for highlight
                bool statusChanged = existing.Status != saved.Status;
                var idx = _allItems.IndexOf(existing);
                _allItems[idx] = saved;

                if (statusChanged) {
                    _recentlyMovedIds.Add(saved.SampleItemId);
                    ApplyFilter();
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(2000);
                    _recentlyMovedIds.Remove(saved.SampleItemId);
                    await InvokeAsync(StateHasChanged);
                }
            } else {
                _allItems.Add(saved);
            }

            ApplyFilter();
            await InvokeAsync(StateHasChanged);
        } else if (update.UpdateType == DataObjects.SignalRUpdateType.SampleItemDeleted) {
            var id = update.ItemId;
            _allItems.RemoveAll(i => i.SampleItemId == id);
            ApplyFilter();
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Data Loading ──

    private async Task LoadData()
    {
        var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
        if (result != null) {
            _allItems = result.Where(i => !i.Deleted).ToList();
            _allCategories = _allItems
                .Where(i => !string.IsNullOrWhiteSpace(i.Category))
                .Select(i => i.Category!)
                .Distinct()
                .OrderBy(c => c)
                .ToList();
        }

        ApplyFilter();
        _loading = false;
        StateHasChanged();
    }

    // ── Filtering ──

    private void ApplyFilter()
    {
        var items = _allItems.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_categoryFilter)) {
            items = items.Where(i => i.Category == _categoryFilter);
        }

        if (!string.IsNullOrWhiteSpace(_searchTerm)) {
            var term = _searchTerm.ToLower();
            items = items.Where(i =>
                (i.Name?.ToLower().Contains(term) == true) ||
                (i.Description?.ToLower().Contains(term) == true) ||
                (i.Category?.ToLower().Contains(term) == true));
        }

        _filteredItems = items.ToList();
    }

    private void ClearSearch()
    {
        _searchTerm = "";
        ApplyFilter();
    }

    // ── Drag & Drop ──

    private void HandleDragStart(DataObjects.SampleItem item)
    {
        _draggedItemId = item.SampleItemId;
    }

    private void HandleDragOver()
    {
        // We track the column in HandleDragOverColumn via @ondragover on each column div.
        // preventDefault is set via @ondragover:preventDefault="true" to allow drop.
    }

    private void HandleDragLeave()
    {
        _dragOverColumn = null;
    }

    private void HandleDragEnd()
    {
        _draggedItemId = null;
        _dragOverColumn = null;
    }

    private async Task HandleDrop(DataObjects.SampleItemStatus newStatus)
    {
        _dragOverColumn = null;

        if (_draggedItemId == null) return;

        var item = _allItems.FirstOrDefault(i => i.SampleItemId == _draggedItemId);
        _draggedItemId = null;

        if (item == null || item.Status == newStatus) return;

        // Record move
        var oldStatus = item.Status;
        _moveHistory.Insert(0, new MoveEntry {
            Time = DateTime.Now,
            ItemName = item.Name,
            FromStatus = oldStatus,
            ToStatus = newStatus,
        });

        // Optimistic update
        item.Status = newStatus;
        ApplyFilter();
        StateHasChanged();

        // Highlight animation
        _recentlyMovedIds.Add(item.SampleItemId);

        // Save to server
        _saving = true;
        var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/SaveSampleItems", new List<DataObjects.SampleItem> { item });
        _saving = false;

        if (result == null || !result.Any()) {
            // Revert on failure
            item.Status = oldStatus;
            _moveHistory.RemoveAt(0);
            Model.AddMessage("Failed to save status change.", MessageType.Danger);
        } else {
            // Update with server response
            var saved = result.First();
            var idx = _allItems.IndexOf(item);
            if (idx >= 0) _allItems[idx] = saved;
        }

        ApplyFilter();
        StateHasChanged();

        // Clear highlight after delay
        var movedId = item.SampleItemId;
        await Task.Delay(2000);
        _recentlyMovedIds.Remove(movedId);
        StateHasChanged();
    }

    // ── Helpers ──

    private string GetPriorityBadge(int priority) => priority switch {
        >= 5 => "bg-danger",
        4 => "bg-warning text-dark",
        3 => "bg-info",
        2 => "bg-secondary",
        _ => "bg-light text-dark border",
    };

    private string GetStatusBadge(DataObjects.SampleItemStatus status) => status switch {
        DataObjects.SampleItemStatus.Draft => "bg-secondary",
        DataObjects.SampleItemStatus.Active => "bg-success",
        DataObjects.SampleItemStatus.Completed => "bg-primary",
        DataObjects.SampleItemStatus.Archived => "bg-dark",
        _ => "bg-secondary",
    };

    // ── Inner Types ──

    private record KanbanColumn(DataObjects.SampleItemStatus Status, string Title, string Icon, string HeaderClass);

    private class MoveEntry
    {
        public DateTime Time { get; set; }
        public string ItemName { get; set; } = "";
        public DataObjects.SampleItemStatus FromStatus { get; set; }
        public DataObjects.SampleItemStatus ToStatus { get; set; }
    }
}
