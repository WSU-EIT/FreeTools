@page "/Examples/FileDemoV5"
@page "/{TenantCode}/Examples/FileDemoV5"
@implements IDisposable
@inject BlazorDataModel Model

@* V5: Evidence Collection — attach files to a case/ticket as supporting evidence *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-paperclip me-1"></i> Case Attachments</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-paperclip me-1"></i> V5: Case Attachments <StickyMenuIcon /></h1>
        </div>
        <AboutSection Title="File Upload in Context: Ticket Attachments" Subtitle="Attach screenshots, logs, and evidence to a support ticket" IconClass="fa-solid fa-paperclip">
            <p class="small text-muted mb-0">A support ticket where users attach screenshots, error logs, and evidence. Each attachment gets a note explaining what it shows. This is the Jira, Zendesk, or GitHub issue attachment pattern.</p>
        </AboutSection>

        @* Ticket Header *@
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-danger text-white d-flex justify-content-between">
                <span><i class="fa-solid fa-bug me-1"></i> TICKET-4821: Login page returns 500 error after SSO upgrade</span>
                <span class="badge bg-warning text-dark">Priority: High</span>
            </div>
            <div class="card-body">
                <div class="row mb-2 small">
                    <div class="col-md-3"><strong class="text-muted">Reporter:</strong> Sarah Kim</div>
                    <div class="col-md-3"><strong class="text-muted">Assignee:</strong> Mike Dean</div>
                    <div class="col-md-3"><strong class="text-muted">Status:</strong> <span class="badge bg-warning text-dark">In Progress</span></div>
                    <div class="col-md-3"><strong class="text-muted">Created:</strong> Today, 9:42 AM</div>
                </div>
                <p class="small mb-0">After the SSO upgrade last night, users clicking "Sign in with SSO" get a 500 error. Affects all browsers. Traditional login still works.</p>
            </div>
        </div>

        @* Attachments *@
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-white d-flex justify-content-between">
                <span class="fw-semibold small"><i class="fa-solid fa-paperclip me-1"></i> Attachments (@_attachments.Count)</span>
                <button class="btn btn-sm btn-outline-primary" @onclick="AddAttachment"><i class="fa-solid fa-plus me-1"></i> Add Attachment</button>
            </div>
            <div class="card-body p-0">
                @if (!_attachments.Any()) {
                    <div class="text-center py-4 text-muted small">No attachments yet. Click "Add Attachment" to add evidence.</div>
                }
                @foreach (var att in _attachments) {
                    <div class="border-bottom px-3 py-2 d-flex align-items-start gap-3">
                        <div class="rounded bg-light d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px; height:48px;">
                            <i class="fa-solid @GetIcon(att.Type) @GetIconColor(att.Type)"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="small fw-semibold">@att.FileName</div>
                            <div class="small text-muted">@att.Size · Uploaded by @att.UploadedBy · @att.Time</div>
                            @if (!string.IsNullOrWhiteSpace(att.Note)) {
                                <div class="small fst-italic text-muted mt-1"><i class="fa-solid fa-quote-left me-1" style="font-size:0.5rem;"></i>@att.Note</div>
                            }
                        </div>
                        <button class="btn btn-sm btn-outline-danger flex-shrink-0" @onclick="@(() => _attachments.Remove(att))">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "filedemov5";
    private int _counter = 0;

    private List<Attachment> _attachments = new() {
        new("screenshot_error_500.png", "image", "1.2 MB", "Sarah Kim", "9:45 AM", "Browser shows 500 Internal Server Error immediately after clicking SSO button"),
        new("sso_error_log.txt", "text", "48 KB", "Mike Dean", "10:15 AM", "Stack trace from Application Insights showing NullReferenceException in AuthMiddleware"),
        new("network_trace.har", "code", "890 KB", "Mike Dean", "10:22 AM", "HAR file showing the failed POST to /auth/sso/callback — returns 500 with no body"),
    };

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }

    private void AddAttachment() {
        _counter++;
        string[] names = { "additional_screenshot.png", "browser_console.txt", "config_diff.patch", "repro_video.mp4", "workaround_notes.docx" };
        string[] types = { "image", "text", "code", "video", "doc" };
        int idx = _counter % names.Length;
        _attachments.Add(new(names[idx], types[idx], "250 KB", "Current User", DateTime.Now.ToString("h:mm tt"), ""));
    }

    private string GetIcon(string type) => type switch { "image" => "fa-file-image", "text" => "fa-file-lines", "code" => "fa-file-code", "video" => "fa-file-video", "doc" => "fa-file-word", _ => "fa-file" };
    private string GetIconColor(string type) => type switch { "image" => "text-primary", "text" => "text-secondary", "code" => "text-success", "video" => "text-danger", _ => "text-muted" };

    private record Attachment(string FileName, string Type, string Size, string UploadedBy, string Time, string Note);
}
