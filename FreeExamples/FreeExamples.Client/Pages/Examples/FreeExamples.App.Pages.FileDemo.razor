@page "/Examples/FileDemo"
@page "/{TenantCode}/Examples/FileDemo"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><Icon Name="Files" /> File Operations Demo</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <Icon Name="Files" /> File Operations Demo
                <StickyMenuIcon />
            </h1>

            <AboutSection Title="About File Operations" Subtitle="Learn how web apps handle files — uploading, downloading, and exporting data" IconClass="fa-solid fa-file-arrow-up">
                <div class="row">
                    <div class="col-md-4 mb-2">
                        <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                        <p class="small text-muted mb-0">
                            This page teaches you how files move between your computer and a web application.
                            You'll see three things: <strong>uploading</strong> (sending a file from your computer to the server),
                            <strong>downloading</strong> (the server creates a file and sends it to your browser),
                            and <strong>listing</strong> (showing the files you've uploaded in a table).
                            These are the same patterns used in real apps like email attachments, form submissions, and data exports.
                        </p>
                    </div>

                    <div class="col-md-4 mb-2">
                        <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                        <ul class="small text-muted mb-0 ps-3">
                            <li><strong>Drag-and-drop upload</strong> — drag a file from your desktop onto the grey area and the browser reads it</li>
                            <li><strong>Download to browser</strong> — the server builds a file (text or CSV) and your browser saves it automatically</li>
                            <li><strong>File listing table</strong> — a table that updates instantly when you upload or remove files</li>
                            <li><strong>File size formatting</strong> — turning raw byte counts like "1048576" into human-readable "1.0 MB"</li>
                        </ul>
                    </div>
                    <div class="col-md-4 mb-2">
                        <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                        <p class="small text-muted mb-2">
                            When you <strong>upload</strong>: your browser reads the file, converts it to bytes, and sends those bytes
                            to the web server over the internet (an HTTP POST request). The server stores the bytes and sends back metadata
                            (file name, size, type).
                        </p>
                        <p class="small text-muted mb-0">
                            When you <strong>download</strong>: your browser asks the server for a file (an HTTP GET request). The server
                            generates the file content, converts it to bytes, and sends it back. JavaScript then triggers your browser's
                            "Save As" dialog.
                        </p>
                    </div>
                </div>

        </AboutSection>

        <ExampleNav />

            <div class="btn-group mb-2" role="group">
                <button type="button" class="btn btn-primary" @onclick="DownloadTextFile" disabled="@_downloading" aria-label="Download text report">
                    <i class="fa-solid fa-file-lines me-1" aria-hidden="true"></i> Download Text Report
                </button>
                <button type="button" class="btn btn-dark" @onclick="DownloadCsvFile" disabled="@_downloading" aria-label="Download CSV export">
                    <i class="fa-solid fa-file-csv me-1" aria-hidden="true"></i> Download CSV Export
                </button>
            </div>
            <InfoTip Title="Download Buttons"
                     Description="These buttons ask the server to generate a file and send it to your browser. 'Text Report' creates a plain .txt file. 'CSV Export' creates a .csv file (a spreadsheet format). The server builds the file in memory, converts it to bytes, and JavaScript triggers your browser's save dialog."
                     Code="await Helpers.DownloadFileToBrowser(result.FileName, result.FileData);" />
        </div>

        @if (_downloading) {
            <LoadingMessage />
        }

        <div class="card mb-3">
            <div class="card-header">
                <strong>Upload Files</strong>
                <InfoTip Title="File Upload Area"
                         Description="This is a drag-and-drop zone. You can either click inside the grey area to browse your computer for a file, or drag a file from your desktop and drop it here. The browser reads the file contents and sends them to the server. Only certain file types are allowed (.TXT, .CSV, .JSON, .XML) to keep things safe."
                         Code="@_codeUpload" />
            </div>
            <div class="card-body">
                <UploadFile UploadType="Microsoft.AspNetCore.Components.Forms.IBrowserFile"
                    AllowMultipleUploads="true"
                    SupportedFileTypes="@(new List<string> { ".txt", ".csv", ".json", ".xml" })"
                    OnUploadComplete="@((List<DataObjects.FileStorage> files) => OnFilesUploaded(files))" />
            </div>
        </div>

        @if (_uploadedFiles.Count > 0) {
            <div class="card mb-3">
                            <div class="card-header">
                                <strong>Uploaded Files</strong> (@_uploadedFiles.Count)
                                <InfoTip Title="File Listing Table"
                                         Description="This table shows every file you uploaded. It updates instantly without reloading the page because Blazor re-renders just the changed parts (reactive rendering). Each row shows the file name, extension, size, and a delete button."
                                         Code="@_codeFileList" />
                            </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0" aria-label="Uploaded files">
                        <thead>
                            <tr>
                                <th scope="col">File Name</th>
                                <th scope="col">Extension</th>
                                <th scope="col" class="text-end">
                                    Size
                                    <InfoTip Title="File Size Formatting"
                                             Description="Computers store file sizes in bytes (a byte is 8 bits, the smallest unit of data). A text file might be 1,500 bytes. But that is hard to read, so we convert it: 1,500 bytes = 1.5 KB (kilobytes). 1,000 KB = 1 MB (megabytes). The FormatBytes() function does this math for us."
                                             Code="@_codeFormatBytes" />
                                </th>
                                <th scope="col"><span class="visually-hidden">Actions</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var file in _uploadedFiles) {
                                <tr>
                                    <td>@file.FileName</td>
                                    <td><span class="badge bg-secondary">@file.Extension</span>
                                        <InfoTip Title="File Extension Badge"
                                                 Description="A file extension is the part after the dot in a file name (like .txt or .csv). It tells the computer what kind of file it is. Here we show it as a badge, a small colored label. This is a Bootstrap CSS class that makes text stand out."
                                                 Code="@_codeBadge" />
                                    </td>
                                    <td class="text-end">@FormatBytes(file.Bytes ?? 0)</td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="@(() => RemoveFile(file))" aria-label="Remove @file.FileName">
                                            <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                        </button>
                                        <InfoTip Title="Remove Button"
                                                 Description="Clicking the trash icon removes this file from the list. It does not reload the whole page. Blazor just removes that one row from the table. The onclick attribute tells Blazor: when someone clicks this button, run this C# method. The method removes the file from the list and Blazor automatically updates the display."
                                                 Code="@_codeRemove" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private bool _downloading = false;
    private string _pageName = "filedemo";
    private List<DataObjects.FileStorage> _uploadedFiles = new();

    // InfoTip code snippets (stored as strings to avoid Razor parsing issues)
    private string _codeUpload = "<UploadFile AllowMultipleUploads=\"true\"\n    SupportedFileTypes=\"new List<string> { \".txt\", \".csv\" }\"\n    OnUploadComplete=\"OnFilesUploaded\" />";
    private string _codeFileList = "@foreach (var file in _uploadedFiles) {\n    <tr>\n        <td>@file.FileName</td>\n        <td>@FormatBytes(file.Bytes ?? 0)</td>\n    </tr>\n}";
    private string _codeFormatBytes = "static string FormatBytes(long bytes) {\n    if (bytes < 1024) return $\"{bytes} B\";\n    if (bytes < 1024 * 1024) return $\"{bytes / 1024.0:F1} KB\";\n    return $\"{bytes / (1024.0 * 1024.0):F1} MB\";\n}";
    private string _codeBadge = "<span class=\"badge bg-secondary\">@file.Extension</span>";
    private string _codeRemove = "void RemoveFile(DataObjects.FileStorage file) {\n    _uploadedFiles.Remove(file);\n    StateHasChanged();\n}";

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
            Model.TenantCodeFromUrl = TenantCode;
        }

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            _loading = false;
            StateHasChanged();
        }

        await Task.CompletedTask;
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    private async Task DownloadTextFile()
    {
        _downloading = true;
        StateHasChanged();

        var result = await Helpers.GetOrPost<DataObjects.SampleFileResponse>("api/Data/GenerateSampleTextFile");
        if (result != null && result.FileData.Length > 0) {
            await Helpers.DownloadFileToBrowser(result.FileName, result.FileData);
            Model.AddMessage("Text report downloaded successfully.", MessageType.Success);
        } else {
            Model.AddMessage("Failed to generate text report.", MessageType.Danger);
        }

        _downloading = false;
        StateHasChanged();
    }

    private async Task DownloadCsvFile()
    {
        _downloading = true;
        StateHasChanged();

        var result = await Helpers.GetOrPost<DataObjects.SampleFileResponse>("api/Data/GenerateSampleCsvExport");
        if (result != null && result.FileData.Length > 0) {
            await Helpers.DownloadFileToBrowser(result.FileName, result.FileData);
            Model.AddMessage("CSV export downloaded successfully.", MessageType.Success);
        } else {
            Model.AddMessage("Failed to generate CSV export.", MessageType.Danger);
        }

        _downloading = false;
        StateHasChanged();
    }

    private void OnFilesUploaded(List<DataObjects.FileStorage> files)
    {
        _uploadedFiles.AddRange(files);
        Model.AddMessage($"Uploaded {files.Count} file(s).", MessageType.Success);
        StateHasChanged();
    }

    private void RemoveFile(DataObjects.FileStorage file)
    {
        _uploadedFiles.Remove(file);
        Model.AddMessage($"Removed {file.FileName}.", MessageType.Warning);
        StateHasChanged();
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
