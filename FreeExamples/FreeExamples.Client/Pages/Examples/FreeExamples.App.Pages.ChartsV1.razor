@page "/Examples/ChartsV1"
@page "/{TenantCode}/Examples/ChartsV1"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-chart-line me-1"></i> Sales Analytics</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-chart-line me-1"></i> V1: Sales Analytics Dashboard <StickyMenuIcon /></h1></div>
        <AboutSection Title="Charts in Context: Sales Analytics" Subtitle="A sales dashboard with KPIs, revenue breakdown, and team leaderboard" IconClass="fa-solid fa-chart-line">
            <p class="small text-muted mb-0">Same charting concepts from Charts Dashboard, but in a sales context. KPI cards up top, category breakdown, and a team performance leaderboard.</p>
        </AboutSection>
        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="KPI Summary Cards"
                     Description="Four KPI cards with h4 numbers and trend arrows (text-success fa-arrow-up or text-danger fa-arrow-down) give instant status. row-cols-2 row-cols-md-4 makes them responsive. This is the standard dashboard header pattern in every production app."
                     Code="@_codeKpiCards" />
            <InfoTip Title="CSS Bar Chart"
                     Description="Monthly revenue bars are pure CSS — div elements with calculated heights. No JavaScript charting library needed. d-flex align-items-end lines up the bars at the bottom. Each bar is a bg-primary rounded-top div with inline height."
                     Code="@_codeBarChart" />
            <InfoTip Title="Ranked Leaderboard"
                     Description="The Top Reps list uses list-group-flush with a rank badge (bg-warning for top 3). Each row has a name, amount, and rank. This leaderboard pattern appears in sales dashboards, gaming, and competition pages."
                     Code="@_codeLeaderboard" />
        </div>

        <div class="row row-cols-2 row-cols-md-4 g-2 mb-3">
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-success">$284k</div><div class="small text-muted">Revenue MTD</div><div class="small text-success"><i class="fa-solid fa-arrow-up"></i> 12%</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-primary">1,247</div><div class="small text-muted">Deals Closed</div><div class="small text-success"><i class="fa-solid fa-arrow-up"></i> 8%</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-warning">$228</div><div class="small text-muted">Avg Deal Size</div><div class="small text-danger"><i class="fa-solid fa-arrow-down"></i> 3%</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-info">34%</div><div class="small text-muted">Win Rate</div><div class="small text-success"><i class="fa-solid fa-arrow-up"></i> 5%</div></div></div>
        </div>
        <div class="row g-3 mb-3">
            <div class="col-md-8"><div class="card shadow-sm border-0 h-100"><div class="card-header bg-white py-2"><span class="small fw-semibold"><i class="fa-solid fa-chart-area me-1"></i> Monthly Revenue</span></div><div class="card-body"><div class="d-flex align-items-end gap-1" style="height:200px;">
                @foreach (var m in new[] { ("Jan",45), ("Feb",62), ("Mar",58), ("Apr",71), ("May",85), ("Jun",78), ("Jul",92), ("Aug",88), ("Sep",95), ("Oct",102), ("Nov",98), ("Dec",110) }) {
                    <div class="flex-grow-1 text-center"><div class="bg-primary rounded-top mx-auto" style="height:@(m.Item2 * 1.8)px; max-width:30px;"></div><div class="small text-muted mt-1" style="font-size:0.6rem;">@m.Item1</div></div>
                }
            </div></div></div></div>
            <div class="col-md-4"><div class="card shadow-sm border-0 h-100"><div class="card-header bg-white py-2"><span class="small fw-semibold"><i class="fa-solid fa-trophy me-1"></i> Top Reps</span></div><div class="card-body p-0"><div class="list-group list-group-flush">
                @{ int rank = 1; }
                @foreach (var rep in new[] { ("Sarah K.", "$82k", 95), ("Mike D.", "$71k", 82), ("Lisa R.", "$64k", 74), ("Tom W.", "$52k", 60), ("Amy C.", "$48k", 55) }) {
                    <div class="list-group-item py-2 d-flex align-items-center gap-2"><span class="badge @(rank <= 3 ? "bg-warning text-dark" : "bg-secondary") rounded-pill" style="width:24px;">@rank</span><span class="small flex-grow-1">@rep.Item1</span><span class="small fw-semibold">@rep.Item2</span>@{ rank++; }</div>
                }
            </div></div></div></div>
        </div>
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "chartsv1";
    private string _codeKpiCards = "<div class=\"card text-center py-2\">\n  <div class=\"h4 text-success\">$284k</div>\n  <div class=\"small text-muted\">Revenue MTD</div>\n  <div class=\"small text-success\"><i class=\"fa-solid fa-arrow-up\"></i> 12%</div>\n</div>";
    private string _codeBarChart = "<div class=\"d-flex align-items-end gap-1\" style=\"height:200px\">\n  <div class=\"bg-primary rounded-top\" style=\"height:@(val*1.8)px\"></div>\n</div>";
    private string _codeLeaderboard = "<div class=\"list-group-item d-flex align-items-center gap-2\">\n  <span class=\"badge bg-warning\">1</span>\n  <span>Sarah K.</span>\n  <span class=\"fw-semibold\">$82k</span>\n</div>";
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
}
