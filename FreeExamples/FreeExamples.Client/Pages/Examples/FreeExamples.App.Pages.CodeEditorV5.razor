@page "/Examples/CodeEditorV5"
@page "/{TenantCode}/Examples/CodeEditorV5"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-wand-magic-sparkles me-1"></i> Template Engine</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-wand-magic-sparkles me-1"></i> V5: Template Engine <StickyMenuIcon /></h1></div>
        <AboutSection Title="Code Editor in Context: Template Engine" Subtitle="Write a template with variables, see the rendered output live" IconClass="fa-solid fa-wand-magic-sparkles">
            <p class="small text-muted mb-0">Write an email template with placeholders like {{Name}}, fill in variable values, see the rendered preview update live. The Mailchimp / SendGrid template pattern.</p>
        </AboutSection>
        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Template Placeholder System"
                     Description="Templates use {{placeholders}} that get replaced with actual values. The editor shows the template with highlighted placeholders. A preview panel shows the rendered output. This is the Handlebars/Mustache pattern used in email templates and code generation."
                     Code="@_codeTemplatePlaceholder" />
            <InfoTip Title="Variable Binding Panel"
                     Description="A side panel lists all template variables with input fields. As users type values, the preview updates live. Each variable shows its name, type, and current value. This is the mail-merge / template-engine pattern."
                     Code="@_codeVariablePanel" />
            <InfoTip Title="Copy to Clipboard"
                     Description="A 'Copy' button copies the rendered output to the clipboard. The button text changes to 'Copied!' for 2 seconds as feedback. In Blazor, navigator.clipboard.writeText via JSInterop handles this. Every code display should have a copy button."
                     Code="@_codeCopyClipboard" />
        </div>
        <div class="row">
            <div class="col-md-3 mb-3"><div class="card shadow-sm border-0"><div class="card-header bg-white py-2"><span class="small fw-semibold">Variables</span></div><div class="card-body">
                <label class="form-label small">Name</label><input type="text" class="form-control form-control-sm mb-2" @bind="_varName" @bind:event="oninput" />
                <label class="form-label small">Company</label><input type="text" class="form-control form-control-sm mb-2" @bind="_varCompany" @bind:event="oninput" />
                <label class="form-label small">Amount</label><input type="text" class="form-control form-control-sm mb-2" @bind="_varAmount" @bind:event="oninput" />
                <label class="form-label small">Date</label><input type="text" class="form-control form-control-sm" @bind="_varDate" @bind:event="oninput" />
            </div></div></div>
            <div class="col-md-4 mb-3"><div class="card shadow-sm border-0"><div class="card-header bg-dark text-white py-1"><span class="small">Template</span></div>
                <pre class="bg-dark text-light p-3 mb-0" style="font-size:0.75rem;">Dear <span class="text-warning">{{Name}}</span>,

Thank you for your order from <span class="text-warning">{{Company}}</span>.

Your total: <span class="text-warning">{{Amount}}</span>
Order date: <span class="text-warning">{{Date}}</span>

Best regards,
FreeExamples Team</pre></div></div>
            <div class="col-md-5 mb-3"><div class="card shadow-sm border-0"><div class="card-header bg-white py-2"><span class="small fw-semibold"><i class="fa-solid fa-eye me-1"></i> Preview</span></div>
                <div class="card-body bg-light"><div class="bg-white p-3 rounded shadow-sm small">
                    <p>Dear <strong>@(string.IsNullOrWhiteSpace(_varName) ? "{{Name}}" : _varName)</strong>,</p>
                    <p>Thank you for your order from <strong>@(string.IsNullOrWhiteSpace(_varCompany) ? "{{Company}}" : _varCompany)</strong>.</p>
                    <p>Your total: <strong>@(string.IsNullOrWhiteSpace(_varAmount) ? "{{Amount}}" : _varAmount)</strong><br/>Order date: <strong>@(string.IsNullOrWhiteSpace(_varDate) ? "{{Date}}" : _varDate)</strong></p>
                    <p>Best regards,<br/>FreeExamples Team</p>
                </div></div></div></div>
        </div>
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "codeeditorv5";
    private string _codeTemplatePlaceholder = "Hello {{FirstName}},\n\nYour order #{{OrderId}} has shipped.\n\nTracking: {{TrackingNumber}}";
    private string _codeVariablePanel = "<div class=\"mb-2\">\n  <label>{{FirstName}}</label>\n  <input @bind=\"_vars[\"FirstName\"]\" />\n</div>";
    private string _codeCopyClipboard = "<button @onclick=\"CopyToClipboard\">\n  @(_copied ? \"Copied!\" : \"Copy\")\n</button>\n// await JSRuntime.InvokeVoidAsync(\"navigator.clipboard.writeText\", text);";
    private string _varName = "Jane Doe", _varCompany = "Acme Corp", _varAmount = "$2,400", _varDate = "March 15, 2024";
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
}
