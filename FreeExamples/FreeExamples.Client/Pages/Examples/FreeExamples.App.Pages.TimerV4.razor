@page "/Examples/TimerV4"
@page "/{TenantCode}/Examples/TimerV4"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-hourglass-half me-1"></i> Quiz Timer</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-hourglass-half me-1"></i> V4: Timed Quiz <StickyMenuIcon /></h1></div>
        <AboutSection Title="Timer in Context: Timed Quiz" Subtitle="A countdown timer with per-question time limits — the online exam pattern" IconClass="fa-solid fa-hourglass-half">
            <p class="small text-muted mb-0">Timer creates urgency in an exam context. Each question has a time limit. When it expires, auto-advance to the next question.</p>
        </AboutSection>
        <div class="card shadow-sm border-0 mb-3"><div class="card-header bg-primary text-white d-flex justify-content-between"><span>Question @(_currentQ + 1) of @_questions.Count</span><span class="badge bg-light text-dark">@_timeLeft s remaining</span></div><div class="card-body">
            <div class="progress mb-3" style="height:4px;"><div class="progress-bar @(_timeLeft <= 5 ? "bg-danger" : "bg-success")" style="width:@(_timeLeft * 100 / 30)%"></div></div>
            <h5 class="mb-3">@_questions[_currentQ].Question</h5>
            @foreach (var opt in _questions[_currentQ].Options) {
                <div class="form-check mb-2"><input type="radio" class="form-check-input" name="q" @onchange="@(() => _selectedAnswer = opt)" checked="@(_selectedAnswer == opt)" /><label class="form-check-label">@opt</label></div>
            }
        </div><div class="card-footer bg-light d-flex justify-content-between">
            <span class="small text-muted">Score: @_score / @_currentQ</span>
            <button class="btn btn-sm btn-primary" @onclick="NextQuestion" disabled="@(string.IsNullOrEmpty(_selectedAnswer))">Next <i class="fa-solid fa-arrow-right ms-1"></i></button>
        </div></div>
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "timerv4";
    private int _currentQ = 0, _timeLeft = 30, _score = 0;
    private string _selectedAnswer = "";
    private System.Timers.Timer? _timer;
    private List<QuizQ> _questions = new() {
        new("What does CSS stand for?", new[] { "Cascading Style Sheets", "Computer Style Sheets", "Creative Style System", "Cascading System Styles" }, "Cascading Style Sheets"),
        new("Which HTML tag is used for the largest heading?", new[] { "<heading>", "<h1>", "<h6>", "<head>" }, "<h1>"),
        new("What does API stand for?", new[] { "Application Programming Interface", "Applied Program Integration", "Application Process Interface", "Automated Programming Interface" }, "Application Programming Interface"),
    };
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); _timer?.Dispose(); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); _timer = new System.Timers.Timer(1000); _timer.Elapsed += (s, e) => InvokeAsync(() => { _timeLeft--; if (_timeLeft <= 0) NextQuestion(); StateHasChanged(); }); _timer.Start(); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
    private void NextQuestion() { if (_selectedAnswer == _questions[_currentQ].Answer) _score++; _currentQ = Math.Min(_currentQ + 1, _questions.Count - 1); _selectedAnswer = ""; _timeLeft = 30; }
    private record QuizQ(string Question, string[] Options, string Answer);
}
