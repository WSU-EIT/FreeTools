@page "/Examples/SampleItemsV5"
@page "/{TenantCode}/Examples/SampleItemsV5"
@implements IDisposable
@inject BlazorDataModel Model

@* V5: Stats Dashboard — aggregate stats + charts of sample items data *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-chart-pie me-1"></i> Stats Dashboard</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-chart-pie me-1"></i> V5: Sample Items — Stats Dashboard <StickyMenuIcon /></h1>
        </div>
        <AboutSection Title="Stats Dashboard View" Subtitle="Aggregate statistics and breakdowns of the same SampleItem data" IconClass="fa-solid fa-chart-pie">
            <p class="small text-muted mb-0">Instead of listing individual items, this view shows aggregate stats: counts by status, category breakdown, amount distribution, priority summary. Same API, analytical perspective.</p>
        </AboutSection>

        @* KPI Row *@
        <div class="row row-cols-2 row-cols-md-4 g-2 mb-3">
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-primary">@_items.Count</div><div class="small text-muted">Total Items</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-success">@_items.Sum(i => i.Amount).ToString("C0")</div><div class="small text-muted">Total Amount</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-warning">@(_items.Any() ? _items.Average(i => i.Priority).ToString("F1") : "0")</div><div class="small text-muted">Avg Priority</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-info">@_items.Count(i => i.Enabled)</div><div class="small text-muted">Enabled</div></div></div>
        </div>

        <div class="row g-3 mb-3">
            @* Status Breakdown *@
            <div class="col-md-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white py-2"><span class="small fw-semibold"><i class="fa-solid fa-circle-half-stroke me-1"></i> By Status</span></div>
                    <div class="card-body p-0">
                        @foreach (var group in _items.GroupBy(i => i.Status).OrderByDescending(g => g.Count())) {
                            int pct = _items.Count > 0 ? (int)(group.Count() * 100.0 / _items.Count) : 0;
                            <div class="px-3 py-2 border-bottom d-flex align-items-center gap-2">
                                <span class="badge @GetStatusBadge(group.Key)" style="min-width:80px;">@group.Key</span>
                                <div class="flex-grow-1">
                                    <div class="progress" style="height:6px;">
                                        <div class="progress-bar @GetStatusBadge(group.Key)" style="width:@pct%"></div>
                                    </div>
                                </div>
                                <span class="small fw-semibold" style="min-width:50px; text-align:right;">@group.Count() (@pct%)</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Category Breakdown *@
            <div class="col-md-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white py-2"><span class="small fw-semibold"><i class="fa-solid fa-tags me-1"></i> By Category</span></div>
                    <div class="card-body p-0">
                        @foreach (var group in _items.GroupBy(i => i.Category ?? "Other").OrderByDescending(g => g.Count())) {
                            int pct = _items.Count > 0 ? (int)(group.Count() * 100.0 / _items.Count) : 0;
                            <div class="px-3 py-2 border-bottom d-flex align-items-center gap-2">
                                <span class="badge bg-light text-dark border" style="min-width:80px; font-size:0.65rem;">@group.Key</span>
                                <div class="flex-grow-1">
                                    <div class="progress" style="height:6px;">
                                        <div class="progress-bar bg-info" style="width:@pct%"></div>
                                    </div>
                                </div>
                                <span class="small fw-semibold" style="min-width:80px; text-align:right;">@group.Sum(i => i.Amount).ToString("C0")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Top Items *@
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-white py-2"><span class="small fw-semibold"><i class="fa-solid fa-ranking-star me-1"></i> Top 5 by Amount</span></div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light"><tr><th class="small">#</th><th class="small">Name</th><th class="small">Category</th><th class="small text-end">Amount</th></tr></thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var item in _items.OrderByDescending(i => i.Amount).Take(5)) {
                            <tr>
                                <td class="small fw-semibold">@(rank++)</td>
                                <td class="small">@item.Name</td>
                                <td class="small">@item.Category</td>
                                <td class="small text-end fw-semibold text-primary">@item.Amount.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "sampleitemsv5";
    private List<DataObjects.SampleItem> _items = new();

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
            if (result != null) _items = result.Where(i => !i.Deleted).ToList();
            _loading = false; StateHasChanged();
        }
    }
    private string GetStatusBadge(DataObjects.SampleItemStatus s) => s switch { DataObjects.SampleItemStatus.Active => "bg-success", DataObjects.SampleItemStatus.Completed => "bg-primary", DataObjects.SampleItemStatus.Archived => "bg-dark", _ => "bg-secondary" };
}
