@page "/Examples/FileDemoV2"
@page "/{TenantCode}/Examples/FileDemoV2"
@implements IDisposable
@inject BlazorDataModel Model

@* V2: Document Library — SharePoint-style file browser with folders *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-folder-tree me-1"></i> Document Library</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-folder-tree me-1"></i> V2: Document Library <StickyMenuIcon /></h1>
        </div>

        <ExampleNav />
        <AboutSection Title="File Upload in Context: Document Library" Subtitle="SharePoint/Google Drive-style browseable file library" IconClass="fa-solid fa-folder-tree">
            <p class="small text-muted mb-0">Files organized into folders with breadcrumb navigation. Upload files into any folder. This is the SharePoint, Google Drive, or Dropbox pattern — a browseable file tree.</p>
        </AboutSection>

        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Breadcrumb Navigation"
                     Description="Bootstrap's breadcrumb component shows the current folder path. Each segment is clickable to navigate back. The last item has the 'active' class (not a link). NavigateTo(idx) trims the path. This is the SharePoint/Windows Explorer navigation pattern."
                     Code="@_codeBreadcrumb" />
            <InfoTip Title="File Type Icons"
                     Description="Each file gets an icon based on its extension: fa-file-pdf for PDF, fa-file-excel for XLSX, fa-file-word for DOCX, fa-folder for folders. A switch expression maps extensions to icons. This visual distinction helps users find files quickly."
                     Code="@_codeFileIcons" />
            <InfoTip Title="Folder Navigation in Table"
                     Description="Clicking a folder row calls EnterFolder() which adds to the breadcrumb. The '..' row at the top calls GoUp(). Items are sorted folders-first with OrderByDescending(i => i.IsFolder). The table-hover class gives rows a highlight on hover."
                     Code="@_codeFolderNav" />
        </div>

        @* Breadcrumb *@
        <nav class="mb-3">
            <ol class="breadcrumb mb-0">
                @for (int i = 0; i < _breadcrumb.Count; i++) {
                    int idx = i;
                    @if (i == _breadcrumb.Count - 1) {
                        <li class="breadcrumb-item active small">@_breadcrumb[i]</li>
                    } else {
                        <li class="breadcrumb-item small"><a href="#" @onclick="@(() => NavigateTo(idx))" @onclick:preventDefault>@_breadcrumb[i]</a></li>
                    }
                }
            </ol>
        </nav>

        <div class="d-flex gap-2 mb-3">
            <button class="btn btn-sm btn-primary" @onclick="AddMockFile"><i class="fa-solid fa-file-arrow-up me-1"></i> Upload File</button>
            <button class="btn btn-sm btn-outline-primary" @onclick="AddFolder"><i class="fa-solid fa-folder-plus me-1"></i> New Folder</button>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-light">
                        <tr><th class="small" style="width:40px;"></th><th class="small">Name</th><th class="small">Type</th><th class="small">Size</th><th class="small">Modified</th></tr>
                    </thead>
                    <tbody>
                        @if (_breadcrumb.Count > 1) {
                            <tr role="button" @onclick="GoUp">
                                <td><i class="fa-solid fa-arrow-turn-up text-muted"></i></td>
                                <td class="small">..</td><td></td><td></td><td></td>
                            </tr>
                        }
                        @foreach (var item in CurrentItems.OrderByDescending(i => i.IsFolder).ThenBy(i => i.Name)) {
                            <tr role="button" @onclick="@(() => { if (item.IsFolder) EnterFolder(item.Name); })">
                                <td>
                                    @if (item.IsFolder) { <i class="fa-solid fa-folder text-warning"></i> }
                                    else { <i class="fa-solid @GetFileIcon(item.Extension) text-muted"></i> }
                                </td>
                                <td class="small fw-semibold">@item.Name</td>
                                <td class="small text-muted">@(item.IsFolder ? "Folder" : item.Extension.ToUpper())</td>
                                <td class="small text-muted">@(item.IsFolder ? $"{item.ChildCount} items" : item.Size)</td>
                                <td class="small text-muted">@item.Modified</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "filedemov2";
    private string _codeBreadcrumb = "<ol class=\"breadcrumb\">\n  <li class=\"breadcrumb-item\"><a @onclick=\"NavigateTo(0)\">Documents</a></li>\n  <li class=\"breadcrumb-item active\">Reports</li>\n</ol>";
    private string _codeFileIcons = "string GetFileIcon(string ext) => ext switch {\n  \"pdf\" => \"fa-file-pdf\",\n  \"xlsx\" => \"fa-file-excel\",\n  _ => \"fa-file\"\n};";
    private string _codeFolderNav = "<tr @onclick=\"() => EnterFolder(item.Name)\">\n  <td><i class=\"fa-solid fa-folder text-warning\"></i></td>\n  <td>@item.Name</td>\n</tr>";
    private List<string> _breadcrumb = new() { "Documents" };
    private int _fileCounter = 0;

    private Dictionary<string, List<DocItem>> _folders = new() {
        { "Documents", new List<DocItem> {
            new("Reports", true, "", "—", "Jan 3, 2024", 3),
            new("Templates", true, "", "—", "Feb 14, 2024", 2),
            new("Q4 Budget.xlsx", false, "xlsx", "245 KB", "Dec 1, 2023"),
            new("Team Photo.jpg", false, "jpg", "3.2 MB", "Nov 15, 2023"),
            new("Meeting Notes.docx", false, "docx", "89 KB", "Jan 10, 2024"),
        }},
        { "Documents/Reports", new List<DocItem> {
            new("Annual Report 2023.pdf", false, "pdf", "12.4 MB", "Jan 15, 2024"),
            new("Q3 Summary.pdf", false, "pdf", "5.1 MB", "Oct 2, 2023"),
            new("KPI Dashboard.xlsx", false, "xlsx", "380 KB", "Dec 20, 2023"),
        }},
        { "Documents/Templates", new List<DocItem> {
            new("Invoice Template.docx", false, "docx", "45 KB", "Aug 5, 2023"),
            new("Proposal Template.pptx", false, "pptx", "2.1 MB", "Sep 12, 2023"),
        }},
    };

    private List<DocItem> CurrentItems => _folders.GetValueOrDefault(string.Join("/", _breadcrumb), new List<DocItem>());

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }

    private void EnterFolder(string name) { _breadcrumb.Add(name); }
    private void GoUp() { if (_breadcrumb.Count > 1) _breadcrumb.RemoveAt(_breadcrumb.Count - 1); }
    private void NavigateTo(int idx) { _breadcrumb = _breadcrumb.Take(idx + 1).ToList(); }
    private void AddMockFile() { _fileCounter++; var key = string.Join("/", _breadcrumb); if (!_folders.ContainsKey(key)) _folders[key] = new(); _folders[key].Add(new($"upload_{_fileCounter:D3}.pdf", false, "pdf", "1.2 MB", DateTime.Now.ToString("MMM d, yyyy"))); }
    private void AddFolder() { _fileCounter++; var key = string.Join("/", _breadcrumb); if (!_folders.ContainsKey(key)) _folders[key] = new(); var name = $"New Folder {_fileCounter}"; _folders[key].Add(new(name, true, "", "—", DateTime.Now.ToString("MMM d, yyyy"))); _folders[key + "/" + name] = new(); }
    private string GetFileIcon(string ext) => ext switch { "pdf" => "fa-file-pdf", "xlsx" or "xls" => "fa-file-excel", "docx" or "doc" => "fa-file-word", "pptx" or "ppt" => "fa-file-powerpoint", "jpg" or "png" or "gif" => "fa-file-image", _ => "fa-file" };

    private record DocItem(string Name, bool IsFolder, string Extension, string Size, string Modified, int ChildCount = 0);
}
