@page "/Examples/SearchAutocomplete"
@page "/{TenantCode}/Examples/SearchAutocomplete"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-magnifying-glass me-1"></i> Search & Autocomplete</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-magnifying-glass me-1"></i> Search & Autocomplete Demo
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="About Search & Autocomplete" Subtitle="Type-ahead suggestions — the Google / GitHub pattern" IconClass="fa-solid fa-magnifying-glass">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This demonstrates <strong>autocomplete</strong> (also called typeahead) — a search box that
                        shows suggestions as you type. Google, GitHub, Jira, and every address field use this pattern.
                        It's fundamentally different from our SampleItems filter, which filters an already-loaded list.
                        Here, each keystroke triggers a <strong>debounced</strong> API call to the server.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>Debounced server search</strong> — wait 400ms after you stop typing before querying</li>
                        <li><strong>Dropdown results</strong> — suggestions appear below the input</li>
                        <li><strong>Keyboard navigation</strong> — ↑ ↓ to move, Enter to select, Esc to close</li>
                        <li><strong>Recent searches</strong> — last 5 searches remembered in a list</li>
                        <li><strong>Result highlighting</strong> — matching text is bolded in suggestions</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        When you type, a <code>System.Timers.Timer</code> resets on every keystroke (debounce).
                        After 400ms of no typing, it calls <code>GetSampleItems</code> and filters by keyword.
                        Results appear in a Bootstrap dropdown. Arrow keys change a highlighted index.
                        Enter selects the highlighted item. Escape or clicking outside closes the dropdown.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Search Box ── *@
        <div class="row justify-content-center mb-4">
            <div class="col-md-8 col-lg-6">
                <div class="position-relative">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0">
                            @if (_searching) {
                                <span class="spinner-border spinner-border-sm text-primary"></span>
                            } else {
                                <i class="fa-solid fa-magnifying-glass text-muted"></i>
                            }
                        </span>
                        <input type="text" class="form-control border-start-0"
                               placeholder="Search sample items..."
                               @bind="_searchTerm"
                               @bind:event="oninput"
                               @bind:after="OnSearchInput"
                               @onfocus="OnFocus"
                               @onkeydown="HandleKeydown"
                               @onblur="OnBlur" />
                        @if (!string.IsNullOrWhiteSpace(_searchTerm)) {
                            <button class="btn btn-outline-secondary" @onclick="ClearSearch" @onmousedown:preventDefault>
                                <i class="fa-solid fa-times"></i>
                            </button>
                        }
                    </div>

                    <InfoTip Title="Debounced Search Input"
                             Description="Every keystroke resets a 400ms timer. Only when you stop typing for 400ms does the actual API call fire. This prevents flooding the server with requests while you're still typing 'engineering'. The Timer Demo page explains this pattern in detail."
                             Code="@_codeDebounce" />

                    @* ── Dropdown Results ── *@
                    @if (_showDropdown && (_suggestions.Any() || _recentSearches.Any() || (_searchTerm?.Length >= 2 && !_searching))) {
                        <div class="position-absolute w-100 shadow-lg rounded-bottom border bg-white" style="z-index:1050; max-height:400px; overflow-y:auto;" @onmousedown:preventDefault>
                            @if (_suggestions.Any()) {
                                <div class="px-3 py-1 small text-muted bg-light border-bottom">
                                    <i class="fa-solid fa-search me-1"></i> Results (@_suggestions.Count)
                                </div>
                                @for (int i = 0; i < _suggestions.Count; i++) {
                                    int idx = i;
                                    var item = _suggestions[i];
                                    <button class="btn btn-link text-start text-decoration-none w-100 px-3 py-2 border-bottom @(idx == _highlightIndex ? "bg-primary bg-opacity-10" : "")"
                                            @onclick="@(() => SelectItem(item))" @onmousedown:preventDefault>
                                        <div class="d-flex align-items-center">
                                            <i class="fa-solid fa-file-lines text-muted me-2"></i>
                                            <div class="flex-grow-1">
                                                <div class="small fw-semibold text-dark">@((MarkupString)HighlightMatch(item.Name, _searchTerm))</div>
                                                <div class="d-flex gap-2">
                                                    <span class="badge bg-light text-dark border" style="font-size:0.65rem;">@item.Category</span>
                                                    <span class="badge @GetStatusBadge(item.Status)" style="font-size:0.65rem;">@item.Status</span>
                                                    <span class="small text-muted">@item.Amount.ToString("C")</span>
                                                </div>
                                            </div>
                                            <span class="badge bg-secondary bg-opacity-25 text-dark small ms-2">P@item.Priority</span>
                                        </div>
                                    </button>
                                }
                            } else if (_searchTerm?.Length >= 2 && !_searching) {
                                <div class="text-center py-4">
                                    <i class="fa-solid fa-search fa-2x text-muted opacity-50 mb-2"></i>
                                    <div class="text-muted small">No results for "<strong>@_searchTerm</strong>"</div>
                                </div>
                            }

                            @if (_recentSearches.Any() && string.IsNullOrWhiteSpace(_searchTerm)) {
                                <div class="px-3 py-1 small text-muted bg-light border-bottom d-flex justify-content-between">
                                    <span><i class="fa-solid fa-clock-rotate-left me-1"></i> Recent</span>
                                    <button class="btn btn-link btn-sm p-0 text-muted" @onclick="ClearRecents" @onmousedown:preventDefault>Clear</button>
                                </div>
                                @foreach (var recent in _recentSearches) {
                                    <button class="btn btn-link text-start text-decoration-none w-100 px-3 py-2 border-bottom"
                                            @onclick="@(() => UseRecent(recent))" @onmousedown:preventDefault>
                                        <i class="fa-solid fa-clock-rotate-left text-muted me-2 small"></i>
                                        <span class="small text-dark">@recent</span>
                                    </button>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Selected Item Detail ── *@
        @if (_selectedItem != null) {
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="fa-solid fa-circle-check text-success me-1"></i> Selected Item</span>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => _selectedItem = null)">
                        <i class="fa-solid fa-times me-1"></i> Clear
                    </button>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-2"><strong class="small text-muted">Name</strong><div>@_selectedItem.Name</div></div>
                        <div class="col-md-3 mb-2"><strong class="small text-muted">Category</strong><div><span class="badge bg-light text-dark border">@_selectedItem.Category</span></div></div>
                        <div class="col-md-2 mb-2"><strong class="small text-muted">Status</strong><div><span class="badge @GetStatusBadge(_selectedItem.Status)">@_selectedItem.Status</span></div></div>
                        <div class="col-md-2 mb-2"><strong class="small text-muted">Priority</strong><div>@_selectedItem.Priority</div></div>
                        <div class="col-md-2 mb-2"><strong class="small text-muted">Amount</strong><div>@_selectedItem.Amount.ToString("C")</div></div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_selectedItem.Description)) {
                        <div class="mt-2"><strong class="small text-muted">Description</strong><div class="small">@_selectedItem.Description</div></div>
                    }
                </div>
            </div>
        }

        @* ── InfoTips Row ── *@
        <div class="d-flex flex-wrap gap-1 mt-2">
            <InfoTip Title="Keyboard Navigation"
                     Description="Arrow Up/Down moves a highlighted index through the suggestion list. Enter selects the highlighted item. Escape closes the dropdown. This is the same interaction model as Google's search autocomplete and VS Code's command palette."
                     Code="@_codeKeyboard" />
            <InfoTip Title="Result Highlighting"
                     Description="The matching portion of each suggestion's name is wrapped in a <strong> tag so it appears bold. For example, searching 'eng' in 'Engineering' renders as '<strong>Eng</strong>ineering'. This helps users see why each result matched."
                     Code="@_codeHighlight" />
            <InfoTip Title="Recent Searches"
                     Description="The last 5 search terms are stored in a list. When you focus the empty search box, recent searches appear. Clicking one fills the search box and re-runs the search. In a production app, these would be stored in localStorage for persistence across sessions."
                     Code="@_codeRecent" />
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private bool _searching = false;
    private bool _showDropdown = false;
    private string _pageName = "searchautocomplete";

    // InfoTip snippets
    private string _codeDebounce = "// Timer resets on every keystroke\n_debounceTimer.Stop();\n_debounceTimer.Start();\n// After 400ms, fires SearchAsync()";
    private string _codeKeyboard = "if (e.Key == \"ArrowDown\") _highlightIndex++;\nif (e.Key == \"ArrowUp\") _highlightIndex--;\nif (e.Key == \"Enter\") SelectItem(_suggestions[_highlightIndex]);";
    private string _codeHighlight = "var idx = name.IndexOf(term, StringComparison.OrdinalIgnoreCase);\nreturn name[..idx] + \"<strong>\" + name[idx..(idx+term.Length)] + \"</strong>\" + name[(idx+term.Length)..];";
    private string _codeRecent = "_recentSearches.Insert(0, term);\nif (_recentSearches.Count > 5) _recentSearches.RemoveAt(5);";

    // State
    private string _searchTerm = "";
    private List<DataObjects.SampleItem> _allItems = new();
    private List<DataObjects.SampleItem> _suggestions = new();
    private DataObjects.SampleItem? _selectedItem;
    private int _highlightIndex = -1;
    private List<string> _recentSearches = new();
    private System.Timers.Timer _debounceTimer = null!;

    // ── Lifecycle ──

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.Subscribers_OnChange.Remove(_pageName);
        _debounceTimer?.Dispose();
    }

    protected override void OnInitialized()
    {
        Model.View = _pageName;
        Model.OnChange += OnDataModelUpdated;
        if (!Model.Subscribers_OnChange.Contains(_pageName)) { Model.Subscribers_OnChange.Add(_pageName); }

        _debounceTimer = new System.Timers.Timer(400);
        _debounceTimer.Elapsed += DebounceElapsed;
        _debounceTimer.AutoReset = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;

        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;

            // Pre-load all items (in production, the server would handle search)
            var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
            if (result != null) {
                _allItems = result.Where(i => !i.Deleted).ToList();
            }

            _loading = false;
            StateHasChanged();
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) StateHasChanged();
    }

    // ── Search ──

    private void OnSearchInput()
    {
        _highlightIndex = -1;
        _debounceTimer.Stop();

        if (!string.IsNullOrWhiteSpace(_searchTerm) && _searchTerm.Length >= 2) {
            _searching = true;
            _debounceTimer.Start();
        } else {
            _suggestions.Clear();
            _searching = false;
        }
    }

    private async void DebounceElapsed(object? source, System.Timers.ElapsedEventArgs e)
    {
        await InvokeAsync(() => {
            string term = _searchTerm?.ToLower() ?? "";

            _suggestions = _allItems
                .Where(i =>
                    (i.Name?.ToLower().Contains(term) == true) ||
                    (i.Description?.ToLower().Contains(term) == true) ||
                    (i.Category?.ToLower().Contains(term) == true))
                .OrderByDescending(i => i.Name?.ToLower().StartsWith(term) == true)
                .ThenBy(i => i.Name)
                .Take(8)
                .ToList();

            _searching = false;
            _showDropdown = true;
            StateHasChanged();
        });
    }

    // ── Keyboard ──

    private void HandleKeydown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (!_showDropdown || !_suggestions.Any()) {
            if (e.Key == "Escape") {
                _showDropdown = false;
            }
            return;
        }

        if (e.Key == "ArrowDown") {
            _highlightIndex = Math.Min(_highlightIndex + 1, _suggestions.Count - 1);
        } else if (e.Key == "ArrowUp") {
            _highlightIndex = Math.Max(_highlightIndex - 1, 0);
        } else if (e.Key == "Enter" && _highlightIndex >= 0 && _highlightIndex < _suggestions.Count) {
            SelectItem(_suggestions[_highlightIndex]);
        } else if (e.Key == "Escape") {
            _showDropdown = false;
            _highlightIndex = -1;
        }
    }

    // ── Selection ──

    private void SelectItem(DataObjects.SampleItem item)
    {
        _selectedItem = item;
        _showDropdown = false;
        _highlightIndex = -1;

        // Add to recent searches
        if (!string.IsNullOrWhiteSpace(_searchTerm) && !_recentSearches.Contains(_searchTerm)) {
            _recentSearches.Insert(0, _searchTerm);
            if (_recentSearches.Count > 5) _recentSearches.RemoveAt(5);
        }

        _searchTerm = item.Name;
    }

    private void UseRecent(string term)
    {
        _searchTerm = term;
        OnSearchInput();
    }

    private void ClearSearch()
    {
        _searchTerm = "";
        _suggestions.Clear();
        _showDropdown = false;
        _highlightIndex = -1;
        _selectedItem = null;
    }

    private void ClearRecents()
    {
        _recentSearches.Clear();
    }

    private void OnFocus()
    {
        _showDropdown = true;
    }

    private void OnBlur()
    {
        // Small delay to allow click events on dropdown items to fire
        _ = Task.Delay(200).ContinueWith(_ => InvokeAsync(() => {
            _showDropdown = false;
            StateHasChanged();
        }));
    }

    // ── Helpers ──

    private string HighlightMatch(string text, string? term)
    {
        if (string.IsNullOrWhiteSpace(term) || string.IsNullOrWhiteSpace(text)) return text ?? "";

        int idx = text.IndexOf(term, StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return text;

        return text[..idx] + "<strong>" + text[idx..(idx + term.Length)] + "</strong>" + text[(idx + term.Length)..];
    }

    private string GetStatusBadge(DataObjects.SampleItemStatus status) => status switch {
        DataObjects.SampleItemStatus.Draft => "bg-secondary",
        DataObjects.SampleItemStatus.Active => "bg-success",
        DataObjects.SampleItemStatus.Completed => "bg-primary",
        DataObjects.SampleItemStatus.Archived => "bg-dark",
        _ => "bg-secondary",
    };
}
