@page "/Examples/BootstrapV6"
@page "/{TenantCode}/Examples/BootstrapV6"
@implements IDisposable
@inject BlazorDataModel Model

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-filter me-1"></i> Filter Panel</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <i class="fa-solid fa-filter me-1"></i> V6: Advanced Filter Panel
                <StickyMenuIcon />
            </h1>
        </div>

        <AboutSection Title="Bootstrap in Context: Advanced Filter Panel" Subtitle="Multi-field filtering with saved filters — the Helpdesk / TouchPoints pattern" IconClass="fa-solid fa-filter">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-question-circle me-1"></i>What Is This Page?</h6>
                    <p class="small text-muted mb-0">
                        This demonstrates the <strong>advanced filter panel</strong> pattern used in production apps like
                        Helpdesk and TouchPoints. Multiple filter fields (keyword, category, status, date range) combine
                        to narrow results. A saved-filters dropdown lets users recall previous filter combinations.
                    </p>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-lightbulb me-1"></i>What You'll Learn</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li><strong>form-control + form-select + form-switch</strong> in a filter bar</li>
                        <li><strong>btn-group</strong> for view toggle (Grid / List)</li>
                        <li><strong>input-group</strong> with search icon prefix</li>
                        <li><strong>Collapse</strong> to show/hide advanced filters</li>
                        <li><strong>Badges</strong> showing active filter count and record count</li>
                        <li><strong>Dropdown</strong> for saved filter presets</li>
                    </ul>
                </div>
                <div class="col-md-4 mb-2">
                    <h6 class="text-info"><i class="fa-solid fa-road me-1"></i>How Does It Work?</h6>
                    <p class="small text-muted mb-0">
                        Filters are stored as simple state variables. When any filter changes, the results list is
                        re-filtered client-side. The "Advanced" toggle uses Bootstrap <code>collapse</code> to reveal
                        date range and priority fields. The record count badge updates automatically.
                    </p>
                </div>
            </div>
        </AboutSection>

        @* ── Saved Filters Dropdown + Active Filter Count ── *@
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex align-items-center gap-2">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="fa-solid fa-bookmark me-1"></i> Saved Filters
                    </button>
                    <ul class="dropdown-menu">
                        @foreach (var preset in _savedFilters) {
                            <li><button class="dropdown-item" @onclick="@(() => ApplyPreset(preset))"><i class="fa-solid fa-filter me-1 text-muted"></i> @preset.Name</button></li>
                        }
                        @if (_savedFilters.Any()) {
                            <li><hr class="dropdown-divider" /></li>
                        }
                        <li><button class="dropdown-item text-primary" @onclick="SaveCurrentFilter"><i class="fa-solid fa-plus me-1"></i> Save Current Filter</button></li>
                    </ul>
                </div>
                <InfoTip Title="Saved Filters Dropdown"
                         Description="In production apps like Helpdesk, users save filter combinations they use often (e.g. 'My Open Tickets', 'High Priority This Week'). The dropdown-menu lists these presets. Clicking one populates all filter fields at once."
                         Code="@_codeSavedFilters" />
                @if (ActiveFilterCount > 0) {
                    <span class="badge bg-primary rounded-pill">@ActiveFilterCount active filter@(ActiveFilterCount > 1 ? "s" : "")</span>
                }
            </div>
            <div>
                <span class="text-muted small me-2">@_filtered.Count of @_allItems.Count records</span>
                <div class="btn-group btn-group-sm">
                    <button class="btn @(_viewMode == "grid" ? "btn-dark" : "btn-outline-dark")" @onclick="@(() => _viewMode = "grid")"><i class="fa-solid fa-grid-2"></i></button>
                    <button class="btn @(_viewMode == "list" ? "btn-dark" : "btn-outline-dark")" @onclick="@(() => _viewMode = "list")"><i class="fa-solid fa-list"></i></button>
                </div>
                <InfoTip Title="btn-group View Toggle"
                         Description="A btn-group with two buttons toggles between Grid and List views. The active button gets btn-dark while the inactive gets btn-outline-dark. This is the same pattern used in every production list page."
                         Code="@_codeBtnGroup" />
            </div>
        </div>

        @* ── Filter Bar ── *@
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
                            <input type="text" class="form-control" placeholder="Search keyword..." @bind="_keyword" @bind:event="oninput" @bind:after="ApplyFilters" />
                            @if (!string.IsNullOrWhiteSpace(_keyword)) {
                                <button class="btn btn-outline-secondary" @onclick="@(() => { _keyword = ""; ApplyFilters(); })"><i class="fa-solid fa-times"></i></button>
                            }
                        </div>
                    </div>
                    <div class="col-md-2">
                        <select class="form-select form-select-sm" @bind="_filterCategory" @bind:after="ApplyFilters">
                            <option value="">All Categories</option>
                            @foreach (var cat in _categories) {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select class="form-select form-select-sm" @bind="_filterStatus" @bind:after="ApplyFilters">
                            <option value="">All Statuses</option>
                            <option value="Active">Active</option>
                            <option value="Draft">Draft</option>
                            <option value="Completed">Completed</option>
                            <option value="Archived">Archived</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="highPriorityOnly" @bind="_highPriorityOnly" @bind:after="ApplyFilters" />
                            <label class="form-check-label small" for="highPriorityOnly">High Priority</label>
                        </div>
                    </div>
                    <div class="col-md-2 text-end">
                        <button class="btn btn-sm btn-outline-secondary me-1" type="button" data-bs-toggle="collapse" data-bs-target="#advancedFilters">
                            <i class="fa-solid fa-sliders me-1"></i> Advanced
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="ResetFilters"><i class="fa-solid fa-arrows-rotate"></i></button>
                    </div>
                </div>

                <div class="collapse mt-2" id="advancedFilters">
                    <hr class="my-2" />
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label small mb-0">Date From</label>
                            <input type="date" class="form-control form-control-sm" @bind="_dateFrom" @bind:after="ApplyFilters" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-0">Date To</label>
                            <input type="date" class="form-control form-control-sm" @bind="_dateTo" @bind:after="ApplyFilters" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-0">Min Amount</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" @bind="_minAmount" @bind:after="ApplyFilters" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-0">Max Amount</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" @bind="_maxAmount" @bind:after="ApplyFilters" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <InfoTip Title="Advanced Collapse Filter"
                 Description="The 'Advanced' button uses Bootstrap collapse to reveal additional filter fields (date range, amount range). This keeps the default UI clean while giving power users access to more filters. The same pattern is used in Helpdesk Index and TouchPoints search."
                 Code="@_codeCollapse" />

        @* ── Active Filter Pills ── *@
        @if (ActiveFilterCount > 0) {
            <div class="d-flex flex-wrap gap-1 mb-3">
                @if (!string.IsNullOrWhiteSpace(_keyword)) {
                    <span class="badge bg-primary bg-opacity-10 text-primary border">Keyword: @_keyword <button class="btn-close btn-close-sm ms-1" style="font-size:0.5rem;" @onclick="@(() => { _keyword = ""; ApplyFilters(); })"></button></span>
                }
                @if (!string.IsNullOrWhiteSpace(_filterCategory)) {
                    <span class="badge bg-primary bg-opacity-10 text-primary border">Category: @_filterCategory <button class="btn-close btn-close-sm ms-1" style="font-size:0.5rem;" @onclick="@(() => { _filterCategory = ""; ApplyFilters(); })"></button></span>
                }
                @if (!string.IsNullOrWhiteSpace(_filterStatus)) {
                    <span class="badge bg-primary bg-opacity-10 text-primary border">Status: @_filterStatus <button class="btn-close btn-close-sm ms-1" style="font-size:0.5rem;" @onclick="@(() => { _filterStatus = ""; ApplyFilters(); })"></button></span>
                }
                @if (_highPriorityOnly) {
                    <span class="badge bg-warning bg-opacity-25 text-dark border">High Priority Only <button class="btn-close btn-close-sm ms-1" style="font-size:0.5rem;" @onclick="@(() => { _highPriorityOnly = false; ApplyFilters(); })"></button></span>
                }
            </div>
        }

        @* ── Results ── *@
        @if (_viewMode == "list") {
            <table class="table table-hover table-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _filtered) {
                        <tr>
                            <td>@item.Name</td>
                            <td><span class="badge bg-light text-dark border">@item.Category</span></td>
                            <td><span class="badge @GetStatusBadge(item.Status)">@item.Status</span></td>
                            <td>P@item.Priority</td>
                            <td class="text-end">@item.Amount.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        } else {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                @foreach (var item in _filtered) {
                    <div class="col">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <h6 class="card-title mb-1">@item.Name</h6>
                                    <span class="badge @GetStatusBadge(item.Status)">@item.Status</span>
                                </div>
                                <div class="d-flex gap-2 mb-2">
                                    <span class="badge bg-light text-dark border" style="font-size:0.65rem;">@item.Category</span>
                                    <span class="badge bg-secondary bg-opacity-25 text-dark" style="font-size:0.65rem;">P@item.Priority</span>
                                </div>
                                <div class="small text-muted">@item.Amount.ToString("C")</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @if (!_filtered.Any()) {
            <div class="text-center py-5 text-muted">
                <i class="fa-solid fa-filter-circle-xmark fa-3x mb-3 opacity-50"></i>
                <div>No items match the current filters.</div>
                <button class="btn btn-sm btn-outline-primary mt-2" @onclick="ResetFilters">Reset Filters</button>
            </div>
        }

        <div class="d-flex flex-wrap gap-1 mt-3">
            <InfoTip Title="input-group Search"
                     Description="The search field uses input-group to prefix a magnifying glass icon. An 'X' button appears when text is entered. This is the standard search pattern across all production apps."
                     Code="@_codeInputGroup" />
            <InfoTip Title="Filter Pills"
                     Description="Active filters display as removable badge pills above the results. Each pill shows the filter name and value with a close button. Clicking X removes that individual filter. This gives users a clear visual of what's applied."
                     Code="@_codeFilterPills" />
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private string _pageName = "bootstrapv6";

    private string _codeCollapse = "<button data-bs-toggle=\"collapse\" data-bs-target=\"#advancedFilters\">\n  Advanced\n</button>\n<div class=\"collapse\" id=\"advancedFilters\">...</div>";
    private string _codeSavedFilters = "<div class=\"dropdown\">\n  <button class=\"dropdown-toggle\" data-bs-toggle=\"dropdown\">Saved Filters</button>\n  <ul class=\"dropdown-menu\">\n    @foreach (var preset in _savedFilters) { ... }\n  </ul>\n</div>";
    private string _codeBtnGroup = "<div class=\"btn-group btn-group-sm\">\n  <button class=\"btn btn-dark\">Grid</button>\n  <button class=\"btn btn-outline-dark\">List</button>\n</div>";
    private string _codeInputGroup = "<div class=\"input-group\">\n  <span class=\"input-group-text\"><i class=\"fa-solid fa-magnifying-glass\"></i></span>\n  <input class=\"form-control\" @bind=\"_keyword\" />\n</div>";
    private string _codeFilterPills = "<span class=\"badge bg-primary bg-opacity-10 text-primary border\">\n  Category: @_filterCategory\n  <button class=\"btn-close\" @onclick=\"...\"></button>\n</span>";

    // Filter state
    private string _keyword = "";
    private string _filterCategory = "";
    private string _filterStatus = "";
    private bool _highPriorityOnly = false;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private decimal? _minAmount;
    private decimal? _maxAmount;
    private string _viewMode = "list";

    private List<DataObjects.SampleItem> _allItems = new();
    private List<DataObjects.SampleItem> _filtered = new();
    private List<string> _categories = new();
    private List<FilterPreset> _savedFilters = new();

    private int ActiveFilterCount =>
        (string.IsNullOrWhiteSpace(_keyword) ? 0 : 1) +
        (string.IsNullOrWhiteSpace(_filterCategory) ? 0 : 1) +
        (string.IsNullOrWhiteSpace(_filterStatus) ? 0 : 1) +
        (_highPriorityOnly ? 1 : 0) +
        (_dateFrom.HasValue ? 1 : 0) +
        (_dateTo.HasValue ? 1 : 0) +
        (_minAmount.HasValue ? 1 : 0) +
        (_maxAmount.HasValue ? 1 : 0);

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); _savedFilters = new List<FilterPreset> {
        new("Active Engineering", "Engineering", "Active", false),
        new("High Priority", "", "", true),
        new("Completed Items", "", "Completed", false),
    }; }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
            if (result != null) { _allItems = result.Where(i => !i.Deleted).ToList(); _categories = _allItems.Select(i => i.Category).Where(c => !string.IsNullOrWhiteSpace(c)).Distinct().OrderBy(c => c).ToList(); }
            ApplyFilters();
            _loading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters() {
        var q = _allItems.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_keyword)) { var kw = _keyword.ToLower(); q = q.Where(i => (i.Name?.ToLower().Contains(kw) == true) || (i.Description?.ToLower().Contains(kw) == true)); }
        if (!string.IsNullOrWhiteSpace(_filterCategory)) q = q.Where(i => i.Category == _filterCategory);
        if (!string.IsNullOrWhiteSpace(_filterStatus)) q = q.Where(i => i.Status.ToString() == _filterStatus);
        if (_highPriorityOnly) q = q.Where(i => i.Priority <= 2);
        if (_minAmount.HasValue) q = q.Where(i => i.Amount >= _minAmount.Value);
        if (_maxAmount.HasValue) q = q.Where(i => i.Amount <= _maxAmount.Value);
        _filtered = q.OrderBy(i => i.Name).ToList();
    }

    private void ResetFilters() { _keyword = ""; _filterCategory = ""; _filterStatus = ""; _highPriorityOnly = false; _dateFrom = null; _dateTo = null; _minAmount = null; _maxAmount = null; ApplyFilters(); }

    private void ApplyPreset(FilterPreset p) { ResetFilters(); _filterCategory = p.Category; _filterStatus = p.Status; _highPriorityOnly = p.HighPriority; ApplyFilters(); }

    private void SaveCurrentFilter() {
        var name = $"Filter {_savedFilters.Count + 1}";
        _savedFilters.Add(new FilterPreset(name, _filterCategory, _filterStatus, _highPriorityOnly));
    }

    private string GetStatusBadge(DataObjects.SampleItemStatus status) => status switch {
        DataObjects.SampleItemStatus.Draft => "bg-secondary",
        DataObjects.SampleItemStatus.Active => "bg-success",
        DataObjects.SampleItemStatus.Completed => "bg-primary",
        DataObjects.SampleItemStatus.Archived => "bg-dark",
        _ => "bg-secondary",
    };

    private record FilterPreset(string Name, string Category, string Status, bool HighPriority);
}
