@page "/Examples/ChartsV2"
@page "/{TenantCode}/Examples/ChartsV2"
@implements IDisposable
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) { <h1 class="page-title"><i class="fa-solid fa-graduation-cap me-1"></i> Enrollment Stats</h1><LoadingMessage /> } else {
        <div class="@Model.StickyMenuClass"><h1 class="page-title"><i class="fa-solid fa-graduation-cap me-1"></i> V2: Enrollment Analytics <StickyMenuIcon /></h1></div>
        <AboutSection Title="Charts in Context: University Enrollment" Subtitle="Student enrollment KPIs, department breakdown, and retention metrics" IconClass="fa-solid fa-graduation-cap">
            <p class="small text-muted mb-0">Charts applied to a university enrollment context — headcounts, department distribution, retention rates, and admit-to-enroll funnel.</p>
        </AboutSection>
        <div class="d-flex flex-wrap gap-1 mb-3">
            <InfoTip Title="Progress Bar Breakdowns"
                     Description="Each category shows a thin (6px) progress bar with the count. The bar width is calculated as percentage of the largest category. Different bg- colors distinguish categories. This horizontal bar chart is simpler than Highcharts but effective for comparisons."
                     Code="@_codeProgressBars" />
            <InfoTip Title="Funnel Visualization"
                     Description="The admissions funnel uses tall (20px) progress bars that get narrower at each stage. The percentage shows conversion from the top of funnel. This funnel/waterfall pattern is used in CRM, sales pipelines, and enrollment tracking."
                     Code="@_codeFunnel" />
            <InfoTip Title="Inline Data with Tuples"
                     Description="The data is defined inline using C# tuples: (Engineering, 5200, bg-primary). This avoids creating a full model class for static demo data. A foreach loop iterates over the tuple array. Use this pattern for prototypes and examples."
                     Code="@_codeTuples" />
        </div>

        <div class="row row-cols-2 row-cols-md-4 g-2 mb-3">
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-primary">24,891</div><div class="small text-muted">Total Enrolled</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-success">3,142</div><div class="small text-muted">New Freshmen</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-warning">87%</div><div class="small text-muted">Retention Rate</div></div></div>
            <div class="col"><div class="card border-0 shadow-sm text-center py-2"><div class="h4 mb-0 text-info">72%</div><div class="small text-muted">6-Year Grad Rate</div></div></div>
        </div>
        <div class="row g-3 mb-3">
            <div class="col-md-6"><div class="card shadow-sm border-0"><div class="card-header bg-white py-2"><span class="small fw-semibold">Enrollment by College</span></div><div class="card-body p-0">
                @foreach (var c in new[] { ("Engineering", 5200, "bg-primary"), ("Business", 4100, "bg-success"), ("Liberal Arts", 3800, "bg-info"), ("Sciences", 3500, "bg-warning"), ("Education", 2100, "bg-secondary"), ("Other", 6191, "bg-dark") }) {
                    <div class="px-3 py-2 border-bottom d-flex align-items-center gap-2"><span class="small" style="min-width:100px;">@c.Item1</span><div class="flex-grow-1"><div class="progress" style="height:6px;"><div class="progress-bar @c.Item3" style="width:@(c.Item2*100/5200)%"></div></div></div><span class="small fw-semibold">@c.Item2.ToString("N0")</span></div>
                }
            </div></div></div>
            <div class="col-md-6"><div class="card shadow-sm border-0"><div class="card-header bg-white py-2"><span class="small fw-semibold">Admissions Funnel</span></div><div class="card-body">
                @foreach (var s in new[] { ("Applications", 42000, 100), ("Admitted", 28560, 68), ("Enrolled", 12810, 31), ("Retained (Y2)", 11144, 27), ("Graduated", 8516, 20) }) {
                    <div class="mb-2"><div class="d-flex justify-content-between small mb-1"><span>@s.Item1</span><span>@s.Item2.ToString("N0") (@s.Item3%)</span></div><div class="progress" style="height:20px;"><div class="progress-bar bg-primary" style="width:@s.Item3%"></div></div></div>
                }
            </div></div></div>
        </div>
    }
}
@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "chartsv2";
    private string _codeProgressBars = "<div class=\"progress\" style=\"height:6px\">\n  <div class=\"progress-bar bg-primary\" style=\"width:@(val*100/max)%\"></div>\n</div>";
    private string _codeFunnel = "<div class=\"progress\" style=\"height:20px\">\n  <div class=\"progress-bar\" style=\"width:@pct%\">\n    @name (@pct%)\n  </div>\n</div>";
    private string _codeTuples = "@foreach (var c in new[] {\n  (\"Engineering\", 5200, \"bg-primary\"),\n  (\"Business\", 4100, \"bg-success\")\n}) { ... }";
    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) Model.TenantCodeFromUrl = TenantCode; if (Model.Loaded && Model.LoggedIn && !_loadedData) { _loadedData = true; _loading = false; StateHasChanged(); } }
}
