@page "/Examples/SampleItemsV1"
@page "/{TenantCode}/Examples/SampleItemsV1"
@implements IDisposable
@inject BlazorDataModel Model

@* V1: Card Grid — items displayed as cards instead of a table *@

@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title"><i class="fa-solid fa-grip me-1"></i> Card View</h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title"><i class="fa-solid fa-grip me-1"></i> V1: Sample Items — Card Grid <StickyMenuIcon /></h1>
        </div>
        <AboutSection Title="Card Grid View" Subtitle="Same GetSampleItems API, displayed as a responsive card grid" IconClass="fa-solid fa-grip">
            <p class="small text-muted mb-0">Instead of a table, each item is a self-contained card with category badge, status indicator, and amount. Useful when visual scanning matters more than sorting columns.</p>
        </AboutSection>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="badge bg-secondary rounded-pill">@_items.Count items</span>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_sortBy" @bind:after="SortItems">
                <option value="name">Sort: Name</option>
                <option value="amount">Sort: Amount</option>
                <option value="priority">Sort: Priority</option>
                <option value="category">Sort: Category</option>
            </select>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-3 mb-3">
            @foreach (var item in _items) {
                <div class="col">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="card-title mb-0">@item.Name</h6>
                                <span class="badge @GetStatusBadge(item.Status)" style="font-size:0.6rem;">@item.Status</span>
                            </div>
                            <div class="d-flex gap-1 mb-2">
                                <span class="badge bg-light text-dark border" style="font-size:0.6rem;">@item.Category</span>
                                <span class="badge bg-secondary bg-opacity-25 text-dark" style="font-size:0.6rem;">P@item.Priority</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.Description)) {
                                <p class="small text-muted mb-2" style="max-height:40px; overflow:hidden;">@item.Description</p>
                            }
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold text-primary">@item.Amount.ToString("C")</span>
                                <span class="small text-muted">@(item.Enabled ? "✓ Enabled" : "✗ Disabled")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public string? TenantCode { get; set; }
    private bool _loading = true, _loadedData = false;
    private string _pageName = "sampleitemsv1";
    private string _sortBy = "name";
    private List<DataObjects.SampleItem> _items = new();

    public void Dispose() { Model.OnChange -= StateHasChanged; Model.Subscribers_OnChange.Remove(_pageName); }
    protected override void OnInitialized() { Model.View = _pageName; Model.OnChange += StateHasChanged; if (!Model.Subscribers_OnChange.Contains(_pageName)) Model.Subscribers_OnChange.Add(_pageName); }
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) Model.TenantCodeFromUrl = TenantCode;
        if (Model.Loaded && Model.LoggedIn && !_loadedData) {
            _loadedData = true;
            var result = await Helpers.GetOrPost<List<DataObjects.SampleItem>>("api/Data/GetSampleItems", new List<Guid>());
            if (result != null) _items = result.Where(i => !i.Deleted).OrderBy(i => i.Name).ToList();
            _loading = false; StateHasChanged();
        }
    }
    private void SortItems() {
        _items = _sortBy switch {
            "amount" => _items.OrderByDescending(i => i.Amount).ToList(),
            "priority" => _items.OrderBy(i => i.Priority).ToList(),
            "category" => _items.OrderBy(i => i.Category).ThenBy(i => i.Name).ToList(),
            _ => _items.OrderBy(i => i.Name).ToList(),
        };
    }
    private string GetStatusBadge(DataObjects.SampleItemStatus s) => s switch { DataObjects.SampleItemStatus.Active => "bg-success", DataObjects.SampleItemStatus.Completed => "bg-primary", DataObjects.SampleItemStatus.Archived => "bg-dark", _ => "bg-secondary" };
}
