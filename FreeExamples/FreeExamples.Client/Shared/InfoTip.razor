@*
    InfoTip — Inline (i) icon that shows an explanation popover on click.
    Shows a title, description, and optional code snippet.

    Usage:
        <InfoTip Title="Drag-and-Drop Upload"
                 Description="Users can drag files from their computer and drop them onto this area. The browser reads the file and sends it to the server."
                 Code="&lt;UploadFile OnUploadComplete=&quot;@@OnFilesUploaded&quot; /&gt;" />

        You can also place it inline next to a label:
        <strong>Upload Files</strong> <InfoTip Title="..." Description="..." />
*@

<span class="infotip-container d-inline-block position-relative">
    <button type="button" class="btn btn-link btn-sm p-0 ms-1 text-info infotip-trigger"
            @onclick="Toggle" @onclick:stopPropagation="true"
            aria-label="More info: @Title"
            title="Click for more info">
        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
    </button>

    @if (_open) {
        <div class="infotip-popover card shadow border-info position-absolute" style="z-index:1050; width:340px; top:100%; left:0; margin-top:4px;">
            <div class="card-header bg-info bg-opacity-10 py-1 px-2 d-flex justify-content-between align-items-center">
                <strong class="small"><i class="fa-solid fa-graduation-cap me-1"></i>@Title</strong>
                <button type="button" class="btn-close btn-close-sm" @onclick="Close" @onclick:stopPropagation="true" aria-label="Close"></button>
            </div>
            <div class="card-body py-2 px-2">
                <p class="small mb-0">@Description</p>
                @if (!string.IsNullOrWhiteSpace(Code)) {
                    <pre class="bg-dark text-light p-2 rounded small mt-2 mb-0" style="white-space:pre-wrap; word-break:break-all; max-height:160px; overflow-y:auto;"><code>@Code</code></pre>
                }
            </div>
        </div>
    }
</span>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string Code { get; set; } = "";

    private bool _open;

    private void Toggle() => _open = !_open;
    private void Close() => _open = false;
}
